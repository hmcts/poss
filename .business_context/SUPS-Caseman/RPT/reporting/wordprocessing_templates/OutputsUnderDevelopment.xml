<?xml version="1.0" encoding="UTF-8"?>
<!--

	Note to the developer: Use this file when you want to build templates for any number
	of outputs that you are working on and testing. Use this instead of editing the Outputs.xml file
	because it is safer. To use this file simply copy the contents of the <Output> element
	for each template you are working on from the Outputs.xml file and paste inside the <Outputs> elements below. 
	Only those templates identified in the <Outputs> will be generated.

  -->
<Outputs xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation=".\Outputs.xsd">	

</Outputs>
