<!-- DESCRIPTION: This stylesheet is used to create an XSL:FO document that -->
<!-- can be processed into a PDF version.  Business logic -->
<!-- is embedded to generate the correct document text for the order -->
<!-- required. -->
<!--  -->
<!-- INPUTS: XML document containing: the answers to questions asked of the -->
<!-- user; case data retrieved from the database; HTML representing the  -->
<!-- body of the document content (already edited by the user). -->
<!--  -->
<!-- OUTPUTS: XML document with FO tags containing instructions for the -->
<!-- creation of a PDF document. -->
<!--  -->
<!-- ====================================================================== -->
<root xmlns:xsl="http://www.w3.org/1999/XSL/Transform" xmlns:fo="http://www.w3.org/1999/XSL/Format" xmlns="http://eds.com/supsfo">
	<variables>@word.processing.url.xsl@supsfo.xsl</variables>
	<layout>order</layout>
	<duplex/>
	<addressee>
		<blank/>
		<claimants/>
		<defendants/>
		<part20claimants/>
		<part20defendants/>
	</addressee>
	<header>
		<fo:block font-size="16pt" font-weight="bold">Notice of Transfer of Proceedings</fo:block>
	</header>
	<courtcase>
		<court>
			<xsl:copy-of select="$vdCourtHeaderBlock"/>
		</court>
		<caseparameters>
			<parameter>
				<name>
					<fo:block font-weight="bold">Claim Number</fo:block>
				</name>
				<value>
					<fo:block>
						<xsl:value-of select="$vdClaimNumber"/>
					</fo:block>
				</value>
			</parameter>
			<parameter>
				<name>
					<fo:block font-weight="bold">Date</fo:block>
				</name>
				<value>
					<fo:block>
						<xsl:value-of select="$vdEventDate"/>
					</fo:block>
				</value>
			</parameter>
		</caseparameters>
	</courtcase>

	<body>
		<editable useid="N1008C">
		<fo:block space-before="1.0cm" space-after="0.8cm">
			<fo:inline font-weight="bold">To all parties</fo:inline>
		</fo:block>
		<fo:block space-after="0.4cm">
			As a result of the order made on <xsl:value-of select="$vdTransferOrderDate"/> this <xsl:value-of select="$vdCaseProceeding"/> has been transferred to the 
			<xsl:value-of select="$vdTransferCourtNameDescription"/> for trial. If you wish to make any further applications in this claim,
			they should be made to the court to which the claim has been transferred. 
			<xsl:if test="string-length($vdTransferReturnHomeCourt2) > 0">
				<xsl:value-of select="$vdTransferReturnHomeCourt2"/>
			</xsl:if>
			
		</fo:block>
		</editable>
	</body>
	<defaultFooter id="CJR018D"/>
</root>