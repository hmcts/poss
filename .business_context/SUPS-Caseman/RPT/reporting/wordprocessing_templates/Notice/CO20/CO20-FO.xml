<!-- DESCRIPTION: This stylesheet is used to create an XSL:FO document that -->
<!-- can be processed into a PDF version.  Business logic -->
<!-- is embedded to generate the correct document text for the order -->
<!-- required. -->
<!--  -->
<!-- INPUTS: XML document containing: the answers to questions asked of the -->
<!-- user; case data retrieved from the database; HTML representing the  -->
<!-- body of the document content (already edited by the user). -->
<!--  -->
<!-- OUTPUTS: XML document with FO tags containing instructions for the -->
<!-- creation of a PDF document. -->
<!--  -->
<!-- ====================================================================== -->
<root xmlns:xsl="http://www.w3.org/1999/XSL/Transform" xmlns:fo="http://www.w3.org/1999/XSL/Format" xmlns="http://eds.com/supsfo">
	<variables>@word.processing.url.xsl@supsfo.xsl</variables>
	<addressee>
			<blank/>
			<creditor/>
			<debtor/>
			<employer sic='true'/>
	</addressee>
	<header>
		<fo:block font-size="16pt" font-weight="bold">Order Discharging Consolidated</fo:block> 
		<fo:block font-size="16pt" font-weight="bold">Attachment of Earnings Order at</fo:block>
		<fo:block font-size="16pt" font-weight="bold">a hearing</fo:block>
	</header>
	<courtcase>
		<court>
			<xsl:copy-of select="$vdCourtHeaderBlock"/>
		</court>
		<caseparameters>
			<parameter>
				<name>
					<fo:block font-weight="bold">Case Number </fo:block>
				</name>
				<value>
					<fo:block>
						<xsl:value-of select="$vdCaseNumber"/>
					</fo:block>
				</value>
			</parameter>
			<parameter>
				<name>
					<fo:block font-weight="bold">Consolidated A/E Number</fo:block>
				</name>
				<value>
					<fo:block>
						<xsl:value-of select="$vdCONumber"/>
					</fo:block>
				</value>
			</parameter>
			<parameter>
				<name>
					<fo:block font-weight="bold">Creditor</fo:block>
					<fo:block font-size="9pt">(including ref.)</fo:block>
				</name>
				<value>
					<xsl:call-template name="display-creditor-name-and-reference-template">
						<xsl:with-param name="addressee">
							<xsl:value-of select="$addressee"/>
						</xsl:with-param>
					</xsl:call-template>
				</value>
			</parameter>				
			<parameter>
				<name>
					<fo:block font-weight="bold">Debtor</fo:block>
				</name>
				<value>
					<fo:block hyphenate="true">
						<xsl:value-of select="$vdCODebtorName"/>
					</fo:block>
				</value>
			</parameter>
			<parameter>
				<name>
					<fo:block font-weight="bold">Employer's Ref.</fo:block>
				</name>
				<value>
					<fo:block hyphenate="true">
						<xsl:value-of select="$vdCOEmployerReference"/>
					</fo:block>
				</value>
			</parameter>
		</caseparameters>
	</courtcase>
	<bodyintroright><fo:block><fo:inline text-align="center"><seal/></fo:inline></fo:block></bodyintroright>
	
	<body>
	<editable useid="N100D3">
		<fo:block font-weight="bold" space-after="0.4cm">
			Before <xsl:value-of select="$vdJudge"/> sitting at <xsl:value-of select="$vdHearingAtCourtNameDescription"/>, <xsl:value-of select="$vdHearingAtCourtAddress"/>
		</fo:block>
		<fo:block space-after="0.4cm">
			<xsl:value-of select="$vdCOHearingAttendees"/>
		</fo:block>
		<fo:block space-after="0.4cm" font-weight="bold">
			IT IS ORDERED THAT
		</fo:block>
		<fo:block>
			<xsl:if test="string-length($vdCostsText) > 0">1. </xsl:if>
			This Consolidated Attachment of Earnings Order be discharged.
		</fo:block>
		<xsl:if test="string-length($vdCostsText) > 0">
			<fo:block space-after="0.4cm">
				2. <xsl:value-of select="$vdCostsText"/>
			</fo:block>
		</xsl:if>
		<fo:block text-align="right">
			<fo:inline font-weight="bold">Dated </fo:inline><xsl:value-of select="$vdEventDate"/>
		</fo:block>
	</editable>
	</body>
	<defaultFooter id="CO20" CO="true"/>
</root>