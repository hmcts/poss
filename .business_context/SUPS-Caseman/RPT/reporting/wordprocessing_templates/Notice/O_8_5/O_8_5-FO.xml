<!-- DESCRIPTION: This stylesheet is used to create an XSL:FO document that -->
<!-- can be processed into a PDF version.  Business logic -->
<!-- is embedded to generate the correct document text for the order -->
<!-- required. -->
<!--  -->
<!-- INPUTS: XML document containing: the answers to questions asked of the -->
<!-- user; case data retrieved from the database; HTML representing the  -->
<!-- body of the document content (already edited by the user). -->
<!--  -->
<!-- OUTPUTS: XML document with FO tags containing instructions for the -->
<!-- creation of a PDF document. -->
<!--  -->
<!-- ====================================================================== -->
<root xmlns:xsl="http://www.w3.org/1999/XSL/Transform" xmlns:fo="http://www.w3.org/1999/XSL/Format" xmlns="http://eds.com/supsfo">
	<variables>@word.processing.url.xsl@supsfo.xsl</variables>
	<!--layout>warrant</layout-->
	<addressee>
		<blank/>
		<claimants/>
		<defendants/>		
	</addressee>
	<header>
		<fo:block font-size="16pt" font-weight="bold">Notice of transfer to Technology</fo:block>
		<fo:block font-size="16pt" font-weight="bold">and Construction Court</fo:block>
	</header>
	<courtcase>
		<court>
			<xsl:copy-of select="$vdCourtHeaderBlock"/>
		</court>
		<caseparameters>
			<parameter>
				<name>
					<fo:block font-weight="bold">Case Number</fo:block>
				</name>
				<value>
					<fo:block>
						<xsl:value-of select="$vdClaimNumber"/>
					</fo:block>
				</value>
			</parameter>
			<parameter>
				<name>
					<fo:block font-weight="bold">Setting Down No</fo:block>
				</name>
				<value>
					<fo:block>
						<xsl:value-of select="$vdSettingDownNo"/>
					</fo:block>
				</value>
			</parameter>
			<parameter>
				<name>
					<fo:block font-weight="bold">Claimant</fo:block>
					<fo:block font-size="9pt">(including ref.)</fo:block>
				</name>
				<value>
					<fo:block hyphenate="true">
						<xsl:value-of select="$vdClaimantName"/>
					</fo:block>
					<fo:block font-size="9pt" hyphenate="true">
						<xsl:value-of select="$vdClaimantReference"/>
					</fo:block>
				</value>
			</parameter>
			<parameter>
				<name>
					<fo:block font-weight="bold">Defendant</fo:block>
					<fo:block font-size="9pt">(including ref.)</fo:block>
				</name>
				<value>
					<fo:block hyphenate="true">
						<xsl:value-of select="$vdDefendantName"/>
					</fo:block>
					<fo:block font-size="9pt" hyphenate="true">
						<xsl:value-of select="$vdDefendantReference"/>
					</fo:block>
				</value>
			</parameter>
		</caseparameters>
	</courtcase>
	
	<body><editable useid="N100C2">
		<fo:block space-after="0.8cm" space-before="1.2cm"/>
		<fo:block>
			<fo:inline font-weight="bold">TAKE NOTICE</fo:inline> that this action having been set down for trial at <xsl:value-of select="$vdUserCourtName"/>.
		</fo:block>
		<fo:block space-after="0.4cm">
			on <xsl:value-of select="$vdHearingDate1"/> at <xsl:value-of select="$vdHearingTime"/>.
		</fo:block>
		<fo:block space-after="0.4cm">
			<fo:inline font-weight="bold">THE DISTRICT JUDGE</fo:inline> has directed that this matter be transferred to the Technology and Construction Court and that the file be forwarded to the Listing Officer at the Crown Court,
			<xsl:value-of select="$vdUserCourtAddress"/> to whom all future correspondence should be sent.
		</fo:block>
		<fo:block space-after="0.4cm">
			<fo:inline font-weight="bold">Dated </fo:inline><xsl:value-of select="$vdEventDate"/>
		</fo:block>
		<fo:block space-after="0.4cm" font-weight="bold">
			ALL COMMUNICATIONS SHOULD BE ADDRESSED TO <xsl:value-of select="$vdUserCourtAddress"/>
		</fo:block>
		<fo:block font-weight="bold">
			PLEASE NOTE:-
		</fo:block>
		<fo:block space-after="0.4cm">
			The above setting down number <fo:inline font-weight="bold">MUST BE QUOTED IN ALL FUTURE CORRESPONDENCE WITH THE COURT</fo:inline>
		</fo:block>
		<fo:block>
			It is the duty of all parties to inform the Court of likely settlements or of the action having been settled or withdrawn (including an acceptance of monies paid into Court)
		</fo:block>
	</editable></body>
	<defaultFooter id="O_8_5"/>
</root>