<!-- DESCRIPTION: This stylesheet is used to create an XSL:FO document that -->
<!-- can be processed into a PDF version.  Business logic -->
<!-- is embedded to generate the correct document text for the order -->
<!-- required. -->
<!--  -->
<!-- INPUTS: XML document containing: the answers to questions asked of the -->
<!-- user; case data retrieved from the database; HTML representing the  -->
<!-- body of the document content (already edited by the user). -->
<!--  -->
<!-- OUTPUTS: XML document with FO tags containing instructions for the -->
<!-- creation of a PDF document. -->
<!--  -->
<!-- 
@author Sandeep Mullangi
@version 0.1 
Change Hisstory
Sep 10, 2008 Sandeep Mullangi - Printing insolvency number if present as part of RFC 486
-->

<!-- ====================================================================== -->
<root xmlns:xsl="http://www.w3.org/1999/XSL/Transform" xmlns:fo="http://www.w3.org/1999/XSL/Format" xmlns="http://eds.com/supsfo">
	<variables>@word.processing.url.xsl@supsfo.xsl</variables>
	<layout>order</layout>
	<duplex/>	
	<addressee>
		<blank/>
		<debtorparty/>
		<creditorparty/>
		<company/>
		<applicant/>
		<petitioner/>
		<trustee/>
		<insolvencypractitioner/>
		<officialreceiver/>
	</addressee>
	<header>
		<fo:block font-size="16pt" font-weight="bold"><xsl:value-of select="$vdInsolvencyPetitionerHeader"/></fo:block>
	</header>
	<courtcase>
			<court>
			<fo:block text-align="left" font-size="12pt" font-weight="bold">
				In The High Court of Justice
			</fo:block>
			<fo:block text-align="left" font-size="12pt" font-weight="bold">
				Chancery Division
			</fo:block>
			<fo:block text-align="center" font-weight="bold">
				<xsl:value-of select="$vdCourtName"/>
			</fo:block>
			<fo:block text-align="right" font-weight="bold">
				District Registry
			</fo:block>
		</court>
		<caseparameters>
			<!-- adding insolvency number-->
            <parameter>
				<name>
					<fo:block font-weight="bold">
						<xsl:choose>
							<xsl:when test="string-length($vdInsolvencyNumber) > 0">Insolvency Number</xsl:when>
							<xsl:otherwise>Case Number</xsl:otherwise>
						</xsl:choose>
					</fo:block>
				</name>
				<value>
					<fo:block>
						<xsl:choose>
							<xsl:when test="string-length($vdInsolvencyNumber) > 0">
								<xsl:value-of select="substring($vdInsolvencyNumber,1,4)"/> of <xsl:value-of select="substring($vdInsolvencyNumber,5,4)"/>
							</xsl:when>
							<xsl:otherwise>
								<xsl:value-of select="$vdClaimNumber"/>
							</xsl:otherwise>
						</xsl:choose>
					</fo:block>
				</value>
			</parameter>
            <parameter>
				<name>
					<fo:block font-weight="bold">
						<xsl:choose>
								<xsl:when test="$vdEventId='691'">Company</xsl:when>
								<xsl:otherwise>Debtor</xsl:otherwise>
						</xsl:choose>
					</fo:block>
				</name>
				<value>
					<fo:block hyphenate="true">
						<xsl:value-of select="$vdSubjectName"/>
					</fo:block>
				</value>
			</parameter>
		</caseparameters>
	</courtcase>
	
	<body>
		<editable useid="N10097">

		<fo:block space-after="0.8cm"/>
		<fo:block font-weight="bold" space-after="0.4cm">
			Before <xsl:value-of select="$vdJudge"/>
		</fo:block>
		<fo:block space-after="0.4cm">
			Sitting in court on <xsl:value-of select="$vdHearingAtCourtDate"/>
		</fo:block>
		<fo:block space-after="0.4cm">
			In the matter of <xsl:value-of select="$vdSubjectName"/>
		</fo:block>
		<fo:block space-after="0.4cm" font-weight="bold">
			And in the matter of the Insolvency Act 1986
		</fo:block>
		<fo:block space-after="0.4cm">
			Upon the Petition of <xsl:value-of select="$vdInstigatorName"/>
		</fo:block>
		<fo:block space-after="0.4cm">
			Presented to the court on <xsl:value-of select="$vdPetitionDate2"/>
		</fo:block>
		<fo:block space-after="0.4cm">
			<xsl:copy-of select="$vdHearingAttendees"/>
		</fo:block>
		<fo:block space-after="0.4cm">
			And upon reading the evidence 
		</fo:block>					
		<xsl:if test="$vdEventId='690'">
			<fo:block space-after="0.4cm">
				It is ordered that the petition be adjourned to <xsl:value-of select="$vdPetitionAdjournedDate"/>
			</fo:block>
			<fo:block space-after="0.4cm">
				at <xsl:value-of select="$vdPetitionAdjournedTime"/>
			</fo:block>
			<fo:block space-after="0.4cm">
				before a District Judge sitting in Open Court at <xsl:value-of select="$vdHearingCourtNameDescription"/>, <xsl:value-of select="$vdHearingCourtAddress"/>
			</fo:block>
		</xsl:if>		
		<xsl:if test="$vdEventId='691'">
		<fo:block space-after="0.4cm">
			It is ordered that <xsl:value-of select="$vdCompanyName"/>&#xA0;be wound up by this Court under the provisions of the Insolvency Act 1986
		</fo:block>
		</xsl:if>	
		<xsl:if test="$vdEventId='692'">
			<fo:block space-after="0.4cm">
				It is ordered that the Petition be <xsl:value-of select="$vdPetitionAction"/>
			</fo:block>
		</xsl:if>	
		<xsl:if test="$vdEventId='693'">
			<fo:block space-after="0.4cm">
				It is ordered that <xsl:copy-of select="$vdInjunctionOrderDetails"/>
			</fo:block>
		</xsl:if>	
		<fo:block space-after="0.4cm">
			And it is ordered that <xsl:value-of select="$vdInsolvencyPetitionerWording"/>
		</fo:block>
		<fo:block>
			Dated <xsl:value-of select="$vdOrderDate"/>
  		</fo:block>
 		</editable> 	
		<xsl:if test="$vdEventId='691'">
		<footnote noteextent="2.5">
			<fo:block space-after="2cm">
				Note: <xsl:value-of select="$vdNoteWording"/>
			</fo:block>
		</footnote>
		</xsl:if>	
 	</body>
	<defaultFooter id="O_11_1_2_3_4"/>
</root>