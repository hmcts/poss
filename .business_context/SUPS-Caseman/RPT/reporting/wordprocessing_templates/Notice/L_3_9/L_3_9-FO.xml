<!--  -->
<!-- DESCRIPTION: This stylesheet is used to create an XSL:FO document that -->
<!-- can be processed into a PDF version.  Business logic -->
<!-- is embedded to generate the correct document text for the order -->
<!-- required. -->
<!--  -->
<!-- INPUTS: XML document containing: the answers to questions asked of the -->
<!-- user; case data retrieved from the database; HTML representing the  -->
<!-- body of the document content (already edited by the user). -->
<!--  -->
<!-- OUTPUTS: XML document with FO tags containing instructions for the -->
<!-- creation of a PDF document. -->
<!--  -->
<!-- ====================================================================== -->
<root xmlns:xsl="http://www.w3.org/1999/XSL/Transform" xmlns:fo="http://www.w3.org/1999/XSL/Format" xmlns="http://eds.com/supsfo">
	<variables>@word.processing.url.xsl@supsfo.xsl</variables>
	<layout>order</layout>
	<duplex/>
	<addressee>
		<selectedjudgmentcreditor/><!-- Selected party for -->
	</addressee>
	<header>
		<fo:block font-size="16pt" font-weight="bold">Certificate of money provisions contained</fo:block>
		<fo:block font-size="16pt" font-weight="bold">in a judgment for registration in another</fo:block>
		<fo:block font-size="16pt" font-weight="bold"> part of the United Kingdom (Schedule 6</fo:block>
		<fo:block font-size="16pt" font-weight="bold"> to the Civil Jurisdiction and Judgments</fo:block>
		<fo:block font-size="16pt" font-weight="bold"> Act 1982)</fo:block>
	</header>
	<courtcase>
		<court>
			<xsl:copy-of select="$vdCourtHeaderBlock"/>
		</court>
		<caseparameters>
			<parameter>
				<name>
					<fo:block font-weight="bold">Case Number</fo:block>
				</name>
				<value>
					<fo:block>
						<xsl:value-of select="$vdClaimNumber"/>
					</fo:block>
				</value>
			</parameter>
		</caseparameters>
	</courtcase>

	<body>
	<editable useid="N1007F">
		<fo:block space-after="0.4cm"/>
		<fo:block space-after="0.4cm">I hereby certify</fo:block>
		<numbered-list name="possession">
			<list-item>
				<fo:block space-after="0.4cm">
					<fo:block>
					That the <xsl:value-of select="$vdSelectedJudgmentInFavourOfRole"/>&#xa0;<xsl:value-of select="$vdSelectedJudgmentInFavourOfName"/> of:
					</fo:block>
					
					<fo:block>
					<xsl:call-template name="format-address-multi-line">
						<xsl:with-param name="party">
							<xsl:copy-of select="$vdSelectedJudgmentInFavourOfAddress"/>
						</xsl:with-param>
					</xsl:call-template>
					</fo:block>
					
					<fo:block> 
						obtained judgment against the <xsl:value-of select="$vdJudgmentAgainstRole"/>&#xa0;<xsl:value-of select="$vdJudgmentAgainstName"/> of:
					</fo:block>
					
					<fo:block> 
					<xsl:call-template name="format-address-multi-line">
						<xsl:with-param name="party">
							<xsl:copy-of select="$vdJudgmentAgainstAddress1"/>
						</xsl:with-param>
					</xsl:call-template>
					</fo:block>
					
					on <xsl:value-of select="$vdJudgmentDateOut"/> in <xsl:value-of select="$vdJudgmentCourtNameDescription2"/> for payment of the sum of 
					&#163;<xsl:call-template name="correctCalculation">
						<xsl:with-param name="value">
							<xsl:value-of select="$vdAmount"/>
						</xsl:with-param>
					</xsl:call-template>
					in respect of <xsl:copy-of select="$vdClaimNature"/> together with 
					&#163;<xsl:call-template name="correctCalculation">
						<xsl:with-param name="value">
							<xsl:value-of select="$vdCost"/>
						</xsl:with-param>
					</xsl:call-template>
					for costs, and that the sum of
					&#163;<xsl:call-template name="correctCalculation">
						<xsl:with-param name="value">
							<xsl:value-of select="$vdRemainingAmount"/>
						</xsl:with-param>
					</xsl:call-template>
					remains unsatisfied.
				</fo:block>
			</list-item>
			<list-item condition="string-length($vdInterestPercentage) > 0">
				<fo:block space-after="0.4cm">That the judgment carries interest at the rate of <xsl:value-of select="$vdInterestPercentage"/>% per annum calculated on the judgment debt and costs from the date of judgment until payment.</fo:block>
			</list-item>
			<list-item>
				<fo:block space-after="0.4cm">That the conditions specified in paragraph 3(a) and (b) of Schedule 6 to the Civil Jurisdiction and Judgments Act 1982 and Rule 74.17(2)(d) to (h) of the Civil Procedure Rules 1998 are satisfied in relation to the judgment.</fo:block>
			</list-item>
			<list-item>
				<fo:block space-after="2.4cm">This certificate is issued under Schedule 6 to the Civil Jurisdiction and Judgments Act 1982.</fo:block>
			</list-item>
		</numbered-list>
	
		<fo:block space-before="0.4cm" space-after="0.4cm">
			<fo:table table-layout="fixed">
						<fo:table-column column-width="10.00cm"/>
						<fo:table-column column-width="2.03cm"/>
						<fo:table-column column-width="5.00cm"/>
						<fo:table-body>
							<fo:table-row>
								<fo:table-cell text-align="left">
									<fo:block space-before="0.2cm">Signed_____________________________ </fo:block>
								</fo:table-cell>
								<fo:table-cell text-align="right">
									<fo:block space-before="0.2cm">Date </fo:block>
								</fo:table-cell>
								<fo:table-cell  height="0.8cm">
									<fo:block>________________________________  </fo:block>
								</fo:table-cell>
							</fo:table-row>
						</fo:table-body>
				</fo:table>		
		</fo:block>
		<fo:block space-after="1.2cm">
			Title_____________________________
		</fo:block>
		<fo:block>
			Produced for registration under Schedule 6 to the Civil Jurisdiction and Judgment Act 1982 by <xsl:value-of select="$vdSelectedJudgmentInFavourOfRole"/>
		</fo:block>
	</editable>
	</body>

	<defaultFooter id="L_3_9"/>
</root>