<!-- DESCRIPTION: This stylesheet is used to create an XSL:FO document that -->
<!-- can be processed into a PDF version.  Business logic -->
<!-- is embedded to generate the correct document text for the order -->
<!-- required. -->
<!--  -->
<!-- INPUTS: XML document containing: the answers to questions asked of the -->
<!-- user; case data retrieved from the database; HTML representing the  -->
<!-- body of the document content (already edited by the user). -->
<!--  -->
<!-- OUTPUTS: XML document with FO tags containing instructions for the -->
<!-- creation of a PDF document. -->
<!--  -->
<!-- CHANGE HISTORY -->
<!-- 04/02/2013 - Chris Vincent, removed word allocation from content.  Trac 4763. -->
<!-- ====================================================================== -->
<root xmlns:xsl="http://www.w3.org/1999/XSL/Transform" xmlns:fo="http://www.w3.org/1999/XSL/Format" xmlns="http://eds.com/supsfo">
	<variables>@word.processing.url.xsl@supsfo.xsl</variables>
	<layout>letter</layout>
	<logo/>
	<addressee>
		<subject/>
	</addressee>	
	<body>
		<fo:block space-before="0.8cm" font-size="12pt" font-weight="bold" text-align="center">
			<xsl:value-of select="$vdClaimantName"/> v <xsl:value-of select="$vdDefendantName"/> Case Number <xsl:value-of select="$vdClaimNumber"/>
		</fo:block>
		<fo:block space-before="0.8cm">Dear Sir/Madam</fo:block>
		<fo:block space-before="1.5cm">
		Your defence in the above claim has been received by the court. Normally questionnaires for completion by the claimant and the defendant are sent out by the court on receipt of a defence.
		However, when the claim is against more than one defendant, as in this case, the questionnaires are not sent out until all defendants have had an opportunity to reply.
		The time for each defendant to reply to the claim depends on when the claim form is served and so can be different for each of them. You will be contacted again by the court once the time for all
		the replies by all defendants has expired.
		</fo:block>
		<fo:block space-before="1.5cm">Yours faithfully,</fo:block>
		<fo:block space-before="2.0cm"><xsl:value-of select="$vdName"/></fo:block>
		<fo:block><xsl:value-of select="$vdSection"/> Section</fo:block>
		<fo:block space-after="4cm">Ext <xsl:value-of select="$vdExtension"/></fo:block>				
	</body>
	<letterfooter id="CJR016"/>
</root>

