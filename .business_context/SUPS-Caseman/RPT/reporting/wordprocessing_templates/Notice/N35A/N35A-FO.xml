<!--  -->
<!-- DESCRIPTION: This stylesheet is used to create an XSL:FO document that -->
<!-- can be processed into a PDF version.  Business logic -->
<!-- is embedded to generate the correct document text for the order -->
<!-- required. -->
<!--  -->
<!-- INPUTS: XML document containing: the answers to questions asked of the -->
<!-- user; case data retrieved from the database; HTML representing the  -->
<!-- body of the document content (already edited by the user). -->
<!--  -->
<!-- OUTPUTS: XML document with FO tags containing instructions for the -->
<!-- creation of a PDF document. -->
<!--  -->
<!-- ====================================================================== -->
<root xmlns:xsl="http://www.w3.org/1999/XSL/Transform" xmlns:fo="http://www.w3.org/1999/XSL/Format" xmlns="http://eds.com/supsfo">
	<variables>@word.processing.url.xsl@supsfo.xsl</variables>
	<addressee>
		<blank/>
		<partyforselected/>
		<judgmentdebtor/>
	</addressee>
	<header>
		<fo:block font-size="16pt" font-weight="bold">Variation order</fo:block>
		<fo:block font-size="12pt">(determination)</fo:block>
	</header>
	<courtcase>
		<court>
			<xsl:copy-of select="$vdCourtHeaderBlock"/>
		</court>
		<caseparameters>
			<parameter>
				<name>
					<fo:block font-weight="bold">Case Number</fo:block>
				</name>
				<value>
					<fo:block>
						<xsl:value-of select="$vdClaimNumber"/>
					</fo:block>
				</value>
			</parameter>
			<parameter>
				<name>
					<fo:block font-weight="bold">
						<xsl:call-template name="convertcase">
							<xsl:with-param name="toconvert">
								<xsl:value-of select="$vdSubjectPartyCodeOther"/>
							</xsl:with-param>
								<xsl:with-param name="conversion">proper</xsl:with-param>
						</xsl:call-template>
					</fo:block>
					<fo:block font-size="9pt">(including ref.)</fo:block>
				</name>
				<value>
					<fo:block hyphenate="true">
						<xsl:choose>
							<xsl:when test="$vdSubjectPartyRoleCode = 'DEFENDANT'"><xsl:value-of select="$vdClaimantName"/></xsl:when>
							<xsl:when test="$vdSubjectPartyRoleCode = 'CLAIMANT'"><xsl:value-of select="$vdDefendantName"/></xsl:when>
							<xsl:otherwise/>
						</xsl:choose>
					</fo:block>
					<fo:block font-size="9pt" hyphenate="true">
						<xsl:choose>
							<xsl:when test="$vdSubjectPartyRoleCode = 'DEFENDANT'"><xsl:value-of select="$vdClaimantReference"/></xsl:when>
							<xsl:when test="$vdSubjectPartyRoleCode = 'CLAIMANT'"><xsl:value-of select="$vdDefendantReference"/></xsl:when>
							<xsl:otherwise/>
						</xsl:choose>
					</fo:block>
				</value>
			</parameter>
			<parameter condition="string-length($vdSubjectPartyRoleCode) > 0">
				<name>
					<fo:block font-weight="bold">
						<xsl:value-of select="$vdSubjectPartyRole"/>
					</fo:block>
					<fo:block font-size="9pt">(including ref.)</fo:block>
				</name>
				<value>
					<fo:block hyphenate="true">
						<xsl:value-of select="$vdSubjectName"/>
					</fo:block>
					<fo:block font-size="9pt" hyphenate="true">
						<xsl:value-of select="$vdSubjectReference"/>
					</fo:block>
				</value>
			</parameter>
		</caseparameters>
	</courtcase>
	<body>
		<fo:block space-after="1.0cm"/>
		<fo:block space-after="0.6cm">
			Upon the application of the <xsl:value-of select="$vdApplicationToVaryApplicant"/> and the court having considered the papers received from the parties.
		</fo:block>

		<fo:block space-after="0.6cm">The judgment made against the <xsl:value-of select="$vdSubjectPartyCode"/> <xsl:value-of select="$vdJudgmentCourtName"/>
		 on the <xsl:value-of select="$vdJudgmentDateOut"/> for payment of
			&#163;<xsl:call-template name="correctCalculation">
				<xsl:with-param name="value"><xsl:value-of select="$vdAmount - $vdPaidBeforeJudgment"/></xsl:with-param>
			</xsl:call-template>
			and
			&#163;<xsl:call-template name="correctCalculation">
				<xsl:with-param name="value"><xsl:value-of select="$vdCost"/></xsl:with-param>
			</xsl:call-template>
			for costs is hereby varied.</fo:block>
		<fo:block space-after="0.6cm"><fo:inline font-weight="bold">It is now ordered</fo:inline> that the <xsl:value-of select="$vdSubjectPartyCode"/> pay the <xsl:value-of select="$vdSubjectPartyCodeOther"/> the outstanding sum<xsl:if test="$vdInterestIncluded = 'Y'"> including any interest,</xsl:if> 
		<xsl:if test="$vdInterestIncluded = 'Y'">
			of
			&#163;<xsl:call-template name="correctCalculation">
				<xsl:with-param name="value"><xsl:value-of select="$vdInterestIncludedAmount"/></xsl:with-param>
			</xsl:call-template>
		</xsl:if>
		<xsl:if test="$vdJudgmentResult = 'DETERMINED'">
			<xsl:value-of select="$vdPaymentFrequencyValue"/>
		</xsl:if>.</fo:block>
		<fo:block text-align="right"><fo:inline font-weight="bold">Dated </fo:inline> <xsl:value-of select="$vdVariationResultDate"/></fo:block>
	</body>

	<footnote noteextent="10.2">
		<fo:block space-after="0.2cm" font-family="Times" text-align="justify">
			<fo:table table-layout="fixed" width="100%">
				<fo:table-column column-width="18.8cm"/>
				<fo:table-body>
					<fo:table-row>
						<fo:table-cell border-top-style="solid" border-right-style="solid" border-left-style="solid" border-bottom-style="solid"
							border-top-width="0.02cm" border-right-width="0.02cm" border-left-width="0.02cm" border-bottom-width="0.02cm"
							padding-right="0.2cm" padding-left="0.2cm" padding-bottom="0.2cm" padding-top="0.2cm" >
							<fo:block font-size="9pt"><fo:inline font-weight="bold">Note:</fo:inline> Where judgment is entered for more than &#163;5,000.00 or includes a sum in respect of contractual or late payment interest, the <xsl:value-of select="$vdSubjectPartyCodeOther"/> may be entitled to further interest.</fo:block>
						</fo:table-cell>
					</fo:table-row>
				</fo:table-body>
			</fo:table>
		</fo:block>
		<fo:block>
		<fo:table table-layout="fixed" width="100%">
			<fo:table-column column-width="9.4cm"/>
			<fo:table-column column-width="9.4cm"/>
			<fo:table-body table-layout="fixed">
				<fo:table-row  keep-with-next="always">
					<fo:table-cell number-columns-spanned="2" border-top-style="solid" border-top-width="0.02cm" border-left-style="solid" border-left-width="0.02cm" border-right-style="solid" border-right-width="0.02cm">
						<fo:block space-before="0.1cm" space-after="0.1cm" font-size="10pt" text-align="center" font-weight="bold">Take Notice</fo:block>
					</fo:table-cell>
				</fo:table-row>
				<fo:table-row  keep-with-next="always">
					<fo:table-cell border-left-style="solid" border-left-width="0.02cm" padding-left="0.1cm">
						<fo:block font-size="9pt" font-weight="bold">To the <xsl:value-of select="$vdSubjectPartyCode"/></fo:block>
						<fo:block font-size="8pt" >
							If you do not pay in accordance with this order your goods may be removed and sold or other enforcement proceedings may be taken against you. 
							If your circumstances change and you cannot pay, ask at the court office about what you can do.
						</fo:block>
					</fo:table-cell>
					<fo:table-cell border-right-style="solid" border-right-width="0.02cm" padding-left="0.2cm" padding-right="0.1cm">
						<fo:block font-size="8pt">
							<fo:inline font-weight="bold">If you (either the <xsl:value-of select="$vdSubjectPartyCodeOther"/> or the <xsl:value-of select="$vdSubjectPartyCode"/>) object</fo:inline> to the payment rate fixed by the court, you must write to the court with your reasons. 
							You have 16 days from the date of the postmark to do this. A hearing will be arranged and you will both be told when to come to court. If the 
							order is not from the <xsl:value-of select="$vdSubjectPartyCode"/>'s local court, it will be automatically transferred to that court for hearing
						</fo:block>
						<fo:block space-after="0.2cm"/>
					</fo:table-cell>
				</fo:table-row>
				<fo:table-row  keep-with-next="always">
					<fo:table-cell border-left-style="solid" border-left-width="0.02cm">
						<fo:block font-size="9pt" text-align="center">Address for Payment</fo:block>
					</fo:table-cell>
					<fo:table-cell font-size="8pt" number-rows-spanned="2" border-right-style="solid" border-right-width="0.02cm" border-bottom-style="solid" 
									border-bottom-width="0.02cm" padding-left="0.1cm" padding-right="0.1cm">
						<fo:block font-size="9pt" text-align="center" font-weight="bold">How to Pay</fo:block>
						<list type="bullet">
							<list-item><fo:block font-weight="bold">PAYMENT(S) MUST BE MADE to the person named at the address for payment quoting their reference and the court case number.</fo:block></list-item>
							<list-item><fo:block font-weight="bold">DO NOT bring or send payments to the court. THEY WILL NOT BE ACCEPTED.</fo:block></list-item>
							<list-item><fo:block>You should allow <fo:inline text-decoration="underline">at least</fo:inline> 4 days for your payment to reach the <xsl:value-of select="$vdSubjectPartyCodeOther"/> or his representative.</fo:block></list-item>
							<list-item><fo:block>Make sure that you keep records and can account for all payments made. Proof may be required if there is a disagreement. It is not safe to send cash unless you use registered post.</fo:block></list-item>
							<list-item><fo:block>A leaflet giving further advice about payment can be obtained from the court.</fo:block></list-item>
							<list-item><fo:block>If you need more information you should contact the <xsl:value-of select="$vdSubjectPartyCodeOther"/> or his representative.</fo:block></list-item>
						</list>
					</fo:table-cell>
				</fo:table-row>
				<fo:table-row>
					<fo:table-cell border-style="solid" border-width="0.02cm">
						<address suppressborder="true">
							<xsl:call-template name="partyforaddressee"/>
						</address>
					</fo:table-cell>
				</fo:table-row>
			</fo:table-body>
		</fo:table>
		</fo:block>
	</footnote>
	<defaultFooter id="N35A"/>
</root>