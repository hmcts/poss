<!-- DESCRIPTION: This stylesheet is used to create an XSL:FO document that -->
<!-- can be processed into a PDF version.  Business logic -->
<!-- is embedded to generate the correct document text for the order -->
<!-- required. -->
<!--  -->
<!-- INPUTS: XML document containing: the answers to questions asked of the -->
<!-- user; case data retrieved from the database; HTML representing the  -->
<!-- body of the document content (already edited by the user). -->
<!--  -->
<!-- OUTPUTS: XML document with FO tags containing instructions for the -->
<!-- creation of a PDF document. -->
<!--  -->
<!-- ====================================================================== -->
<root xmlns:xsl="http://www.w3.org/1999/XSL/Transform" xmlns:fo="http://www.w3.org/1999/XSL/Format" xmlns="http://eds.com/supsfo">
	<variables>@word.processing.url.xsl@supsfo.xsl</variables>
	<layout yourRef="true">letter</layout>
	<logo/>
	<addressee>
		<eventSelectedWarrantPartyAgainst/>
	</addressee>	
	<body>
		<editable>
		<fo:block space-after="0.4cm">Dear <xsl:value-of select="$vdGreeting"/></fo:block>
		<fo:block space-after="0.4cm" font-size="12pt" font-weight="bold" text-align="center">Re: Case Number: <xsl:value-of select="$vdWarrantCaseNumber"/>&#xa0;<xsl:value-of select="$vdPartyForName"/> v <xsl:value-of select="$vdPartyAgainstName"/>
		</fo:block>
		<fo:block space-after="0.4cm" font-size="12pt" font-weight="bold" text-align="left">
			Warrant Number: <xsl:choose>
								<xsl:when test="string-length($vdWarrantLocalNumber) > 0"><xsl:value-of select="$vdWarrantLocalNumber"/></xsl:when>
								<xsl:otherwise><xsl:value-of select="$vdWarrantNumber"/></xsl:otherwise>
							</xsl:choose>
		</fo:block>
		<fo:block space-after="0.4cm" text-align="center" font-weight="bold">
			FINAL NOTICE
		</fo:block>
		<fo:block space-after="0.8cm" >
			This warrant has been issued for the payment of £<cursor text="Enter Oustanding Amount here."/> 				
			or the removal of your goods to the sale room. Unless within 24 hours the above amount is paid into the Court Office, you will leave me no alternative but to carry out the warrant by
			re-attending your premises with the auctioneers van and porters, to remove your goods to the sale room, to satisfy the warrant. You will have to pay additional removal and auctioneers costs. 
		</fo:block>
		<fo:block space-after="1.5cm"><xsl:value-of select="$vdLetterEnding"/></fo:block>
		<fo:block><xsl:value-of select="$vdBailiffName"/></fo:block>
		<fo:block>Bailiff</fo:block>		
		<fo:block>Telephone <xsl:value-of select="$vdBailiffTelephone" /> between <xsl:value-of select="$vdBailiffAvailability"/></fo:block>
		</editable>
	</body>
	<defaultFooter id="L_13_1" type="bailiff"/>
</root>