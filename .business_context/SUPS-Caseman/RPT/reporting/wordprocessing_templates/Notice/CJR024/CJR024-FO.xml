<!-- DESCRIPTION: This stylesheet is used to create an XSL:FO document that -->
<!-- can be processed into a PDF version.  Business logic -->
<!-- is embedded to generate the correct document text for the order -->
<!-- required. -->
<!--  -->
<!-- INPUTS: XML document containing: the answers to questions asked of the -->
<!-- user; case data retrieved from the database; HTML representing the  -->
<!-- body of the document content (already edited by the user). -->
<!--  -->
<!-- OUTPUTS: XML document with FO tags containing instructions for the -->
<!-- creation of a PDF document. -->
<!--  -->
<!-- ====================================================================== -->
<root xmlns:xsl="http://www.w3.org/1999/XSL/Transform" xmlns:fo="http://www.w3.org/1999/XSL/Format" xmlns="http://eds.com/supsfo">
	<variables>@word.processing.url.xsl@supsfo.xsl</variables>
	<layout famenf="true">order</layout>
	<duplex/>
	<addressee>
		<blank/>
		<claimants/>
		<defendants/>
		<part20claimants/>
		<part20defendants/>
	</addressee>
	<header>
		<fo:block font-size="16pt" font-weight="bold"><xsl:value-of select="$vdNoticePTRTitle"/></fo:block>
	</header>
	<courtcase>
		<court>
			<xsl:copy-of select="$vdCourtHeaderBlock"/>
		</court>
		<caseparameters>
			<parameter>
				<name>
					<fo:block font-weight="bold">Claim Number</fo:block>
				</name>
				<value>
					<fo:block>
						<xsl:value-of select="$vdClaimNumber"/>
					</fo:block>
				</value>
			</parameter>
			<parameter>
				<name>
					<fo:block font-weight="bold">Date</fo:block>
				</name>
				<value>
					<fo:block><xsl:value-of select="$vdEventDate"/>
					</fo:block>
				</value>
			</parameter>
		</caseparameters>
	</courtcase>
	<bodyintroright><fo:block space-before="0.4cm"><fo:inline text-align="center"><seal/></fo:inline></fo:block></bodyintroright>
	
	<body>
		<editable useid="N10085">
		<fo:block space-before="1.0cm" space-after="0.4cm">
			TAKE NOTICE that the <xsl:value-of select="$vdNotice"/>&#xa0;<xsl:value-of select="$vdHearingWording2"/>
		</fo:block>
		<fo:block space-after="0.4cm">
			<xsl:value-of select="$vdHearingDate"/> at <xsl:value-of select="$vdHearingTime"/>
		</fo:block>
		<fo:block space-after="0.4cm">
			at <xsl:value-of select="$vdHearingCourtNameDescription"/>,&#xa0;<xsl:value-of select="$vdHearingCourtAddress"/>
		</fo:block>
		<fo:block space-after="0.4cm">
			When you should attend
		</fo:block>
		<xsl:if test="string-length($vdHearingDurationWording) > 0">
			<fo:block space-after="0.8cm">
				<xsl:value-of select="$vdHearingDurationWording"/>
			</fo:block>
		</xsl:if>
		<fo:block>
			<fo:inline font-weight="bold">Please Note:</fo:inline> This case may be released to another Judge, possibly at a different Court
		</fo:block>
		</editable>
	</body>
	<defaultFooter id="CJR024"/>
</root>