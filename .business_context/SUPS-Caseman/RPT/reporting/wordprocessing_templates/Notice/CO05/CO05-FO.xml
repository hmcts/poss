<!-- Version: $Revision: 1.11 $ -->
<!--  -->
<!-- DESCRIPTION: This stylesheet is used to create an XSL:FO document that -->
<!-- can be processed into a PDF version.  Business logic -->
<!-- is embedded to generate the correct document text for the order -->
<!-- required. -->
<!--  -->
<!-- INPUTS: XML document containing: the answers to questions asked of the -->
<!-- user; case data retrieved from the database; HTML representing the  -->
<!-- body of the document content (already edited by the user). -->
<!--  -->
<!-- OUTPUTS: XML document with FO tags containing instructions for the -->
<!-- creation of a PDF document. -->
<!--  -->
<!-- ====================================================================== -->
<root xmlns:xsl="http://www.w3.org/1999/XSL/Transform" xmlns:fo="http://www.w3.org/1999/XSL/Format" xmlns:supsfo="http://eds.com/supsfo" xmlns="http://eds.com/supsfo">
	<variables>@word.processing.url.xsl@supsfo.xsl</variables>
	<layout>warrant</layout>
	<duplex/>
	<addressee copies="2">
		<blank/>
	</addressee>
	<header>
		<fo:block font-size="16pt" font-weight="bold">Warrant of Committal to Prison</fo:block>
		<fo:block font-size="16pt" font-weight="bold">(Section 23 Attachment of</fo:block>
		<fo:block font-size="16pt" font-weight="bold">Earnings Act 1971)</fo:block>
	</header>
	<courtcase>
		<court>
			<xsl:copy-of select="$vdCourtHeaderBlock"/>
		</court>
		<caseparameters>
			<parameter>
				<name>
					<fo:block font-weight="bold">AO/CAEO Number</fo:block>
				</name>
				<value>
					<fo:block>
						<xsl:value-of select="$vdCONumber"/>
					</fo:block>
				</value>
			</parameter>
			<parameter>
				<name>
					<fo:block font-weight="bold">Creditor</fo:block>
				</name>
				<value>
					<fo:block>
						Various
					</fo:block>
				</value>
			</parameter>				
			<parameter>
				<name>
					<fo:block font-weight="bold">Debtor</fo:block>
				</name>
				<value>
					<fo:block hyphenate="true">
						<xsl:value-of select="$vdCODebtorName"/>
					</fo:block>
				</value>
			</parameter>
			<parameter>
				<name>
					<fo:block font-weight="bold">Warrant Number</fo:block>
				</name>
				<value>
					<fo:block>
						<xsl:value-of select="$vdWarrantNumber"/>
					</fo:block>
				</value>
			</parameter>
		</caseparameters>	
		</courtcase>
	<bodyintroright><fo:block><fo:inline text-align="center"><seal/></fo:inline></fo:block></bodyintroright>
	
	<body>
		<editable useid="N100B3">
		<fo:block space-after="0.4cm">
			<fo:table table-layout="fixed">
				<fo:table-column column-width="3.0cm"></fo:table-column>
				<fo:table-column column-width="14.2cm"></fo:table-column>
				<fo:table-body>
					<fo:table-row>
						<fo:table-cell>
							<fo:block>
								To 
							</fo:block>
						</fo:table-cell>
						<fo:table-cell>
							<list type="bullet">
								<list-item>
									<fo:block>the District Judge</fo:block>
								</list-item>
								<list-item>
									<fo:block>every constable within his jurisdiction</fo:block>
								</list-item>
								<list-item>
									<fo:block>the Governor of Her Majesty's Prison at <xsl:value-of select="$vdCOPrisonName"/></fo:block>
								</list-item>
							</list>
						</fo:table-cell>
					</fo:table-row>
				</fo:table-body>
			</fo:table>
		</fo:block>
		<fo:block space-after="0.4cm">
			<fo:table table-layout="fixed">
				<fo:table-column column-width="5.0cm"></fo:table-column>
				<fo:table-column column-width="14.2cm"></fo:table-column>
				<fo:table-body>
					<fo:table-row>
						<fo:table-cell border-top-style="solid" border-left-style="solid" border-top-width="0.02cm" border-left-width="0.02cm">
							<fo:block>The Debtor</fo:block>
						</fo:table-cell>
						<fo:table-cell border-top-style="solid" border-right-style="solid" border-top-width="0.02cm" border-right-width="0.02cm">
							<fo:block><xsl:value-of select="$vdCODebtorName"/></fo:block>
						</fo:table-cell>
					</fo:table-row>
					<fo:table-row>
						<fo:table-cell border-bottom-style="solid" border-left-style="solid" border-bottom-width="0.02cm" border-left-width="0.02cm">
							<fo:block>Of</fo:block>
						</fo:table-cell>
						<fo:table-cell border-bottom-style="solid" border-right-style="solid" border-bottom-width="0.02cm" border-right-width="0.02cm">
							<fo:block><xsl:value-of select="$vdCODebtorAddress"/></fo:block>
						</fo:table-cell>
					</fo:table-row>
				</fo:table-body>
			</fo:table>
		</fo:block>
		<fo:block space-after="0.4cm">
			<fo:table table-layout="fixed">
				<fo:table-column column-width="5.0cm"></fo:table-column>
				<fo:table-column column-width="14.2cm"></fo:table-column>
				<fo:table-body>
					<fo:table-row>
						<fo:table-cell border-top-style="solid" border-left-style="solid" border-top-width="0.02cm" border-left-width="0.02cm">
							<fo:block>Employer<fo:inline font-style="italic"> (if known)</fo:inline></fo:block>
						</fo:table-cell>
						<fo:table-cell border-top-style="solid" border-right-style="solid" border-top-width="0.02cm" border-right-width="0.02cm">
							<fo:block><xsl:value-of select="$vdEmployerName"/></fo:block>
						</fo:table-cell>
					</fo:table-row>
					<fo:table-row>
						<fo:table-cell border-bottom-style="solid" border-left-style="solid" border-bottom-width="0.02cm" border-left-width="0.02cm">
							<fo:block>Of</fo:block>
						</fo:table-cell>
						<fo:table-cell border-bottom-style="solid" border-right-style="solid" border-bottom-width="0.02cm" border-right-width="0.02cm">
							<fo:block><xsl:value-of select="$vdEmployerAddress"/></fo:block>
						</fo:table-cell>
					</fo:table-row>
				</fo:table-body>
			</fo:table>
		</fo:block>

		<fo:block space-after="0.4cm" font-weight="bold">
			Before <xsl:value-of select="$vdJudge"/> sitting at <xsl:value-of select="$vdHearingAtCourtNameDescription"/>, <xsl:value-of select="$vdHearingAtCourtAddress"/>
		</fo:block>
		<fo:block space-after="0.4cm">
			<xsl:value-of select="$vdCOHearingAttendees"/>
		</fo:block>
		<fo:block space-after="0.4cm">
			<xsl:value-of select="$vdDFLT1-2"/>
		</fo:block>
		<fo:block space-after="0.4cm">
			<fo:inline font-weight="bold">IT IS ORDERED </fo:inline>that the Debtor be committed to prison for <xsl:value-of select="$vdDisobedienceArrestCommittalDays"/> days.
		</fo:block>
		<fo:block space-after="0.4cm">
			<fo:inline font-weight="bold">You the District Judge, Bailiffs and others </fo:inline>are therefore required to arrest the Debtor and to deliver him to the prison and you the Governor to receive the Debtor and safely keep him in prison for <xsl:value-of select="$vdDisobedienceArrestCommittalDays"/> days from the arrest under this order or until he shall be sooner discharged by due course of law.
		</fo:block>
		<fo:block space-after="0.4cm" text-align="right">
			<fo:inline font-weight="bold">Dated </fo:inline><xsl:value-of select="$vdEventDate"/>
		</fo:block>
		</editable>
	
		<fo:block break-before="page">
		<fo:table table-layout="fixed">
			<fo:table-column column-width="9.64cm"></fo:table-column>
			<fo:table-column column-width="9.64cm"></fo:table-column>
			<fo:table-body>
				<fo:table-row>
					<fo:table-cell padding-right="0.2cm">
						<fo:block space-after="0.4cm">
							To the Governor of Her Majesty's Prison at <xsl:value-of select="$vdCOPrisonName" />
						</fo:block>
						<fo:block space-after="0.4cm">
							TAKE NOTICE that in accordance with the provisions of section 122 of the County Courts Act, 1984 this Warrant of Committal has been sent to this Court and that the Debtor, if arrested within the jurisdiction of this Court, is to be conveyed to the Prison of this Court, and is to be there kept for the time mentioned in the Warrant of Committal unless sooner discharged by law.
						</fo:block>
						<fo:block space-after="0.4cm">
							DATED:
						</fo:block>
						<fo:block space-after="0.4cm">
							N75 Indorsement on a warrant of committal sent to a Foreign Court
						</fo:block>
						<fo:block space-after="1cm">
							To the District Judge of the County Court at
						</fo:block>
						<fo:block space-after="0.8cm" text-align="right">
							&#xa0;
						</fo:block>
						<fo:block space-after="0.4cm">
							TAKE NOTICE.  This Warrant has been issued out of this Court for execution at an address within the jurisdiction of your Court</fo:block>
						<fo:block space-after="0.4cm">
							YOU ARE THEREFORE required to execute the said Warrant.
						</fo:block>
						<fo:block space-after="0.4cm">
							DATED:
						</fo:block>
					</fo:table-cell>
					<fo:table-cell>
						<fo:block font-weight="bold" space-after="0.4cm">
							In the County Court at <xsl:value-of select="$vdCourtName"/></fo:block>
						<fo:block space-after="0.8cm">
							AO/CAEO No. <xsl:value-of select="$vdCONumber"/>
						</fo:block>
						<fo:block space-after="1.2cm">
							WARRANT OF COMMITTAL No. <xsl:value-of select="$vdWarrantNumber"/>
						</fo:block>
						<fo:block font-weight="bold" space-after="0.4cm">
							<xsl:value-of select="$vdCODebtorName"/> Debtor
						</fo:block>
						<fo:block>
							I arrested the within-named debtor
						</fo:block>
						<fo:block>
							On the&#xa0;&#xa0;&#xa0;&#xa0;&#xa0;&#xa0;&#xa0;&#xa0;&#xa0;&#xa0;&#xa0;&#xa0;&#xa0;&#xa0;&#xa0;&#xa0;&#xa0;&#xa0;&#xa0;&#xa0;&#xa0;&#xa0;&#xa0;&#xa0;&#xa0;&#xa0;&#xa0;&#xa0;&#xa0;&#xa0;&#xa0;&#xa0;&#xa0;&#xa0;&#xa0;&#xa0;&#xa0;&#xa0;&#xa0;&#xa0; and delivered him 
						</fo:block>
						<fo:block space-after="0.8cm">
							Into custody of the Governor of HM Prison at <xsl:value-of select="$vdCOPrisonName" />
						</fo:block>
						<fo:block space-after="2.0cm">
							on the
						</fo:block>
						<fo:block text-align="right">
							BAILIFF OF THE COUNTY COURT
						</fo:block>
					</fo:table-cell>
				</fo:table-row>
			</fo:table-body>
		</fo:table>	
		</fo:block>

	</body>
	<defaultFooter id="CO05" CO="true"/>
</root>