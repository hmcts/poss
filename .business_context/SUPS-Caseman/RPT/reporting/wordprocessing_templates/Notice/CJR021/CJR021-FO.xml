<!-- DESCRIPTION: This stylesheet is used to create an XSL:FO document that -->
<!-- can be processed into a PDF version.  Business logic -->
<!-- is embedded to generate the correct document text for the order -->
<!-- required. -->
<!--  -->
<!-- INPUTS: XML document containing: the answers to questions asked of the -->
<!-- user; case data retrieved from the database; HTML representing the  -->
<!-- body of the document content (already edited by the user). -->
<!--  -->
<!-- OUTPUTS: XML document with FO tags containing instructions for the -->
<!-- creation of a PDF document. -->
<!--  -->
<!-- CHANGE HISTORY -->
<!-- 28/01/2013 - Chris Vincent, removed word allocation from content.  Trac 4763. -->
<!-- ====================================================================== -->
<root xmlns:xsl="http://www.w3.org/1999/XSL/Transform" xmlns:fo="http://www.w3.org/1999/XSL/Format" xmlns="http://eds.com/supsfo">
	<variables>@word.processing.url.xsl@supsfo.xsl</variables>
	<layout>order</layout>
	<duplex/>
	<addressee>
		<blank/>
		<claimants/>
		<defendants/>
		<part20claimants/>
		<part20defendants/>
	</addressee>
	<header>
		<fo:block font-size="16pt" font-weight="bold">Notice of Allocation to the</fo:block>
		<fo:block font-size="16pt" font-weight="bold">Multi-track</fo:block>
	</header>
	<courtcase>
		<court>
			<xsl:copy-of select="$vdCourtHeaderBlock"/>
		</court>
		<caseparameters>
			<parameter>
				<name>
					<fo:block font-weight="bold">Claim Number</fo:block>
				</name>
				<value>
					<fo:block>
						<xsl:value-of select="$vdClaimNumber"/>
					</fo:block>
				</value>
			</parameter>
			<parameter>
				<name>
					<fo:block font-weight="bold">Date</fo:block>
				</name>
				<value>
					<fo:block>
						<xsl:value-of select="$vdEventDate"/>
					</fo:block>
				</value>
			</parameter>
		</caseparameters>
	</courtcase>
	<bodyintroright><fo:block space-before="0.4cm"><fo:inline text-align="center"><seal/></fo:inline></fo:block></bodyintroright>

	<body>
		<editable useid="N10091">
		<fo:block space-after="0.8cm">
			<xsl:value-of select="$vdJudge"/> has considered the statements of case and questionnaires filed 
			and allocated the <xsl:value-of select="$vdAQConsideredInRespectOf"/> <fo:inline font-weight="bold">to the multi-track.</fo:inline>
		</fo:block>
		
		<fo:block space-after="0.8cm">          
        <xsl:choose>
            <xsl:when test="$vdMultiTrackTransfer= 'CTC'">
                The claim is being transferred to the Civil Trial Centre at the County Court at 
            <xsl:call-template name="convertcase">
                    <xsl:with-param name="toconvert">
                        <xsl:value-of select="variabledata/transfer/court/cname"/>
                    </xsl:with-param>
                    <xsl:with-param name="conversion">proper</xsl:with-param>
                </xsl:call-template>
                where all future applications, correspondence and so on will be dealt with.
            </xsl:when>
            <xsl:when test="$vdMultiTrackTransfer= 'RCJ'">
                The claim is being transferred to 
                <xsl:value-of select="variabledata/transfer/court/rcjdivision"/> 
                Division of the Royal Court of Justice where all future applications, correspondence and so on will be dealt with.
            </xsl:when>
            <xsl:when test="$vdMultiTrackTransfer= 'NT'"/>
        </xsl:choose>
		</fo:block>

		<fo:block space-after="0.8cm">
		<xsl:choose>
			<xsl:when test="$vdAllocationReasonGiven = 'Y'">
				<fo:block>The reasons the judge has given for allocation to this track are that</fo:block>
			</xsl:when>
			<xsl:otherwise>
				<fo:block>The reason the judge has given for allocation to this track is that</fo:block>
			</xsl:otherwise>
		</xsl:choose>
		</fo:block>
		<fo:block><xsl:call-template name="formatTextAreaText">
					<xsl:with-param name="text"><xsl:copy-of select="$vdAllocationReason"/>
					</xsl:with-param></xsl:call-template></fo:block>
		
	</editable>
	</body>
	<footnote noteextent="4">
		<fo:block space-after="0.2cm">
		<fo:table table-layout="fixed" width="100%" font-size="10pt" font-family="Times">
			<fo:table-column column-width="9.4cm"/>
			<fo:table-column column-width="9.4cm"/>
			<fo:table-body>
				<fo:table-row keep-with-next="always">
					<fo:table-cell padding-left="0.1cm" padding-right="0.1cm" border-top-style="solid" border-top-width="0.02cm" border-left-style="solid" border-left-width="0.02cm" border-right-style="solid" border-right-width="0.02cm" border-bottom-style="solid" border-bottom-width="0.02cm">
						<fo:block font-weight="bold">Notes:</fo:block>
						<list type="bullet">
							<list-item>
								<fo:block>You and the other party, or parties, may agree to extend the time periods given in the directions</fo:block>
								<fo:block><fo:inline font-weight="bold">except</fo:inline></fo:block>
							</list-item>
						</list>
						<fo:block start-indent="5mm">
							- where a rule, practice direction or court order requires a party to comply with a direction within a specified time <fo:inline font-weight="bold">and</fo:inline> specifies the consequences of failing to comply;
						</fo:block>
						<fo:block start-indent="5mm">
							- where an extension of time will affect the date given for returning the pre-trial checklist or the date of the trial or trial period.
						</fo:block>
					</fo:table-cell>
					<fo:table-cell padding-left="0.1cm" padding-right="0.1cm" border-top-style="solid" border-top-width="0.02cm" border-left-style="solid" border-left-width="0.02cm" border-right-style="solid" border-right-width="0.02cm" border-bottom-style="solid" border-bottom-width="0.02cm">
						<fo:block space-after="0.2cm"/>
						<list type="bullet">
							<list-item><fo:block>If you do not comply with these directions, any other party to the claim will be entitled to apply to the court for an order that your statement of case (claim or defence) be struck out.</fo:block></list-item>
							<list-item><fo:block>Leaflets explaining more about what happens when your case is allocated to the Multi-track are available from the court office, <fo:inline font-weight="bold">or online at</fo:inline> www.hmcourts-service.gov.uk/cms/infoabout.htm.</fo:block></list-item>
						</list>
					</fo:table-cell>
				</fo:table-row>
			</fo:table-body>
		</fo:table>
	</fo:block>	
	</footnote>
	<defaultFooter id="CJR021"/>	
</root>