<!--  -->
<!-- DESCRIPTION: This stylesheet is used to create an XSL:FO document that -->
<!-- can be processed into a PDF version.  Business logic -->
<!-- is embedded to generate the correct document text for the order -->
<!-- required. -->
<!--  -->
<!-- INPUTS: XML document containing: the answers to questions asked of the -->
<!-- user; case data retrieved from the database; HTML representing the  -->
<!-- body of the document content (already edited by the user). -->
<!--  -->
<!-- OUTPUTS: XML document with FO tags containing instructions for the -->
<!-- creation of a PDF document. -->
<!--  -->
<!--
@author Sandeep Mullangi
@version 0.1
Change Hisstory
Oct 27, 2008 Sandeep Mullangi - Printing insolvency number if present as part of RFC 486
-->
<!-- ====================================================================== -->
<root xmlns:xsl="http://www.w3.org/1999/XSL/Transform" xmlns:fo="http://www.w3.org/1999/XSL/Format" xmlns="http://eds.com/supsfo">
	<variables>@word.processing.url.xsl@supsfo.xsl</variables>
	<layout>order</layout>
	<duplex/>	
	<addressee>
		<blank/>
		<debtorparty/>
		<creditorparty/>
		<company/>
		<applicant/>
		<petitioner/>
		<trustee/>
		<insolvencypractitioner/>
		<officialreceiver/>
	</addressee>
	<header>
		<fo:block font-size="10pt" font-weight="bold">Section 256</fo:block>
		<fo:block font-size="16pt" font-weight="bold">Order extending effect of Interim Order</fo:block>
	</header>
	<courtcase>
		<court>
			<xsl:copy-of select="$vdCourtHeaderBlock"/>
		</court>
		<caseparameters>
			<!-- adding insolvency number-->
            <parameter>
                <name>
                    <fo:block font-weight="bold">
                        <xsl:choose>
                            <xsl:when test="string-length($vdInsolvencyNumber) > 0">Insolvency Number</xsl:when>
                            <xsl:otherwise>Case Number</xsl:otherwise>
                        </xsl:choose>
                    </fo:block>
                </name>
                <value>
                    <fo:block>
                        <xsl:choose>
                            <xsl:when test="string-length($vdInsolvencyNumber) > 0">
                                <xsl:value-of select="substring($vdInsolvencyNumber,1,4)"/> of <xsl:value-of select="substring($vdInsolvencyNumber,5,4)"/>
                            </xsl:when>
                            <xsl:otherwise>
                                <xsl:value-of select="$vdClaimNumber"/>
                            </xsl:otherwise>
                        </xsl:choose>
                    </fo:block>
                </value>
			</parameter>
            <parameter>
				<name>
					<fo:block font-weight="bold">Debtor</fo:block>
				</name>
				<value>
					<fo:block hyphenate="true">
						<xsl:value-of select="$vdSubjectName"/>
					</fo:block>
				</value>
			</parameter>
		</caseparameters>
	</courtcase>
	
	<body>
		<editable useid="N10091">
		<fo:block space-after="0.8cm"/>
		<fo:block font-weight="bold" space-after="0.4cm" font-size="12pt">
			In Bankruptcy
		</fo:block>
		<fo:block font-weight="bold" space-after="0.4cm">
			Before <xsl:value-of select="$vdJudge"/>
		</fo:block>
		<fo:block space-after="0.4cm">
			Upon the application of
		</fo:block>	
		<fo:block space-after="0.4cm">
			<xsl:copy-of select="$vdInstigatorAddressMultiLine"/>
		</fo:block>

		<fo:block space-after="0.4cm">
			<xsl:value-of select="$vdHearingAttendees"/>
		</fo:block>

		<fo:block space-after="0.4cm">
			And upon reading the evidence 
		</fo:block>

		<fo:block space-after="0.4cm">
			And the court having this day considered the report of the nominee submitted pursuant to section 256 of the Insolvency Act 1986 and filed on <xsl:value-of select="$vdNomineeReportDate"/>
		</fo:block>

		<fo:block space-after="0.4cm">
			It is ordered that the period for which the interim order made on <xsl:value-of select="$vdInterimOrderDate"/> has effect to be 
			extended to <xsl:value-of select="$vdInterimOrderExtendedDate"/> to enable a meeting of the debtor's creditors 
			to be summoned to consider the debtor's proposals, such meeting as proposed by the nominee to be held on:
		</fo:block>

		<fo:block space-after="0.4cm">
			Date: <xsl:value-of select="$vdMeetingDate"/>  
 		</fo:block>
		<fo:block space-after="0.4cm">			
			Time: <xsl:value-of select="$vdMeetingTime"/>
 		</fo:block>
 		
		<fo:block space-after="0.4cm">
			at <xsl:value-of select="$vdMeetingAddress"/>
 		</fo:block>

		<fo:block space-after="0.4cm">
			And it is ordered that this application be adjourned to:
		</fo:block>
			
		<fo:block space-after="0.4cm">
			Date: <xsl:value-of select="$vdHearingDate1"/>  
 		</fo:block>
		<fo:block space-after="0.4cm">			
			Time: <xsl:value-of select="$vdHearingTime"/>
 		</fo:block>
 		
		<fo:block space-after="0.4cm">
			at <xsl:value-of select="$vdHearingCourtName"/>
 		</fo:block>

		<fo:block space-after="0.4cm">
			for consideration of the report of the chairman of the creditors' meeting.
 		</fo:block>

		<fo:block space-after="0.4cm">
			Dated <xsl:value-of select="$vdEventDate"/>
 		</fo:block>
		</editable>
 	</body>
	<defaultFooter id="O_10_4"/>
</root>