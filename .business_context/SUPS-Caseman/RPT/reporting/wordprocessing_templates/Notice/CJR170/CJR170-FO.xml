<!-- Version: $Revision: 1.11 $ -->
<!--  -->
<!-- DESCRIPTION: This stylesheet is used to create an XSL:FO document that -->
<!-- can be processed into a PDF version.  Business logic -->
<!-- is embedded to generate the correct document text for the order -->
<!-- required. -->
<!--  -->
<!-- INPUTS: XML document containing: the answers to questions asked of the -->
<!-- user; case data retrieved from the database; HTML representing the  -->
<!-- body of the document content (already edited by the user). -->
<!--  -->
<!-- OUTPUTS: XML document with FO tags containing instructions for the -->
<!-- creation of a PDF document. -->
<!--  -->
<!-- ====================================================================== -->
<root xmlns:xsl="http://www.w3.org/1999/XSL/Transform" xmlns:fo="http://www.w3.org/1999/XSL/Format" xmlns="http://eds.com/supsfo">
	<variables>@word.processing.url.xsl@supsfo.xsl</variables>
	<addressee>
		<deponent/>
	</addressee>
	<header>
		<fo:block font-size="16pt" font-weight="bold">Order for Examination</fo:block>
		<fo:block font-size="16pt" font-weight="bold">of Deponent</fo:block>
		<fo:block font-size="16pt" font-weight="bold">(before the hearing)</fo:block>
	</header>
	<courtcase>
		<court>
			<xsl:copy-of select="$vdCourtHeaderBlock"/>
		</court>
		<caseparameters>
			<parameter>
				<name>
					<fo:block font-weight="bold">Claim Number</fo:block>
				</name>
				<value>
					<fo:block>
						<xsl:value-of select="$vdClaimNumber"/>
					</fo:block>
				</value>
			</parameter>
			<parameter>
				<name>
					<fo:block font-weight="bold">Claimant</fo:block>
					<fo:block font-size="9pt">(including ref.)</fo:block>
				</name>
				<value>
					<fo:block hyphenate="true">
						<xsl:value-of select="$vdClaimantName"/>
					</fo:block>
					<fo:block font-size="9pt" hyphenate="true">
						<xsl:value-of select="$vdClaimantReference"/>
					</fo:block>
				</value>
			</parameter>
			<parameter>
				<name>
					<fo:block font-weight="bold">Defendant</fo:block>
					<fo:block font-size="9pt">(including ref.)</fo:block>
				</name>
				<value>
					<fo:block hyphenate="true">
						<xsl:value-of select="$vdDefendantName"/>
					</fo:block>
					<fo:block font-size="9pt" hyphenate="true">
						<xsl:value-of select="$vdDefendantReference"/>
					</fo:block>
				</value>
			</parameter>
			<parameter>
				<name>
					<fo:block font-weight="bold">Date</fo:block>
				</name>
				<value>
					<fo:block>
						<xsl:value-of select="$vdEventDate"/>
					</fo:block>
				</value>
			</parameter>
		</caseparameters>
	</courtcase>
	<bodyintroright><fo:block><fo:inline text-align="center"><seal/></fo:inline></fo:block></bodyintroright>

	<body>
	<editable useid="N100C8">
		<fo:block space-after="0.4cm">
			Before <xsl:value-of select="$vdJudge"/> sitting at <xsl:value-of select="$vdHearingAtCourtNameDescription"/>, <xsl:value-of select="$vdHearingAtCourtAddress"/>
		</fo:block>
		<fo:block space-after="0.4cm"><xsl:copy-of select="$vdHearingAttendees"/></fo:block>
		<fo:block space-after="0.4cm">Upon the application of the <xsl:value-of select="$vdDeponentClaimantDefendant"/>, <xsl:value-of select="$vdJudge"/> has ordered you to attend at <xsl:value-of select="$vdHearingTime"/> on <xsl:value-of select="$vdHearingDate"/> at <xsl:value-of select="$vdHearingCourtNameDescription"/>, <xsl:value-of select="$vdHearingCourtAddress"/> to be examined on oath <xsl:if test="$vdDocumentExists = 'Y'">and to produce the following document(s): <xsl:copy-of select="$vdDocumentToProduce"/> </xsl:if>
		</fo:block>
		<fo:block space-after="0.4cm"><xsl:value-of select="$vdDeponentExpensesWording"/></fo:block>
	</editable>
	</body>
	
	<footnote noteextent="6.1">
		<fo:block space-after="0.1cm" font-family="Times" text-align="justify">
	
		<fo:table table-layout="fixed">
			<fo:table-column column-width="19cm"></fo:table-column>
			<fo:table-body>
				<fo:table-row>
					<fo:table-cell border-top-style="solid" border-top-width="0.02cm"  border-left-style="solid" border-left-width="0.02cm"
						border-right-style="solid" border-right-width="0.02cm" border-bottom-style="solid" border-bottom-width="0.02cm" height="5.7cm">
						<fo:block padding-left="0.1cm" padding-right="0.1cm" font-weight="bold" font-size="10pt">
							Do not ignore this order
						</fo:block>
						<fo:block padding-left="0.1cm" padding-right="0.1cm" space-after="0.4cm" font-size="9pt">
							If you were offered money for travel expenses and compensation for loss of time at the time it was served on you and you
						</fo:block>
						<list type="bullet">
							<list-item>
								<fo:block padding-left="0.1cm" padding-right="0.1cm"  font-size="9pt">
									fail to attend or produce documents as required by the order: or
								</fo:block>
							</list-item>
							<list-item>
								<fo:block padding-left="0.1cm" padding-right="0.1cm" space-after="0.4cm"  font-size="9pt">
									refuse to take an oath or affirm for the purpose of the examination or to answer any lawful question or produce any document at the examination
								</fo:block>
							</list-item>
						</list>
						<fo:block padding-left="0.1cm" padding-right="0.1cm" font-size="9pt">
							you may be liable to fine and may in addition be ordered to pay any costs resulting from your failure to attend or refusal to take an oath or affirm.	  
						</fo:block>
					</fo:table-cell>
				</fo:table-row>
			</fo:table-body>
		</fo:table>	
	
	</fo:block>	
	</footnote>
	<defaultFooter id="CJR170"/>
</root>