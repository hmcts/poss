<!-- Version: $Revision: 1.23 $ -->
<!--  -->
<!-- DESCRIPTION: This stylesheet is used to create an XSL:FO document that -->
<!-- can be processed into a PDF version.  Business logic -->
<!-- is embedded to generate the correct document text for the order -->
<!-- required. -->
<!--  -->
<!-- INPUTS: XML document containing: the answers to questions asked of the -->
<!-- user; case data retrieved from the database; HTML representing the  -->
<!-- body of the document content (already edited by the user). -->
<!--  -->
<!-- OUTPUTS: XML document with FO tags containing instructions for the -->
<!-- creation of a PDF document. -->
<!--  -->
<!-- 
@author Sandeep Mullangi
@version 0.1
Change History
Oct 27, 2008 Sandeep Mullangi - Printing insolvency number if present as part of RFC 486
30 Aug 2012, Chris Vincent.  Trac 4714, replaced hard coded opening hours with variable vdCourtAvailability.
07 Sep 2012, Chris Vincent.  Trac 4718, replaced vdCourtAvailability with vdFooterCourtAvailability.
-->
<!-- ====================================================================== -->
<root xmlns:xsl="http://www.w3.org/1999/XSL/Transform" xmlns:fo="http://www.w3.org/1999/XSL/Format" xmlns="http://eds.com/supsfo">
	<variables>@word.processing.url.xsl@supsfo.xsl</variables>
	<layout>order</layout>
	<duplex/>
	<addressee>
		<blank/>
		<debtorparty/>
		<creditorparty/>
		<company/>
		<applicant/>
		<petitioner/>
		<trustee/>
		<insolvencypractitioner/>
		<officialreceiver/>
	</addressee>
	<header>
		<fo:block font-size="10pt" font-weight="bold">Form 6.30</fo:block>
		<fo:block font-size="10pt" font-weight="bold">Rule 6.45, 6.48</fo:block>
		<fo:block font-size="16pt" font-weight="bold">Bankruptcy Order on Debtor's Petition</fo:block>
	</header>
	<courtcase>
		<court>
			<xsl:copy-of select="$vdCourtHeaderBlock"/>
		</court>
		<caseparameters>
			<!-- adding insolvency number-->
            <parameter>
                <name>
                    <fo:block font-weight="bold">
                        <xsl:choose>
                            <xsl:when test="string-length($vdInsolvencyNumber) > 0">Insolvency Number</xsl:when>
                            <xsl:otherwise>Case Number</xsl:otherwise>
                        </xsl:choose>
                    </fo:block>
                </name>
                <value>
                    <fo:block>
                        <xsl:choose>
                            <xsl:when test="string-length($vdInsolvencyNumber) > 0">
                                <xsl:value-of select="substring($vdInsolvencyNumber,1,4)"/> of <xsl:value-of select="substring($vdInsolvencyNumber,5,4)"/>
                            </xsl:when>
                            <xsl:otherwise>
                                <xsl:value-of select="$vdClaimNumber"/>
                            </xsl:otherwise>
                        </xsl:choose>
                    </fo:block>
                </value>
			</parameter>
			<parameter>
				<name>
					<fo:block font-weight="bold">Debtor</fo:block>
				</name>
				<value>
					<fo:block hyphenate="true">
						<xsl:value-of select="$vdSubjectName"/>
					</fo:block>
				</value>
			</parameter>
		</caseparameters>
	</courtcase>
	
	<body>
	<editable useid="N10096">
		<fo:block font-weight="bold" space-after="0.4cm" font-size="12pt">
			In Bankruptcy
		</fo:block>
		<fo:block space-after="0.4cm">
			Before <xsl:value-of select="$vdJudge"/>
		</fo:block>
		<fo:block space-after="0.4cm">
			Upon the petition of the above named debtor which was presented on <xsl:value-of select="$vdPetitionDate"/>
		</fo:block>
		<fo:block space-after="0.4cm">
			<xsl:value-of select="$vdHearingAttendees" />
		</fo:block>
		<xsl:if test="string-length($vdPractitionerName) > 0">
			<fo:block space-after="0.4cm">
				And on considering the report of  <xsl:value-of select="$vdPractitionerName"/> appointed under section 273(2) of the Insolvency Act 1986
			</fo:block>
		</xsl:if>
		<fo:block space-after="0.4cm">
			And upon reading the petition and Statement of Affairs
		</fo:block>
		<fo:block >
			It is ordered that <xsl:value-of select="$vdSubjectName"/>
		</fo:block>
		<fo:block space-after="0.4cm">
			<xsl:copy-of select="$vdDescription"/>
		</fo:block>
		<fo:block space-after="0.4cm">
			be adjudged bankrupt
		</fo:block>
		
		<xsl:if test="$vdECRegulation != 'Y'">
			<fo:block space-after="0.4cm">
				And the court is satisfied that the EC Regulation does not apply in relation to these proceedings
			</fo:block>
		</xsl:if>
		
		<xsl:if test="$vdECRegulation = 'Y'">
			<fo:block space-after="0.4cm">
				And the court being satisfied that the EC Regulation does apply and that these proceedings are <xsl:value-of select="$vdECProceedingType"/> proceedings as defined in Article 3 of the regulation
			</fo:block>
		</xsl:if>
		 		
 		<fo:block space-after="0.4cm">
			Date: <xsl:value-of select="$vdOrderDate"/>  
 		</fo:block>
		<fo:block space-after="0.4cm">		
			Time: <xsl:value-of select="$vdHearingTime"/>
 		</fo:block>
		
		<footnote noteextent="8.3"> 		
		<fo:block  font-size="10pt"  font-family="Times">
		<fo:block space-after="0.4cm" text-decoration="underline">
			Important Notice to Bankrupt
		</fo:block>
		<fo:block space-after="0.4cm">
			The Official Receiver attached to the Court is by virtue of this Order receiver and manager of the bankrupt's estate.
			You are required to attend upon the Official Receiver of the Court at <xsl:value-of select="$vdReceiverAddress"/> <xsl:value-of select="$vdOfficialReceiverPartyTelephone"/>
			immediately after you have received this order
		</fo:block>
		<fo:block space-after="0.4cm" font-style="italic">
			The Official Receiver's offices are open Monday to Friday (except on holidays) <xsl:value-of select="$vdFooterCourtAvailability"/>
		</fo:block>
		<xsl:if test="$vdJudgmentDebtorHasSolicitor= 'Y'">
			<fo:block space-after="0.1cm">
				<fo:table table-layout="fixed">
					<fo:table-column column-width="19.cm"></fo:table-column>
					<fo:table-body>
						<fo:table-row>
							<fo:table-cell padding-left="0.2cm" padding-right="0.2cm" border-style="solid" border-width="0.02cm">
								<fo:block font-weight="bold" space-before="0.2cm" space-after="0.4cm">Endorsement on Order</fo:block>
								<fo:block space-after="0.4cm">The solicitor to the debtor is:</fo:block>
								<fo:block space-after="0.4cm">Name: <xsl:value-of select="$vdJudgmentDebtorSolicitorName"/></fo:block>
								<fo:block space-after="0.4cm">Address: <xsl:call-template name="format-address-single-line">
									<xsl:with-param name="theAddress"><xsl:copy-of select="$vdJudgmentDebtorSolicitorAddress"/></xsl:with-param>
									</xsl:call-template></fo:block>
								<fo:block space-after="0.4cm">Telephone No: <xsl:value-of select="$vdJudgmentDebtorSolicitorTelephone"/></fo:block>
								<fo:block space-after="0.2cm">Reference: <xsl:value-of select="$vdSubjectReference"/></fo:block>
							</fo:table-cell>
						</fo:table-row>
					</fo:table-body>
				</fo:table>
			</fo:block>
		</xsl:if>
		<xsl:if test="$vdJudgmentDebtorHasSolicitor != 'Y'">
			<fo:block space-after="4.8cm">&#xa0;</fo:block>
		</xsl:if>
		</fo:block>
	</footnote> 					
	</editable>
 	</body> 		
	<defaultFooter id="O_10_12"/>
</root>