<!-- DESCRIPTION: This stylesheet is used to create an XSL:FO document that -->
<!-- can be processed into a PDF version.  Business logic -->
<!-- is embedded to generate the correct document text for the order -->
<!-- required. -->
<!--  -->
<!-- INPUTS: XML document containing: the answers to questions asked of the -->
<!-- user; case data retrieved from the database; HTML representing the  -->
<!-- body of the document content (already edited by the user). -->
<!--  -->
<!-- OUTPUTS: XML document with FO tags containing instructions for the -->
<!-- creation of a PDF document. -->
<!--  -->
<!-- ====================================================================== -->
<root xmlns:xsl="http://www.w3.org/1999/XSL/Transform" xmlns:fo="http://www.w3.org/1999/XSL/Format" xmlns="http://eds.com/supsfo">
	<variables>@word.processing.url.xsl@supsfo.xsl</variables>
	<layout yourRef="true">letter</layout>
	<logo/>
	<addressee>
		<subject/>
	</addressee>	
	<body>
		<editable>
		<fo:block space-after="0.4cm">Dear <xsl:value-of select="$vdGreeting"/></fo:block>
		<fo:block space-after="0.4cm" font-size="12pt" font-weight="bold" text-align="center">Re: Case Number: <xsl:value-of select="$vdClaimNumber"/>&#xa0;<xsl:value-of select="$vdClaimantName"/> v <xsl:value-of select="$vdDefendant1Name"/>
		</fo:block>
		<xsl:if test="$vdSelectLetter = '1'">
			<fo:block space-after="0.4cm">
				Receipt of your Bill of Costs in this matter is acknowledged. Please note the Bill has been given the following number: <xsl:value-of select="$vdBillOfCostsNumber"/>.
			</fo:block>
			<fo:block space-after="0.8cm">
				This number <fo:inline font-weight="bold">MUST</fo:inline> be quoted in all future correspondence. The Court will not be able to trace your papers without it. I thank you for your co-operation in this matter. 
			</fo:block>
		</xsl:if>
		<xsl:if test="$vdSelectLetter = '2'">
			<fo:block space-after="0.4cm">
				I regret the need to return your correspondence dated <xsl:value-of select="$vdCorrespondanceDate"/>, however I am unable to trace your bill/bundle from the information provided.
			</fo:block>
			<fo:block space-after="0.4cm">
				Please return your correspondence with as much of the following information as possible to enable us to answer your enquiry. 
			</fo:block>
			<fo:block space-after="0.4cm">
				1.&#xa0;&#xa0;&#xa0;The bill number. 
			</fo:block>
			<fo:block space-after="0.4cm">
				2.&#xa0;&#xa0;&#xa0;The date the bill/bundle was originally submitted to the Court. 
			</fo:block>
			<fo:block space-after="0.8cm">
				3.&#xa0;&#xa0;&#xa0;The date of any hearing regarding the taxation. 
			</fo:block>
		</xsl:if>
		<xsl:if test="$vdSelectLetter = '3'">
			<fo:block space-after="0.4cm">
				Bill Number: <xsl:value-of select="$vdBillOfCostsNumber"/>
			</fo:block>
			<fo:block space-after="0.4cm">
				I refer to your letter dated <xsl:value-of select="$vdCorrespondanceDate"/> and can confirm that the taxation hearing on <xsl:value-of select="$vdSelectHearingDate"/> has now been vacated, and our records marked "bill settled". 
			</fo:block>
			<fo:block space-after="0.8cm">
				I return your Bill of Costs, together with any supporting documents. 
			</fo:block>
		</xsl:if>
		<xsl:if test="$vdSelectLetter = '4'">
			<fo:block space-after="0.4cm">
				Bill Number: <xsl:value-of select="$vdBillOfCostsNumber"/>
			</fo:block>
			<fo:block space-after="0.4cm">
				I enclose your taxed Bill of Costs in the above case. However I have retained your bundle of documents and would ask that you make arrangements to collect them by <xsl:value-of select="$vdCollectedByDate"/>
				. Due to a restriction on the amount of storage space available, we will have no alternative but to destroy files which are not collected within the time allowed, unless notified otherwise.
			</fo:block>
			<fo:block space-after="0.8cm">
				Please quote the Bill Number when collecting your papers. 
			</fo:block>
		</xsl:if>
		<fo:block space-after="1.5cm"><xsl:value-of select="$vdLetterEnding"/></fo:block>
		<fo:block><xsl:value-of select="$vdName"/></fo:block>
		<fo:block><xsl:value-of select="$vdSection"/> Section</fo:block>
		<fo:block>Ext <xsl:value-of select="$vdExtension"/></fo:block>
		</editable>
	</body>
	<letterfooter id="L_10_1_2_15_16"/>
</root>