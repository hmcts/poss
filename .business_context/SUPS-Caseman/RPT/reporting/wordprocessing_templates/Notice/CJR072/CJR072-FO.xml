<?xml version="1.0" encoding="UTF-8"?>
<root xmlns:xsl="http://www.w3.org/1999/XSL/Transform" xmlns:fo="http://www.w3.org/1999/XSL/Format" xmlns="http://eds.com/supsfo">
	<variables>@word.processing.url.xsl@supsfo.xsl</variables>
	<layout>order</layout>
	<duplex/>
	<addressee>
		<blank/>
		<claimants/>
		<defendants/>
		<part20claimants/>
		<part20defendants/>
	</addressee>
	<header>
		<fo:block font-size="16pt" font-weight="bold">Standard order for failure to file</fo:block>
		<fo:block font-size="16pt" font-weight="bold">listing questionnaires</fo:block>
	</header>
	<courtcase>
		<court>
			<xsl:copy-of select="$vdCourtHeaderBlock"/>
		</court>
		<caseparameters>
			<parameter>
				<name>
					<fo:block font-weight="bold">Claim Number</fo:block>
				</name>
				<value>
					<fo:block>
						<xsl:value-of select="$vdClaimNumber"/>
					</fo:block>
				</value>
			</parameter>
			<parameter>
				<name>
					<fo:block font-weight="bold">Date</fo:block>
				</name>
				<value>
					<fo:block>
						<xsl:value-of select="$vdEventDate"/>
					</fo:block>
				</value>
			</parameter>
		</caseparameters>
	</courtcase>
	<bodyintroright><fo:block space-before="0.4cm"><fo:inline text-align="center"><seal/></fo:inline></fo:block></bodyintroright>
	<body>
		<editable useid="N1008A">
		<fo:block space-before="0.8cm" space-after="0.4cm">
			Before <xsl:value-of select="$vdJudge"/> sitting at <xsl:value-of select="$vdHearingAtCourtNameDescription"/>, <xsl:value-of select="$vdHearingAtCourtAddress"/>
		</fo:block>
		<fo:block space-after="0.4cm"><xsl:copy-of select="$vdHearingAttendees"/></fo:block>
		<fo:block space-after="0.4cm"><xsl:value-of select="$vdFailureWording"/></fo:block>
		<fo:block space-after="0.4cm">
			<xsl:value-of select="$vdJudge"/> has ordered that <xsl:value-of select="$vdInstructionsLQ"/><xsl:value-of select="$vdInstructionsHearing1"/>
		</fo:block>
		<fo:block space-after="0.4cm">Dated <xsl:value-of select="$datetoday"/></fo:block>
		</editable>
	</body>
	<defaultFooter id="CJR072"/>
</root>
