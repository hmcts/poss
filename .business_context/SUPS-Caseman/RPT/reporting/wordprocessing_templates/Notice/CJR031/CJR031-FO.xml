<!--  -->
<!-- DESCRIPTION: This stylesheet is used to create an XSL:FO document that -->
<!-- can be processed into a PDF version.  Business logic -->
<!-- is embedded to generate the correct document text for the order -->
<!-- required. -->
<!--  -->
<!-- INPUTS: XML document containing: the answers to questions asked of the -->
<!-- user; case data retrieved from the database; HTML representing the  -->
<!-- body of the document content (already edited by the user). -->
<!--  -->
<!-- OUTPUTS: XML document with FO tags containing instructions for the -->
<!-- creation of a PDF document. -->
<!--  -->
<!-- ====================================================================== -->
<root xmlns:xsl="http://www.w3.org/1999/XSL/Transform" xmlns:fo="http://www.w3.org/1999/XSL/Format" xmlns="http://eds.com/supsfo">
	<variables>@word.processing.url.xsl@supsfo.xsl</variables>
	<addressee>
		<blank/>
		<claimants/>
		<defendants/>
	</addressee>
	<header>
		<fo:block font-size="16pt" font-weight="bold">Notice that a <xsl:value-of select="$vdFiledNoticeTitle"/></fo:block>
		<fo:block font-size="16pt" font-weight="bold">Has Been Filed</fo:block>
	</header>
	<courtcase>
		<court>
			<xsl:copy-of select="$vdCourtHeaderBlock"/>
		</court>
		<caseparameters>
			<parameter>
				<name>
					<fo:block font-weight="bold">Claim Number</fo:block>
				</name>
				<value>
					<fo:block>
						<xsl:value-of select="$vdClaimNumber"/>
					</fo:block>
				</value>
			</parameter>
			<parameter>
				<name>
					<fo:block font-weight="bold">Claimant</fo:block>
					<fo:block font-size="9pt">(including ref.)</fo:block>
				</name>
				<value>
					<fo:block hyphenate="true">
						<xsl:value-of select="$vdClaimantName"/>
					</fo:block>
					<fo:block font-size="9pt" hyphenate="true">
						<xsl:value-of select="$vdClaimantReference"/>
					</fo:block>
				</value>
			</parameter>
			<parameter>
				<name>
					<fo:block font-weight="bold">Defendant</fo:block>
					<fo:block font-size="9pt">(including ref.)</fo:block>
				</name>
				<value>
					<fo:block hyphenate="true">
						<xsl:call-template name="tmpAddresseesDefendantName">
							<xsl:with-param name="addressee" select="$addressee"/>
						</xsl:call-template>
					</fo:block>
					<fo:block font-size="9pt" hyphenate="true">
						<xsl:call-template name="tmpAddresseesDefendantReference">
							<xsl:with-param name="addressee" select="$addressee"/>
						</xsl:call-template>
					</fo:block>
				</value>
			</parameter>
			<parameter>
				<name>
					<fo:block font-weight="bold">Date</fo:block>
				</name>
				<value>
					<fo:block><xsl:value-of select="$vdEventDate"/>
					</fo:block>
				</value>
			</parameter>
		</caseparameters>
	</courtcase>

	<body font-size="12pt">
		<fo:block space-after="2.0cm"/>
		<fo:block space-after="0.8cm" font-size="12pt">
			<xsl:call-template name="tmpAddresseesFiledCounterclaimText">
				<xsl:with-param name="addressee" select="$addressee"/>
			</xsl:call-template>
		</fo:block>
		<fo:block font-size="12pt">
			<fo:table table-layout="fixed">
				<fo:table-column column-width="10.66cm"/>
				<fo:table-column column-width="3.5cm"/>
				<fo:table-column column-width="4.1cm"/>
				<fo:table-body>
					<fo:table-row>
						<fo:table-cell>
							<fo:block>You must complete the allocation questionnaire on or before</fo:block>
						</fo:table-cell>
						<fo:table-cell border-top-style="solid" border-right-style="solid" border-left-style="solid" border-bottom-style="solid"
							border-top-width="0.02cm" border-right-width="0.02cm" border-left-width="0.02cm" border-bottom-width="0.02cm"
							padding-right="0.1cm" padding-left="0.1cm">
							<fo:block font-weight="bold" text-align="center"><xsl:value-of select="$vdQReturnDate"/></fo:block>
						</fo:table-cell>
						<fo:table-cell padding-left="0.2cm">
							<fo:block>and return it to the</fo:block>
						</fo:table-cell>
					</fo:table-row>
				</fo:table-body>
			</fo:table>
		</fo:block>
		<fo:block space-after="0.8cm" font-size="12pt">court office at</fo:block>
		<fo:block space-after="0.8cm" font-size="12pt">
			<fo:table table-layout="fixed">
				<fo:table-column column-width="16.5cm"/>
				<fo:table-body>
					<fo:table-row>
						<fo:table-cell  border-top-style="solid" border-right-style="solid" border-left-style="solid" border-bottom-style="solid"
							border-top-width="0.02cm" border-right-width="0.02cm" border-left-width="0.02cm" border-bottom-width="0.02cm"
							padding-right="0.1cm" padding-left="0.1cm">
								<fo:block><xsl:value-of select="$vdHearingCourtNameDescription"/>, <xsl:value-of select="$vdHearingCourtAddress"/></fo:block>
						</fo:table-cell>
					</fo:table-row>
				</fo:table-body>
			</fo:table>
		</fo:block>		
		<xsl:if test="string-length($vdAQFee) > 0"> 
			<fo:block space-after="0.8cm" font-size="12pt">
				A fee of 
				&#163;<xsl:call-template name="correctCalculation">
					<xsl:with-param name="value"><xsl:value-of select="$vdAQFee"/></xsl:with-param>
				</xsl:call-template> 
				is payable by the claimant on the filing of their allocation questionnaire.
			</fo:block>
		</xsl:if>
		<xsl:if test="$vdFiledCounterclaim = 'CDF' or $vdFiledCounterclaim = 'CDSF' or $vdFiledCounterclaim = 'DCC' or $vdFiledCounterclaim = 'CC'"> 
			<fo:block space-after="0.8cm" font-size="12pt">
				<xsl:call-template name="tmpFiledNoticeWordingText">
					<xsl:with-param name="addressee" select="$addressee"/>
				</xsl:call-template>
			</fo:block>
		</xsl:if>
	</body>
	<defaultFooter id="CJR031"/>
</root>