<!-- Version: $Revision: 1.14 $ -->
<!--  -->
<!-- DESCRIPTION: This stylesheet is used to create an XSL:FO document that -->
<!-- can be processed into a PDF version.  Business logic -->
<!-- is embedded to generate the correct document text for the order -->
<!-- required. -->
<!--  -->
<!-- INPUTS: XML document containing: the answers to questions asked of the -->
<!-- user; case data retrieved from the database; HTML representing the  -->
<!-- body of the document content (already edited by the user). -->
<!--  -->
<!-- OUTPUTS: XML document with FO tags containing instructions for the -->
<!-- creation of a PDF document. -->
<!--  -->
<!-- ====================================================================== -->
<root xmlns:xsl="http://www.w3.org/1999/XSL/Transform" xmlns:fo="http://www.w3.org/1999/XSL/Format" xmlns="http://eds.com/supsfo">
	<variables>@word.processing.url.xsl@supsfo.xsl</variables>
	<duplex/>
	<addressee>
		<blank/>
	</addressee>
	<suppressaddress/>
	<header>
		<fo:block font-size="16pt" font-weight="bold">Warrant of arrest</fo:block>
		<fo:block font-size="16pt" font-weight="bold">(Housing Act 1996)</fo:block>
	</header>
	<courtcase>
		<court>
			<xsl:copy-of select="$vdCourtHeaderBlock"/>
		</court>
		<caseparameters>
			<parameter>
				<name>
					<fo:block font-weight="bold">Claim Number</fo:block>
				</name>
				<value>
					<fo:block>
						<xsl:value-of select="$vdClaimNumber"/>
					</fo:block>
				</value>
			</parameter>
			<parameter>
				<name>
					<fo:block font-weight="bold">Claimant</fo:block>
					<fo:block font-size="9pt">(including ref.)</fo:block>
				</name>
				<value>
					<fo:block hyphenate="true">
						<xsl:value-of select="$vdClaimantName"/>
					</fo:block>
					<fo:block font-size="9pt" hyphenate="true">
						<xsl:value-of select="$vdClaimantReference"/>
					</fo:block>
				</value>
			</parameter>
			<parameter>
				<name>
					<fo:block font-weight="bold">Defendant</fo:block>
					<fo:block font-size="9pt">(including ref.)</fo:block>
				</name>
				<value>
					<fo:block hyphenate="true">
						<xsl:value-of select="$vdDefendantName"/>
					</fo:block>
					<fo:block font-size="9pt" hyphenate="true">
						<xsl:value-of select="$vdDefendantReference"/>
					</fo:block>
				</value>
			</parameter>
			<parameter>
				<name>
					<fo:block font-weight="bold">Warrant Number</fo:block>
				</name>
				<value>
					<fo:block>
						<xsl:value-of select="$vdWarrantNumber"/>
					</fo:block>
				</value>
			</parameter>			
			<parameter>
				<name>
					<fo:block font-weight="bold">Date</fo:block>
				</name>
				<value>
					<fo:block>
						<xsl:value-of select="$vdEventDate"/>
					</fo:block>
				</value>
			</parameter>
		</caseparameters>
	</courtcase>
	<bodyintroright><fo:block space-before="0.4cm"><fo:inline text-align="center"><seal/></fo:inline></fo:block></bodyintroright>

	<body>
		<editable useid="N100DB">
		<fo:block space-after="1.0cm"/>
		<fo:block space-after="0.8cm">
			<fo:inline font-weight="bold">To</fo:inline> the bailiffs of the court and every constable within the district of the court
		</fo:block>
		<fo:block>
			<fo:inline font-weight="bold">On </fo:inline><xsl:value-of select="$vdWarrantDate"/>, <xsl:value-of select="$vdJudge"/>
		</fo:block>
		<fo:block>
			sitting at <xsl:value-of select="$vdHearingCourtNameDescription"/>, <xsl:value-of select="$vdHearingCourtAddress"/>
		</fo:block>
		<fo:block space-after="0.8cm">
			heard an application by the claimant, supported by evidence that the defendant had disobeyed the order made on <xsl:value-of select="$vdInjunctionDate"/>.
			A copy of that order is attached to this warrant. Details of the breach(es) of the order which are alleged by the claimant are set out <xsl:value-of select="$vdWarrantArrestScheduledAttached"/>
		</fo:block>
		<xsl:if test="string-length($vdBreachDetails) > 0">
			<fo:block space-after="0.8cm">
				<xsl:copy-of select="$vdBreachDetails"/>
			</fo:block>
		</xsl:if>
		<fo:block space-after="0.8cm">
			<fo:inline font-weight="bold">The Judge ordered</fo:inline> that a warrant of arrest be issued <xsl:if test="string-length($vdWarrantArrestDetails) > 0"><xsl:value-of select="$vdWarrantArrestDetails"/></xsl:if>.
		</fo:block>
		<fo:block>
			You the bailiffs and constables are therefore required to arrest the defendant <xsl:value-of select="$vdSubjectName"/>, <xsl:value-of select="$vdSubjectAddress"/>
		</fo:block>
		<fo:block space-after="0.8cm">
			and to bring <xsl:value-of select="$vdDebtorHimHer"/> before a judge <xsl:value-of select="$vdWarrantArrestBringNow"/>
		</fo:block>
		<fo:block>
			Dated <xsl:value-of select="$vdWarrantDate"/>
		</fo:block>

		</editable>

		<fo:block space-after="21cm" break-before="page"/>

		<fo:table table-layout="fixed">
			<fo:table-column column-width="9cm"></fo:table-column>
			<fo:table-column column-width="10.28cm"></fo:table-column>
			<fo:table-body>
				<fo:table-row keep-with-next="always">
					<fo:table-cell border-top-style="solid" border-top-width="0.05cm" number-columns-spanned="2">
						<fo:block font-size="12pt" font-weight="bold" space-after="0.3cm">Bailiff's Certificate</fo:block>
					</fo:table-cell>
				</fo:table-row>
				<fo:table-row keep-with-next="always">
					<fo:table-cell padding-left="0.3cm">
						<fo:block font-size="10pt" space-after="0.6cm">I arrested <xsl:value-of select="$vdSubjectName"/>, the defendant,</fo:block>
					</fo:table-cell>
				</fo:table-row>
				<fo:table-row keep-with-next="always">
					<fo:table-cell padding-left="1cm">
						<fo:block font-size="10pt" space-after="0.6cm">on ______________________________________</fo:block>
					</fo:table-cell>
					<fo:table-cell>
						<fo:block font-size="10pt" space-after="0.6cm">at ______________________________________</fo:block>
					</fo:table-cell>
				</fo:table-row>
				<fo:table-row keep-with-next="always">
					<fo:table-cell padding-left="1cm" number-columns-spanned="2">
						<fo:block font-size="10pt" space-after="0.6cm">and brought  before the judge on ______________________________________.</fo:block>
					</fo:table-cell>
				</fo:table-row>
				<fo:table-row keep-with-next="always" >
					<fo:table-cell padding-left="1cm" number-columns-spanned="2">
						<fo:block font-size="10pt" space-after="0.2cm">Signed ______________________________________</fo:block>
					</fo:table-cell>
				</fo:table-row>
				<fo:table-row keep-with-next="always" >
					<fo:table-cell padding-left="3cm" number-columns-spanned="2">
						<fo:block font-size="10pt">Bailiff of the County Court</fo:block>
					</fo:table-cell>
				</fo:table-row>
			</fo:table-body>
		</fo:table>	
	</body>
	<defaultFooter id="CJR102"/>
</root>