<!-- Version: $Revision: 1.10 $ -->
<!--  -->
<!-- DESCRIPTION: This stylesheet is used to create an XSL:FO document that -->
<!-- can be processed into a PDF version.  Business logic -->
<!-- is embedded to generate the correct document text for the order -->
<!-- required. -->
<!--  -->
<!-- INPUTS: XML document containing: the answers to questions asked of the -->
<!-- user; case data retrieved from the database; HTML representing the  -->
<!-- body of the document content (already edited by the user). -->
<!--  -->
<!-- OUTPUTS: XML document with FO tags containing instructions for the -->
<!-- creation of a PDF document. -->
<!--  -->
<!-- ====================================================================== -->
<root xmlns:xsl="http://www.w3.org/1999/XSL/Transform" xmlns:fo="http://www.w3.org/1999/XSL/Format" xmlns="http://eds.com/supsfo">
	<variables>@word.processing.url.xsl@supsfo.xsl</variables>
	<addressee copies="3">
		<blank/>
	</addressee>
	<header>
		<fo:block font-size="16pt" font-weight="bold"><xsl:if test="$vdOrderWithoutNotice = 'Y'">Interim </xsl:if>Anti-social behaviour (Order under section 1 
			<xsl:choose>
				<xsl:when test="$vdOrderWithoutNotice = 'Y'">D(2) </xsl:when>
				<xsl:when test="$vdOrderWithoutNotice != 'Y'">B(4) </xsl:when>
			</xsl:choose>
			of the Crime and Disorder Act 1998)</fo:block>
	</header>
	<courtcase>
		<court>
			<xsl:copy-of select="$vdCourtHeaderBlock"/>
		</court>
		<caseparameters>
			<parameter>
				<name>
					<fo:block font-weight="bold">Claim Number</fo:block>
				</name>
				<value>
					<fo:block>
						<xsl:value-of select="$vdClaimNumber"/>
					</fo:block>
				</value>
			</parameter>
			<parameter>
				<name>
					<fo:block font-weight="bold">Claimant</fo:block>
					<fo:block font-size="9pt">(including ref.)</fo:block>
				</name>
				<value>
					<fo:block hyphenate="true">
						<xsl:value-of select="$vdClaimantName"/>
					</fo:block>
					<fo:block font-size="9pt" hyphenate="true">
						<xsl:value-of select="$vdClaimantReference"/>
					</fo:block>
				</value>
			</parameter>
			<parameter>
				<name>
					<fo:block font-weight="bold">Defendant</fo:block>
					<fo:block font-size="9pt">(including ref.)</fo:block>
				</name>
				<value>
					<fo:block hyphenate="true">
						<xsl:value-of select="$vdSubjectName"/>
					</fo:block>
					<fo:block font-size="9pt" hyphenate="true">
						<xsl:value-of select="$vdSubjectReference"/>
					</fo:block>
				</value>
			</parameter>
			<parameter condition="string-length($vdOrderApplicantName) > 0">
				<name>
					<fo:block font-weight="bold">Applicant</fo:block>
				</name>
				<value>
					<fo:block><xsl:value-of select="$vdOrderApplicantName"/>
					</fo:block>
				</value>
			</parameter>
		</caseparameters>
	</courtcase>

	<body>
		<editable useid="N100C7">
		<fo:block space-after="0.4cm">
			<fo:inline font-weight="bold">On</fo:inline>&#xa0;<xsl:value-of select="$vdJudgmentDate"/>, <xsl:value-of select="$vdJudge"/>
		</fo:block>
		<fo:block space-after="0.4cm">
			sitting at <xsl:value-of select="$vdHearingAtCourtNameDescription"/>, <xsl:value-of select="$vdHearingAtCourtAddress"/>
		</fo:block>
		<fo:block space-after="0.4cm">
			considered the application of the <xsl:value-of select="$vdOrderApplicant"/> and found that the <xsl:value-of select="$vdOrderClaimantDefendant"/> has acted in an anti-social manner
			that caused or was likely to cause harassment, alarm or distress to one or more persons not of the same household
			as <xsl:value-of select="$vdHimselfHerself"/> and that this order is necessary to protect persons from further anti-social acts by the <xsl:value-of select="$vdOrderClaimantDefendant"/>
		</fo:block>
		<fo:block space-after="0.4cm">
			<fo:inline font-weight="bold">and the court ordered</fo:inline> that 
		</fo:block>
		<fo:block space-after="0.4cm">
			The <xsl:value-of select="$vdOrderClaimantDefendant"/> is forbidden from:-
		</fo:block>
		<fo:block space-after="0.4cm">
			<xsl:value-of select="$vdProhibitedActivity"/>
		</fo:block>
		<xsl:choose>
			<xsl:when test="$vdDateOrderExpires != $emptyDate"><fo:block space-after="0.4cm">until <xsl:value-of select="$vdDateOrderExpires"/></fo:block></xsl:when>
			<xsl:otherwise><fo:block space-after="0.4cm">until further notice</fo:block></xsl:otherwise>
		</xsl:choose>
		<fo:block space-after="0.4cm">
			The <xsl:value-of select="$vdOrderApplicant"/> or <xsl:value-of select="$vdOrderClaimantDefendant"/> may apply to the court for this order to be varied or discharged.
		</fo:block>
		<xsl:if test="$vdOrderWithoutNotice != 'Y'">
			<fo:block space-after="0.4cm">
				Unless both parties consent, this order may not be discharged within two years of the order being served.
			</fo:block>
		</xsl:if>
		<fo:block space-after="0.4cm" font-weight="bold">
			To <xsl:value-of select="$vdSubjectName"/>, <xsl:value-of select="$vdSubjectAddress"/>
		</fo:block>
		<fo:block space-after="0.4cm">
			You must obey this order.  If, without reasonable excuse, you do anything which you are forbidden from doing by this order, you will be liable on conviction to a term of imprisonment not exceeding five years or to a fine or to both.
		</fo:block>
		<xsl:if test="$vdHearingCourtAddress != $emptyAddress">
			<fo:block space-after="0.4cm">
				Notice of further hearing (see also note below)
			</fo:block>
			<fo:block space-after="0.4cm">
				The court will re-consider the application and whether the order should continue at a further hearing
			</fo:block>
			<fo:block>
				at <xsl:value-of select="$vdHearingCourtNameDescription"/>, <xsl:value-of select="$vdHearingCourtAddress"/>
			</fo:block>
			<fo:block space-after="0.4cm">
				on <xsl:value-of select="$vdHearingDate1"/> at <xsl:value-of select="$vdHearingTime"/>
			</fo:block>
			<fo:block space-after="0.4cm">
				If you do not attend at the time shown the court may make an order in your absence.
		</fo:block>
		</xsl:if>
		</editable>
	</body>

	<footnote noteextent="2.0">
		<xsl:if test="$vdOrderWithoutNotice = 'Y'">
		<fo:block font-family="Times" text-align="justify" space-after="0.2cm">
		<fo:table table-layout="fixed" width="100%">
					<fo:table-column column-width="10cm"></fo:table-column>
					<fo:table-column column-width="9.28cm"></fo:table-column>
					<fo:table-body>
						<fo:table-row keep-with-next="always">
							<fo:table-cell number-columns-spanned="2" padding="0.1cm" border-style="solid" border-width="0.02cm">
								<fo:block font-weight="bold" font-size="9pt">Note: This order was made without notice being given to you.
									You may apply for it to be set aside, varied or stayed.  If you wish to apply, do not delay.
									You must make your application to the court within 7 days of the date you received it.
									You may make your application by writing to the court or asking the court for a Form N244 Application Notice.
									You will have to pay a fee to make your application unless you qualify for fee exemption or remission
								</fo:block>
							</fo:table-cell>
						</fo:table-row>
					</fo:table-body>
				</fo:table>	
			</fo:block>
		</xsl:if>
		<xsl:if test="$vdOrderWithoutNotice != 'Y'">
			<fo:block space-after="1.5cm">
				&#xA0;
			</fo:block>
		</xsl:if>
	</footnote>
	<defaultFooter id="CJR061"/>
</root>