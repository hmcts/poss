<!--  -->
<!-- DESCRIPTION: This stylesheet is used to create an XSL:FO document that -->
<!-- can be processed into a PDF version.  Business logic -->
<!-- is embedded to generate the correct document text for the order -->
<!-- required. -->
<!--  -->
<!-- INPUTS: XML document containing: the answers to questions asked of the -->
<!-- user; case data retrieved from the database; HTML representing the  -->
<!-- body of the document content (already edited by the user). -->
<!--  -->
<!-- OUTPUTS: XML document with FO tags containing instructions for the -->
<!-- creation of a PDF document. -->
<!--  -->
<!-- ====================================================================== -->
<root xmlns:xsl="http://www.w3.org/1999/XSL/Transform" xmlns:fo="http://www.w3.org/1999/XSL/Format" xmlns="http://eds.com/supsfo">
	<variables>@word.processing.url.xsl@supsfo.xsl</variables>
	<addressee>
		<blank/>
		<claimant/>
		<subject/>
	</addressee>
	<header>
		<fo:block font-size="16pt" font-weight="bold"><xsl:value-of select="$vdInterimOrder1"/>ospital order</fo:block>
	</header>
	<courtcase>
		<court>
			<xsl:copy-of select="$vdCourtHeaderBlock"/>
		</court>
		<caseparameters>
			<parameter>
				<name>
					<fo:block font-weight="bold">Claim Number</fo:block>
				</name>
				<value>
					<fo:block>
						<xsl:value-of select="$vdClaimNumber"/>
					</fo:block>
				</value>
			</parameter>
			<parameter>
				<name>
					<fo:block font-weight="bold">Claimant</fo:block>
					<fo:block font-size="9pt">(including ref.)</fo:block>
				</name>
				<value>
					<fo:block hyphenate="true">
						<xsl:value-of select="$vdClaimantName"/>
					</fo:block>
					<fo:block font-size="9pt" hyphenate="true">
						<xsl:value-of select="$vdClaimantReference"/>
					</fo:block>
				</value>
			</parameter>
			<parameter>
				<name>
					<fo:block font-weight="bold">Defendant</fo:block>
					<fo:block font-size="9pt">(including ref.)</fo:block>
				</name>
				<value>
					<fo:block hyphenate="true">
						<xsl:value-of select="$vdDefendantName"/>
					</fo:block>
					<fo:block font-size="9pt" hyphenate="true">
						<xsl:value-of select="$vdDefendantReference"/>
					</fo:block>
				</value>
			</parameter>
			<parameter>
				<name>
					<fo:block font-weight="bold">Date</fo:block>
				</name>
				<value>
					<fo:block>
						<xsl:value-of select="$vdEventDate"/>
					</fo:block>
				</value>
			</parameter>
		</caseparameters>
	</courtcase>
	<bodyintroright><fo:block space-before="0.4cm"><fo:inline text-align="center"><seal/></fo:inline></fo:block></bodyintroright>

	<body>
		<editable useid="N100C5">
		<fo:block space-after="1.0cm"/>
		<fo:block>
			On <xsl:value-of select="$vdOrderDate"/>, <xsl:value-of select="$vdJudge"/>
		</fo:block>
		<fo:block space-after="0.8cm">
			sitting at <xsl:value-of select="$vdHearingCourtNameDescription"/>, <xsl:value-of select="$vdHearingCourtAddress"/>
		</fo:block>
		<fo:block space-after="0.8cm">
			a) found, as recorded in an order of <xsl:value-of select="$vdBreachOrderDate"/>, that the defendant had disobeyed an injunction made under section
			<xsl:value-of select="$vdGuardianshipSection"/> of the Housing Act 1996,
		</fo:block>
		<fo:block space-after="0.8cm">
			b) <xsl:value-of select="$vdEvidenceGiven"/> evidence of two medical practitioners <xsl:value-of select="$vdMedicalPractitioner1"/> and <xsl:value-of select="$vdMedicalPractitioner2"/> as required by the provisions of section <xsl:value-of select="$vdSectionNumber"/> of the Mental Health
			Act 1983 that the defendant is suffering from <xsl:value-of select="$vdDefendantDisability"/> within the meaning of that Act,
		</fo:block>
		<fo:block space-after="0.8cm">
			c) found that all other conditions, which under section <xsl:value-of select="$vdSectionNumber"/> of the Mental Health Act 1983 are required to be satisfied for the making of <xsl:value-of select="$vdInterimOrder2"/>ospital order, are satisfied in respect of the defendant and
		</fo:block>
		<fo:block space-after="0.8cm">
			d) was satisfied that arrangements have been made for the defendant's admission to the hospital named below within 28 days of the date of this order;
		</fo:block>
		<fo:block>
			<fo:inline font-weight="bold">and the court orders that</fo:inline>
		</fo:block>
		<fo:block>
			The defendant <xsl:value-of select="$vdSubjectName"/> of <xsl:value-of select="$vdSubjectAddress"/> be admitted to and detained in <xsl:value-of select="$vdHospitalName"/> at <xsl:value-of select="$vdHospitalAddress"/>
			<xsl:if test="string-length($vdHospitalOrderDetentionPeriod) > 0"><xsl:value-of select="$vdHospitalOrderDetentionPeriod"/></xsl:if>
			and be conveyed there by <xsl:value-of select="$vdConveyerName"/><xsl:value-of select="$vdHospitalOrder1"/>
		</fo:block>

		</editable>
	
		<fo:block space-after="20cm" break-before="page"/>

		<fo:block font-size="14pt" font-weight="bold" space-after="0.5cm">Certificate of Service</fo:block>
		<fo:block font-size="12pt" space-after="0.5cm">I certify that a copy of this order was served by me on the claimant, by posting</fo:block>
		<fo:block font-size="12pt" space-after="0.5cm">on ______________________________________.</fo:block>
		<fo:block font-size="12pt" space-after="0.5cm">Signed ______________________________________</fo:block>
		<fo:block font-size="12pt" space-after="0.5cm">       Officer of the court</fo:block>
	</body>
	<defaultFooter id="CJR101" />
</root>