<!--  -->
<!-- DESCRIPTION: This stylesheet is used to create an XSL:FO document that -->
<!-- can be processed into a PDF version.  Business logic -->
<!-- is embedded to generate the correct document text for the order -->
<!-- required. -->
<!--  -->
<!-- INPUTS: XML document containing: the answers to questions asked of the -->
<!-- user; case data retrieved from the database; HTML representing the  -->
<!-- body of the document content (already edited by the user). -->
<!--  -->
<!-- OUTPUTS: XML document with FO tags containing instructions for the -->
<!-- creation of a PDF document. -->
<!--  -->
<!-- ====================================================================== -->
<root xmlns:xsl="http://www.w3.org/1999/XSL/Transform" xmlns:fo="http://www.w3.org/1999/XSL/Format" xmlns="http://eds.com/supsfo">
	<variables>@word.processing.url.xsl@supsfo.xsl</variables>
	<layout>order</layout>
	<duplex/>
	<addressee>
		<blank/>
		<claimants/>
		<defendants/>
		<part20claimants/>
		<part20defendants/>
	</addressee>
	<header>
		<fo:block font-size="16pt" font-weight="bold">General Form of Judgment or</fo:block>
		<fo:block font-size="16pt" font-weight="bold">Order</fo:block>
	</header>
	<courtcase>
		<court>
			<xsl:copy-of select="$vdCourtHeaderBlock"/>
		</court>
		<caseparameters>
			<parameter>
				<name>
					<fo:block font-weight="bold">Claim Number</fo:block>
				</name>
				<value>
					<fo:block>
						<xsl:value-of select="$vdClaimNumber"/>
					</fo:block>
				</value>
			</parameter>
			<parameter>
				<name>
					<fo:block font-weight="bold">Date</fo:block>
				</name>
				<value>
					<fo:block>
						<xsl:value-of select="$vdEventDate"/>
					</fo:block>
				</value>
			</parameter>
		</caseparameters>
	</courtcase>
	<bodyintroright><fo:block><fo:inline text-align="center"><seal/></fo:inline></fo:block></bodyintroright>
	<body>
	<editable useid="N10090">
		<fo:block space-after="1cm"/>
		<fo:block font-weight="bold">
			Expert Evidence
		</fo:block>
		<fo:block space-after="0.4cm">
			The parties have permission to rely at the trial on the expert evidence as follows:
		</fo:block>
		<fo:table table-layout="fixed">

			<fo:table-column column-width="4.5cm"></fo:table-column>
			<fo:table-column column-width="4cm"></fo:table-column>
			<fo:table-column column-width="11.28cm"></fo:table-column>
			<fo:table-body>

				<fo:table-row keep-with-next="always">
					<fo:table-cell>
						<fo:block>The Claimant:</fo:block>
					</fo:table-cell>
					<fo:table-cell>
						<fo:block>oral evidence:</fo:block>
					</fo:table-cell>
					<fo:table-cell>
						<fo:block><xsl:value-of select="$vdClaimantOralBy"/></fo:block>
					</fo:table-cell>
				</fo:table-row>

				<fo:table-row keep-with-next="always">
					<fo:table-cell/>
					<fo:table-cell>
						<fo:block>written evidence:</fo:block>
					</fo:table-cell>
					<fo:table-cell>
						<fo:block><xsl:value-of select="$vdClaimantWrittenBy"/></fo:block>
					</fo:table-cell>
				</fo:table-row>

				<fo:table-row keep-with-next="always">
					<fo:table-cell>
						<fo:block>The Defendant:</fo:block>
					</fo:table-cell>
					<fo:table-cell>
						<fo:block>oral evidence:</fo:block>
					</fo:table-cell>
					<fo:table-cell>
						<fo:block><xsl:value-of select="$vdDefendantOralBy"/></fo:block>
					</fo:table-cell>
				</fo:table-row>

				<fo:table-row keep-with-next="always">
					<fo:table-cell/>
					<fo:table-cell>
						<fo:block>written evidence:</fo:block>
					</fo:table-cell>
					<fo:table-cell>
						<fo:block><xsl:value-of select="$vdDefendantWrittenBy"/></fo:block>
					</fo:table-cell>
				</fo:table-row>

			</fo:table-body>

		</fo:table>	

		<fo:block space-before="0.8cm" font-weight="bold">
			Trial Timetable
		</fo:block>
		
		<xsl:choose>
			<xsl:when test="$vdTimetableAgreed = 'Y'">
				<fo:block>The timetable for the trial may be agreed by the parties, subject to the approval of the judge.</fo:block>
			</xsl:when>
			<xsl:otherwise>The timetable for the trial (subject to approval of the judge) will be that
				<xsl:if test="string-length($vdClaimantTime) > 0">
					<fo:block>The time allowed for the Claimant's evidence is <xsl:value-of select="$vdClaimantTime"/></fo:block>
				</xsl:if>
				<xsl:if test="string-length($vdDefendantTime) > 0">
					<fo:block>The time allowed for the Defendant's evidence is <xsl:value-of select="$vdDefendantTime"/></fo:block>
				</xsl:if>
				<xsl:if test="string-length($vdSubmissionTime) > 0">
					<fo:block>The time allowed for the submission on behalf of each party is <xsl:value-of select="$vdSubmissionTime"/></fo:block>
				</xsl:if>
				<xsl:if test="string-length($vdRemainingTime) > 0">
					<fo:block>The remainder of the time allowed for the trial (being <xsl:value-of select="$vdRemainingTime"/>) is reserved for the judge to consider and give the judgment and to deal with the costs.</fo:block>
				</xsl:if>
			</xsl:otherwise>
		</xsl:choose>
		
		<fo:block font-weight="bold" space-before="0.8cm">
			Trial Bundle
		</fo:block>
		<fo:block>
			An indexed bundle of documents contained in a ring binder with each page clearly numbered shall be lodged at the court at least 7 days before the hearing.
		</fo:block>
		
		<xsl:if test="$vdCaseSummary = 'Y'">
			<fo:block>A case summary of no more than 250 words, outlining the matters still in issue, and referring where appropriate to the relevant documents shall be included in the bundle for the assistance of the judge in reading the papers before the trial.</fo:block>
		</xsl:if>
		
		<xsl:if test="$vdAgreeBundle = 'Y'">
			<fo:block>
				<xsl:choose>
					<xsl:when test="$vdCaseSummary = 'Y'">The parties shall seek to agree the contents of the bundle and the case summary.</xsl:when>
					<xsl:otherwise>The parties shall seek to agree the contents of the bundle.</xsl:otherwise>
				</xsl:choose>
			</fo:block>
		</xsl:if>
		<fo:block space-after="0.8cm"/>
		<fo:block text-align="right">
			Dated <xsl:value-of select="$vdEventDate"/>
		</fo:block>
	</editable>
	</body>
	<defaultFooter id="CJR199"/>
</root>