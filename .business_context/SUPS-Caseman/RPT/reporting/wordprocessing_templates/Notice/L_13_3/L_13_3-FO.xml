<!--  -->
<!-- DESCRIPTION: This stylesheet is used to create an XSL:FO document that -->
<!-- can be processed into a PDF version.  Business logic -->
<!-- is embedded to generate the correct document text for the order -->
<!-- required. -->
<!--  -->
<!-- INPUTS: XML document containing: the answers to questions asked of the -->
<!-- user; case data retrieved from the database; HTML representing the  -->
<!-- body of the document content (already edited by the user). -->
<!--  -->
<!-- OUTPUTS: XML document with FO tags containing instructions for the -->
<!-- creation of a PDF document. -->
<!--  -->
<!-- ====================================================================== -->
<root xmlns:xsl="http://www.w3.org/1999/XSL/Transform" xmlns:fo="http://www.w3.org/1999/XSL/Format" xmlns="http://eds.com/supsfo">
	<variables>@word.processing.url.xsl@supsfo.xsl</variables>
	<duplex/>
	<addressee>
		<eventSelectedWarrantPartyAgainst/>
	</addressee>
	<header>
		<fo:block font-size="16pt" font-weight="bold">Notice of non payment</fo:block>
		<fo:block font-size="16pt" font-weight="bold">of Warrant</fo:block>
	</header>
	<courtcase>
		<court>
			<xsl:copy-of select="$vdWarrantCourtHeaderBlock"/>
		</court>
		<caseparameters>
			<parameter>
				<name>
					<fo:block font-weight="bold">Case Number</fo:block>
				</name>
				<value>
					<fo:block>
						<xsl:value-of select="$vdWarrantCaseNumber"/>
					</fo:block>
				</value>
			</parameter>
			<parameter>
				<name>
					<fo:block font-weight="bold">Warrant Number</fo:block>
				</name>
				<value>
					<fo:block>
						<xsl:choose>
							<xsl:when test="string-length($vdWarrantLocalNumber) > 0"><xsl:value-of select="$vdWarrantLocalNumber"/></xsl:when>
							<xsl:otherwise><xsl:value-of select="$vdWarrantNumber"/></xsl:otherwise>
						</xsl:choose>
					</fo:block>
				</value>
			</parameter>
			<parameter>
				<name>
					<fo:block font-weight="bold">Name of Foreign Court</fo:block>
				</name>
				<value>
					<fo:block>
						<xsl:value-of select="$vdWarrantIssueCourtName"/>
					</fo:block>
				</value>
			</parameter>
			<parameter>
				<name>
					<fo:block font-weight="bold">Judgment Creditor</fo:block>
				</name>
				<value>
					<fo:block>
						<xsl:value-of select="$vdPartyForName"/>
					</fo:block>
				</value>
			</parameter>
			<parameter>
				<name>
					<fo:block font-weight="bold">Date of visit</fo:block>
				</name>
				<value>
					<fo:block>
						<xsl:value-of select="$vdWarrantReceiptDate"/>
					</fo:block>
				</value>
			</parameter>
		</caseparameters>
	</courtcase>
	<body>
		<editable useid="N100C1">
			<fo:block font-size="12pt">
				<fo:block space-after="0.8cm"/>
			
		
				<fo:block space-after="0.8cm">
				We agreed how you would pay the warrant but you have not kept to that agreement
				</fo:block>
		
				<fo:block space-after="0.8cm">
				Unless you pay the amount of £<cursor text="Enter Oustanding Amount here."/> to the court office before:-
				</fo:block>
		
				<fo:block space-after="0.8cm">
					<fo:table table-layout="fixed" width="100%">
						<fo:table-column column-width="10cm"/>
						<fo:table-body table-layout="fixed">
							<fo:table-row keep-with-next="always">
								<fo:table-cell padding-left="0.1cm" padding-right="0.1cm" border-style="solid" border-width="0.02cm">
									<fo:block space-before="0.2cm" space-after="0.2cm"><xsl:value-of select="$vdWarrantPaymentDue"/></fo:block>
								</fo:table-cell>
							</fo:table-row>
						</fo:table-body>
					</fo:table>
				</fo:block>		
		
				<fo:block space-after="1.5cm">
				your goods <fo:inline font-weight="bold">will be removed and sold.</fo:inline>
				</fo:block>
		
				<fo:block text-align="right">Date <xsl:value-of select="$datetoday"/></fo:block>
				
				<fo:block space-after="2.0cm"/>
				<fo:block><xsl:value-of select="$vdBailiffName"/></fo:block>
				<fo:block>Bailiff</fo:block>				
				<fo:block>Telephone <xsl:value-of select="$vdBailiffTelephone" /> between <xsl:value-of select="$vdBailiffAvailability"/></fo:block>
				<fo:block space-after="4cm"/>	
			</fo:block>
		</editable>
	</body>
	<defaultFooter id="L_13_3" type="bailiff"/>
</root>