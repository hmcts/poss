<!-- DESCRIPTION: This stylesheet is used to create an XSL:FO document that -->
<!-- can be processed into a PDF version.  Business logic -->
<!-- is embedded to generate the correct document text for the order -->
<!-- required. -->
<!--  -->
<!-- INPUTS: XML document containing: the answers to questions asked of the -->
<!-- user; case data retrieved from the database; HTML representing the  -->
<!-- body of the document content (already edited by the user). -->
<!--  -->
<!-- OUTPUTS: XML document with FO tags containing instructions for the -->
<!-- creation of a PDF document. -->
<!--  -->


<!-- 
@author Sandeep Mullangi
@version 0.1 
Change Hisstory
Sep 10, 2008 Sandeep Mullangi - Printing insolvency number if present as part of RFC 486
Dec 08, 2011 Nilesh Mistry - Adding in logic for new case type of COMPANY ADMIN ORDER. Trac 4586
-->
<!-- ====================================================================== -->
<root xmlns:xsl="http://www.w3.org/1999/XSL/Transform" xmlns:fo="http://www.w3.org/1999/XSL/Format" xmlns="http://eds.com/supsfo">
	<variables>@word.processing.url.xsl@supsfo.xsl</variables>
	<layout yourRef="false">letter</layout>
	<logo/>
	<addressee>
		<blank/>
		<courtbeinformed/>
	</addressee>	
	<body>
		<editable useid="N10030">
		<fo:block space-after="1.0cm"/>
			<xsl:choose>
				<xsl:when test="$vdCaseType='CREDITORS PETITION'">
					<fo:block font-weight="bold">DEBTOR'S NAME</fo:block>
				</xsl:when>
				<xsl:when test="$vdCaseType='DEBTORS PETITION' or $vdCaseType='APP ON DEBT PETITION'">
					<fo:block font-weight="bold">DEBTOR'S NAME</fo:block>
				</xsl:when>
				<xsl:when test="$vdCaseType ='WINDING UP PETITION'">
					<fo:block font-weight="bold">COMPANY NAME</fo:block>
				</xsl:when>
                                <xsl:when test="$vdCaseType ='COMPANY ADMIN ORDER'">
					<fo:block font-weight="bold">COMPANY NAME</fo:block>
				</xsl:when>
			</xsl:choose>
		<fo:block space-after="0.4cm">
			<xsl:choose>
				<xsl:when test="$vdCaseType='CREDITORS PETITION'">
					<xsl:value-of select="$vdDebtorName"/>
				</xsl:when>
				<xsl:when test="$vdCaseType='DEBTORS PETITION' or $vdCaseType='APP ON DEBT PETITION'">
					<xsl:value-of select="$vdDebtorName"/>
				</xsl:when>
				<xsl:when test="$vdCaseType ='WINDING UP PETITION'">
					<xsl:value-of select="$vdCompanyName"/>			
				</xsl:when>
                                <xsl:when test="$vdCaseType ='COMPANY ADMIN ORDER'">
					<xsl:value-of select="$vdCompanyName"/>			
				</xsl:when>
			</xsl:choose>
		</fo:block>
		<fo:block font-weight="bold">
			ADDRESS
		</fo:block>
		
		<fo:block space-after="0.4cm">
			<xsl:choose>
			<xsl:when test="$vdCaseType='CREDITORS PETITION'">
				<xsl:call-template name="format-address-multi-line">
					<xsl:with-param name="party">
						<xsl:copy-of select="$vdDebtorAddress"/>
					</xsl:with-param>
				</xsl:call-template>
			</xsl:when>
			<xsl:when test="$vdCaseType='DEBTORS PETITION' or $vdCaseType='APP ON DEBT PETITION'">
				<xsl:call-template name="format-address-multi-line">
					<xsl:with-param name="party">
						<xsl:copy-of select="$vdDebtorAddress"/>
					</xsl:with-param>
				</xsl:call-template>
			</xsl:when>
			<xsl:when test="$vdCaseType ='WINDING UP PETITION'">
				<xsl:call-template name="format-address-multi-line">
					<xsl:with-param name="party">
						<xsl:copy-of select="$vdCompanyAddress"/>	
					</xsl:with-param>
				</xsl:call-template>
			</xsl:when>
                        <xsl:when test="$vdCaseType ='COMPANY ADMIN ORDER'">
				<xsl:call-template name="format-address-multi-line">
					<xsl:with-param name="party">
						<xsl:copy-of select="$vdCompanyAddress"/>	
					</xsl:with-param>
				</xsl:call-template>
			</xsl:when>
			</xsl:choose>
		</fo:block>
		
		<fo:block space-after="0.4cm" font-weight="bold">
			 PROCEEDINGS ISSUED
			<xsl:choose>
				<xsl:when test="$vdCaseType='CREDITORS PETITION'">
					BANKRUPTCY
				</xsl:when>
				<xsl:when test="$vdCaseType='DEBTORS PETITION' or $vdCaseType='APP ON DEBT PETITION'">
					BANKRUPTCY
				</xsl:when>
				<xsl:when test="$vdCaseType ='WINDING UP PETITION'">
					WINDING UP
				</xsl:when>
                                <xsl:when test="$vdCaseType ='COMPANY ADMIN ORDER'">
					COMPANY ADMINISTRATION ORDER
				</xsl:when>
			</xsl:choose>
		</fo:block>
		<fo:block space-after="0.4cm">
			<xsl:choose>
			    <xsl:when test="string-length(variabledata/claim/insolvencynumber) > 0">
					<fo:inline font-weight="bold">INSOLVENCY NUMBER</fo:inline>&#xa0;&#xa0;<xsl:value-of select="substring($vdInsolvencyNumber,1,4)"/> of <xsl:value-of select="substring($vdInsolvencyNumber,5,4)"/>&#xa0;
				</xsl:when>
				<xsl:otherwise>
					<fo:inline font-weight="bold">NUMBER</fo:inline>&#xa0;&#xa0;<xsl:value-of select="$vdClaimNumber"/>
				</xsl:otherwise>
			</xsl:choose>
		</fo:block>
		<fo:block space-after="0.4cm">
			<fo:inline font-weight="bold">DATE ISSUED</fo:inline>&#xa0;&#xa0;<xsl:value-of select="$vdEventDate"/>
		</fo:block>
		<fo:block space-after="0.4cm">
			<fo:inline font-weight="bold">HEARING DATE</fo:inline>&#xa0;&#xa0;<xsl:value-of select="$vdHearingDate1"/>, <xsl:value-of select="$vdHearingTime"/>
		</fo:block>
		<fo:block space-after="0.4cm">
			<fo:inline font-weight="bold">AT</fo:inline>&#xa0;&#xa0;<xsl:value-of select="$vdHearingCourtNameDescription"/>, <xsl:value-of select="$vdHearingCourtAddress"/>
		</fo:block>
		<fo:block space-after="2.0cm">&#xa0;</fo:block>
				
		<fo:block><xsl:value-of select="$vdName"/></fo:block>
		<fo:block><xsl:value-of select="$vdSection"/> Section</fo:block>
		<fo:block>Ext <xsl:value-of select="$vdExtension"/></fo:block>
		
		</editable>
	</body>
	<letterfooter id="L_14_1"/>
</root>