<!--  -->
<!-- DESCRIPTION: This stylesheet is used to create an XSL:FO document that -->
<!-- can be processed into a PDF version.  Business logic -->
<!-- is embedded to generate the correct document text for the order -->
<!-- required. -->
<!--  -->
<!-- INPUTS: XML document containing: the answers to questions asked of the -->
<!-- user; case data retrieved from the database; HTML representing the  -->
<!-- body of the document content (already edited by the user). -->
<!--  -->
<!-- OUTPUTS: XML document with FO tags containing instructions for the -->
<!-- creation of a PDF document. -->
<!--  -->
<!-- ====================================================================== -->
<root xmlns:xsl="http://www.w3.org/1999/XSL/Transform" xmlns:fo="http://www.w3.org/1999/XSL/Format" xmlns="http://eds.com/supsfo">
	<variables>@word.processing.url.xsl@supsfo.xsl</variables>
	<duplex/>
	<addressee>
		<blank/>
		<additionalblank/>
		<subject/>
	</addressee>
	<header>
		<fo:block font-size="16pt" font-weight="bold">Order to attend Court</fo:block>
		<fo:block font-size="16pt" font-weight="bold">for questioning</fo:block>
		<fo:block font-size="12pt" font-weight="bold">Rules 33.3(2)(b) &amp; 33.3(3) FPR 2010</fo:block>
	</header>
	<courtcase>
		<court>
			<xsl:copy-of select="$vdCourtHeaderBlock"/>
		</court>
		<caseparameters>
			<parameter>
				<name>
					<fo:block font-weight="bold">Claim Number</fo:block>
				</name>
				<value>
					<fo:block>
						<xsl:value-of select="$vdClaimNumber"/>
					</fo:block>
				</value>
			</parameter>
			<parameter>
				<name>
					<fo:block font-weight="bold">Applicant</fo:block>
				</name>
				<value>
					<fo:block hyphenate="true">
						<xsl:value-of select="$vdClaimantName"/>
					</fo:block>
				</value>
			</parameter>
			<parameter>
				<name>
					<fo:block font-weight="bold">Respondent</fo:block>
				</name>
				<value>
					<fo:block hyphenate="true">
						<xsl:value-of select="$vdSubjectName"/>
					</fo:block>
				</value>
			</parameter>
		</caseparameters>
	</courtcase>
	<bodyintroright><fo:block space-before="0.4cm"><fo:inline text-align="center"><seal/></fo:inline></fo:block></bodyintroright>

	<body font-size="12pt">
		<editable useid="N1008B">
			<fo:block font-weight="bold" space-after="0.4cm" font-size="12pt">
				You have not complied with the following order
			</fo:block>
			
			<fo:block space-after="0.4cm" start-indent="1cm" font-size="12pt">
				On <xsl:value-of select="$vdInterimChargingOrderDate2"/>, <xsl:value-of select="$vdJudge"/> sitting at <xsl:value-of select="$vdJudgmentCourtNameDescription"/> 
				ordered the respondent <xsl:value-of select="$vdSubjectName"/> to pay &#163;<xsl:value-of select="$vdGoodsMonthlyInstalment"/> per <xsl:value-of select="$vdInstalmentPeriodValue"/> to the applicant <xsl:value-of select="$vdClaimantName"/>.
			</fo:block>
			<fo:block space-after="0.4cm" font-size="12pt">
				On <xsl:value-of select="$vdOrderDate"/> an application under Rule 33.3(2) for an order for such method of enforcement as the court may consider appropriate was made.
			</fo:block>
			<fo:block font-size="12pt">
				<fo:inline font-weight="bold">You are now ordered to attend court</fo:inline> to disclose full details of your income and outgoings and your assets (what you own) and liabilities (what you owe).
			</fo:block>
			<fo:block space-after="0.4cm" font-size="12pt">
				(If you have been ordered to attend as an officer of a company or corporation, you will be required to disclose the same details about the company or corporation.)
			</fo:block>
			
			<fo:block font-weight="bold" space-after="0.2cm" font-size="12pt">
				It is ordered:
			</fo:block>
			<fo:block space-after="0.4cm" font-size="12pt">					
				1. That you <xsl:value-of select="$vdSubjectName"/> (the respondent) must attend <xsl:value-of select="$vdHearingCourtNameDescription"/>, <xsl:value-of select="$vdHearingCourtAddress"/> on <xsl:value-of select="$vdHearingDate1"/> at <xsl:value-of select="$vdHearingTime"/> to give information about your
				income and outgoings and your assets and liabilities and any other information required to enforce the maintenance order.
			</fo:block>
			<fo:block space-after="0.4cm" font-size="12pt">2. You (the respondent) must produce at court all documents in your control which relate to the your means of paying the amount due under the maintenance order.</fo:block>
			<fo:block space-after="0.4cm" font-size="12pt">3. You (the respondent) must answer on oath, all the questions which the court asks and if appropriate which the court allows the applicant to ask.</fo:block>
			<fo:block space-after="0.4cm" font-size="12pt">4. The court where the questioning is to take place may make an order for payment of the costs of the application and of the hearing.</fo:block>
		</editable>
			
		<fo:block space-after="0.2cm">
			<fo:table table-layout="fixed" width="100%" text-align="justify" font-family="Times" font-size="12pt">
				<fo:table-column column-width="100%"/>
				<fo:table-body>
					<fo:table-row>
						<fo:table-cell border-top-style="solid" border-right-style="solid" border-left-style="solid" border-bottom-style="solid"
							border-top-width="0.02cm" border-right-width="0.02cm" border-left-width="0.02cm" border-bottom-width="0.02cm"
							padding-right="0.2cm" padding-left="0.2cm" padding-bottom="0.2cm" padding-top="0.2cm" >
							<fo:block font-weight="bold">
								If you do not comply with this order and any subsequent order to attend you may be held to be in contempt of court and imprisoned or fined, or your assets may be seized.
							</fo:block>
						</fo:table-cell>
					</fo:table-row>
				</fo:table-body>
			</fo:table>
		</fo:block>
		
		<fo:block font-weight="bold" break-before="page">
			Amount owing
		</fo:block>
		<fo:block text-align="justify" space-after="0.4cm">
			<fo:table table-layout="fixed" font-size="12pt">
				<fo:table-column column-width="10cm"></fo:table-column>
				<fo:table-column column-width="3.5cm"></fo:table-column>
				<fo:table-body>
					<fo:table-row>
						<fo:table-cell padding-right="0.2cm">
							<fo:block space-after="0.4cm">
								The application shows that the amount owing under the maintenance order (including any costs and interest) is
							</fo:block>
							<fo:block></fo:block>
						</fo:table-cell>
						<fo:table-cell>
							<fo:block text-align="right" space-after="0.4cm">
								&#163;<xsl:call-template name="correctCalculation">
								<xsl:with-param name="value"><xsl:value-of select="$vdAmountOutstanding"/></xsl:with-param>
								</xsl:call-template>	
							</fo:block>
						</fo:table-cell>
					</fo:table-row>
					<fo:table-row>
						<fo:table-cell padding-right="0.2cm">
							<fo:block space-after="0.4cm">
								The applicant has paid a court fee of
							</fo:block>
							<fo:block></fo:block>
						</fo:table-cell>
						<fo:table-cell>
							<fo:block text-align="right" space-after="0.4cm">
								&#163;<xsl:value-of select="$vdApplicationFee"/>
							</fo:block>
						</fo:table-cell>
					</fo:table-row>
					<fo:table-row>
						<fo:table-cell padding-right="0.2cm">
							<fo:block space-after="0.4cm">
								Total
							</fo:block>
						</fo:table-cell>
						<fo:table-cell border-top-style="solid" border-top-width="0.03cm" border-bottom-style="solid" border-bottom-width="0.03cm">
							<fo:block text-align="right" space-after="0.4cm">
								&#163;<xsl:value-of select="$vdQuestioningTotalOwing"/>
							</fo:block>
						</fo:table-cell>
					</fo:table-row>
				</fo:table-body>
			</fo:table>
		</fo:block>
		<fo:block space-after="0.4cm" font-size="12pt">If the total amount owing is paid, the applicant may agree that the questioning need not take place (but may ask for an order for costs).</fo:block>
			
		<fo:block font-weight="bold" space-after="0.4cm">To the respondent</fo:block>
		<fo:block space-after="0.4cm">
			Correspondence for the court relating to the hearing should be addressed to the court where the hearing is to
			take place or the Maintenance Enforcement Business Centre if your maintenance order is managed by them.
		</fo:block>
		
		<fo:block font-weight="bold" space-after="0.4cm">Documents in your control</fo:block>
		<fo:block space-after="0.4cm">
			You must produce original documents which confirm the information required. If you do not have them in
			your possession, you must get them if you can.
		</fo:block>
		
		<fo:block>These will include:</fo:block>
		<fo:block space-after="0.8cm">
			<list type="bullet">
				<list-item>
					<fo:block>pay slips</fo:block>
				</list-item>
				<list-item>
					<fo:block>evidence of state benefits received</fo:block>
				</list-item>
				<list-item>
					<fo:block>bank statements</fo:block>
				</list-item>
				<list-item>
					<fo:block>building society books</fo:block>
				</list-item>
				<list-item>
					<fo:block>share certificates</fo:block>
				</list-item>
				<list-item>
					<fo:block>rent book</fo:block>
				</list-item>
				<list-item>
					<fo:block>mortgage statement</fo:block>
				</list-item>
				<list-item>
					<fo:block>hire-purchase and similar agreements</fo:block>
				</list-item>
				<list-item>
					<fo:block>court orders on which you still owe money</fo:block>
				</list-item>
				<list-item>
					<fo:block>other outstanding bills</fo:block>
				</list-item>
				<list-item>
					<fo:block>electricity, gas, water and council tax bills for the last year.</fo:block>
				</list-item>
			</list>
		</fo:block>
		
		<fo:block>If you have a business or you are a partner in a business, they will include the above documents so far as they relate to the business and</fo:block>
		<fo:block space-after="0.8cm">
			<list type="bullet">
				<list-item>
					<fo:block>bills or invoices owed to the judgment debtor</fo:block>
				</list-item>
				<list-item>
					<fo:block>two years' balance sheets and profit and loss accounts</fo:block>
				</list-item>
				<list-item>
					<fo:block>current management accounts.</fo:block>
				</list-item>
			</list>
		</fo:block>
		
		<fo:block>If a list of additional documents is attached to this order, these too must be produced.</fo:block>
	</body>
	<defaultFooter id="FE45"/>
</root>