<!--  -->
<!-- DESCRIPTION: This stylesheet is used to create an XSL:FO document that -->
<!-- can be processed into a PDF version.  Business logic -->
<!-- is embedded to generate the correct document text for the order -->
<!-- required. -->
<!--  -->
<!-- INPUTS: XML document containing: the answers to questions asked of the -->
<!-- user; case data retrieved from the database; HTML representing the  -->
<!-- body of the document content (already edited by the user). -->
<!--  -->
<!-- OUTPUTS: XML document with FO tags containing instructions for the -->
<!-- creation of a PDF document. -->
<!--  -->
<!-- 
@author Sandeep Mullangi
@version 0.1
Change Hisstory
Oct 27, 2008 Sandeep Mullangi - Printing insolvency number if present as part of RFC 486
-->
<!-- ====================================================================== -->
<root xmlns:xsl="http://www.w3.org/1999/XSL/Transform" xmlns:fo="http://www.w3.org/1999/XSL/Format" xmlns="http://eds.com/supsfo">
	<variables>@word.processing.url.xsl@supsfo.xsl</variables>
	<layout>order</layout>
	<duplex/>	
	<addressee>
		<blank/>
		<debtorparty/>
		<creditorparty/>
		<company/>
		<applicant/>
		<petitioner/>
		<trustee/>
		<insolvencypractitioner/>
		<officialreceiver/>
	</addressee>
	<header>
		<fo:block font-size="10pt" font-weight="bold">Form 6.29</fo:block>
		<fo:block font-size="10pt" font-weight="bold">Rule 6.44</fo:block>
		<fo:block font-size="16pt" font-weight="bold">Order of Appointment of Insolvency</fo:block>
		<fo:block font-size="16pt" font-weight="bold">Practitioner to Prepare a Report Under</fo:block>
		<fo:block font-size="16pt" font-weight="bold">Section 274(1) of the Insolvency Act 1986</fo:block>
	</header>
	<courtcase>
		<court>
			<xsl:copy-of select="$vdCourtHeaderBlock"/>
		</court>
		<caseparameters>
			<!-- adding insolvency number-->
            <parameter>
                <name>
                    <fo:block font-weight="bold">
                        <xsl:choose>
                            <xsl:when test="string-length($vdInsolvencyNumber) > 0">Insolvency Number</xsl:when>
                            <xsl:otherwise>Case Number</xsl:otherwise>
                        </xsl:choose>
                    </fo:block>
                </name>
                <value>
                    <fo:block>
                        <xsl:choose>
                            <xsl:when test="string-length($vdInsolvencyNumber) > 0">
                                <xsl:value-of select="substring($vdInsolvencyNumber,1,4)"/> of <xsl:value-of select="substring($vdInsolvencyNumber,5,4)"/>
                            </xsl:when>
                            <xsl:otherwise>
                                <xsl:value-of select="$vdClaimNumber"/>
                            </xsl:otherwise>
                        </xsl:choose>
                    </fo:block>
                </value>
			</parameter>
			<parameter>
				<name>
					<fo:block font-weight="bold">Debtor</fo:block>
				</name>
				<value>
					<fo:block hyphenate="true">
						<xsl:value-of select="$vdSubjectName"/>
					</fo:block>
				</value>
			</parameter>
		</caseparameters>
	</courtcase>
	
	<body><editable useid="N1009F">
		<fo:block space-after="0.8cm"/>
		<fo:block font-weight="bold" space-after="0.4cm" font-size="12pt">
			In Bankruptcy
		</fo:block>
		<fo:block font-weight="bold" space-after="0.4cm">
			Before <xsl:value-of select="$vdJudge"/>
		</fo:block>
		<fo:block>
			Upon hearing the petition of
		</fo:block>
		<fo:block space-after="0.4cm">
			<xsl:copy-of select="$vdSubjectAddressMultiLine"/>
		</fo:block>
		<fo:block space-after="0.4cm">
			the above named debtor, which was presented on <xsl:value-of select="$vdPetitionDate"/>
		</fo:block>
		<xsl:if test="string-length($vdHearingAttendees) > 0">
			<fo:block space-after="0.4cm"><xsl:copy-of select="$vdHearingAttendees"/></fo:block>
		</xsl:if>
		<fo:block>
			And upon reading the evidence 
		</fo:block>
		<fo:block>
			It is ordered that <xsl:value-of select="$vdInstigatorName"/>
		</fo:block>
		<fo:block space-after="1.0cm">
			<xsl:copy-of select="$vdInstigatorAddressMultiLine"/>
		</fo:block>
		<fo:block space-after="0.4cm">
			a person who is qualified to act as an insolvency practitioner in relation to the above-named debtor, be appointed to prepare and submit a report to the court by <xsl:value-of select="$vdReportDate"/> as to whether the above-named debtor is willing to make a proposal for a voluntary arrangement
 		</fo:block>
		<fo:block space-after="0.4cm">
			And it is ordered that the court will consider the report on:
		</fo:block>
		<fo:block space-after="0.4cm">
			Date: <xsl:value-of select="$vdHearingDate1"/>
 		</fo:block>
		<fo:block space-after="0.4cm"> 		
			Time: <xsl:value-of select="$vdHearingTime"/>
 		</fo:block>
		<fo:block space-after="0.4cm">
			at <xsl:value-of select="$vdHearingCourtNameDescription"/>, <xsl:value-of select="$vdHearingCourtAddress"/>
 		</fo:block>
		<xsl:if test="string-length($vdDebtorAttendance) > 0">
			<fo:block space-after="0.4cm"><xsl:value-of select="$vdDebtorAttendance"/></fo:block>
		</xsl:if>
		<fo:block space-after="0.4cm">
			Dated <xsl:value-of select="$vdOrderDate"/>
 		</fo:block>
 	</editable></body>
	<defaultFooter id="O_10_11"/>
</root>