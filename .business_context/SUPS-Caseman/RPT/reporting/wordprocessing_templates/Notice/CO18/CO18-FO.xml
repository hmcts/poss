				<fo:block>The normal deduction rate is <xsl:value-of select="$vdCOInstalmentAmount"/> per <xsl:value-of select="$vdInstallmentPeriod"/></fo:block>
			</list-item>
			<list-item>
				<fo:block space-after="0.4cm">The protected earnings rate is <xsl:value-of select="$vdPerRate"/> per <xsl:value-of select="$vdInstallmentPeriod"/></fo:block>
			</list-item>
		</list>
		<fo:block space-after="0.4cm">
