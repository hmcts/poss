							<fo:block text-align="right">
								<fo:inline font-weight="bold">Dated </fo:inline><xsl:value-of select="$datetoday"/>
							</fo:block>
						</fo:table-cell>
					</fo:table-row>
				</fo:table-body>
			</fo:table>
		</fo:block>
		<fo:block>
			<fo:inline font-weight="bold">You are therefore ordered </fo:inline>to make deductions out of the earnings of the Debtor in accordance with the Attachment of Earnings Act 1971 until
			&#163;<xsl:value-of select="$vdOsNomicBalance1"/> the total amount payable under the judgments, together with any interest*, has been paid
		</fo:block>
		<fo:block space-after="0.4cm" font-style="italic">* see over</fo:block>
	</editable>
		<fo:block>
			For the purpose of calculating the deductions
		</fo:block>
		<list type="bullet">
