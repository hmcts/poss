<xs:schema xmlns:xs="http://www.w3.org/2001/XMLSchema" xmlns:xls="http://www.w3.org/1999/XSL/Transform" elementFormDefault="qualified" attributeFormDefault="unqualified">
	<xs:complexType name="addresstype">
		<xs:annotation>
			<xs:documentation>Type to define standard address information.</xs:documentation>
		</xs:annotation>
		<xs:sequence>
			<xs:element name="id" minOccurs="0">
				<xs:annotation>
					<xs:documentation>Address ID</xs:documentation>
				</xs:annotation>
			</xs:element>
			<xs:element name="type" minOccurs="0">
				<xs:annotation>
					<xs:documentation>Address Type (type of address, not the XML Type)</xs:documentation>
				</xs:annotation>
			</xs:element>
			<xs:element name="line1">
				<xs:annotation>
					<xs:documentation>Address Line 1</xs:documentation>
				</xs:annotation>
			</xs:element>
			<xs:element name="line2">
				<xs:annotation>
					<xs:documentation>Address Line 2</xs:documentation>
				</xs:annotation>
			</xs:element>
			<xs:element name="line3">
				<xs:annotation>
					<xs:documentation>Address Line 3</xs:documentation>
				</xs:annotation>
			</xs:element>
			<xs:element name="line4">
				<xs:annotation>
					<xs:documentation>Address Line 4</xs:documentation>
				</xs:annotation>
			</xs:element>
			<xs:element name="line5">
				<xs:annotation>
					<xs:documentation>Address Line 5</xs:documentation>
				</xs:annotation>
			</xs:element>
			<xs:element name="postcode">
				<xs:annotation>
					<xs:documentation>Address Post Code</xs:documentation>
				</xs:annotation>
			</xs:element>
			<xs:element name="reference" minOccurs="0">
				<xs:annotation>
					<xs:documentation>Address reference</xs:documentation>
				</xs:annotation>
			</xs:element>
			<xs:element name="createdby" minOccurs="0">
				<xs:annotation>
					<xs:documentation>Address created by</xs:documentation>
				</xs:annotation>
			</xs:element>
		</xs:sequence>
	</xs:complexType>
	<xs:complexType name="partytype">
		<xs:annotation>
			<xs:documentation>Type to define generic party information for claimants, defendants and representatives.</xs:documentation>
		</xs:annotation>
		<xs:sequence>
			<xs:element name="id">
				<xs:annotation>
					<xs:documentation>Id of the party</xs:documentation>
				</xs:annotation>
			</xs:element>
			<xs:element name="number">
				<xs:annotation>
					<xs:documentation>The sequence number of this party.</xs:documentation>
				</xs:annotation>
			</xs:element>
			<xs:element name="reference" minOccurs="0">
				<xs:annotation>
					<xs:documentation>Reference of the party</xs:documentation>
				</xs:annotation>
			</xs:element>
			<xs:element name="address" type="addresstype" minOccurs="0">
				<xs:annotation>
					<xs:documentation>Address of the party</xs:documentation>
				</xs:annotation>
			</xs:element>
		</xs:sequence>
	</xs:complexType>
	<xs:complexType name="copartytype">
		<xs:annotation>
			<xs:documentation>Type to define generic party information for consolidated orders - creditors, debitors and other representatives there in.</xs:documentation>
		</xs:annotation>
		<xs:sequence>
			<xs:element name="id">
				<xs:annotation>
					<xs:documentation>Id of the party</xs:documentation>
				</xs:annotation>
			</xs:element>
			<xs:element name="dx" minOccurs="0">
				<xs:annotation>
					<xs:documentation>The party DX number</xs:documentation>
				</xs:annotation>
			</xs:element>
			<xs:element name="telno" minOccurs="0">
				<xs:annotation>
					<xs:documentation>The telephone number</xs:documentation>
				</xs:annotation>
			</xs:element>
			<xs:element name="faxno" minOccurs="0">
				<xs:annotation>
					<xs:documentation>The fax number</xs:documentation>
				</xs:annotation>
			</xs:element>
			<xs:element name="email" minOccurs="0">
				<xs:annotation>
					<xs:documentation>The email address</xs:documentation>
				</xs:annotation>
			</xs:element>
			<xs:element name="commmethod" minOccurs="0">
				<xs:annotation>
					<xs:documentation>The Communication Method</xs:documentation>
				</xs:annotation>
			</xs:element>
			<xs:element name="translationtowelsh" minOccurs="0">
				<xs:annotation>
					<xs:documentation>Should it be translated to welsh</xs:documentation>
				</xs:annotation>
			</xs:element>
			<xs:element name="address" minOccurs="0">
				<xs:annotation>
					<xs:documentation>Address of the party</xs:documentation>
				</xs:annotation>
				<xs:complexType>
					<xs:complexContent>
						<xs:extension base="addresstype">
							<xs:sequence>
								<xs:element name="validfrom" minOccurs="0">
									<xs:annotation>
										<xs:documentation>When it is valid from</xs:documentation>
									</xs:annotation>
								</xs:element>
								<xs:element name="validto" minOccurs="0">
									<xs:annotation>
										<xs:documentation>When it is valid to</xs:documentation>
									</xs:annotation>
								</xs:element>
							</xs:sequence>
						</xs:extension>
					</xs:complexContent>
				</xs:complexType>
			</xs:element>
			<xs:element name="AddressHistory" minOccurs="0">
				<xs:annotation>
					<xs:documentation>the history of the address</xs:documentation>
				</xs:annotation>
			</xs:element>
		</xs:sequence>
	</xs:complexType>
	<xs:element name="variabledata">
		<xs:annotation>
			<xs:documentation>The variabledata root element holds elements to be transformed into an (Notice) output .fo document.</xs:documentation>
		</xs:annotation>
		<xs:complexType>
			<xs:sequence>
				<xs:element name="xhtml" minOccurs="0">
					<xs:complexType>
						<xs:sequence>
							<xs:any/>
						</xs:sequence>
					</xs:complexType>
				</xs:element>
				<xs:element name="division">
					<xs:annotation>
						<xs:documentation>The division, IIT Division (Chancery or Queen's Bench), derived from cm_general.f_division function using the casename as argument</xs:documentation>
					</xs:annotation>
				</xs:element>
				<xs:element name="court">
					<xs:annotation>
						<xs:documentation>The court</xs:documentation>
					</xs:annotation>
					<xs:complexType>
						<xs:complexContent>
							<xs:extension base="courttype">
								<xs:sequence>
									<xs:element name="bailiff" minOccurs="0">
										<xs:annotation>
											<xs:documentation>Th baliff details</xs:documentation>
										</xs:annotation>
										<xs:complexType>
											<xs:sequence>
												<xs:element name="name" minOccurs="0">
													<xs:annotation>
														<xs:documentation>The baliffs name</xs:documentation>
													</xs:annotation>
												</xs:element>
												<xs:element name="telephoneno" minOccurs="0">
													<xs:annotation>
														<xs:documentation>The baliffs telephone number</xs:documentation>
													</xs:annotation>
												</xs:element>
												<xs:element name="workhoursfrom" minOccurs="0">
													<xs:annotation>
														<xs:documentation>The hours the baliff starts work</xs:documentation>
													</xs:annotation>
												</xs:element>
												<xs:element name="workhoursto" minOccurs="0">
													<xs:annotation>
														<xs:documentation>The hours the baliff stops work</xs:documentation>
													</xs:annotation>
												</xs:element>
											</xs:sequence>
										</xs:complexType>
									</xs:element>
									<xs:element name="dx" minOccurs="0"/>
								</xs:sequence>
							</xs:extension>
						</xs:complexContent>
					</xs:complexType>
				</xs:element>
				<xs:element name="claim">
					<xs:annotation>
						<xs:documentation>Groups claim related elements</xs:documentation>
					</xs:annotation>
					<xs:complexType>
						<xs:sequence>
							<xs:element name="number">
								<xs:annotation>
									<xs:documentation>The Claim's Number, case number, select case_number from case_events where event_seq = P_EVENT_SEQ</xs:documentation>
								</xs:annotation>
							</xs:element>
							<xs:element name="issuefee">
								<xs:annotation>
									<xs:documentation>The issue fee of the claim</xs:documentation>
								</xs:annotation>
							</xs:element>
							<xs:element name="dateofissue" minOccurs="0">
								<xs:annotation>
									<xs:documentation>The date the notice was issued</xs:documentation>
								</xs:annotation>
							</xs:element>
							<xs:element name="mainclaimantid" minOccurs="0">
								<xs:annotation>
									<xs:documentation>The claimant who's name will appear on the notice.</xs:documentation>
								</xs:annotation>
							</xs:element>
							<xs:element name="maindefendantid" minOccurs="0">
								<xs:annotation>
									<xs:documentation>The defendant who's name will appear on the notice.</xs:documentation>
								</xs:annotation>
							</xs:element>
							<xs:element name="claimant" maxOccurs="unbounded">
								<xs:annotation>
									<xs:documentation>Claimant(s) on the claim/casee</xs:documentation>
								</xs:annotation>
								<xs:complexType>
									<xs:complexContent>
										<xs:extension base="partytype">
											<xs:sequence minOccurs="0">
												<xs:element name="dx" minOccurs="0">
													<xs:annotation>
														<xs:documentation>The DX Number</xs:documentation>
													</xs:annotation>
												</xs:element>
												<xs:element name="representativeid" minOccurs="0">
													<xs:annotation>
														<xs:documentation>Claimant representative id(s)</xs:documentation>
													</xs:annotation>
												</xs:element>
												<xs:element name="solicitorsurrogateid" minOccurs="0">
													<xs:annotation>
														<xs:documentation>The representatives surrogate id</xs:documentation>
													</xs:annotation>
												</xs:element>
												<xs:element name="solicitorreference" minOccurs="0">
													<xs:annotation>
														<xs:documentation>The reference id of the solicitor</xs:documentation>
													</xs:annotation>
												</xs:element>
												<xs:element name="solicitorpayee" minOccurs="0">
													<xs:annotation>
														<xs:documentation>States if the solicitor or party is the payee.</xs:documentation>
													</xs:annotation>
												</xs:element>
												<xs:element name="telephonenumber" minOccurs="0">
													<xs:annotation>
														<xs:documentation>The claimants telephone number</xs:documentation>
													</xs:annotation>
												</xs:element>
											</xs:sequence>
										</xs:extension>
									</xs:complexContent>
								</xs:complexType>
							</xs:element>
							<xs:element name="defendant" maxOccurs="unbounded">
								<xs:annotation>
									<xs:documentation>Defendant(s) on the claim/case</xs:documentation>
								</xs:annotation>
								<xs:complexType>
									<xs:complexContent>
										<xs:extension base="partytype">
											<xs:sequence minOccurs="0">
												<xs:element name="dx" minOccurs="0">
													<xs:annotation>
														<xs:documentation>The DX Number</xs:documentation>
													</xs:annotation>
												</xs:element>
												<xs:element name="representativeid" minOccurs="0">
													<xs:annotation>
														<xs:documentation>Defendant representative id(s)</xs:documentation>
													</xs:annotation>
												</xs:element>
												<xs:element name="solicitorsurrogateid" minOccurs="0">
													<xs:annotation>
														<xs:documentation>The representatives surrogate id</xs:documentation>
													</xs:annotation>
												</xs:element>
												<xs:element name="solicitorreference" minOccurs="0">
													<xs:annotation>
														<xs:documentation>The reference id of the solicitor</xs:documentation>
													</xs:annotation>
												</xs:element>
												<xs:element name="solicitorpayee" minOccurs="0">
													<xs:annotation>
														<xs:documentation>States if the solicitor or party is the payee.</xs:documentation>
													</xs:annotation>
												</xs:element>
											</xs:sequence>
										</xs:extension>
									</xs:complexContent>
								</xs:complexType>
							</xs:element>
							<xs:element name="representative" minOccurs="0" maxOccurs="unbounded">
								<xs:annotation>
									<xs:documentation>Representative(s) on the claim/case</xs:documentation>
								</xs:annotation>
								<xs:complexType>
									<xs:complexContent>
										<xs:extension base="partytype">
											<xs:sequence minOccurs="0">
												<xs:element name="dx" minOccurs="0">
													<xs:annotation>
														<xs:documentation>The representatives dx number</xs:documentation>
													</xs:annotation>
												</xs:element>
												<xs:element name="telephonenumber" minOccurs="0">
													<xs:annotation>
														<xs:documentation>The telephone number</xs:documentation>
													</xs:annotation>
												</xs:element>
												<xs:element name="surrogateid" minOccurs="0">
													<xs:annotation>
														<xs:documentation>The surrogate id</xs:documentation>
													</xs:annotation>
												</xs:element>
											</xs:sequence>
										</xs:extension>
									</xs:complexContent>
								</xs:complexType>
							</xs:element>
							<xs:element name="particulars" minOccurs="0">
								<xs:annotation>
									<xs:documentation>Indication of whether the particulars of the case are included.  Choose Y or N.</xs:documentation>
								</xs:annotation>
							</xs:element>
							<xs:element name="hearing" minOccurs="0">
								<xs:annotation>
									<xs:documentation>Hearing for this claim/case</xs:documentation>
								</xs:annotation>
								<xs:complexType>
									<xs:sequence minOccurs="0">
										<xs:element name="date">
											<xs:annotation>
												<xs:documentation>Date of the hearing</xs:documentation>
											</xs:annotation>
										</xs:element>
										<xs:element name="time">
											<xs:annotation>
												<xs:documentation>Time of the hearing</xs:documentation>
											</xs:annotation>
										</xs:element>
										<xs:element name="court" type="courttype">
											<xs:annotation>
												<xs:documentation>Court of the hearing</xs:documentation>
											</xs:annotation>
										</xs:element>
										<xs:element name="attendees">
											<xs:annotation>
												<xs:documentation>Attendees at hearing</xs:documentation>
											</xs:annotation>
											<xs:complexType>
												<xs:sequence>
													<xs:element name="attendee" minOccurs="0" maxOccurs="unbounded">
														<xs:annotation>
															<xs:documentation>The attendee details</xs:documentation>
														</xs:annotation>
														<xs:complexType>
															<xs:sequence>
																<xs:element name="type">
																	<xs:annotation>
																		<xs:documentation>The party type i.e. CLAIMANT or DEFENDANT</xs:documentation>
																	</xs:annotation>
																</xs:element>
																<xs:element name="number">
																	<xs:annotation>
																		<xs:documentation>The number of the party  i.e. CLAIMANT 1 or DEFENDANT 1</xs:documentation>
																	</xs:annotation>
																</xs:element>
																<xs:element name="attendance">
																	<xs:annotation>
																		<xs:documentation>Decode whether or not the party will be attending.      0- not attending,                1 - represented by counsel,   2 - represented by solicitor,  3 - in person,                     4 - (upon reading)                5 - other</xs:documentation>
																	</xs:annotation>
																</xs:element>
																<xs:element name="other" minOccurs="0">
																	<xs:annotation>
																		<xs:documentation>The attending reason if other is chosen</xs:documentation>
																	</xs:annotation>
																</xs:element>
															</xs:sequence>
														</xs:complexType>
													</xs:element>
												</xs:sequence>
											</xs:complexType>
										</xs:element>
										<xs:element name="preliminaryhearingreason" minOccurs="0">
											<xs:annotation>
												<xs:documentation>Reason for preliminary hearing.  Choose from DIS (dispose of the case) and SD (judge has special directions for the case)</xs:documentation>
											</xs:annotation>
										</xs:element>
										<xs:element name="hearinglisted" minOccurs="0">
											<xs:annotation>
												<xs:documentation>Listed hearing.  Choose from Y or N.</xs:documentation>
											</xs:annotation>
										</xs:element>
										<xs:element name="hearingreasonclaimantdefendant" minOccurs="0">
											<xs:annotation>
												<xs:documentation>Whether the claimant/defendant is the reason for cancelling the hearing.  Choose from CLM (claimant) and DEFT (defendant).</xs:documentation>
											</xs:annotation>
											<xs:complexType>
												<xs:sequence>
													<xs:element name="partyid" minOccurs="0">
														<xs:annotation>
															<xs:documentation>The unique ID of the party</xs:documentation>
														</xs:annotation>
													</xs:element>
												</xs:sequence>
											</xs:complexType>
										</xs:element>
										<xs:element name="timeallowed" minOccurs="0">
											<xs:annotation>
												<xs:documentation>The estimated duration of the trial</xs:documentation>
											</xs:annotation>
										</xs:element>
										<xs:element name="timeallowedunits" minOccurs="0">
											<xs:annotation>
												<xs:documentation>The estimated duration of the trial Units.  Choose from Minute, Hour, Day</xs:documentation>
											</xs:annotation>
										</xs:element>
										<xs:element name="timetable" minOccurs="0">
											<xs:annotation>
												<xs:documentation>The timetble for the hearing. choose from AGR - (The timetable may be agreed by both parties)                   APP - (The timetable(subject to approval by the judge) will be)</xs:documentation>
											</xs:annotation>
										</xs:element>
										<xs:element name="clmcrossexaminationtime" minOccurs="0">
											<xs:annotation>
												<xs:documentation>The cross examination time for the claimant</xs:documentation>
											</xs:annotation>
										</xs:element>
										<xs:element name="clmcrossexaminationtimeunits" minOccurs="0">
											<xs:annotation>
												<xs:documentation>The cross examination time units for the claimant</xs:documentation>
											</xs:annotation>
										</xs:element>
										<xs:element name="defcrossexaminationtime" minOccurs="0">
											<xs:annotation>
												<xs:documentation>The cross examination time for the defendant</xs:documentation>
											</xs:annotation>
										</xs:element>
										<xs:element name="defcrossexaminationtimeunits" minOccurs="0">
											<xs:annotation>
												<xs:documentation>The cross examination time units for the defendant</xs:documentation>
											</xs:annotation>
										</xs:element>
										<xs:element name="clmevidencetime" minOccurs="0">
											<xs:annotation>
												<xs:documentation>The time allowed for the claimants evidence</xs:documentation>
											</xs:annotation>
										</xs:element>
										<xs:element name="clmevidencetimeunits" minOccurs="0">
											<xs:annotation>
												<xs:documentation>The time units allowed for the claimants evidence</xs:documentation>
											</xs:annotation>
										</xs:element>
										<xs:element name="defevidencetime" minOccurs="0">
											<xs:annotation>
												<xs:documentation>The time allowed for the defendants evidence</xs:documentation>
											</xs:annotation>
										</xs:element>
										<xs:element name="defevidencetimeunits" minOccurs="0">
											<xs:annotation>
												<xs:documentation>The time units allowed for the claimants evidence</xs:documentation>
											</xs:annotation>
										</xs:element>
										<xs:element name="remainingtime" minOccurs="0">
											<xs:annotation>
												<xs:documentation>The time remaining in the case</xs:documentation>
											</xs:annotation>
										</xs:element>
										<xs:element name="remainingtimeunits" minOccurs="0">
											<xs:annotation>
												<xs:documentation>The time remaining units in the case</xs:documentation>
											</xs:annotation>
										</xs:element>
										<xs:element name="submissiontime" minOccurs="0">
											<xs:annotation>
												<xs:documentation>The time allowed for submission</xs:documentation>
											</xs:annotation>
										</xs:element>
										<xs:element name="submissiontimeunits" minOccurs="0">
											<xs:annotation>
												<xs:documentation>The time units allowed for submission</xs:documentation>
											</xs:annotation>
										</xs:element>
										<xs:element name="clmshalllodge" minOccurs="0">
											<xs:annotation>
												<xs:documentation>Will the claimant lodge proceedings</xs:documentation>
											</xs:annotation>
										</xs:element>
										<xs:element name="casesummary" minOccurs="0">
											<xs:annotation>
												<xs:documentation>a case summary should not be more than 250 words</xs:documentation>
											</xs:annotation>
										</xs:element>
										<xs:element name="agrebundle" minOccurs="0">
											<xs:annotation>
												<xs:documentation>Parties should agree the bundle for the court</xs:documentation>
											</xs:annotation>
										</xs:element>
										<xs:element name="informcourt" minOccurs="0">
											<xs:annotation>
												<xs:documentation>Parties should inform the court if they are unablee to proceed</xs:documentation>
											</xs:annotation>
										</xs:element>
										<xs:element name="applicationoutcome" minOccurs="0">
											<xs:annotation>
												<xs:documentation>The outcome of the application</xs:documentation>
											</xs:annotation>
										</xs:element>
										<xs:element name="for" minOccurs="0">
											<xs:annotation>
												<xs:documentation>Whether the hearing is for allocation or listing</xs:documentation>
											</xs:annotation>
										</xs:element>
										<xs:element name="hearingtype" minOccurs="0">
											<xs:annotation>
												<xs:documentation>If the hearing is an allocation or listing</xs:documentation>
											</xs:annotation>
										</xs:element>
										<xs:element name="fasttrack" minOccurs="0">
											<xs:complexType>
												<xs:sequence minOccurs="0">
													<xs:element name="fthrgdate" minOccurs="0"/>
													<xs:element name="fthrgtime" minOccurs="0"/>
													<xs:element name="Court" type="courttype" minOccurs="0">
														<xs:annotation>
															<xs:documentation>The court the fasttract is taking place at</xs:documentation>
														</xs:annotation>
													</xs:element>
													<xs:element name="wftstartdate" minOccurs="0">
														<xs:annotation>
															<xs:documentation>Windows for trial start date</xs:documentation>
														</xs:annotation>
													</xs:element>
													<xs:element name="wftenddate" minOccurs="0">
														<xs:annotation>
															<xs:documentation>Windows for trial end date</xs:documentation>
														</xs:annotation>
													</xs:element>
													<xs:element name="jdgtrfaftalloc" minOccurs="0">
														<xs:annotation>
															<xs:documentation>The first paragraph</xs:documentation>
