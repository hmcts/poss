<!-- DESCRIPTION: This stylesheet is used to create an XSL:FO document that -->
<!-- can be processed into a PDF version.  Business logic -->
<!-- is embedded to generate the correct document text for the order -->
<!-- required. -->
<!--  -->
<!-- INPUTS: XML document containing: the answers to questions asked of the -->
<!-- user; case data retrieved from the database; HTML representing the  -->
<!-- body of the document content (already edited by the user). -->
<!--  -->
<!-- OUTPUTS: XML document with FO tags containing instructions for the -->
<!-- creation of a PDF document. -->
<!--  -->
<!-- 
@author Sandeep Mullangi
@version 0.1
Change Hisstory
Oct 27, 2008 Sandeep Mullangi - Printing insolvency number if present as part of RFC 486
-->
<!-- ====================================================================== -->
<root xmlns:xsl="http://www.w3.org/1999/XSL/Transform" xmlns:fo="http://www.w3.org/1999/XSL/Format" xmlns="http://eds.com/supsfo">
	<variables>@word.processing.url.xsl@supsfo.xsl</variables>
	<layout>order</layout>
	<duplex/>
	<addressee>
		<blank/>
		<debtorparty/>
		<company/>
	</addressee>
	<header>
		<fo:block font-size="10pt" font-weight="bold">Form 6.77</fo:block>
		<fo:block font-size="10pt" font-weight="bold">Rule 6.220</fo:block>
		<fo:block font-size="16pt" font-weight="bold">Certificate of Discharge</fo:block>
	</header>
	<courtcase>
		<court>
			<xsl:copy-of select="$vdCourtHeaderBlock"/>
		</court>
		<caseparameters>
			<!-- adding insolvency number-->
            <parameter>
                <name>
                    <fo:block font-weight="bold">
                        <xsl:choose>
                            <xsl:when test="string-length($vdInsolvencyNumber) > 0">Insolvency Number</xsl:when>
                            <xsl:otherwise>Case Number</xsl:otherwise>
                        </xsl:choose>
                    </fo:block>
                </name>
                <value>
                    <fo:block>
                        <xsl:choose>
                            <xsl:when test="string-length($vdInsolvencyNumber) > 0">
                                <xsl:value-of select="substring($vdInsolvencyNumber,1,4)"/> of <xsl:value-of select="substring($vdInsolvencyNumber,5,4)"/>
                            </xsl:when>
                            <xsl:otherwise>
                                <xsl:value-of select="$vdClaimNumber"/>
                            </xsl:otherwise>
                        </xsl:choose>
                    </fo:block>
                </value>
			</parameter>
			<parameter>
				<name>
					<fo:block font-weight="bold">Debtor</fo:block>
				</name>
				<value>
					<fo:block hyphenate="true">
						<xsl:value-of select="$vdSubjectName"/>
					</fo:block>
				</value>
			</parameter>
		</caseparameters>
	</courtcase>
	
	<body>
		<editable useid="N1008C">
		<fo:block space-after="0.8cm"/>
		<fo:block font-weight="bold" space-after="0.4cm" font-size="12pt">
			In Bankruptcy
		</fo:block>
		<fo:block space-after="0.4cm">
			A bankruptcy order having been made by this court against
		</fo:block>
		<fo:block start-indent="1cm" space-after="0.4cm"  font-weight="bold">
			<xsl:copy-of select="$vdSubjectAddressMultiLine"/>
		</fo:block>
		<fo:block space-after="0.4cm">
			on <xsl:value-of select="$vdBankruptcyDate"/>
		</fo:block>
		<fo:block space-after="0.4cm">
			<fo:inline font-weight="bold">It is certified that the said </fo:inline> <xsl:value-of select="$vdSubjectName"/>
		</fo:block>
		<fo:block space-after="0.4cm">
			<fo:inline font-weight="bold">was discharged from his/her Bankruptcy </fo:inline> on <xsl:value-of select="$vdBankruptcyDischargeDate"/>
		</fo:block>
		<fo:block space-after="0.8cm">
			Dated  <xsl:value-of select="$vdEventDate"/>
		</fo:block>
		<footnote noteextent="2.5"> 				
			<fo:block space-after="0.4cm" text-decoration="underline">
				Notice to Bankrupt
			</fo:block>
			<fo:block space-after="0.4cm">
				Should you, the bankrupt, require advertisement of this order in a local newspaper and/or the Gazette, you should, notify the Secretary of State enclosing the prescribed fee details of which can be obtained by contacting the official receiver
			</fo:block>
		</footnote>
	</editable>
	</body>
	<defaultFooter id="O_10_16"/>
</root>