<!-- Version: $Revision: 1.6 $ -->
<!--  -->
<!-- DESCRIPTION: This stylesheet is used to create an XSL:FO document that -->
<!-- can be processed into a PDF version.  Business logic -->
<!-- is embedded to generate the correct document text for the order -->
<!-- required. -->
<!--  -->
<!-- INPUTS: XML document containing: the answers to questions asked of the -->
<!-- user; case data retrieved from the database; HTML representing the  -->
<!-- body of the document content (already edited by the user). -->
<!--  -->
<!-- OUTPUTS: XML document with FO tags containing instructions for the -->
<!-- creation of a PDF document. -->
<!--  -->
<!-- ====================================================================== -->
<!-- Change History:
09-NOV-2011 Des Johnston - Trac 4589. Include defendants tag to the addressee xml so that defendant(s) notice copies are produced as well as the Claimant's copy
27-Jan-2012 Chris Vincent - Trac 4589, number of copies produced is equal to number of defendants, each addressed to claimant, but each copy has a unique
							Defendant Name.
--> 
<root xmlns:xsl="http://www.w3.org/1999/XSL/Transform" xmlns:fo="http://www.w3.org/1999/XSL/Format" xmlns="http://eds.com/supsfo">
	<variables>@word.processing.url.xsl@supsfo.xsl</variables>
	<addressee>
		<noticeissuespecial/> 
	</addressee>
	<header>
		<fo:block font-size="16pt" font-weight="bold">Notice of Issue <xsl:value-of select="$vdDuplicateEvent" /></fo:block>
		<fo:block font-size="12pt">(accelerated possession procedure)</fo:block>
		<fo:block font-size="12pt">(assured shorthold tenancy)</fo:block>
		<fo:block font-size="12pt"></fo:block>
	</header>
	<courtcase>
		<court>
			<xsl:copy-of select="$vdCourtHeaderBlock"/>
		</court>
		<caseparameters>
			<parameter>
				<name>
					<fo:block font-weight="bold">Claim Number</fo:block>
				</name>
				<value>
					<fo:block>
						<xsl:value-of select="$vdClaimNumber"/>
					</fo:block>
				</value>
			</parameter>
			<parameter>
				<name>
					<fo:block font-weight="bold">Claimant</fo:block>
					<fo:block font-size="9pt">(including ref.)</fo:block>
				</name>
				<value>
					<fo:block hyphenate="true">
						<xsl:value-of select="$vdClaimantName"/>
					</fo:block>
					<fo:block font-size="9pt" hyphenate="true">
						<xsl:value-of select="$vdClaimantReference"/>
					</fo:block>
				</value>
			</parameter>
			<parameter>
				<name>
					<fo:block font-weight="bold">Defendant</fo:block>
					<fo:block font-size="9pt">(including ref.)</fo:block>
				</name>
				<value>
					<fo:block hyphenate="true">
						<xsl:call-template name="noticeIssueDefendantName">
							<xsl:with-param name="defendant">
								<xsl:value-of select="$defendant"/>
							</xsl:with-param>
						</xsl:call-template>
					</fo:block>
					<fo:block font-size="9pt" hyphenate="true">
						<xsl:call-template name="noticeIssueDefendantReference">
							<xsl:with-param name="defendant">
								<xsl:value-of select="$defendant"/>
							</xsl:with-param>
						</xsl:call-template>
					</fo:block>
				</value>
			</parameter>
			<parameter>
				<name>
					<fo:block font-weight="bold">Issue Fee</fo:block>
				</name>
				<value>
					<fo:block>
						&#163;<xsl:call-template name="correctCalculation">
							<xsl:with-param name="value"><xsl:value-of select="$vdIssueFee"/></xsl:with-param>
						</xsl:call-template>
					</fo:block>
				</value>
			</parameter>
		</caseparameters>
	</courtcase>
	<bodyintroright><fo:block><fo:inline text-align="center"><seal/></fo:inline></fo:block></bodyintroright>

	<body>
		<fo:block font-size="9pt" space-after="0.3cm">Your claim was issued on <xsl:value-of select="$vdClaimDateOfIssue"/>.</fo:block>
		<xsl:choose>
			<xsl:when test="$vdServiceDate1 != $emptyDate or $vdServiceDate1 = ''"><fo:block font-size="9pt" space-after="0.3cm">The court has sent it to the defendant and it will be deemed served on <xsl:value-of select="$vdServiceDate"/>.</fo:block></xsl:when>
			<xsl:otherwise><fo:block font-size="9pt" space-after="0.3cm">The court has not yet served the claim on the defendant. When it does so, it will send you a separate notice of service.</fo:block></xsl:otherwise>
		</xsl:choose>
		<fo:block font-size="9pt" space-after="0.3cm">The defendant has 14 days from service to file a defence. If a defence is filed, the court will send you a copy.</fo:block>
		<fo:block font-size="9pt" space-after="0.3cm">If the defendant does not file a defence, you may ask the court to make a possession order and (if applied for) an order of costs. Complete the tear-off portion of this form and return it to the court office.</fo:block>
		<fo:block font-size="9pt" space-after="0.3cm">On receiving either the defence or your request for an order, the court staff will refer the claim to a judge to decide whether or not to make an order without a hearing.</fo:block>
		<fo:block font-size="9pt" space-after="0.4cm">You have three months from the date by which the defendant should file a defence to file your request for an order. If by then the court has not received either a defence or your request, the claim will be stayed.</fo:block>
		<getFooter></getFooter>			
		<leader/>
		<fo:block>
			<fo:table table-layout="fixed">
				<fo:table-column column-width="10.34cm"/>
				<fo:table-column column-width="8.39cm"/>
				<fo:table-body table-layout="fixed">
					<fo:table-row>
						<fo:table-cell>
							<fo:block font-size="12pt" font-weight="bold">Request for Possession order and costs</fo:block>
							<fo:block font-size="9pt">(accelerated possession procedure)</fo:block>
							<fo:block font-size="9pt">(assured shorthold tenancy)</fo:block>
						</fo:table-cell>
						<fo:table-cell>
							<courtcase>
								<court>
									<xsl:copy-of select="$vdCourtHeaderBlock"/>
								</court>
								<caseparameters>
									<parameter>
										<name>
											<fo:block font-weight="bold">Claim Number</fo:block>
										</name>
										<value>
											<fo:block><xsl:value-of select="$vdClaimNumber"/></fo:block>
										</value>
									</parameter>
									<parameter>
										<name>
											<fo:block font-weight="bold">Claimant</fo:block>
											<fo:block font-size="9pt">(including ref.)</fo:block>
										</name>
										<value>
											<fo:block hyphenate="true"><xsl:value-of select="$vdClaimantName"/></fo:block>
											<fo:block font-size="9pt" hyphenate="true"><xsl:value-of select="$vdClaimantReference"/></fo:block>
										</value>
									</parameter>
									<parameter>
										<name>
											<fo:block font-weight="bold">Defendant</fo:block>
											<fo:block font-size="9pt">(including ref.)</fo:block>
										</name>
										<value>
											<fo:block hyphenate="true">
												<xsl:call-template name="noticeIssueDefendantName">
													<xsl:with-param name="defendant">
														<xsl:value-of select="$defendant"/>
													</xsl:with-param>
												</xsl:call-template>
											</fo:block>
											<fo:block font-size="9pt" hyphenate="true">
												<xsl:call-template name="noticeIssueDefendantReference">
													<xsl:with-param name="defendant">
														<xsl:value-of select="$defendant"/>
													</xsl:with-param>
												</xsl:call-template>
											</fo:block>
										</value>
									</parameter>
								</caseparameters>
							</courtcase>
						</fo:table-cell>
					</fo:table-row>
				</fo:table-body>
			</fo:table>
		</fo:block>
		<fo:block font-size="9pt" font-weight="bold">To the court</fo:block>
		<fo:block font-size="9pt" space-after="0.5cm">The defendant has not filed a defence to my claim and the time for doing so has expired.</fo:block>
		<fo:block font-size="9pt" space-after="0.5cm">I ask the court to order the defendant to give me possession of the premises [and to pay my costs].</fo:block>
		<fo:block font-size="9pt" space-after="1.5cm">[The defendant has given me possession of the premises. I ask the court to order the defendant to pay my costs.]</fo:block>
		<signature signaturetype="signature" showguardiantext = 'true'/>
	</body>
	<defaultFooter id="CJR188" suppress="true"/>
</root>