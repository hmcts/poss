<!-- Version: $Revision: 1.6 $ -->
<!--  -->
<!-- DESCRIPTION: This stylesheet is used to create an XSL:FO document that -->
<!-- can be processed into a PDF version.  Business logic -->
<!-- is embedded to generate the correct document text for the order -->
<!-- required. -->
<!--  -->
<!-- INPUTS: XML document containing: the answers to questions asked of the -->
<!-- user; case data retrieved from the database; HTML representing the  -->
<!-- body of the document content (already edited by the user). -->
<!--  -->
<!-- OUTPUTS: XML document with FO tags containing instructions for the -->
<!-- creation of a PDF document. -->
<!--  -->
<!-- ====================================================================== -->
<!-- Change History:
--> 
<root xmlns:xsl="http://www.w3.org/1999/XSL/Transform" xmlns:fo="http://www.w3.org/1999/XSL/Format" xmlns="http://eds.com/supsfo">
	<variables>@word.processing.url.xsl@supsfo.xsl</variables>
	<addressee>
		<claimant/>
	</addressee>
	<header>
		<fo:block font-size="16pt" font-weight="bold">Notice of Issue of Fixed Date <xsl:value-of select="$vdDuplicateEvent" /></fo:block>
		<fo:block font-size="12pt" >(Summons or Originating Application)</fo:block>
		<fo:block font-size="12pt"></fo:block>
	</header>
	<courtcase>
		<court>
			<xsl:copy-of select="$vdCourtHeaderBlock"/>
		</court>
		<caseparameters>
			<parameter>
				<name>
					<fo:block font-weight="bold">Claim Number</fo:block>
				</name>
				<value>
					<fo:block>
						<xsl:value-of select="$vdClaimNumber"/>
					</fo:block>
				</value>
			</parameter>
			<parameter>
				<name>
					<fo:block font-weight="bold">Claimant</fo:block>
					<fo:block font-size="9pt">(including ref.)</fo:block>
				</name>
				<value>
					<fo:block hyphenate="true">
						<xsl:value-of select="$vdClaimantName"/>
					</fo:block>
					<fo:block font-size="9pt" hyphenate="true">
						<xsl:value-of select="$vdClaimantReference"/>
					</fo:block>
				</value>
			</parameter>
			<parameter>
				<name>
					<fo:block font-weight="bold">Date</fo:block>
				</name>
				<value>
					<fo:block>
						<xsl:value-of select="$vdClaimDateOfIssue"/>
					</fo:block>
				</value>
			</parameter>
		</caseparameters>
	</courtcase>
	<bodyintroright>
		<fo:block font-size="10pt" font-weight="bold" space-before="0.8cm">Please bring this notice with you to Court</fo:block>
		<bodyintroright><fo:block><fo:inline text-align="center"><seal/></fo:inline></fo:block></bodyintroright>
	</bodyintroright>

	<body>
		<fo:table table-layout="fixed">
			<fo:table-column column-width="4.29cm"/>
			<fo:table-column column-width="11.27cm"/>
			<fo:table-column column-width="3.06cm"/>
			<fo:table-body>
				<fo:table-row>
					<fo:table-cell>
						<fo:block font-size="10pt" font-weight="bold" text-align="center">Case Number</fo:block>
					</fo:table-cell>
					<fo:table-cell>
						<fo:block font-size="10pt" font-weight="bold" text-align="center">Defendant(s)</fo:block>
					</fo:table-cell>
					<fo:table-cell>
						<fo:block font-size="10pt" font-weight="bold" text-align="center">Issue fee</fo:block>
					</fo:table-cell>
				</fo:table-row>
				<fo:table-row>
					<fo:table-cell border-width="0.02cm" border-style="solid" padding="0.2cm">
						<fo:block font-size="9pt"><xsl:value-of select="$vdClaimNumber"/></fo:block>
					</fo:table-cell>
					<fo:table-cell border-width="0.02cm" border-style="solid" padding="0.2cm">
						<fo:block font-size="9pt"><xsl:value-of select="$vdDefendantName"/></fo:block>
					</fo:table-cell>
					<fo:table-cell border-width="0.02cm" border-style="solid" padding="0.2cm">
						<fo:block>
							&#163;<xsl:call-template name="correctCalculation">
								<xsl:with-param name="value"><xsl:value-of select="$vdIssueFee"/></xsl:with-param>
							</xsl:call-template>
						</fo:block>
					</fo:table-cell>
				</fo:table-row>
			</fo:table-body>
		</fo:table>
		<fo:block font-size="10pt" space-before="0.8cm" space-after="0.6cm">The above case was issued today and you must attend the</fo:block>
		<fo:block>
			<fo:table table-layout="fixed">
				<fo:table-column column-width="8.90cm"/>
				<fo:table-column column-width="1.00cm"/>
				<fo:table-column column-width="8.72cm"/>
				<fo:table-body>
					<fo:table-row>
						<fo:table-cell number-columns-spanned="3" border-width="0.02cm" border-style="solid" padding="0.2cm">
							<fo:block font-size="10pt" space-after="0.6cm"><fo:inline font-weight="bold">Hearing</fo:inline> when the proceedings will be heard</fo:block>
							<fo:block font-size="10pt" font-style="italic" space-after="1.0cm">(If you intend to ask the district judge to give any particular direction, you must give notice of your intention to him and the defendant)</fo:block>
							<fo:block font-size="10pt" space-after="0.6cm">at the County Court at <xsl:value-of select="$vdHearingCourtName"/>, <xsl:value-of select="$vdHearingCourtAddress"/></fo:block>
							<fo:block font-size="10pt">on <xsl:value-of select="$vdHearingDate"/> at <xsl:value-of select="$vdHearingTime"/></fo:block>
						</fo:table-cell>
					</fo:table-row>
					<fo:table-row>
						<fo:table-cell number-columns-spanned="3">
							<fo:block font-size="9pt" font-weight="bold" space-before="0.4cm" space-after="0.4cm">Notes</fo:block>
							<fo:block />
						</fo:table-cell>
					</fo:table-row>
					<fo:table-row>
						<fo:table-cell>
						  <list type="bullet">
							<list-item><fo:block font-size="9pt" font-weight="bold">Always quote the case number.</fo:block></list-item>
							<list-item><fo:block font-size="9pt"><fo:inline font-weight="bold">You must inform the court IMMEDIATELY</fo:inline> if you receive any payment before the hearing date.</fo:block></list-item>
							<list-item><fo:block font-size="9pt">Always bring this notice with you when you come to the court office for any purpose connected with your case(s). On the day of hearing bring all books and papers necessary to prove the claim.</fo:block></list-item>
							<list-item><fo:block font-size="9pt">If judgment is entered, the defendant will be ordered to pay you or your representative.</fo:block></list-item>
						  </list>
						</fo:table-cell>
						<fo:table-cell>
							<fo:block></fo:block>
						</fo:table-cell>
						<fo:table-cell>
						  <list type="bullet">
							<list-item><fo:block font-size="9pt">You should keep a record of any payments you receive from the defendant. At the hearing if you wish to take steps to enforce the judgment, you will need to satisfy the court about the balance outstanding. You should give the defendant a receipt. Payment in cash should always be acknowledged. You should tell the defendant how much he owes if he asks.</fo:block></list-item>
						  </list>
						</fo:table-cell>
					</fo:table-row>
					<fo:table-row>
						<fo:table-cell number-columns-spanned="3">
							<fo:block space-after="1.0cm"/>
						</fo:table-cell>
					</fo:table-row>
					<fo:table-row>
						<fo:table-cell number-columns-spanned="3" background-color="#aaaaaa" padding="0.2cm">
							<fo:block font-size="9pt" font-weight="bold" text-align="center">Proceedings after judgment</fo:block>
							<fo:block font-size="9pt" text-align="center"><fo:inline font-weight="bold">You must inform the court IMMEDIATELY</fo:inline> if you receive any payment while a warrant or other enforcement is current and/or before any hearing date.</fo:block>
						</fo:table-cell>
					</fo:table-row>
				</fo:table-body>
			</fo:table>
		</fo:block>
	</body>
	<defaultFooter id="CJR187"/>
</root>