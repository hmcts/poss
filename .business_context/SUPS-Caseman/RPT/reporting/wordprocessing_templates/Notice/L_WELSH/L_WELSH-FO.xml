<!-- DESCRIPTION: This stylesheet is used to create an XSL:FO document that -->
<!-- can be processed into a PDF version.  Business logic -->
<!-- is embedded to generate the correct document text for the order -->
<!-- required. -->
<!--  -->
<!-- INPUTS: XML document containing: the answers to questions asked of the -->
<!-- user; case data retrieved from the database; HTML representing the  -->
<!-- body of the document content (already edited by the user). -->
<!--  -->
<!-- OUTPUTS: XML document with FO tags containing instructions for the -->
<!-- creation of a PDF document. -->
<!--  -->
<!-- ====================================================================== -->
<root xmlns:xsl="http://www.w3.org/1999/XSL/Transform" xmlns:fo="http://www.w3.org/1999/XSL/Format" xmlns="http://eds.com/supsfo">
	<variables>@word.processing.url.xsl@supsfo.xsl</variables>
	<layout>letter</layout>
	<logo/>
	<addressee>
		<welsh/>
	</addressee>	
	<body>
		
		<fo:block space-after="0.8cm"/>
		<fo:block font-size="12pt" font-weight="bold" text-align="center">
			<xsl:value-of select="$vdEventDate"/>
		</fo:block>
		<fo:block space-after="0.8cm"/>
		<fo:block>Dear Sir/Madam</fo:block>
		<fo:block space-after="0.8cm"/>
		<fo:block font-size="12pt" font-weight="bold" text-align="left">
			<fo:inline text-decoration="underline">REQUEST FOR TRANSLATION INTO WELSH</fo:inline>
		</fo:block>
		<fo:block font-size="12pt" font-weight="bold" text-align="center">
			Case No: <xsl:value-of select="$vdClaimNumber"/>
		</fo:block>
		<fo:block space-after="0.8cm">
			Please find enclosed documents for translation in the above named case.
		</fo:block>
		<fo:block space-after="0.8cm"/>
		<fo:block>
			<fo:table table-layout="fixed">
				<fo:table-column column-width="8.0cm"></fo:table-column>
				<fo:table-body>
					<fo:table-row>
						<fo:table-cell padding-left="0.2cm" padding-right="0.2cm" border-style="solid" border-width="0.02cm">
							<fo:block space-before="0.2cm" space-after="0.2cm">Name and Address of Party to be served</fo:block>
						</fo:table-cell>
					</fo:table-row>
					<fo:table-row>
						<fo:table-cell padding-left="0.2cm" padding-right="0.2cm" border-style="solid" border-width="0.02cm">
							<fo:block space-before="0.2cm" space-after="0.2cm">Date by which Party should be served</fo:block>
						</fo:table-cell>
					<fo:table-row>
				</fo:table-body>
				<fo:table-column column-width="11.0cm"></fo:table-column>
				<fo:table-body>
					<fo:table-row>
						<fo:table-cell padding-left="0.2cm" padding-right="0.2cm" border-style="solid" border-width="0.02cm">
							<fo:block space-after="0.4cm">Address: <xsl:call-template name="format-address-multi-line">
								<xsl:with-param name="theAddress"><xsl:copy-of select="$vdXXXXXXXXXX"/></xsl:with-param>
								</xsl:call-template></fo:block>
						</fo:table-cell>
					</fo:table-row>
					<fo:table-row>
						<fo:table-cell padding-left="0.2cm" padding-right="0.2cm" border-style="solid" border-width="0.02cm"/>
					</fo:table-row>
				</fo:table-body>
			</fo:table>				
		</fo:block>
		<fo:block space-after="0.8cm"/>
		<fo:block>Yours faithfully,</fo:block>
		<fo:block space-after="0.8cm"/>
		<fo:block><xsl:value-of select="$vdName"/></fo:block>
		<fo:block><xsl:value-of select="$vdSection"/> Section</fo:block>
		<fo:block space-after="0.8cm">Ext <xsl:value-of select="$vdExtension"/></fo:block>
		<fo:block font-weight="bold" font-size="12pt" space-after="0.8cm"/>
			This request form and document is to be faxed to the Welsh Language Unit.
		</fo:block>
		<fo:block font-weight="bold" font-size="12pt" space-after="0.8cm"/>
			Fax No.			01248 750778
		</fo:block>
		<fo:block font-weight="bold" font-size="12pt" space-after="0.8cm"/>
			Enquiries		01248 750225
		</fo:block>
		
	</body>
	
</root>

