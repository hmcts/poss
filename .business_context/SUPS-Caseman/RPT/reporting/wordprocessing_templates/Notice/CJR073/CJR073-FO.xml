<!-- DESCRIPTION: This stylesheet is used to create an XSL:FO document that -->
<!-- can be processed into a PDF version.  Business logic -->
<!-- is embedded to generate the correct document text for the order -->
<!-- required. -->
<!--  -->
<!-- INPUTS: XML document containing: the answers to questions asked of the -->
<!-- user; case data retrieved from the database; HTML representing the  -->
<!-- body of the document content (already edited by the user). -->
<!--  -->
<!-- OUTPUTS: XML document with FO tags containing instructions for the -->
<!-- creation of a PDF document. -->
<!--  -->
<!-- ====================================================================== -->
<root xmlns:xsl="http://www.w3.org/1999/XSL/Transform" xmlns:fo="http://www.w3.org/1999/XSL/Format" xmlns="http://eds.com/supsfo">
	<variables>@word.processing.url.xsl@supsfo.xsl</variables>
	<layout>order</layout>
	<duplex/>
	<addressee>
		<blank/>
		<claimants/>
		<defendants/>
		<part20claimants/>
		<part20defendants/>
	</addressee>
	<header>
		<fo:block font-size="16pt" font-weight="bold">Order for Substituted Service</fo:block>
	</header>
	<courtcase>
		<court>
			<xsl:copy-of select="$vdCourtHeaderBlock"/>
		</court>
		<caseparameters>
			<parameter>
				<name>
					<fo:block font-weight="bold">Claim Number</fo:block>
				</name>
				<value>
					<fo:block>
						<xsl:value-of select="$vdClaimNumber"/>
					</fo:block>
				</value>
			</parameter>
			<parameter>
				<name>
					<fo:block font-weight="bold">Date</fo:block>
				</name>
				<value>
					<fo:block>
						<xsl:value-of select="$vdEventDate"/>
					</fo:block>
				</value>
			</parameter>
		</caseparameters>
	</courtcase>
	<bodyintroright><fo:block space-before="0.4cm" space-after="1cm"><fo:inline text-align="center"><seal/></fo:inline></fo:block></bodyintroright>
	<body>
		<editable useid="N10085">
		<fo:block space-after="0.8cm"/>
		<fo:block space-after="0.4cm">
			Before <xsl:value-of select="$vdJudge"/> sitting at <xsl:value-of select="$vdHearingAtCourtNameDescription"/>, <xsl:value-of select="$vdHearingAtCourtAddress"/>
		</fo:block>
		<fo:block space-after="0.4cm">
			<xsl:value-of select="$vdHearingAttendees"/>
		</fo:block>
		<fo:block space-after="0.4cm">
			Upon reading the evidence of <xsl:value-of select="$vdWhoseEvidence"/> dated <xsl:value-of select="$vdDateEvidence"/>
		</fo:block>
		<fo:block space-after="0.4cm">
			<xsl:value-of select="$vdJudge"/> ORDERED
		</fo:block>
		<fo:block space-after="0.4cm">
			<xsl:value-of select="$vdInstructionsSubstituted1"/> <xsl:value-of select="$vdServiceAddress3"/> <xsl:value-of select="$vdInstructionsSubstituted3"/> shall be deemed to be good and sufficient service of the <xsl:value-of select="$vdInstructionsSubstitutedDocument"/> on the defendant <xsl:value-of select="$vdGoodServiceWording"/>.
		</fo:block>
		<fo:block>
			Dated <xsl:value-of select="$vdReceiptDate"/>
		</fo:block>
		</editable>
	</body>
	<defaultFooter id="CJR073"/>
</root>