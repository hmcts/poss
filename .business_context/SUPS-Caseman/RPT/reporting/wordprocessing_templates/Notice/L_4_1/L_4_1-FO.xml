<!-- DESCRIPTION: This stylesheet is used to create an XSL:FO document that -->
<!-- can be processed into a PDF version.  Business logic -->
<!-- is embedded to generate the correct document text for the order -->
<!-- required. -->
<!--  -->
<!-- INPUTS: XML document containing: the answers to questions asked of the -->
<!-- user; case data retrieved from the database; HTML representing the  -->
<!-- body of the document content (already edited by the user). -->
<!--  -->
<!-- OUTPUTS: XML document with FO tags containing instructions for the -->
<!-- creation of a PDF document. -->
<!--  -->
<!-- ====================================================================== -->
<root xmlns:xsl="http://www.w3.org/1999/XSL/Transform" xmlns:fo="http://www.w3.org/1999/XSL/Format" xmlns="http://eds.com/supsfo">
	<variables>@word.processing.url.xsl@supsfo.xsl</variables>
	<layout yourRef="true">letter</layout>
	<logo/>
	<addressee>
		<blank/>
		<subject/>
	</addressee>	
	<body>
		<editable>
		<fo:block space-after="0.4cm">Dear <xsl:value-of select="$vdGreeting"/></fo:block>
		<fo:block space-after="0.4cm" font-size="12pt" font-weight="bold" text-align="center">Re: Case Number: <xsl:value-of select="$vdClaimNumber"/>&#xa0;<xsl:value-of select="$vdClaimantName"/> v <xsl:value-of select="$vdDefendant1Name"/>
		</fo:block>
 		<xsl:if test="$vdFeeRetained  = 'Y'">
			<fo:block space-after="0.4cm" font-weight="bold">
				Suspense Item : <xsl:value-of select="$vdSuspenseItem"/>
			</fo:block>
		</xsl:if>
		<fo:block space-after="0.8cm">
			Your
			<xsl:choose>
				<xsl:when test="$vdLetterRequestOth = 'L'">
					letter dated <xsl:value-of select="$vdLetterDate"/>
				</xsl:when>
				<xsl:when test="$vdLetterRequestOth = 'IR'">
					request for issue of <xsl:value-of select="$vdTypeOfProcess"/>
				</xsl:when>
				<xsl:when test="$vdLetterRequestOth = 'OTH'"><xsl:value-of select="$vdLetterRequestOthOther"/></xsl:when>
			</xsl:choose>
			has been referred to the <xsl:value-of select="$vdDistrictCircuitJudge" /> for directions. We will 
			notify you of the decision made in due course.
		</fo:block>
 		<xsl:if test="$vdFeeRetained  = 'Y'">
			<fo:block space-after="0.8cm">
				In the meantime your process will be retained and your fee entered into our suspense account.
				Should you need to contact the court please quote the above suspense item number on all communication.
			</fo:block>
		</xsl:if>
		<fo:block space-after="1.5cm"><xsl:value-of select="$vdLetterEnding"/></fo:block>
		<fo:block><xsl:value-of select="$vdName"/></fo:block>
		<fo:block><xsl:value-of select="$vdSection"/> Section</fo:block>
		<fo:block>Ext <xsl:value-of select="$vdExtension"/></fo:block>
		</editable>
	</body>
	<letterfooter id="L_4_1"/>
</root>