<!-- DESCRIPTION: This stylesheet is used to create an XSL:FO document that -->
<!-- can be processed into a PDF version.  Business logic -->
<!-- is embedded to generate the correct document text for the order -->
<!-- required. -->
<!--  -->
<!-- INPUTS: XML document containing: the answers to questions asked of the -->
<!-- user; case data retrieved from the database; HTML representing the  -->
<!-- body of the document content (already edited by the user). -->
<!--  -->
<!-- OUTPUTS: XML document with FO tags containing instructions for the -->
<!-- creation of a PDF document. -->
<!--  -->
<!-- ====================================================================== -->
<root xmlns:xsl="http://www.w3.org/1999/XSL/Transform" xmlns:fo="http://www.w3.org/1999/XSL/Format" xmlns="http://eds.com/supsfo">
	<variables>@word.processing.url.xsl@supsfo.xsl</variables>
	<duplex/>
	<addressee copies="2">
	           <employer sic="true"/>
	</addressee>
	<header>
		<fo:block font-size="16pt" font-weight="bold">Summons for Offence Under</fo:block>
		<fo:block font-size="16pt" font-weight="bold">Attachment of Earnings Act 1971</fo:block>
	</header>
	<courtcase>
		<court>
			<xsl:copy-of select="$vdCourtHeaderBlock"/>
		</court>
		<caseparameters>
			<parameter>
				<name>
					<fo:block font-weight="bold">AO/CAEO Number</fo:block>
				</name>
				<value>
					<fo:block>
						<xsl:value-of select="$vdCONumber"/>
					</fo:block>
				</value>
			</parameter>
			<parameter>
				<name>
					<fo:block font-weight="bold">Creditor</fo:block>
				</name>
				<value>
					<fo:block>
						Various
					</fo:block>
				</value>
			</parameter>				
			<parameter>
				<name>
					<fo:block font-weight="bold">Debtor</fo:block>
				</name>
				<value>
					<fo:block hyphenate="true">
						<xsl:value-of select="$vdCODebtorName"/>
					</fo:block>
				</value>
			</parameter>
			<parameter>
				<name>
					<fo:block font-weight="bold">Employer's Ref.</fo:block>
				</name>
				<value>
					<fo:block hyphenate="true">
						<xsl:value-of select="$vdCOEmployerReference"/>
					</fo:block>
				</value>
			</parameter>
		</caseparameters>
	</courtcase>
	<bodyintroright><fo:block><fo:inline text-align="center"><seal/></fo:inline></fo:block></bodyintroright>
	
	<body>
	<editable useid="N100AC">
		<fo:block space-after="0.4cm" font-weight="bold">
			Before <xsl:value-of select="$vdJudge"/> sitting at <xsl:value-of select="$vdHearingAtCourtNameDescription"/>, <xsl:value-of select="$vdHearingAtCourtAddress"/>
		</fo:block>
		<fo:block space-after="0.4cm">
			<xsl:value-of select="$vdCOHearingAttendees"/>
		</fo:block>
		<fo:block space-after="0.4cm">
			To <xsl:value-of select="$vdEmployerNamedPerson"/>, <xsl:value-of select="$vdEmployerName"/>
		</fo:block>
		<fo:block space-after="0.4cm">
			of <xsl:value-of select="$vdEmployerAddress"/>
		</fo:block>
		<fo:block space-after="0.4cm">
			YOU ARE SUMMONED to appear at <xsl:value-of select="$vdHearingCourtNameDescription"/>, <xsl:value-of select="$vdHearingCourtAddress"/>
		</fo:block>
		<fo:block space-after="0.4cm">
			on the <xsl:value-of select="$vdHearingDate"/>
		</fo:block>
		<fo:block space-after="0.4cm">
			at <xsl:value-of select="$vdHearingTime"/>
		</fo:block>
		<fo:block space-after="0.4cm">
			to show cause why an order should not be made against you under Section 23(3) of the Attachment of Earnings Act 1971, for the payment of a fine not exceeding <xsl:value-of select="$vdMaxfine"/> or for your committal to prison for not more than 14 days for failing
			to comply with an attachment of earnings order made by this court on the <xsl:value-of select="$vdCOOrderDate"/> in that you have <xsl:copy-of select="$vdDetailsOfOffence"/>
		</fo:block>
		<fo:block space-after="0.4cm" font-weight="bold">
			Important notes are set out overleaf
		</fo:block>
		<fo:block space-after="0.4cm" text-align="right">
			<fo:inline font-weight="bold">Dated </fo:inline><xsl:value-of select="$vdEventDate"/>
		</fo:block>
	</editable>


		<fo:block space-after="0.4cm" font-weight="bold" break-before="page">
			Important notes
		</fo:block>
		<list type="bullet">
			<list-item>
				<fo:block space-after="0.4cm">The Court has the power to send you to prison if it finds that any of the allegations made against you are true.</fo:block>
			</list-item>
			<list-item>
				<fo:block space-after="0.4cm">You must attend court on the day shown on the front of this form.  It is in your own interests to do so.  At the hearing, the judge will explain to you why this summons has been issued and why the Court is considering fining you or sending you to prison.  You will then have the opportunity to put your case.  You should bring any witnesses and documents with you which you think will help you put your side of the case.</fo:block>
			</list-item>
			<list-item>
				<fo:block space-after="0.4cm">If you need advice you should show this document at once to your solicitor or go to a Citizens' Advice Bureau.  If you do not already have a solicitor acting for you the Court can give details of local solicitors.  You may be entitled to help towards the cost of legal advice.</fo:block>
			</list-item>
		</list>
		
		<fo:block space-after="0.4cm">
			<fo:table table-layout="fixed">
			<fo:table-column column-width="19.28cm"></fo:table-column>
			<fo:table-body>
				<fo:table-row>
					<fo:table-cell border-top-style="solid" border-top-width="0.1cm">
						<fo:block space-after="0.4cm" space-before="0.4cm">
							<fo:inline font-weight="bold" font-size="14pt">Certificate of Service</fo:inline><fo:inline font-style="italic"> (to be completed by the court)</fo:inline> 
						</fo:block>
						<fo:block space-after="0.4cm">
							AO/CAEO Number:  <xsl:value-of select="$vdCONumber"/>
						</fo:block>
						<fo:block>
							I certify that the summons of which this is a true copy, was served by me on&#xa0;&#xa0;&#xa0;&#xa0;&#xa0;&#xa0;&#xa0;&#xa0;&#xa0;&#xa0;&#xa0;&#xa0;&#xa0;&#xa0;&#xa0;&#xa0;&#xa0;&#xa0;&#xa0;&#xa0;&#xa0;&#xa0;&#xa0;.&#xa0;&#xa0;&#xa0;&#xa0;&#xa0;&#xa0;
							on the&#xa0;&#xa0;&#xa0;&#xa0;&#xa0;&#xa0;&#xa0;&#xa0;&#xa0;&#xa0;&#xa0;&#xa0;&#xa0;&#xa0;&#xa0;&#xa0;&#xa0;&#xa0;&#xa0;&#xa0;
						</fo:block>
						<fo:block>
							personally, at the address stated in the summons, or at
						</fo:block>
						<fo:block space-after="0.8cm">
							<fo:inline font-style="italic">or in accordance with an order for substituted service.</fo:inline>  
						</fo:block>
						<fo:block space-after="0.4cm" text-align="right">
								Bailiff/Officer of the Court
						</fo:block>
						<fo:block space-after="0.4cm">
							<fo:inline font-weight="bold">NOTICE OF NON-SERVICE</fo:inline>
						</fo:block>
						<fo:block space-after="0.8cm">
							I certify that the summons of which this is a true copy, was served by me on&#xa0;&#xa0;&#xa0;&#xa0;&#xa0;&#xa0;&#xa0;&#xa0;&#xa0;&#xa0;&#xa0;&#xa0;&#xa0;&#xa0;&#xa0;&#xa0;&#xa0;&#xa0;&#xa0;&#xa0;&#xa0;&#xa0;&#xa0;&#xa0;&#xa0;&#xa0;&#xa0;&#xa0;&#xa0;&#xa0;on the&#xa0;&#xa0;&#xa0;&#xa0;&#xa0;&#xa0;&#xa0;&#xa0;&#xa0;&#xa0;&#xa0;&#xa0;&#xa0;&#xa0;&#xa0;&#xa0;&#xa0;&#xa0;&#xa0;&#xa0;&#xa0;&#xa0;&#xa0;&#xa0;&#xa0;&#xa0;&#xa0;&#xa0;&#xa0;&#xa0;
							personally, at the address stated in the summons, or at&#xa0;&#xa0;&#xa0;&#xa0;&#xa0;&#xa0;&#xa0;&#xa0;&#xa0;&#xa0;&#xa0;&#xa0;&#xa0;&#xa0;&#xa0;&#xa0;&#xa0;&#xa0;&#xa0;&#xa0;&#xa0;&#xa0;&#xa0;&#xa0;&#xa0;&#xa0;&#xa0;&#xa0;&#xa0;&#xa0;<fo:inline font-style="italic"> or in accordance with an order for substituted service.</fo:inline>   
						</fo:block>
						<fo:block space-after="0.4cm" text-align="right">
								Bailiff/Officer of the Court 
						</fo:block>
					</fo:table-cell>
				</fo:table-row>
			</fo:table-body>
		</fo:table>	
		</fo:block>
	</body>
	<defaultFooter id="CO10" CO="true"/>
</root>