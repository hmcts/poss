<!-- DESCRIPTION: This stylesheet is used to create an XSL:FO document that -->
<!-- can be processed into a PDF version.  Business logic -->
<!-- is embedded to generate the correct document text for the order -->
<!-- required. -->
<!--  -->
<!-- INPUTS: XML document containing: the answers to questions asked of the -->
<!-- user; case data retrieved from the database; HTML representing the  -->
<!-- body of the document content (already edited by the user). -->
<!--  -->
<!-- OUTPUTS: XML document with FO tags containing instructions for the -->
<!-- creation of a PDF document. -->
<!--  -->
<!-- CHANGE HISTORY -->
<!-- 28/01/2013 - Chris Vincent, removed word allocation from content.  Trac 4763. -->
<!-- ====================================================================== -->
<root xmlns:xsl="http://www.w3.org/1999/XSL/Transform" xmlns:fo="http://www.w3.org/1999/XSL/Format" xmlns="http://eds.com/supsfo">
	<variables>@word.processing.url.xsl@supsfo.xsl</variables>
	<duplex/>
	<layout>order</layout>
	<addressee>
		<blank/>
		<claimants/>
		<defendants/>
		<part20claimants/>
		<part20defendants/>
	</addressee>
	<header>
		<fo:block font-size="16pt" font-weight="bold">Notice of Allocation to the Small </fo:block>
		<fo:block font-size="16pt" font-weight="bold">Claims Track (preliminary hearing)</fo:block>
	</header>
	<courtcase>
		<court>
			<xsl:copy-of select="$vdCourtHeaderBlock"/>
		</court>
		<caseparameters>
			<parameter>
				<name>
					<fo:block font-weight="bold">Claim Number</fo:block>
				</name>
				<value>
					<fo:block>
						<xsl:value-of select="$vdClaimNumber"/>
					</fo:block>
				</value>
			</parameter>
			<parameter>
				<name>
					<fo:block font-weight="bold">Date</fo:block>
				</name>
				<value>
					<fo:block>
						<xsl:value-of select="$vdEventDate"/>
					</fo:block>
				</value>
			</parameter>
		</caseparameters>
	</courtcase>

	<body>
	<editable useid="N1008A">
		<fo:block space-before="0.4cm" space-after="0.4cm">
			<xsl:value-of select="$vdJudge"/> has considered the statements of case and questionnaires filed and allocated the <xsl:value-of select="$vdAllocation"/> to the <fo:inline font-weight="bold">small claims track</fo:inline>.
		</fo:block>
		<fo:block space-after="0.4cm">
			Before the <xsl:value-of select="$vdAllocation"/> is listed for hearing, the judge has ordered that a preliminary hearing should take place :-	
		</fo:block>
		<fo:block space-after="0.4cm" start-indent="1cm">
				<xsl:value-of select="$vdPreliminaryHearingReasonValue"/>
		</fo:block>
		<fo:block space-after="0.4cm">
			The preliminary hearing will take place at <xsl:call-template name="format-time"><xsl:with-param name="theTime"><xsl:value-of select="$vdHearingTime"/></xsl:with-param></xsl:call-template> on <xsl:value-of select="$vdHearingDate1"/> at <xsl:value-of select="$vdHearingCourtNameDescription"/>,  <xsl:value-of select="$vdHearingCourtAddress"/>.
		</fo:block>
		<fo:block space-after="0.4cm">
		<xsl:choose>
			<xsl:when test="string-length($vdAllocationReason) > 0">
				<xsl:choose>
					<xsl:when test="$vdAllocationReasonGiven = 'Y'">
						The reasons the judge has given for allocation to this track are that  
					</xsl:when>
					<xsl:otherwise>
						The reason the judge has given for allocation to this track is that  
					</xsl:otherwise>
				</xsl:choose>
			<xsl:call-template name="formatTextAreaText">
					<xsl:with-param name="text"><xsl:copy-of select="$vdAllocationReason"/>
					</xsl:with-param></xsl:call-template>.
			</xsl:when>
			<xsl:otherwise/>
		</xsl:choose>
		</fo:block>
	</editable>
	</body>
	<footnote noteextent="3.0">
		<fo:block font-family="Times" font-size="10pt" text-align="justify">
			<fo:table table-layout="fixed">
				<fo:table-column column-width="10cm"></fo:table-column>
				<fo:table-column column-width="9.28cm"></fo:table-column>
				<fo:table-body>
					<fo:table-row>
						<fo:table-cell border-top-style="solid" border-right-style="solid" border-left-style="solid" 
							border-top-width="0.02cm" border-right-width="0.02cm" border-left-width="0.02cm" number-columns-spanned="2">
							<fo:block text-align="center" font-weight="bold" space-after="0.2cm" space-before="0.2cm">NOTES</fo:block>
						</fo:table-cell>
					</fo:table-row>
					<fo:table-row>
						<fo:table-cell border-right-width="0.02cm" border-left-width="0.02cm" border-left-style="solid" padding-right="0.1cm" 
							border-bottom-width="0.02cm" border-bottom-style="solid" padding-bottom="0.2cm">
							<list type="bullet">
								<list-item>
									<fo:block font-size="9pt">
										If you do not attend the hearing the court may make an order in your absence.
									</fo:block>
								</list-item>
							</list>
							<list type="bullet">
								<list-item>
									<fo:block font-size="9pt">
										If it is practical to do so and you and the other parties agree, the judge may decide to treat the preliminary hearing as the final hearing.
									</fo:block>
								</list-item>
							</list>
						</fo:table-cell>
						<fo:table-cell border-right-width="0.02cm" border-right-style="solid" padding-left="0.1cm" padding-right="0.1cm" 
								border-bottom-width="0.02cm" border-bottom-style="solid" padding-bottom="0.2cm">
							<list type="bullet">
								<list-item>
									<fo:block font-size="9pt" text-align="left">
										Leaflets explaining more about what you should do and what happens when your case is allocated to the small claims track are available from the court office, <fo:inline font-weight="bold">or online at</fo:inline> www.hmcourts-service.gov.uk/cms/infoabout.htm.
									</fo:block>
								</list-item>
							</list>						
						</fo:table-cell>
					</fo:table-row>
				</fo:table-body>
			</fo:table>
		</fo:block>
	</footnote>
	<defaultFooter id="CJR023D"/>
</root>