<!--  -->
<!-- DESCRIPTION: This stylesheet is used to create an XSL:FO document that -->
<!-- can be processed into a PDF version.  Business logic -->
<!-- is embedded to generate the correct document text for the order -->
<!-- required. -->
<!--  -->
<!-- INPUTS: XML document containing: the answers to questions asked of the -->
<!-- user; case data retrieved from the database; HTML representing the  -->
<!-- body of the document content (already edited by the user). -->
<!--  -->
<!-- OUTPUTS: XML document with FO tags containing instructions for the -->
<!-- creation of a PDF document. -->
<!--  -->
<!-- ====================================================================== -->
<root xmlns:xsl="http://www.w3.org/1999/XSL/Transform" xmlns:fo="http://www.w3.org/1999/XSL/Format" xmlns="http://eds.com/supsfo">
	<variables>@word.processing.url.deploy@/Notice/L_13_12/L_13_12-VAR.xsl</variables>
	<layout>order</layout>	
	<duplex/>
	<addressee>
		<blank/>
	</addressee>
	<header>
		<fo:block font-size="16pt" font-weight="bold">Application for Substituted Service</fo:block>
		<fo:block font-size="16pt" font-weight="bold">(Bailiff)</fo:block>
	</header>
	<courtcase>
		<court>
			<xsl:copy-of select="$vdCourtHeaderBlock"/>
		</court>
		<caseparameters>
			<parameter>
				<name>
					<fo:block font-weight="bold">Case Number</fo:block>
				</name>
				<value>
					<fo:block>
						<xsl:value-of select="$vdClaimNumber"/>
					</fo:block>
				</value>
			</parameter>
		</caseparameters>
	</courtcase>

	<body>
		<editable useid="N10074">
		<fo:block space-before="0.8cm" space-after="0.4cm" font-weight="bold">
			To the District Judge
		</fo:block>
		<fo:block space-after="0.4cm">
			I apply for an order for leave to serve the <xsl:value-of select="$vdSubjectPartyRoleLower"/> with the attached <xsl:value-of select="$vdTypeOfProcess"/> by substituted service through the letter box at the <xsl:value-of select="$vdSubjectPartyRoleLower"/>'s
			address, having been unable to serve the process personally.
		</fo:block>
		<fo:block space-after="0.4cm">
			I have visited the <xsl:value-of select="$vdSubjectPartyRoleLower"/>'s address on the following days and times:-
		</fo:block>
		<fo:block space-after="0.4cm">
			<fo:table table-layout="fixed" border-style="solid">
				<fo:table-column column-width="4.28cm" />
				<fo:table-column column-width="5cm" />
				<fo:table-column column-width="10.0cm" />
				<fo:table-body border-style="solid">
					<fo:table-row keep-with-next="always" border-style="solid">
						<fo:table-cell border-style="solid" border-width="0.02cm" >
							<fo:block>Date</fo:block>
						</fo:table-cell>
						<fo:table-cell border-style="solid" border-width="0.02cm" >
							<fo:block>Time</fo:block>
						</fo:table-cell>
						<fo:table-cell border-style="solid" border-width="0.02cm" >
							<fo:block>Result of visit</fo:block>
						</fo:table-cell>
					</fo:table-row>
						<xsl:copy-of select="$vdBailiffVisitTable"/>
				</fo:table-body>
			</fo:table>
		</fo:block>
		<fo:block space-after="0.4cm">
			I believe that the <xsl:value-of select="$vdSubjectPartyRoleLower"/> lives at the address because:-
		</fo:block>
		<fo:block space-after="0.4cm">
			<xsl:value-of select="$vdBailiffVisitReason"/>
		</fo:block>
		<fo:block space-after="0.4cm">
			On the <xsl:value-of select="$vdLetterLeftDate"/> I left a letter, a copy of which is attached, at the <xsl:value-of select="$vdSubjectPartyRoleLower"/>'s address asking the <xsl:value-of select="$vdSubjectPartyRoleLower"/> to contact me within seven days
			to arrange an appointment for the process to be served. There has been no reply to that letter.
		</fo:block>
		</editable>
		<fo:table table-layout="fixed" space-after="1cm">
			<fo:table-column column-width="15.28cm"/>
			<fo:table-column column-width="5.28cm"/>
			<fo:table-body>
				<fo:table-row keep-with-next="always" space-after="0.4cm">
					<fo:table-cell>
						<fo:block>Signed_____________________________________ Bailiff</fo:block>
					</fo:table-cell>	
					<fo:table-cell>
						<fo:block>Date___________</fo:block>
					</fo:table-cell>
				</fo:table-row>
				<fo:table-row keep-with-next="always">
					<fo:table-cell>
						<fo:block>Countersigned_______________________________ Bailiff Manager</fo:block>
					</fo:table-cell>	
					<fo:table-cell>
						<fo:block>Date___________</fo:block>
					</fo:table-cell>
				</fo:table-row>		
			</fo:table-body>	
		</fo:table>			
		<fo:block space-after="0.4cm">
			____________________________________________________________________________________________________
		</fo:block>		
		<fo:block space-after="0.4cm" keep-with-next="always" >
			To be completed by the District Judge
		</fo:block>
		<fo:block space-after="0.7cm" keep-with-next="always" >
			<fo:table table-layout="fixed">
				<fo:table-column column-width="10cm" />
				<fo:table-column column-width="2.5cm" />
				<fo:table-column column-width="2.64cm" />
				<fo:table-column column-width="2.5cm" />
				<fo:table-column column-width="2.64cm" />
				<fo:table-body>
					<fo:table-row>
						<fo:table-cell>
							<fo:block>Leave for substituted service as requested - </fo:block>
						</fo:table-cell>
						<fo:table-cell>
							<fo:block>granted</fo:block>
						</fo:table-cell>
						<fo:table-cell>
							<fo:block>[ ]</fo:block>
						</fo:table-cell>
						<fo:table-cell>
							<fo:block>refused</fo:block>
						</fo:table-cell>
						<fo:table-cell>
							<fo:block>[ ]</fo:block>
						</fo:table-cell>
					</fo:table-row>
				</fo:table-body>
			</fo:table> 
		</fo:block>
		<fo:block keep-with-previous="always" >
			_____________________________________________________________ District Judge
		</fo:block>
		
	</body>

	<defaultFooter id="L_13_12"/>
</root>