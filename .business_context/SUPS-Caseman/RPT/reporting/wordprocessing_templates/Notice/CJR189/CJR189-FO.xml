<!--  -->
<!-- DESCRIPTION: This stylesheet is used to create an XSL:FO document that -->
<!-- can be processed into a PDF version.  Business logic -->
<!-- is embedded to generate the correct document text for the order -->
<!-- required. -->
<!--  -->
<!-- INPUTS: XML document containing: the answers to questions asked of the -->
<!-- user; case data retrieved from the database; HTML representing the  -->
<!-- body of the document content (already edited by the user). -->
<!--  -->
<!-- OUTPUTS: XML document with FO tags containing instructions for the -->
<!-- creation of a PDF document. -->
<!--  -->
<!-- ====================================================================== -->
<!-- Change History:
--> 
<root xmlns:xsl="http://www.w3.org/1999/XSL/Transform" xmlns:fo="http://www.w3.org/1999/XSL/Format" xmlns="http://eds.com/supsfo">
	<variables>@word.processing.url.xsl@supsfo.xsl</variables>
	<addressee>
		<claimant/>
	</addressee>
	<header>
		<fo:block font-size="16pt" font-weight="bold">Notice of Issue <xsl:value-of select="$vdDuplicateEvent" /></fo:block>
		<fo:block font-size="12pt">(possession claim) </fo:block>
		<fo:block font-size="12pt"></fo:block>
	</header>
	<courtcase>
		<court>
			<xsl:copy-of select="$vdCourtHeaderBlock"/>
		</court>
		<caseparameters>
			<parameter>
				<name>
					<fo:block font-weight="bold">Claim Number</fo:block>
				</name>
				<value>
					<fo:block>
						<xsl:value-of select="$vdClaimNumber"/>
					</fo:block>
				</value>
			</parameter>
			<parameter>
				<name>
					<fo:block font-weight="bold">Claimant</fo:block>
					<fo:block font-size="9pt">(including ref.)</fo:block>
				</name>
				<value>
					<fo:block hyphenate="true">
						<xsl:value-of select="$vdClaimantName"/>
					</fo:block>
					<fo:block font-size="9pt" hyphenate="true">
						<xsl:value-of select="$vdClaimantReference"/>
					</fo:block>
				</value>
			</parameter>
			<parameter>
				<name>
					<fo:block font-weight="bold">Defendant</fo:block>
					<fo:block font-size="9pt">(including ref.)</fo:block>
				</name>
				<value>
					<fo:block hyphenate="true">
						<xsl:value-of select="$vdDefendantName"/>
					</fo:block>
					<fo:block font-size="9pt" hyphenate="true">
						<xsl:value-of select="$vdDefendantReference"/>
					</fo:block>
				</value>
			</parameter>
			<parameter>
				<name>
					<fo:block font-weight="bold">Issue Fee</fo:block>
				</name>
				<value>
					<fo:block>
						&#163;<xsl:call-template name="correctCalculation">
							<xsl:with-param name="value"><xsl:value-of select="$vdIssueFee"/></xsl:with-param>
						</xsl:call-template>
					</fo:block>
				</value>
			</parameter>
		</caseparameters>
	</courtcase>
	<bodyintroright><fo:block><fo:inline text-align="center"><seal/></fo:inline></fo:block></bodyintroright>

	<body>
		<fo:block space-after="0.8cm">Your claim was issued on <xsl:value-of select="$vdClaimDateOfIssue"/>.</fo:block>
		<fo:block space-after="0.8cm">Date of hearing:</fo:block>
		<fo:block space-after="0.8cm">The claim will be heard on <xsl:value-of select="$vdHearingDate1"/> at <xsl:value-of select="$vdHearingTime"/>.</fo:block>
		<fo:block space-after="1.2cm">At the County Court at <xsl:value-of select="$vdHearingCourtName"/>, <xsl:value-of select="$vdHearingCourtAddress"/>.</fo:block>
		<fo:block font-weight="bold">Evidence</fo:block>
		<list>
			<list-item><fo:block>If you intend to rely on any witness statements, you must file them in the court office and serve copies on all other parties <fo:inline font-weight="bold">no later than 2 clear working days before the hearing.</fo:inline></fo:block></list-item>
			<list-item><fo:block>In a claim for possession against trespassers, any witness statements must be served with a claim form.</fo:block></list-item>
			<list-item><fo:block>Some tenancy agreements attract the payment of stamp duty. If the agreement you wish to use as evidence in this claim is one of these, you must produce at the hearing evidence to show that the Stamp Duty has been paid. If you do not produce this evidence your claim may be adjourned or dismissed.</fo:block></list-item>
		</list>
		<fo:block font-weight="bold" space-before="0.8cm">Hearing</fo:block>
		<fo:block>At the hearing the court may:</fo:block>
		<list>
			<list-item><fo:block>decide the claim;</fo:block></list-item>
			<list-item><fo:block>adjourn the claim to be heard on another day, or</fo:block></list-item>
			<list-item><fo:block>give case management directions, and in some cases, allocate the claim to a track.</fo:block></list-item>
		</list>
	</body>
	<defaultFooter id="CJR189"/>
</root>