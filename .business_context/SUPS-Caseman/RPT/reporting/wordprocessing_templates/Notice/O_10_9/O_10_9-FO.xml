<!--  -->
<!-- DESCRIPTION: This stylesheet is used to create an XSL:FO document that -->
<!-- can be processed into a PDF version.  Business logic -->
<!-- is embedded to generate the correct document text for the order -->
<!-- required. -->
<!--  -->
<!-- INPUTS: XML document containing: the answers to questions asked of the -->
<!-- user; case data retrieved from the database; HTML representing the  -->
<!-- body of the document content (already edited by the user). -->
<!--  -->
<!-- OUTPUTS: XML document with FO tags containing instructions for the -->
<!-- creation of a PDF document. -->
<!--  -->
<!--
@author Sandeep Mullangi
@version 0.1
Change Hisstory
Oct 27, 2008 Sandeep Mullangi - Printing insolvency number if present as part of RFC 486
-->
<!-- ====================================================================== -->
<root xmlns:xsl="http://www.w3.org/1999/XSL/Transform" xmlns:fo="http://www.w3.org/1999/XSL/Format" xmlns="http://eds.com/supsfo">
	<variables>@word.processing.url.xsl@supsfo.xsl</variables>
	<layout>order</layout>
	<duplex/>	
	<addressee>
		<blank/>
		<debtorparty/>
		<creditorparty/>
		<company/>
		<applicant/>
		<petitioner/>
		<trustee/>
		<insolvencypractitioner/>
		<officialreceiver/>
	</addressee>
	<header>
		<fo:block font-size="10pt" font-weight="bold">Form 6.24B</fo:block>
		<fo:block font-size="10pt" font-weight="bold">Rule 6.31</fo:block>
		<fo:block font-size="16pt" font-weight="bold">Change of Carriage Order</fo:block>
	</header>
	<courtcase>
		<court>
			<xsl:copy-of select="$vdCourtHeaderBlock"/>
		</court>
		<caseparameters>
			<!-- adding insolvency number-->
            <parameter>
                <name>
                    <fo:block font-weight="bold">
                        <xsl:choose>
                            <xsl:when test="string-length($vdInsolvencyNumber) > 0">Insolvency Number</xsl:when>
                            <xsl:otherwise>Case Number</xsl:otherwise>
                        </xsl:choose>
                    </fo:block>
                </name>
                <value>
                    <fo:block>
                        <xsl:choose>
                            <xsl:when test="string-length($vdInsolvencyNumber) > 0">
                                <xsl:value-of select="substring($vdInsolvencyNumber,1,4)"/> of <xsl:value-of select="substring($vdInsolvencyNumber,5,4)"/>
                            </xsl:when>
                            <xsl:otherwise>
                                <xsl:value-of select="$vdClaimNumber"/>
                            </xsl:otherwise>
                        </xsl:choose>
                    </fo:block>
                </value>
			</parameter>
			<parameter>
				<name>
					<fo:block font-weight="bold"><xsl:value-of select="$vdSubjectPartyRole"/></fo:block>
				</name>
				<value>
					<fo:block hyphenate="true">
						<xsl:value-of select="$vdSubjectName"/>
					</fo:block>
				</value>
			</parameter>
		</caseparameters>
	</courtcase>
	
	<body>
	<editable useid="N10097">
		<fo:block space-after="0.8cm"/>
		<fo:block space-after="0.4cm" font-size="12pt" font-weight="bold">
			In Bankruptcy
		</fo:block>
		<fo:block space-after="0.4cm">
			<fo:inline  font-weight="bold">Before </fo:inline> <xsl:value-of select="$vdJudge"/>
		</fo:block>
		<fo:block space-after="0.4cm">
			Upon the hearing of this petition this day
		</fo:block>
		<fo:block space-after="0.4cm">
			And upon the application of <xsl:value-of select="$vdInstigatorName"/>, a creditor of the debtor, for an order giving him carriage of the petition in place of the said <xsl:value-of select="$vdOriginalPetitioner"/> (the petitioning creditor) pursuant to Rule 6.31 of the Insolvency Rules 1986
		</fo:block>
		<xsl:if test="string-length($vdHearingAttendees) > 0">
			<fo:block space-after="0.8cm"><xsl:copy-of select="$vdHearingAttendees"/></fo:block>
		</xsl:if>
		<fo:block space-after="0.4cm">
			And upon reading the evidence 
		</fo:block>
		<fo:block space-after="0.4cm">
			It is ordered that the carriage of this petition be given to the said <xsl:value-of select="$vdInstigatorName"/> in place of the said <xsl:value-of select="$vdOriginalPetitioner"/> and that all further proceedings herein be carried on by the said <xsl:value-of select="$vdInstigatorName"/> in the name of the said <xsl:value-of select="$vdOriginalPetitioner"/>
		</fo:block>
		<fo:block space-after="0.4cm">
			And it is ordered that the said <xsl:value-of select="$vdInstigatorName"/> do within <xsl:value-of select="$vdDaysServedBy"/> days from the date of this order serve upon the said debtor and the said <xsl:value-of select="$vdOriginalPetitioner"/> a sealed copy of this order
		</fo:block>
		<fo:block space-after="0.4cm">
			And it is ordered that the said <xsl:value-of select="$vdInstigatorName"/> may rely upon all evidence previously adduced in these proceedings whether by affidavit or otherwise
		</fo:block>
		<fo:block space-after="0.4cm">
			And it is ordered that the further hearing of this petition be adjourned to:
		</fo:block>
		<fo:block space-after="0.4cm">
			Date: <xsl:value-of select="$vdHearingDate1"/>
 		</fo:block>
		<fo:block space-after="0.4cm"> 		
			Time: <xsl:value-of select="$vdHearingTime"/>
 		</fo:block>
		<fo:block space-after="0.4cm">
			at <xsl:value-of select="$vdHearingCourtNameDescription"/>, <xsl:value-of select="$vdHearingCourtAddress"/>
 		</fo:block>
		<fo:block space-after="0.4cm">
			And it is ordered that the question of the costs of the said <xsl:value-of select="$vdOriginalPetitioner"/> be reserved until the final determination of this petition
 		</fo:block>
		<fo:block space-after="0.4cm">
			Dated <xsl:value-of select="$vdOrderDate"/>
 		</fo:block>
 	</editable>
 	</body>
	<defaultFooter id="O_10_9"/>
</root>