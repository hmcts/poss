<!-- DESCRIPTION: This stylesheet is used to create an XSL:FO document that -->
<!-- can be processed into a PDF version.  Business logic -->
<!-- is embedded to generate the correct document text for the order -->
<!-- required. -->
<!--  -->
<!-- INPUTS: XML document containing: the answers to questions asked of the -->
<!-- user; case data retrieved from the database; HTML representing the  -->
<!-- body of the document content (already edited by the user). -->
<!--  -->
<!-- OUTPUTS: XML document with FO tags containing instructions for the -->
<!-- creation of a PDF document. -->
<!--  -->
<!-- ====================================================================== -->
<root xmlns:xsl="http://www.w3.org/1999/XSL/Transform" xmlns:fo="http://www.w3.org/1999/XSL/Format" xmlns="http://eds.com/supsfo">
	<variables>@word.processing.url.xsl@supsfo.xsl</variables>
	<layout>letter</layout>
			<logo/>
			<addressee>
				<applicant/>
			</addressee>
			<body>
				<editable>
				<fo:block space-after="0.4cm">Dear <xsl:value-of select="$vdGreeting"/></fo:block>
				<fo:block space-after="0.4cm" font-size="12pt" font-weight="bold" text-align="center">Re: Case Number: <xsl:value-of select="$vdClaimNumber"/>&#xa0;<xsl:value-of select="variabledata/claim/applicant[./number = 1]/name"/>
				</fo:block>
				<fo:block space-after="0.4cm" font-weight="bold">
					Your application to set aside a statutory demand.
				</fo:block>
				<fo:block space-after="0.4cm">
					The court has received your application to set aside a statutory demand.
				</fo:block>
				<fo:block space-after="0.4cm">
					Your application will not be given a hearing date immediately. It will first be referred to a District Judge. If the judge considers that your application shows no cause for setting the demand aside, your application may be dismissed. If this happens you and the judgment creditor will be told.
				</fo:block>
				<fo:block space-after="0.8cm">
					If the district judge does not dismiss your application on this first consideration, you and the judgment creditor will be sent a time and date when the application will be reconsidered.
				</fo:block>
				<fo:block space-after="1.5cm"><xsl:value-of select="$vdLetterEnding"/>,</fo:block>
				<fo:block><xsl:value-of select="$vdName"/></fo:block>
				<fo:block><xsl:value-of select="$vdSection"/> Section</fo:block>
				<fo:block>Ext <xsl:value-of select="$vdExtension"/></fo:block>
				</editable>
			</body>
		<letterfooter id="L_14_8"/>
</root>