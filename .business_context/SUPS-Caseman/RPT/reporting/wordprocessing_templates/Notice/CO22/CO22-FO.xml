<!--  -->
<!-- DESCRIPTION: This stylesheet is used to create an XSL:FO document that -->
<!-- can be processed into a PDF version.  Business logic -->
<!-- is embedded to generate the correct document text for the order -->
<!-- required. -->
<!--  -->
<!-- INPUTS: XML document containing: the answers to questions asked of the -->
<!-- user; case data retrieved from the database; HTML representing the  -->
<!-- body of the document content (already edited by the user). -->
<!--  -->
<!-- OUTPUTS: XML document with FO tags containing instructions for the -->
<!-- creation of a PDF document. -->
<!--  -->
<!--  08 Aug 2010, Mark Groen. Trac 3023. Refer to $vdDebtorTable4  instead of $vdDebtorTable -->
<!-- ====================================================================== -->
<root xmlns:xsl="http://www.w3.org/1999/XSL/Transform" xmlns:fo="http://www.w3.org/1999/XSL/Format" xmlns="http://eds.com/supsfo">
	<variables>@word.processing.url.xsl@supsfo.xsl</variables>
	<addressee>
			<blank/>
			<creditor/>
			<debtor/>
			<employer sic='true'/>
	</addressee>
	<header>
		<fo:block font-size="16pt" font-weight="bold">Notice of Application to</fo:block>
		<fo:block font-size="16pt" font-weight="bold">add Case to Consolidated</fo:block>
		<fo:block font-size="16pt" font-weight="bold">Attachment of Earnings Order</fo:block>
	</header>
	<courtcase>
		<court>
			<xsl:copy-of select="$vdCourtHeaderBlock"/>
		</court>
		<caseparameters>
			<parameter>
				<name>
					<fo:block font-weight="bold">Consolidated A/E No.</fo:block>
				</name>
				<value>
					<fo:block>
						<xsl:value-of select="$vdCONumber"/>
					</fo:block>
				</value>
			</parameter>
			<parameter>
				<name>
					<fo:block font-weight="bold">Creditor</fo:block>
					<fo:block font-size="9pt">(including ref.)</fo:block>
				</name>
				<value>
					<xsl:call-template name="display-creditor-name-and-reference-template">
						<xsl:with-param name="addressee">
							<xsl:value-of select="$addressee"/>
						</xsl:with-param>
					</xsl:call-template>					
				</value>
			</parameter>				
			<parameter>
				<name>
					<fo:block font-weight="bold">Debtor</fo:block>
				</name>
				<value>
					<fo:block hyphenate="true">
						<xsl:value-of select="$vdCODebtorName"/>
					</fo:block>
				</value>
			</parameter>
		</caseparameters>
	</courtcase>
	<bodyintroright><fo:block><fo:inline text-align="center"><seal/></fo:inline></fo:block></bodyintroright>

	
	<body>
		<editable useid="N100AC">
			<fo:block space-after="0.4cm">
				<fo:inline font-weight="bold">TAKE NOTICE </fo:inline>that an application to add case no. <xsl:value-of select="$vdCOAddedCaseNumber"/> to this Consolidated Attachment of Earnings Order by 
				<xsl:value-of select="$vdApplicantText"/><xsl:if test="variabledata/order/coorder/applicant/applicanttext = 'CRED'">, <xsl:if test="string-length($vdRemovedDebtorName) > 0"><xsl:value-of select="$vdRemovedDebtorName"/> of <xsl:value-of select="$vdCreditorAddress"/>&#xa0;</xsl:if> </xsl:if> has been received.
			</fo:block>
		</editable>
		<fo:block>
			This will mean that
		</fo:block>
		<list type="bullet">
			<list-item>
				<fo:block space-after="0.2cm">the above case will be brought together, as set out below with the following cases which are already included in the existing order -</fo:block>
			</list-item>
		</list>
		<fo:block space-after="0.2cm">
			<fo:table table-layout="fixed">
				<fo:table-column column-width="133.6pt" />
				<fo:table-column column-width="453.9pt" />
				<fo:table-body>
					<fo:table-row>
						<fo:table-cell padding-left="0.03cm" padding-right="0.03cm" border-style="solid" border-width="0.02cm" >
							<fo:block font-weight="bold">Note:</fo:block>
							<fo:block font-size="8pt">This order replaces the orders listed here.  It does not replace any existing PRIORITY attachment of earnings orders.</fo:block>
						</fo:table-cell>
						<fo:table-cell>
							<fo:table table-layout="fixed">
								<fo:table-column column-width="82.6pt" />
								<fo:table-column column-width="205.5pt" />
								<fo:table-column column-width="115.8pt" />
								<fo:table-body>
									<fo:table-row keep-with-next="always">
										<fo:table-cell padding-left="0.03cm" padding-right="0.03cm" border-style="solid" border-width="0.02cm" >
											<fo:block>Case Number</fo:block>
										</fo:table-cell>
										<fo:table-cell padding-left="0.03cm" padding-right="0.03cm" border-style="solid" border-width="0.02cm" >
											<fo:block>Creditor</fo:block>
										</fo:table-cell>
										<fo:table-cell padding-left="0.03cm" padding-right="0.03cm" border-style="solid" border-width="0.02cm" >
											<fo:block>Balance due when order made<fo:inline font-style="italic"> (actual date calculated <xsl:copy-of select="$vdEventDate"/>)</fo:inline></fo:block>
										</fo:table-cell>
									</fo:table-row>
									<xsl:copy-of select="$vdDebtorTable4"/>
								</fo:table-body>
							</fo:table>
						</fo:table-cell>
					</fo:table-row>
				</fo:table-body>
			</fo:table>
		</fo:block>
		<list type="bullet">
			<list-item>
				<fo:block>the employer will be required to make only one deduction from his employee's earnings</fo:block>
			</list-item>
			<list-item>
				<fo:block>the court will hold the money and pay regular dividends</fo:block>
			</list-item>
		</list>

		<fo:block space-after="0.4cm">
			<fo:table table-layout="fixed">
				<fo:table-column column-width="14.2cm"></fo:table-column>
				<fo:table-column column-width="5.0cm"></fo:table-column>
				<fo:table-body>
					<fo:table-row>
						<fo:table-cell>
							<list type="bullet">
								<list-item>
									<fo:block>the court will deduct an administration fee from the money paid into court</fo:block>
								</list-item>
							</list>
						</fo:table-cell>
						<fo:table-cell>
							<fo:block text-align="right">
								<fo:inline font-weight="bold">Dated </fo:inline><xsl:value-of select="$vdEventDate"/>
							</fo:block>
						</fo:table-cell>
					</fo:table-row>
				</fo:table-body>
			</fo:table>
		</fo:block>
	
		<fo:block>
			<fo:table table-layout="fixed">
				<fo:table-column column-width="19.00cm"></fo:table-column>
				<fo:table-body>
					<fo:table-row>
						<fo:table-cell border-style="solid" border-width="0.02cm">
							<fo:block space-after="0.4cm">
								<fo:inline font-weight="bold">If you (either the debtor or any of the creditors) object </fo:inline>to this application, you must give your reasons in the space provided below and return the form to the court.
								Your objection must be received by the court by <xsl:value-of select="$vdObjectionDate"/>. Only in exceptional circumstances will the application not be granted.  The court will inform the parties of its decision.
							</fo:block>
							<fo:block space-after="2.5cm">
								<fo:inline font-weight="bold">I object to this case being added to the consolidated attachment of earnings order because</fo:inline>
							</fo:block>
							<fo:block space-after="0.4cm"><signature signaturetype="signature"/></fo:block>
							<fo:block space-after="0.2cm"><signature signaturetype="COdetailssignature"/></fo:block>
						</fo:table-cell>
					</fo:table-row>
				</fo:table-body>
			</fo:table>
		</fo:block>
	</body>
	<defaultFooter id="CO22" CO="true"/>
</root>