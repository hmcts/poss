<!-- DESCRIPTION: This stylesheet is used to create an XSL:FO document that -->
<!-- can be processed into a PDF version.  Business logic -->
<!-- is embedded to generate the correct document text for the order -->
<!-- required. -->
<!--  -->
<!-- INPUTS: XML document containing: the answers to questions asked of the -->
<!-- user; case data retrieved from the database; HTML representing the  -->
<!-- body of the document content (already edited by the user). -->
<!--  -->
<!-- OUTPUTS: XML document with FO tags containing instructions for the -->
<!-- creation of a PDF document. -->
<!--  -->
<!-- ====================================================================== -->
<root xmlns:xsl="http://www.w3.org/1999/XSL/Transform" xmlns:fo="http://www.w3.org/1999/XSL/Format" xmlns="http://eds.com/supsfo">
	<variables>@word.processing.url.xsl@supsfo.xsl</variables>
	<addressee>
		<blank/>
		<subject/>
		<instigators/>
	</addressee>
	<header>
		<fo:block font-size="16pt" font-weight="bold">Judgment for Claimant</fo:block>
		<fo:block font-size="12pt">(amount to be decided by the court)</fo:block>
	</header>
	<courtcase>
		<court>
			<xsl:copy-of select="$vdCourtHeaderBlock"/>
		</court>
		<caseparameters>
			<parameter>
				<name>
					<fo:block font-weight="bold">Claim Number</fo:block>
				</name>
				<value>
					<fo:block>
						<xsl:value-of select="$vdClaimNumber"/>
					</fo:block>
				</value>
			</parameter>
			<parameter>
				<name>
					<fo:block font-weight="bold"><xsl:value-of select="$vdInstigatorPartyRole"/></fo:block>
					<fo:block font-size="9pt">(including ref.)</fo:block>
				</name>
				<value>
					<fo:block hyphenate="true">
						<xsl:value-of select="$vdInstigatorName"/>
					</fo:block>
					<fo:block font-size="9pt" hyphenate="true">
						<xsl:value-of select="$vdInstigatorReference"/>
					</fo:block>
				</value>
			</parameter>
			<parameter>
				<name>
					<fo:block font-weight="bold"><xsl:value-of select="$vdSubjectPartyRole"/></fo:block>
					<fo:block font-size="9pt">(including ref.)</fo:block>
				</name>
				<value>
					<fo:block hyphenate="true">
						<xsl:value-of select="$vdSubjectName"/>
					</fo:block>
					<fo:block font-size="9pt" hyphenate="true">
						<xsl:value-of select="$vdSubjectReference"/>
					</fo:block>
				</value>
			</parameter>
			<parameter>
				<name>
					<fo:block font-weight="bold">Date</fo:block>
				</name>
				<value>
					<fo:block><xsl:value-of select="$vdSystemDate"/>
					</fo:block>
				</value>
			</parameter>
		</caseparameters>
	</courtcase>

	<body>
		<editable useid="N100C1">
			<fo:block space-after="0.8cm">
				<xsl:value-of select="$vdJudgementReason"/>t is ordered that the defendant must pay the claimant an amount which the court will decide, and costs. To prepare for hearing
			</fo:block>
			<fo:block space-after="0.8cm">
				<xsl:value-of select="$vdJudge"/> orders that:	
			</fo:block>
			<xsl:if test="$vdHearingListed ='Y'">
				<fo:block space-after="0.4cm">
					You should attend the court at <xsl:call-template name="format-time"><xsl:with-param name="theTime"><xsl:value-of select="$vdHearingTime"/></xsl:with-param></xsl:call-template> on <xsl:value-of select="$vdHearingDate"/>, <xsl:value-of select="$vdHearingCourtAddress"/> when the court will make its decision.
				</fo:block>
			</xsl:if>
		</editable>
	</body>
	<defaultFooter id="CJR046"/>
</root>