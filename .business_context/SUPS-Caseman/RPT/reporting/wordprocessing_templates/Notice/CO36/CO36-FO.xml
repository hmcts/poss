<!-- Version: $Revision: 1.11 $ -->
<!--  -->
<!-- DESCRIPTION: This stylesheet is used to create an XSL:FO document that -->
<!-- can be processed into a PDF version.  Business logic -->
<!-- is embedded to generate the correct document text for the order -->
<!-- required. -->
<!--  -->
<!-- INPUTS: XML document containing: the answers to questions asked of the -->
<!-- user; case data retrieved from the database; HTML representing the  -->
<!-- body of the document content (already edited by the user). -->
<!--  -->
<!-- OUTPUTS: XML document with FO tags containing instructions for the -->
<!-- creation of a PDF document. -->
<!--  -->
<!-- ====================================================================== -->
<root xmlns:xsl="http://www.w3.org/1999/XSL/Transform" xmlns:fo="http://www.w3.org/1999/XSL/Format" xmlns="http://eds.com/supsfo">
	<variables>@word.processing.url.xsl@supsfo.xsl</variables>
	<duplex/>
	<addressee copies="2">
			<debtor/>
	</addressee>
	<header>
		<fo:block font-size="16pt" font-weight="bold">Order for Debtor to be arrested and</fo:block>
		<fo:block font-size="16pt" font-weight="bold">brought before the court</fo:block>
	</header>
	<courtcase>
		<court>
			<xsl:copy-of select="$vdCourtHeaderBlock"/>
		</court>
		<caseparameters>
			<parameter>
				<name>
					<fo:block font-weight="bold">AO/CAEO No.</fo:block>
				</name>
				<value>
					<fo:block>
						<xsl:value-of select="$vdCONumber"/>
					</fo:block>
				</value>
			</parameter>
			<parameter>
				<name>
					<fo:block font-weight="bold">Creditor</fo:block>
				</name>
				<value>
					<fo:block>
						Various
					</fo:block>
				</value>
			</parameter>				
			<parameter>
				<name>
					<fo:block font-weight="bold">Debtor</fo:block>
				</name>
				<value>
					<fo:block hyphenate="true">
						<xsl:value-of select="$vdCODebtorName"/>
					</fo:block>
				</value>
			</parameter>
		</caseparameters>
	</courtcase>
	<bodyintroright><fo:block><fo:inline text-align="center"><seal/></fo:inline></fo:block></bodyintroright>
	
	<body>
	<editable useid="N10097">
		<fo:block space-after="0.8cm"/>
		<fo:block font-weight="bold" space-after="0.4cm">
			Before <xsl:value-of select="$vdJudge"/> sitting at <xsl:value-of select="$vdHearingAtCourtNameDescription"/>, <xsl:value-of select="$vdHearingAtCourtAddress"/>
		</fo:block>
		<fo:block space-after="0.4cm">
			<xsl:value-of select="$vdCOHearingAttendees"/>
		</fo:block>
		<fo:block space-after="0.4cm">
			To the Bailiffs of the court and every constable within the jurisdiction of the district judge
		</fo:block>
		<fo:block space-after="0.4cm">
			The Debtor was ordered to attend on a specified day to give good reasons why <xsl:value-of select="$vdCOOrderHeShe"/> should not be fined or imprisoned for failure to provide a statement of means in accordance with section 14 of the Attachment of Earnings Act 1971 and the Debtor failed to attend the hearing
		</fo:block>
		<fo:block space-after="0.4cm">
			<fo:inline font-weight="bold">It is therefore ordered </fo:inline>that the Debtor be arrested and brought before this court forthwith
		</fo:block>
		<fo:block space-after="0.4cm">
			You, the bailiffs and others are therefore required to arrest the Debtor and to bring <xsl:value-of select="$vdCOOrderHimHer"/> before this court
		</fo:block>
		<fo:block text-align="right" space-after="1.2cm">
			<fo:inline font-weight="bold">Dated </fo:inline><xsl:value-of select="$vdEventDate"/>
		</fo:block>
		<fo:block>
			<fo:table table-layout="fixed">
				<fo:table-column column-width="8.64cm"/>
				<fo:table-column column-width="2.0cm"/>
				<fo:table-column column-width="8.64cm"/>
				<fo:table-body>
					<fo:table-row>
						<fo:table-cell padding-left="0.2cm" padding-right="0.2cm" border-style="solid" border-width="0.02cm">
							<fo:block space-after="0.4cm" font-style="italic">
								Description of Debtor
							</fo:block>
							<fo:block>
								<xsl:copy-of select="$vdCODebtorDesc"/>
							</fo:block>
						</fo:table-cell>
						<fo:table-cell/>
						<fo:table-cell padding-left="0.2cm" padding-right="0.2cm" border-style="solid" border-width="0.02cm">
							<fo:block space-after="0.4cm" font-style="italic">
								Debtor's place of employment
							</fo:block>
							<fo:block>
								<xsl:value-of select="$vdEmployerName"/>
							</fo:block>
							<fo:block>
								<xsl:if test="string-length($vdDebtorWorkAddress)>0">
									<xsl:value-of select="$vdDebtorWorkAddress"/>
								</xsl:if>
								<xsl:if test="string-length($vdDebtorWorkAddress)=0">
									<xsl:value-of select="$vdEmployerAddress"/>
								</xsl:if>
							</fo:block>
						</fo:table-cell>
					</fo:table-row>
				</fo:table-body>
			</fo:table>
		</fo:block>
	</editable>
		<fo:block break-before="page"/>

		<fo:block space-after="0.4cm">
			<fo:inline font-weight="bold" font-size="12pt">Certificate of Service </fo:inline><fo:inline font-style="italic">(to be completed by the court)</fo:inline>
		</fo:block>
		<fo:block space-after="0.4cm">
			AO/CAEO Number: <xsl:value-of select="$vdCONumber"/>
		</fo:block>
		<fo:block>
			I certify that the summons of which this is a true copy, was served by me on&#xa0;&#xa0;&#xa0;&#xa0;&#xa0;&#xa0;&#xa0;&#xa0;&#xa0;&#xa0;&#xa0;&#xa0;&#xa0;&#xa0;&#xa0;&#xa0;&#xa0;&#xa0;&#xa0;&#xa0;&#xa0;&#xa0;&#xa0;.&#xa0;&#xa0;&#xa0;&#xa0;&#xa0;&#xa0;
			on the&#xa0;&#xa0;&#xa0;&#xa0;&#xa0;&#xa0;&#xa0;&#xa0;&#xa0;&#xa0;&#xa0;&#xa0;&#xa0;&#xa0;&#xa0;&#xa0;&#xa0;&#xa0;&#xa0;&#xa0;
		</fo:block>
		<fo:block>
			personally, at the address stated in the summons, or at
		</fo:block>
		<fo:block space-after="0.8cm">
			<fo:inline font-style="italic">or in accordance with an order for substituted service.</fo:inline>  
		</fo:block>
		<fo:block space-after="0.8cm" text-align="right">
			Bailiff/Officer of the Court
		</fo:block>
		<fo:block space-after="0.4cm" font-weight="bold">
			NOTICE OF NON-SERVICE
		</fo:block>
		<fo:block space-after="0.8cm">
			I certify that the summons has not been served for the following reasons:
		</fo:block>
		<fo:block space-after="0.4cm" text-align="right">
			Bailiff/Officer of the Court 
		</fo:block>

	</body>
	<defaultFooter id="CO36" CO="true"/>
</root>