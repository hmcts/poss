<project name="build-set-classpath" basedir=".">

	<!-- Add jars from directory to which all mcol application jars are written -->
	<path id="lib.app.dir">
		<fileset dir="${lib.app.dir}">
			<include name="*.jar" />
		</fileset>
	</path>

	<!-- Add jars from directory to which all mcol test jars are written -->
	<path id="lib.test.dir">
		<fileset dir="${lib.test.dir}">
			<include name="*.jar" />
		</fileset>
	</path>

