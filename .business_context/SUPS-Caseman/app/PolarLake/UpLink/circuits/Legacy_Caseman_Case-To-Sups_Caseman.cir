                    <pl:parameter name="alias" value="Print Message"/>
                </pl:parameter>
                <pl:parameter name="trigger" value="start"/>
                <pl:parameter name="message" value="-&#10;--&gt; Attempting AE Events inserts for Case Number = {$case_number-complex}  &#10;--&gt; SEQUENCE - Process AE Events Sequence&#10;--&gt; VIEW - Process AE Events View&#10;--&gt; CIRCUIT - {$CircuitName}&#10;----------------------------------------------------------------------------------"/>
                <pl:parameter name="use_log4j" value="true"/>
                <pl:parameter name="log_level" value="INFO"/>
            </pl:eventprocessor>
            <pl:eventprocessor name="pl:sqltoxml" disable="false">
                <pl:parameter name="design">
                    <pl:parameter name="uid" value="1088"/>
                    <pl:parameter name="alias" value="DB SQL - Get Event Sequence"/>
                </pl:parameter>
                <pl:parameter name="transaction_key" value="Second"/>
                <pl:parameter name="sql" value="select ae_event_seq.nextval from dual"/>
                <pl:parameter name="forward_option" value="9"/>
                <pl:parameter name="sqlwarntoerror" value="false"/>
                <pl:parameter name="query" value="true"/>
                <pl:parameter name="input_mappings">
