                <pl:parameter name="transaction_key" value="First"/>
                <pl:parameter name="sql" value=" SELECT&#10;  DA.DEFT_CASE_NUMBER AS &quot;DEFT.CASE_NUMBER&quot;,&#10;  DA.DEFT_ID AS &quot;DEFT.DEFT_ID&quot;,&#10;  DA.CRT_CODE &quot;DEFT.CRT_CODE&quot;,&#10;  DA.ADDR_TYPE &quot;DEFT.ADDR_TYPE&quot;,&#10;  DA.ADDR_1 &quot;DEFT.ADDR_1&quot;,&#10;  DA.ADDR_2 &quot;DEFT.ADDR_2&quot;,&#10;  DA.ADDR_3 &quot;DEFT.ADDR_3&quot;,&#10;  DA.ADDR_4 &quot;DEFT.ADDR_4&quot;,&#10;  DA.ADDR_5 &quot;DEFT.ADDR_5&quot;,&#10;  DA.POSTCODE &quot;DEFT.POSTCODE&quot;,&#10;  DA.USERNAME &quot;DEFT.USERNAME&quot;,&#10;  DA.VALID_FROM &quot;DEFT.VALID_FROM&quot;,&#10;  DA.VALID_TO &quot;DEFT.VALID_TO&quot; &#10;  FROM DEFENDANT_ADDRESSES DA&#10;  WHERE DA.DEFT_CASE_NUMBER = ?&#10;  AND DA.TRANS_SEQ = ?&#10;  AND DA.DEFT_ID = NULL&#10;  AND DA.ADDR_TYPE = &apos;POSS&apos;"/>
