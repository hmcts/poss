            <pl:eventprocessor name="pl:printmessage" disable="false">
                <pl:parameter name="design">
                    <pl:parameter name="uid" value="835"/>
                    <pl:parameter name="alias" value="Print Message"/>
                </pl:parameter>
                <pl:parameter name="trigger" value="start"/>
                <pl:parameter name="message" value="-&#10;--&gt; Starting Sql Select/Retrieve for Defendants - Case Number = {$case_number-complex}&#10;--&gt; SEQUENCE - Retrieve and Update Case Data &#10;--&gt; VIEW - Retrieve and Update Case Data View&#10;--&gt; CIRCUIT - {$CircuitName}&#10;----------------------------------------------------------------------------------"/>
                <pl:parameter name="use_log4j" value="true"/>
                <pl:parameter name="log_level" value="INFO"/>
            </pl:eventprocessor>
            <pl:eventprocessor name="pl:sqltoxml" disable="false">
                <pl:parameter name="design">
                    <pl:parameter name="uid" value="899"/>
                    <pl:parameter name="alias" value="DB SQL - Get Defendant and Defendant Address"/>
                </pl:parameter>
                <pl:parameter name="transaction_key" value="First"/>
                <pl:parameter name="sql" value="SELECT&#10;  DA.DEFT_CASE_NUMBER AS &quot;DEFT.CASE_NUMBER&quot;,&#10;  DA.DEFT_ID AS &quot;DEFT.DEFT_ID&quot;,&#10;  DA.CRT_CODE &quot;DEFT.CRT_CODE&quot;,&#10;  DA.ADDR_TYPE &quot;DEFT.ADDR_TYPE&quot;,&#10;  DA.ADDR_1 &quot;DEFT.ADDR_1&quot;,&#10;  DA.ADDR_2 &quot;DEFT.ADDR_2&quot;,&#10;  DA.ADDR_3 &quot;DEFT.ADDR_3&quot;,&#10;  DA.ADDR_4 &quot;DEFT.ADDR_4&quot;,&#10;  DA.ADDR_5 &quot;DEFT.ADDR_5&quot;,&#10;  DA.POSTCODE &quot;DEFT.POSTCODE&quot;,&#10;  DA.USERNAME &quot;DEFT.USERNAME&quot;,&#10;  DA.VALID_FROM &quot;DEFT.VALID_FROM&quot;,&#10;  DA.VALID_TO &quot;DEFT.VALID_TO&quot;, &#10;  D.NAME &quot;DEFT.NAME&quot;,    &#10;  D.DATE_OF_SERVICE_RO &quot;DEFT.DATE_OF_SERVICE_RO&quot;, &#10;  D.DATE_OF_SERVICE_OTHER &quot;DEFT.DATE_OF_SERVICE_OTHER&quot;, &#10;  D.SOL_CODE,&#10;  D.SOLICITOR_NAME,&#10;  D.SOLICITOR_ADDR_1,&#10;  D.SOLICITOR_ADDR_2, &#10;  D.SOLICITOR_ADDR_3, &#10;  D.SOLICITOR_ADDR_4,  &#10;  D.SOLICITOR_ADDR_5, &#10;  D.SOLICITOR_POSTCODE,&#10;  D.SOLICITOR_TEL_NO,&#10;  D.SOL_DX,&#10;  D.BAR_JUDGMENT &quot;DEFT.BAR_JUDGMENT&quot;, &#10;  D.METHOD_OF_SERVICE &quot;DEFT.METHOD_OF_SERVICE&quot;&#10;  FROM DEFENDANTS D, DEFENDANT_ADDRESSES DA&#10;  WHERE D.CASE_NUMBER = ? &#10;  AND D.TRANS_SEQ = ?&#10;  AND D.TRANS_SEQ = DA.TRANS_SEQ&#10;  AND D.CASE_NUMBER = DA.DEFT_CASE_NUMBER&#10;  AND D.ID != 0&#10; AND D.ID = DA.DEFT_ID&#10;  AND DA.ADDR_TYPE = &apos;SERVICE&apos;"/>
                <pl:parameter name="forward_option" value="0"/>
                <pl:parameter name="sqlwarntoerror" value="false"/>
                <pl:parameter name="query" value="true"/>
                <pl:parameter name="input_mappings">
                    <pl:parameter name="input schemas">
                        <pl:parameter name="0">
                            <pl:parameter name="root" value="/any"/>
                            <pl:parameter name="schema" value=""/>
                            <pl:parameter name="using" value="."/>
                        </pl:parameter>
                    </pl:parameter>
                    <pl:parameter name="output schemas">
                        <pl:parameter name="0">
                            <pl:parameter name="root" value="/aa:parameters"/>
                            <pl:parameter name="schema" value="dbsqlinput.2"/>
