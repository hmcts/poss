                    <pl:application-data name="url" type="property" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value=""/>
                    <pl:application-data name="remote" type="property" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value="false"/>
                    <pl:application-data name="type" type="property" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value="beanshell"/>
                    <pl:application-data name="cache" type="property" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value="never_resolve"/>
                    <pl:application-data name="script" type="property" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value="import org.apache.log4j.Logger;&#10;import org.jdom.*;  &#10;import org.jdom.input.*;  &#10;import org.jdom.output.*;  &#10;import com.polarlake.platform.api.*;  &#10;import com.polarlake.platform.api.helper.*;  &#10;import com.polarlake.platform.api.exception.*;  &#10;import com.polarlake.platform.common.ParameterName;&#10;  &#10;/**  &#10; * A JDOM beanshell must return a JDOM document.  &#10; */  &#10; Document processDocument(Document doc, ExecutiveProcessInterface process) &#10; { &#10;       XMLOutputter xo = new XMLOutputter(Format.getPrettyFormat());&#10;       Logger logger = Logger.getLogger(&quot;com.info&quot;);&#10;&#10;       String processCaseName = Util.getProcessVariable (process, new ParameterName(&quot;case_number-complex&quot;));&#10;&#10;       String processCircuitName = Util.getProcessVariable (process, new ParameterName(&quot;CircuitName&quot;));&#10;&#10;       logger.info(&quot;\n&quot; +&#10;     &quot;In Caseman Transfer Script Printing Xml Doc in Circuit = &quot; +  &#10;      processCircuitName +&#10;      &quot;\n For CaseNumber = &quot; +&#9;&#10;       processCaseName+ &#10;       &quot;\n&quot;+ &#10;       xo.outputString(doc));&#10;      return doc;&#9;&#10;} &#10;"/>
                    <pl:application-data name="description" type="property" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value="A PolarLake Platform Beanshell script must be coded to return a JDOM document.They can be composed from calls to imported modules as well as local methods.Only the first method in the script will be executed, so it should make any appropriate method calls if the entire script is not contained in it."/>
                </pl:application-data>
                <pl:application-data name="JDom Processing" type="script" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value="">
                    <pl:application-data name="url" type="property" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value=""/>
                    <pl:application-data name="remote" type="property" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value="false"/>
                    <pl:application-data name="type" type="property" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value="beanshell"/>
                    <pl:application-data name="cache" type="property" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value="never_resolve"/>
                    <pl:application-data name="script" type="property" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value="import org.jdom.*;&#10;import org.jdom.input.*;&#10;import org.jdom.output.*;&#10;import com.polarlake.platform.api.*;&#10;import com.polarlake.platform.api.helper.*;&#10;import com.polarlake.platform.api.exception.*;&#10;&#10;/**&#10; * A JDOM beanshell must return a JDOM document.&#10; */&#10;Document processDocument(Document doc) {&#10;&#10;   return doc;&#10;}"/>
                    <pl:application-data name="description" type="property" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value="This returns the empty doc without doing anything."/>
                </pl:application-data>
                <pl:application-data name="Process Doc Logger Fatal - Caseman" type="script" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value="">
                    <pl:application-data name="url" type="property" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value=""/>
                    <pl:application-data name="remote" type="property" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value="false"/>
                    <pl:application-data name="type" type="property" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value="beanshell"/>
                    <pl:application-data name="cache" type="property" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value="never_resolve"/>
                    <pl:application-data name="script" type="property" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value="import org.apache.log4j.Logger;&#10;import org.jdom.*;  &#10;import org.jdom.input.*;  &#10;import org.jdom.output.*;  &#10;import com.polarlake.platform.api.*;  &#10;import com.polarlake.platform.api.helper.*;  &#10;import com.polarlake.platform.api.exception.*;  &#10;import com.polarlake.platform.common.ParameterName;&#10;  &#10;/**  &#10; * A JDOM beanshell must return a JDOM document.  &#10; */  &#10; Document processDocument(Document doc, ExecutiveProcessInterface process) &#10; { &#10;       XMLOutputter xo = new XMLOutputter(Format.getPrettyFormat());&#10;       Logger logger = Logger.getLogger(&quot;com.fatal&quot;);&#10;&#10;       String processCaseName = Util.getProcessVariable (process, new ParameterName(&quot;case_number-complex&quot;));&#10;       String processCircuitName = Util.getProcessVariable (process, new ParameterName(&quot;CircuitName&quot;));&#10;       logger.error(&quot;\n&quot; +&#10;     &quot;Fatal Error in Caseman Transfer Script Printing Xml Doc in Circuit = &quot; +  &#10;      processCircuitName +&#10;      &quot;\n For CaseNumber = &quot; +&#9;&#10;       processCaseName+ &#10;       &quot;\n&quot;+ &#10;       xo.outputString(doc));&#10;      return doc;&#9;&#10;} &#10;"/>
                    <pl:application-data name="description" type="property" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value="A PolarLake Platform Beanshell script must be coded to return a JDOM document.They can be composed from calls to imported modules as well as local methods.Only the first method in the script will be executed, so it should make any appropriate method calls if the entire script is not contained in it."/>
                </pl:application-data>
                <pl:application-data name="MapCaseEvent" type="script" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value="">
                    <pl:application-data name="url" type="property" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value=""/>
                    <pl:application-data name="remote" type="property" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value="false"/>
                    <pl:application-data name="type" type="property" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value="beanshell"/>
                    <pl:application-data name="cache" type="property" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value="never_resolve"/>
                    <pl:application-data name="script" type="property" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value="import java.util.Iterator;&#10;import java.util.List;&#10;&#10;import org.apache.log4j.Logger;&#10;&#10;import org.jdom.*;  &#10;import org.jdom.input.*;  &#10;import org.jdom.output.*;  &#10;import org.jdom.xpath.XPath;&#10;&#10;import com.polarlake.platform.api.*;  &#10;import com.polarlake.platform.api.helper.*;  &#10;import com.polarlake.platform.api.exception.*;  &#10;import com.polarlake.platform.common.ParameterName;&#10;  &#10;/**  &#10; * A JDOM beanshell must return a JDOM document.  &#10; */  &#10; Document processDocument(Document doc, ExecutiveProcessInterface process) &#10; { &#10;&#10;       XMLOutputter xo = new XMLOutputter(Format.getPrettyFormat());&#10;       Logger loggerI = Logger.getLogger(&quot;com.info&quot;);&#10;       Logger loggerE = Logger.getLogger(&quot;com.error&quot;);&#10;       Document docEvent;&#10;       String eventString = &quot;Event Id has been mapped from &quot;;&#10;&#10;      try &#10;      { &#10;          VariableContainerInterface vci = process.getProcessDocGroup(); &#10;&#10;          if (vci != null) &#10;          { &#10;              VariableInterface vi = vci.getVariable(&quot;CaseEventMap&quot;); &#10;              docEvent = (Document)vi.getValue();  &#10;          } &#10;      } &#10;      catch (DocVariableException dve) &#10;      { &#10;          loggerE.error(&quot;\n Error in Run Script Map Events&quot;);&#10;      } &#10;&#10;        List paramsEvents;&#10;        try {&#10;            paramsEvents = XPath.selectNodes(doc, &quot;//CaseEvent&quot;);&#10;&#10;            Iterator it = paramsEvents.iterator();&#10;            while(it.hasNext()) {&#10;                Element currentElement = (Element) it.next();&#10;&#10;                if(currentElement instanceof Element) {&#10;&#10;                    Element paramsDetails = (Element) XPath.selectSingleNode(currentElement, &quot;./Details&quot;);&#10;                    Element paramsEventID = (Element) XPath.selectSingleNode(currentElement, &quot;./StandardEventID&quot;);                      &#10;                 &#10;                    if(paramsEventID != null &amp;&amp; paramsEventID.getText() != null &amp;&amp;  (!paramsEventID.getText().equals(&quot;&quot;))) {&#10;&#10;                    String eventIdStr = paramsEventID.getText();&#10;                        List paramMappedEventIdList = XPath.selectNodes(docEvent, &quot;//NonLegacyEvent[LegacyEventID =&quot; +eventIdStr+ &quot;]&quot;);&#10;                              &#10;                        Iterator itEventMap = paramMappedEventIdList.iterator();&#10;                        while(itEventMap.hasNext()) {&#10;&#10;                            Element mappedElement = (Element) itEventMap.next();&#10;&#10;                            Element paramsSupsEventId = (Element) XPath.selectSingleNode(mappedElement, &quot;./SupsEventID&quot;);&#10;    &#10;                            paramsEventID.setText(paramsSupsEventId.getText());&#10;                            if(paramsDetails.getText().length()+eventString.length()+4 &lt; 2000) {&#10;                                paramsDetails.setText(paramsDetails.getText()+ eventString+eventIdStr);&#10;                            }&#10;                            &#10;                        }&#10;                    }&#10;                }&#10;            }&#10;        } catch (JDOMException e) {&#10;            loggerE.error(&quot;Jdom Exception ErrorError in Run Script Map Events = &quot; + e.getMessage(), e);  &#10;        }&#10;      return doc;&#9;&#10;} "/>
                    <pl:application-data name="description" type="property" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value="A PolarLake Platform Beanshell script must be coded to return a JDOM document.They can be composed from calls to imported modules as well as local methods.Only the first method in the script will be executed, so it should make any appropriate method calls if the entire script is not contained in it."/>
                </pl:application-data>
                <pl:application-data name="mapJudgmentSeqToVariation" type="script" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value="">
                    <pl:application-data name="url" type="property" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value=""/>
                    <pl:application-data name="remote" type="property" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value="false"/>
                    <pl:application-data name="type" type="property" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value="beanshell"/>
                    <pl:application-data name="cache" type="property" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value="never_resolve"/>
                    <pl:application-data name="script" type="property" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value="import java.util.Iterator;&#10;import java.util.List;&#10;&#10;import org.apache.log4j.Logger;&#10;&#10;import org.jdom.*;  &#10;import org.jdom.input.*;  &#10;import org.jdom.output.*;  &#10;import org.jdom.xpath.XPath;&#10;&#10;import com.polarlake.platform.api.*;  &#10;import com.polarlake.platform.api.helper.*;  &#10;import com.polarlake.platform.api.exception.*;  &#10;import com.polarlake.platform.common.ParameterName;&#10;  &#10;/**  &#10; * A JDOM beanshell must return a JDOM document.  &#10; */  &#10; Document processDocument(Document doc, ExecutiveProcessInterface process) &#10; { &#10;&#10;       XMLOutputter xo = new XMLOutputter(Format.getPrettyFormat());&#10;       Logger loggerI = Logger.getLogger(&quot;com.info&quot;);&#10;       Logger loggerE = Logger.getLogger(&quot;com.error&quot;);&#10;       Document docJudg;&#10;&#10;      try &#10;      { &#10;          VariableContainerInterface vci = process.getProcessDocGroup(); &#10;&#10;          if (vci != null) &#10;          { &#10;              VariableInterface vi = vci.getVariable(&quot;Case-Judgment&quot;); &#10;              docJudg = (Document)vi.getValue();  &#10;          } &#10;      } &#10;      catch (DocVariableException dve) &#10;      { &#10;          loggerE.error(&quot;\n Error in Run Script mapJudgmentSeqToVariation for Case-Judgment-To-Variation Mapper&quot;);&#10;      } &#10;&#10;        List paramsVariations;&#10;        try {&#10;            paramsVariations = XPath.selectNodes(doc, &quot;//Variation&quot;);&#10;&#10;            Iterator it = paramsVariations.iterator();&#10;            while(it.hasNext()) {&#10;                Element currentElement = (Element) it.next();&#10;&#10;                if(currentElement instanceof Element) {&#10;&#10;                    Element paramsOldJudgeSeq = (Element) XPath.selectSingleNode(currentElement, &quot;./JudgSequence&quot;);                      &#10;                    if(paramsOldJudgeSeq != null &amp;&amp; paramsOldJudgeSeq.getText() != null &amp;&amp; (!paramsOldJudgeSeq.getText().equals(&quot;&quot;))) {&#10;&#10;                    String judgIdStr = paramsOldJudgeSeq.getText();&#10;&#10;                        Attribute mappedAttribute = (Attribute) XPath.selectSingleNode(docJudg, &quot;//Judgment[JudgmentSequence =&quot; +judgIdStr+ &quot;]/JudgmentSequence/@newSequenceNumber&quot;);&#10;&#10;    &#9;&#9;&#9;if(mappedAttribute != null) {&#10;                            paramsOldJudgeSeq.setText(mappedAttribute.getValue());&#10;                        } else {&#10;                            throw new RuntimeException(&quot;Variation Judgment Sequence has not been mapped for &quot; + paramsOldJudgeSeq.getText());&#10;                        }&#10;                            &#10;                    }&#10;                }&#10;            }&#10;        } catch (JDOMException e) {&#10;            loggerE.error(&quot;Jdom Exception ErrorError in Run Script mapJudgmentSeqToVariation for = &quot; + e.getMessage(), e);  &#10;        }&#10;      return doc;&#9;&#10;} "/>
                    <pl:application-data name="description" type="property" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value="A PolarLake Platform Beanshell script must be coded to return a JDOM document.They can be composed from calls to imported modules as well as local methods.Only the first method in the script will be executed, so it should make any appropriate method calls if the entire script is not contained in it."/>
                </pl:application-data>
                <pl:application-data name="mapJudgmentSeqAndVariationSeqToCaseEvent" type="script" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value="">
                    <pl:application-data name="url" type="property" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value=""/>
                    <pl:application-data name="remote" type="property" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value="false"/>
                    <pl:application-data name="type" type="property" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value="beanshell"/>
                    <pl:application-data name="cache" type="property" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value="never_resolve"/>
                    <pl:application-data name="script" type="property" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value="import java.util.Iterator;&#10;import java.util.List;&#10;&#10;import org.apache.log4j.Logger;&#10;&#10;import org.jdom.*;  &#10;import org.jdom.input.*;  &#10;import org.jdom.output.*;  &#10;import org.jdom.xpath.XPath;&#10;&#10;import com.polarlake.platform.api.*;  &#10;import com.polarlake.platform.api.helper.*;  &#10;import com.polarlake.platform.api.exception.*;  &#10;import com.polarlake.platform.common.ParameterName;&#10;  &#10;/**  &#10; * A JDOM beanshell must return a JDOM document.  &#10; */  &#10; Document processDocument(Document doc, ExecutiveProcessInterface process) &#10; { &#10; &#10;       XMLOutputter xo = new XMLOutputter(Format.getPrettyFormat());&#10;       Logger loggerI = Logger.getLogger(&quot;com.info&quot;);&#10;       Logger loggerE = Logger.getLogger(&quot;com.error&quot;);&#10;       Document docJudg;&#10;       Document docVariation;&#10;&#10;      try &#10;      { &#10;          VariableContainerInterface vci = process.getProcessDocGroup(); &#10;&#10;          if (vci != null) &#10;          { &#10;              VariableInterface vi = vci.getVariable(&quot;Case-Judgment&quot;); &#10;              docJudg = (Document)vi.getValue();  &#10;              VariableInterface vi = vci.getVariable(&quot;Case-Variation&quot;); &#10;              docVariation = (Document)vi.getValue(); &#10;          } &#10;      } &#10;      catch (DocVariableException dve) &#10;      { &#10;          loggerE.error(&quot;\n Error in Run Script mapJudgmentSeqAndVariationSeqToCaseEvent for Judgement-And-Variations-To-CaseEvent Mapper&quot;);&#10;      } &#10;&#10;        List paramsVariations;&#10;        try {&#10;            paramsCaseEvent = XPath.selectNodes(doc, &quot;//CaseEvent&quot;);&#10;&#10;            Iterator it = paramsCaseEvent.iterator();&#10;            while(it.hasNext()) {&#10;                Element currentElement = (Element) it.next();&#10;&#10;                if(currentElement instanceof Element) {&#10;&#10;                    Element paramsOldJudgeSeq = (Element) XPath.selectSingleNode(currentElement, &quot;./JudgmentSequence&quot;);    &#10;                    Element paramsOldVariationSeq = (Element) XPath.selectSingleNode(currentElement, &quot;./VariationSequence&quot;);                   &#10;                    &#10;                    if(paramsOldJudgeSeq != null &amp;&amp; paramsOldJudgeSeq.getText() != null &amp;&amp; (!paramsOldJudgeSeq.getText().equals(&quot;&quot;))) {&#10;&#10;                    String judgIdStr = paramsOldJudgeSeq.getText();&#10;&#10;                        Attribute mappedAttribute = (Attribute) XPath.selectSingleNode(docJudg, &quot;//Judgment[JudgmentSequence =&quot; +judgIdStr+ &quot;]/JudgmentSequence/@newSequenceNumber&quot;);&#10;&#10;    &#9;&#9;&#9;if(mappedAttribute != null) {&#10;                            paramsOldJudgeSeq.setText(mappedAttribute.getValue());&#10;                        } else {&#10;                            throw new RuntimeException(&quot;Case Event - Judgment Sequence has not been mapped for &quot; + paramsOldJudgeSeq.getText());&#10;                        }&#10;                            &#10;                    } &#10;                    &#10;                    if(paramsOldVariationSeq != null &amp;&amp; paramsOldVariationSeq.getText() != null &amp;&amp; (!paramsOldVariationSeq.getText().equals(&quot;&quot;))) {&#10;&#10;                    String varIdStr = paramsOldVariationSeq.getText();&#10;&#10;                        Attribute mappedAttribute = (Attribute) XPath.selectSingleNode(docVariation, &quot;//Variation[VarySequence =&quot; +varIdStr+ &quot;]/VarySequence/@newSequenceNumber&quot;);&#10;&#10;    &#9;&#9;&#9;if(mappedAttribute != null) {&#10;                            paramsOldVariationSeq.setText(mappedAttribute.getValue());&#10;                        } else {&#10;                            throw new RuntimeException(&quot;Case Event - Variation Sequence has not been mapped for &quot; + paramsOldVariationSeq.getText());&#10;                        }&#10;                            &#10;                    } &#10;                    &#10;                }&#10;            }&#10;        } catch (JDOMException e) {&#10;            loggerE.error(&quot;Jdom Exception ErrorError in Run Script mapJudgmentSeqAndVariationSeqToCaseEvent for Judgement-And-Variations-To-CaseEvent = &quot; + e.getMessage(), e);  &#10;        }&#10;      return doc;&#9;&#10;} "/>
                    <pl:application-data name="description" type="property" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value="A PolarLake Platform Beanshell script must be coded to return a JDOM document.They can be composed from calls to imported modules as well as local methods.Only the first method in the script will be executed, so it should make any appropriate method calls if the entire script is not contained in it."/>
                </pl:application-data>
                <pl:application-data name="MapAEEvent" type="script" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value="">
                    <pl:application-data name="url" type="property" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value=""/>
                    <pl:application-data name="remote" type="property" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value="false"/>
                    <pl:application-data name="type" type="property" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value="beanshell"/>
                    <pl:application-data name="cache" type="property" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value="never_resolve"/>
                    <pl:application-data name="script" type="property" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value="import java.util.Iterator;&#10;import java.util.List;&#10;&#10;import org.apache.log4j.Logger;&#10;&#10;import org.jdom.*;  &#10;import org.jdom.input.*;  &#10;import org.jdom.output.*;  &#10;import org.jdom.xpath.XPath;&#10;&#10;import com.polarlake.platform.api.*;  &#10;import com.polarlake.platform.api.helper.*;  &#10;import com.polarlake.platform.api.exception.*;  &#10;import com.polarlake.platform.common.ParameterName;&#10;  &#10;/**  &#10; * A JDOM beanshell must return a JDOM document.  &#10; */  &#10; Document processDocument(Document doc, ExecutiveProcessInterface process) &#10; { &#10;&#10;       XMLOutputter xo = new XMLOutputter(Format.getPrettyFormat());&#10;       Logger loggerI = Logger.getLogger(&quot;com.info&quot;);&#10;       Logger loggerE = Logger.getLogger(&quot;com.error&quot;);&#10;       Document docEvent;&#10;       String eventString = &quot;Event Id has been mapped from &quot;;&#10;&#10;      try &#10;      { &#10;          VariableContainerInterface vci = process.getProcessDocGroup(); &#10;&#10;          if (vci != null) &#10;          { &#10;              VariableInterface vi = vci.getVariable(&quot;CaseEventMap&quot;); &#10;              docEvent = (Document)vi.getValue();  &#10;          } &#10;      } &#10;      catch (DocVariableException dve) &#10;      { &#10;          loggerE.error(&quot;\n Error in Run Script Map AE Events&quot;);&#10;      } &#10;&#10;        List paramsEvents;&#10;        try {&#10;            paramsEvents = XPath.selectNodes(doc, &quot;//AEEvent&quot;);&#10;&#10;            Iterator it = paramsEvents.iterator();&#10;            while(it.hasNext()) {&#10;                Element currentElement = (Element) it.next();&#10;&#10;                if(currentElement instanceof Element) {&#10;&#10;                    Element paramsDetails = (Element) XPath.selectSingleNode(currentElement, &quot;./Details&quot;);&#10;                    Element paramsEventID = (Element) XPath.selectSingleNode(currentElement, &quot;./EventID&quot;);                      &#10;                 &#10;                    if(paramsEventID != null &amp;&amp; paramsEventID.getText() != null &amp;&amp;  (!paramsEventID.getText().equals(&quot;&quot;))) {&#10;&#10;                    String eventIdStr = paramsEventID.getText();&#10;                        List paramMappedEventIdList = XPath.selectNodes(docEvent, &quot;//NonLegacyEvent[LegacyEventID =&quot; +eventIdStr+ &quot;]&quot;);&#10;                              &#10;                        Iterator itEventMap = paramMappedEventIdList.iterator();&#10;                        while(itEventMap.hasNext()) {&#10;&#10;                            Element mappedElement = (Element) itEventMap.next();&#10;&#10;                            Element paramsSupsEventId = (Element) XPath.selectSingleNode(mappedElement, &quot;./SupsEventID&quot;);&#10;    &#10;                            paramsEventID.setText(paramsSupsEventId.getText());&#10;                            if(paramsDetails.getText().length()+eventString.length()+4 &lt; 2000) {&#10;                                paramsDetails.setText(paramsDetails.getText()+ eventString+eventIdStr);&#10;                            }&#10;                            &#10;                        }&#10;                    }&#10;                }&#10;            }&#10;        } catch (JDOMException e) {&#10;            loggerE.error(&quot;Jdom Exception ErrorError in Run Script Map AE Events = &quot; + e.getMessage(), e);  &#10;        }&#10;      return doc;&#9;&#10;} "/>
                    <pl:application-data name="description" type="property" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value="A PolarLake Platform Beanshell script must be coded to return a JDOM document.They can be composed from calls to imported modules as well as local methods.Only the first method in the script will be executed, so it should make any appropriate method calls if the entire script is not contained in it."/>
                </pl:application-data>
                <pl:application-data name="mapCaseEventSeqAndAEEventSeqToObligation" type="script" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value="">
                    <pl:application-data name="url" type="property" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value=""/>
                    <pl:application-data name="remote" type="property" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value="false"/>
                    <pl:application-data name="type" type="property" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value="beanshell"/>
                    <pl:application-data name="cache" type="property" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value="never_resolve"/>
                    <pl:application-data name="script" type="property" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value="import java.util.Iterator;&#10;import java.util.List;&#10;&#10;import org.apache.log4j.Logger;&#10;&#10;import org.jdom.*;  &#10;import org.jdom.input.*;  &#10;import org.jdom.output.*;  &#10;import org.jdom.xpath.XPath;&#10;&#10;import com.polarlake.platform.api.*;  &#10;import com.polarlake.platform.api.helper.*;  &#10;import com.polarlake.platform.api.exception.*;  &#10;import com.polarlake.platform.common.ParameterName;&#10;  &#10;/**  &#10; * A JDOM beanshell must return a JDOM document.  &#10; */  &#10; Document processDocument(Document doc, ExecutiveProcessInterface process) &#10; { &#10; &#10;       XMLOutputter xo = new XMLOutputter(Format.getPrettyFormat());&#10;       Logger loggerI = Logger.getLogger(&quot;com.info&quot;);&#10;       Logger loggerE = Logger.getLogger(&quot;com.error&quot;);&#10;       Document docCaseEvent;&#10;       Document docAEEvent;&#10;&#10;      try &#10;      { &#10;          VariableContainerInterface vci = process.getProcessDocGroup(); &#10;&#10;          if (vci != null) &#10;          { &#10;              VariableInterface vi = vci.getVariable(&quot;Case-Events&quot;); &#10;              docCaseEvent = (Document)vi.getValue();  &#10;              VariableInterface vi = vci.getVariable(&quot;Case-AEEvents&quot;); &#10;              docAEEvent = (Document)vi.getValue(); &#10;          } &#10;      } &#10;      catch (DocVariableException dve) &#10;      { &#10;          loggerE.error(&quot;\n Error in Run Script mapCaseEventSeqAndAEEventSeqToObligation for CaseEvent-And-AEEvent-To-Obligations Mapper&quot;);&#10;      } &#10;&#10;        List paramsObligation;&#10;        try {&#10;            paramsObligation = XPath.selectNodes(doc, &quot;//Obligation&quot;);&#10;&#10;            Iterator it = paramsObligation.iterator();&#10;            while(it.hasNext()) {&#10;                Element currentElement = (Element) it.next();&#10;&#10;                if(currentElement instanceof Element) {&#10;&#10;                    Element paramsCaseEventSeq = (Element) XPath.selectSingleNode(currentElement, &quot;./EventSeq&quot;);    &#10;                    Element paramsAEEventSeq = (Element) XPath.selectSingleNode(currentElement, &quot;./AEEventSeq&quot;);                   &#10;                    &#10;                    if(paramsCaseEventSeq != null &amp;&amp; paramsCaseEventSeq.getText() != null &amp;&amp; (!paramsCaseEventSeq.getText().equals(&quot;&quot;))) {&#10;&#10;                    String ceIdStr = paramsCaseEventSeq.getText();&#10;&#10;                        Attribute mappedAttribute = (Attribute) XPath.selectSingleNode(docCaseEvent, &quot;//CaseEvent[EventSequence =&quot; +ceIdStr+ &quot;]/EventSequence/@newSequenceNumber&quot;);&#10;&#10;    &#9;&#9;&#9;if(mappedAttribute != null) {&#10;                            paramsCaseEventSeq.setText(mappedAttribute.getValue());&#10;                        } else {&#10;                            throw new RuntimeException(&quot;Obligation - Case Event Sequence has not been mapped for &quot; + paramsCaseEventSeq.getText());&#10;                        }&#10;                            &#10;                    } &#10;                    &#10;                    if(paramsAEEventSeq != null &amp;&amp; paramsAEEventSeq.getText() != null &amp;&amp; (!paramsAEEventSeq.getText().equals(&quot;&quot;))) {&#10;&#10;                    String aeIdStr = paramsAEEventSeq.getText();&#10;&#10;                        Attribute mappedAttribute = (Attribute) XPath.selectSingleNode(docAEEvent, &quot;//AEEvent[AEEventSequence =&quot; +aeIdStr+ &quot;]/AEEventSequence/@newSequenceNumber&quot;);&#10;&#10;    &#9;&#9;&#9;if(mappedAttribute != null) {&#10;                            paramsAEEventSeq.setText(mappedAttribute.getValue());&#10;                        } else {&#10;                            throw new RuntimeException(&quot;Obligation - AEEvent Sequence has not been mapped for &quot; + paramsAEEventSeq.getText());&#10;                        }&#10;                            &#10;                    } &#10;                    &#10;                }&#10;            }&#10;        } catch (JDOMException e) {&#10;            loggerE.error(&quot;Jdom Exception ErrorError in Run Script mapCaseEventSeqAndAEEventSeqToObligation for CaseEvent-And-AEEvent-To-Obligations = &quot; + e.getMessage(), e);  &#10;        }&#10;      return doc;&#9;&#10;} "/>
