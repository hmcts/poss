            <pl:application-data name="Format Request processors" type="FormatRequestProcessors" application="com.polarlake.platform.librarymodule.LibraryModuleApplication"/>
            <pl:application-data name="Server Document Variables" type="serverdocumentvariables" application="SYSTEM"/>
            <pl:application-data name="Databases" type="dbroot" application="com.polarlake.platform.databasemodule.DatabaseModuleApplication"/>
            <pl:application-data name="ScheduledEvents" type="ScheduledEvents" application="com.polarlake.scheduler.SchedulerModuleApplication">
                <pl:application-data name="Start_Legacy" type="ScheduledEvent">
                    <pl:application-data name="Case" type="Schedule">
                        <pl:application-data name="Seconds" type="property" value="*"/>
                        <pl:application-data name="Minutes" type="property" value="*"/>
