        <pl:seqlist name="Main Sups Caseman to Legacy Sequence">
            <pl:eventprocessor name="pl:interpreter" disable="false">
                <pl:parameter name="useview" value="Clean Down Transfer Errors View"/>
                <pl:parameter name="design">
                    <pl:parameter name="uid" value="595"/>
                    <pl:parameter name="alias" value="PolarLake Interpreter"/>
                </pl:parameter>
            </pl:eventprocessor>
            <pl:eventprocessor name="pl:interpreter" disable="false">
                <pl:parameter name="useview" value="Setup Process Variables View"/>
                <pl:parameter name="design">
                    <pl:parameter name="uid" value="481"/>
                    <pl:parameter name="alias" value="PolarLake Interpreter"/>
                </pl:parameter>
            </pl:eventprocessor>
            <pl:eventprocessor name="pl:printmessage" disable="false">
                <pl:parameter name="design">
                    <pl:parameter name="uid" value="473"/>
                    <pl:parameter name="alias" value="Print Message"/>
                </pl:parameter>
                <pl:parameter name="trigger" value="start"/>
                <pl:parameter name="message" value="Start {$CircuitName}"/>
                <pl:parameter name="use_log4j" value="true"/>
                <pl:parameter name="log_level" value="WARN"/>
            </pl:eventprocessor>
            <pl:eventprocessor name="pl:trap" disable="false">
                <pl:parameter name="design">
                    <pl:parameter name="uid" value="428"/>
                    <pl:parameter name="alias" value="SNMP Trap"/>
                </pl:parameter>
                <pl:parameter name="beforestart" value="Start Sups Caseman to Legacy Case Transfer Circuit"/>
                <pl:parameter name="afterstart" value=""/>
                <pl:parameter name="beforeend" value=""/>
                <pl:parameter name="afterend" value=""/>
                <pl:parameter name="host" value="{pl$SnmpHost}"/>
                <pl:parameter name="port" value="162"/>
                <pl:parameter name="version1" value="false"/>
            </pl:eventprocessor>
            <pl:eventprocessor name="pl:printmessage" disable="false">
                <pl:parameter name="design">
                    <pl:parameter name="uid" value="58"/>
                    <pl:parameter name="alias" value="Print Message"/>
                </pl:parameter>
                <pl:parameter name="trigger" value="start"/>
                <pl:parameter name="message" value="-&#10;--&gt; Start {$CircuitName}&#10;--&gt; SEQUENCE - Main Sups Caseman to Legacy Sequence&#10;--&gt; VIEW - Main Sups Caseman to Legacy View&#10;--&gt; CIRCUIT - {$CircuitName}&#10;----------------------------------------------------------------------------------"/>
                <pl:parameter name="use_log4j" value="true"/>
                <pl:parameter name="log_level" value="INFO"/>
            </pl:eventprocessor>
            <pl:eventprocessor name="pl:starttransaction" disable="false">
                <pl:parameter name="design">
                    <pl:parameter name="uid" value="13"/>
                    <pl:parameter name="alias" value="DB Start"/>
                </pl:parameter>
                <pl:parameter name="trigger" value="start"/>
                <pl:parameter name="connection" value="CasemanSups"/>
                <pl:parameter name="transaction_key" value="First"/>
                <pl:parameter name="transaction_level" value="0"/>
            </pl:eventprocessor>
            <pl:eventprocessor name="pl:sqltoxml" disable="false">
                <pl:parameter name="design">
                    <pl:parameter name="uid" value="8"/>
                    <pl:parameter name="alias" value="DB SQL"/>
                </pl:parameter>
                <pl:parameter name="transaction_key" value="First"/>
                <pl:parameter name="sql" value="select case_number from cases where transfer_status = 3"/>
                <pl:parameter name="forward_option" value="0"/>
                <pl:parameter name="sqlwarntoerror" value="false"/>
                <pl:parameter name="query" value="true"/>
                <pl:parameter name="input_mappings"/>
                <pl:parameter name="output_mappings">
                    <pl:parameter name="input schemas">
