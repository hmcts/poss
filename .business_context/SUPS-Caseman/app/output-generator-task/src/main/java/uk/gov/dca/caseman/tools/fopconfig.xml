<configuration>
	<!-- The baseDir MUST point to the directory containg sups.xml and sups.ttf -->
	<entry>
		<key>baseDir</key>
		<value>/sups</value>
	</entry>
	<fonts>
	 	<font metrics-file="sups.xml" kerning="yes" embed-file="sups.ttf">
	    	<font-triplet name="sups" style="normal" weight="normal"/>
	 	</font>
	</fonts>
</configuration>
