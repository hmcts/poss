<?xml version="1.0" encoding="UTF-8"?>
<Question xmlns:html="http://www.w3.org/TR/REC-html40" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://eds.com/questionxhtml ..\Question.xsd">
	<Id>303</Id>
	<Label>List of items of loss or damage filed?</Label>
	<ObjectName>LossDamageItemsFiled</ObjectName>
	<Html>
		<input type="checkbox" id="LossDamageItemsFiled"></input>
	</Html>
	
	<Javascript>
		<XPath>/ds/EnterVariableData/SmallTrack/lossDamageItemsFiled</XPath>
		<HintText>Check box if list of items of loss or damage is to be filed</HintText>
		<modelValue>checked: "Y", unchecked: "N"</modelValue>
		<enableOn>DirectionsTypeReqd.dataBinding</enableOn>
		<isEnabled>
		
			var val1 = Services.getValue(DirectionsTypeReqd.dataBinding);
			return( 'RDDT' == val1);
		</isEnabled>
		<logicOn>BringOrigDocs.dataBinding, DirectionsTypeReqd.dataBinding</logicOn>
		<logic>

			var val1 = Services.getValue(DirectionsTypeReqd.dataBinding);
			if(val1 != 'RDDT')
			{	Services.setValue(LossDamageItemsFiled.dataBinding, "N");
			}
		</logic>		
	</Javascript>
</Question>