<Question xmlns:html="http://www.w3.org/TR/REC-html40" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://eds.com/questionxhtml ..\Question.xsd">
	<Id>9175</Id>
	<Label>Enter the amount and terms of offer</Label>
	<ObjectName>AmountTerms</ObjectName>
	<Html>
		<input type="text" size="70" id="AmountTerms"/>
	</Html>
	<Javascript>
		<XPath>/ds/EnterVariableData/amountTerms</XPath>
		<HintText>Enter the amount and terms of offer</HintText>
		<isMandatory>return true;</isMandatory> 
	
		<enableOn>SelectLetter2.dataBinding</enableOn>
		<isEnabled>
			var val1 = Services.getValue(SelectLetter2.dataBinding);	
			return ("1" == val1 || "2" == val1 );
		</isEnabled>
		<logicOn>SelectLetter2.dataBinding</logicOn>
		<logic>
			var val1 = Services.getValue(SelectLetter2.dataBinding);
			if("1" != val1 &amp;&amp; "2" != val1  )
			{	
				Services.setValue(AmountTerms.dataBinding, "");
			}
		</logic>
	
