<?xml version="1.0" encoding="UTF-8"?>
<Question xmlns:html="http://www.w3.org/TR/REC-html40" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://eds.com/questionxhtml ..\Question.xsd">
	<Id>9157</Id>
	<Label>Enter details</Label>
	<ObjectName>DetEnclosedInst</ObjectName>
	<Html>
		<textarea id="DetEnclosedInst" rows="5" cols="80"></textarea>
	</Html>			
	<Javascript>
		<XPath>/ds/EnterVariableData/detEnclosedInst</XPath>
		<HintText>Enter details of papers enclosed and any instructions</HintText>
		<isMandatory>return true;</isMandatory>	
		<mandatoryOn>ReplyType.dataBinding</mandatoryOn>
		<enableOn>ReplyType.dataBinding</enableOn>
		<isEnabled>return ("5" == Services.getValue(ReplyType.dataBinding))</isEnabled>
		<transformToModel>return WPU.encodeLineBreaks( this, value );</transformToModel>
		<transformToDisplay>return WPU.decodeLineBreaks( this, value );</transformToDisplay>      		
		<logicOn>ReplyType.dataBinding</logicOn>
		<logic>
			if("5" != Services.getValue(ReplyType.dataBinding))
			{	
				Services.setValue(DetEnclosedInst.dataBinding, "");
			}
		</logic>		
	</Javascript>
</Question>  