<?xml version="1.0" encoding="UTF-8"?>
<Question xmlns:html="http://www.w3.org/TR/REC-html40" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://eds.com/questionxhtml ..\Question.xsd">
	<Id>306</Id>
	<Label>Who is to pay for the loss or damage?</Label>
	<ObjectName>WhoPaysLossDamage</ObjectName>
	<Html>
		<select id="WhoPaysLossDamage">
			<option value=""></option>
			<option value="CLM">Claimant</option>
			<option value="DEF">Defendant</option>
			<option value="OTH">Other</option>
		</select>
	</Html>
	
	<Javascript>
		<XPath>/ds/EnterVariableData/SmallTrack/whoPaysLossDamage</XPath>
		<HintText>Who is to pay for the loss or damage</HintText>
		<isMandatory>return true;</isMandatory>
		<enableOn>LossDamageItemsFiled.dataBinding</enableOn>
		<isEnabled>return('Y' == Services.getValue(LossDamageItemsFiled.dataBinding));</isEnabled>
		<logicOn>LossDamageItemsFiled.dataBinding</logicOn>
		<logic>
			if('Y' != Services.getValue(LossDamageItemsFiled.dataBinding))
			{	Services.setValue(WhoPaysLossDamage.dataBinding, "");
			}
		</logic>
	</Javascript>
</Question>