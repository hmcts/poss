<Question xmlns:html="http://www.w3.org/TR/REC-html40" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://eds.com/questionxhtml ..\Question.xsd">
	<Id>Q_AllPartiesFiledAQs</Id>
	<Label>Check box if All Parties Files DQs</Label>
	<ObjectName>AllPartiesFiledAQs</ObjectName>
	<Html>
		<input id="AllPartiesFiledAQs" type="checkbox"/>
	</Html>
	<Javascript>
		<XPath>/ds/var/page/OracleReportForm/AllPartiesFiledAQs</XPath>
		<ReportVariableName>EXCEPT_YORN</ReportVariableName>
		<ReportVariableValue>returnDefault(Services.getValue(AllPartiesFiledAQs.dataBinding))</ReportVariableValue>
		<ReportVariableCode>2270</ReportVariableCode>
		<HintText></HintText>
		<isMandatory>return true;</isMandatory>
		<initialise></initialise>
		<setDefault>
			Services.setValue(AllPartiesFiledAQs.dataBinding, "N");
		</setDefault>		
		<validateOn>
		</validateOn>
		<validate>
		</validate>
		<miscCode>
			AllPartiesFiledAQs.modelValue = {checked: 'Y', unchecked: 'N'};
			function returnDefault(value)
			{
				//debugger;
				if (value == null)
				{
					return "N";
				}
				else
				{
					return value;
				}
			}			
		</miscCode>
	</Javascript>
</Question>