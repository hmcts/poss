<?xml version="1.0" encoding="UTF-8"?>
<!--Question xmlns="http://eds.com/questionxhtml" xmlns:html="http://www.w3.org/TR/REC-html40" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://eds.com/questionxhtml ..\Question.xsd"-->
<Question xmlns:html="http://www.w3.org/TR/REC-html40" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://eds.com/questionxhtml ..\Question.xsd">
	<Id>Q_MaintPeriod</Id>
	<Label>Maintenance Period</Label>
	<ObjectName>MaintenancePeriod</ObjectName>
	<Html>
		<select id="MaintenancePeriod">
			<option value=""></option>
			<option value="WK">WEEKLY</option>
			<option value="FOR">FORTNIGHTLY</option>
			<option value="MTH">MONTHLY</option>
		</select>
	</Html>
	<Javascript>
		<XPath>/ds/var/page/OracleReportForm/MaintenancePeriod</XPath>
		<ReportVariableName>REPORT_VALUE_12</ReportVariableName>
		<ReportVariableValue>Services.getValue(MaintenancePeriod.dataBinding)</ReportVariableValue>
		<ReportVariableCode>9363</ReportVariableCode>
		<HintText>Select a maintenance period from the list of values</HintText>
		<mandatoryOn></mandatoryOn>
		<isMandatory>return true;</isMandatory>
		<enableOn>IsMaintenancePayment.dataBinding</enableOn>
		<isEnabled>
			var blnEnableField = Services.getValue(IsMaintenancePayment.dataBinding);
			if (blnEnableField == "Y")
			{
				return true;
			}
			else
			{
				Services.setValue(MaintenancePeriod.dataBinding, "");
				return false;
			}	
		</isEnabled>
		<setDefault></setDefault>
		<validateOn></validateOn>
		<readOnlyOn></readOnlyOn>
		<isReadOnly></isReadOnly>
		<maxLength></maxLength>	
		<logicOn></logicOn>
		<logic></logic>
		<miscCode>
		</miscCode>
		<IsQuestion></IsQuestion>
	</Javascript>
</Question>