<Question xmlns:html="http://www.w3.org/TR/REC-html40" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://eds.com/questionxhtml ..\Question.xsd">
	<Id>509</Id>
	<Label>Is the charged land debtor's address?</Label>
	<ObjectName>IsChargedLandDebtorsAdd</ObjectName>
	<Html>	
		<input type="checkbox" id="IsChargedLandDebtorsAdd"></input>
	</Html>			
	<Javascript>
		<XPath>/ds/EnterVariableData/InterimCharge/isChargedLandDebtorsAdd</XPath>
		<componentName>##label##</componentName>
		<modelValue>checked: "Y", unchecked: "N"</modelValue>
		<HintText>Check box if the charged land is debtor's address</HintText>	
		<enableOn>IsAssetChargedLand.dataBinding</enableOn>
		<isEnabled>return( 'Y' == Services.getValue(IsAssetChargedLand.dataBinding));</isEnabled>
		<logicOn>IsAssetChargedLand.dataBinding</logicOn>
		<logic>
			if( 'Y' != Services.getValue(IsAssetChargedLand.dataBinding))
			{	Services.setValue(IsChargedLandDebtorsAdd.dataBinding, "N");
			}
		</logic>				
	</Javascript>
</Question>