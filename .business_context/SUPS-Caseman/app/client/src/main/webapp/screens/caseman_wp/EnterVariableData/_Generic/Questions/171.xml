<?xml version="1.0" encoding="UTF-8"?>
<Question xmlns:html="http://www.w3.org/TR/REC-html40" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://eds.com/questionxhtml ..\Question.xsd">
	<Id>171</Id>
	<Label>Are further statements of case required?</Label>
	<ObjectName>FurtherStatementReqd</ObjectName>
	<Html>	
		<input type="checkbox" id="FurtherStatementReqd"></input>
	</Html>
	<Javascript>
		<XPath>/ds/EnterVariableData/FastTrack/furtherStatementReqd</XPath>
		<HintText>Check box if further statements of case required</HintText>
		<modelValue>checked: "Y", unchecked: "N"</modelValue>
		<Context ScreenId="CJR020">
			<enableOn>TrialDateFixed.dataBinding</enableOn>
			<isEnabled>return(TrialDateFixed.isEnabled());</isEnabled>
			<logicOn>TrialDateFixed.dataBinding</logicOn>
			<logic>
				if(!TrialDateFixed.isEnabled())
				{	Services.setValue(FurtherStatementReqd.dataBinding, "N");
				}
			</logic>
		</Context>		
	</Javascript>
</Question>