<?xml version="1.0" encoding="UTF-8"?>
<Question xmlns:html="http://www.w3.org/TR/REC-html40" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://eds.com/questionxhtml ..\Question.xsd">
	<Id>198</Id>
	<Label>Other party</Label>
	<ObjectName>ServedOnOther</ObjectName>
	<Html>	
		<input type="text" id="ServedOnOther"></input>
	</Html>
	<Javascript>
		<XPath>/ds/EnterVariableData/FastTrack/servedOnOther</XPath>
		<HintText>Enter the party or parties</HintText>
		<isMandatory>return true;</isMandatory>	
		<enableOn>ServedOn.dataBinding</enableOn>
		<isEnabled>return('OTH' == Services.getValue(ServedOn.dataBinding));</isEnabled>
		<logicOn>ServedOn.dataBinding</logicOn>
		<logic>
			if('OTH' != Services.getValue(ServedOn.dataBinding))
			{	Services.setValue(ServedOnOther.dataBinding, "");				
			}
		</logic>
		
		<Context ScreenId="CJR060">
			<HintText>Enter the party or parties e.g. claimant, defendant 1 etc</HintText>
		</Context>
	</Javascript>
</Question>