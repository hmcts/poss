<?xml version="1.0" encoding="UTF-8"?>
<Question xmlns:html="http://www.w3.org/TR/REC-html40" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://eds.com/questionxhtml ..\Question.xsd">
	<Id>272</Id>
	<Label>Details of information required</Label>
	<ObjectName>InfoDetailsReqd</ObjectName>
	<Html>	  
		<input type="text" id="InfoDetailsReqd"></input>
	</Html>
	<Javascript>
		<XPath>/ds/EnterVariableData/Allocation/infoDetailsReqd</XPath>
		<componentName>##label##</componentName>
		<HintText>Enter the details of information required</HintText>
		<mandatoryOn>InfoDetailsReqd.dataBinding</mandatoryOn>
		<isMandatory>return true;</isMandatory>
		<enableOn>InfoReqdFrom.dataBinding</enableOn>
		<isEnabled>
			var val = Services.getValue(InfoReqdFrom.dataBinding);
			return( 'CLM' == val || 'DEF' == val);
		</isEnabled>
		<logicOn>InfoReqdFrom.dataBinding</logicOn>
		<logic>
			var val = Services.getValue(InfoReqdFrom.dataBinding);
			if( 'CLM' != val &amp;&amp; 'DEF' != val)
			{	Services.setValue(InfoDetailsReqd.dataBinding, "");
			}
		</logic>	
	</Javascript>
</Question>