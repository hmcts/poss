<?xml version="1.0" encoding="UTF-8"?>
<Question xmlns:html="http://www.w3.org/TR/REC-html40" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://eds.com/questionxhtml ..\Question.xsd">
	<Id>850</Id>
	<Label>Postcode</Label>
	<ObjectName>TransPostcode</ObjectName>
	<Html>
		<input id="TransPostcode" type="text" size="8"></input>
	</Html>		
	
	<Context screenId="CJR021"><isVisible>false</isVisible></Context>	
	
	<Javascript>
		<XPath>/ds/EnterVariableData/FastTrack/transCourtAddress/Address/PostCode</XPath>		
		<isReadOnly>return true;</isReadOnly>		
		<isMandatory>return false;</isMandatory>
		<mandatoryOn>TransPostcode.dataBinding</mandatoryOn>	
		
		<Context ScreenId="CJR020">
			<enableOn>TransferCase.dataBinding</enableOn>
			<isEnabled>
				return ( 'Y' == Services.getValue(TransferCase.dataBinding));											
			</isEnabled>		
			<logicOn>TransferCase.dataBinding</logicOn>
			<logic>
				if( 'Y' != Services.getValue(TransferCase.dataBinding))
				{	Services.setValue(TransPostcode.dataBinding);
				}
			</logic>
		</Context>							
	</Javascript>
</Question>