<Question xmlns:html="http://www.w3.org/TR/REC-html40" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://eds.com/questionxhtml ..\Question.xsd">
	<Id>508</Id>
	<Label>Land Registry title number</Label>
	<ObjectName>LandRegTitleNo</ObjectName>
	<Html>	
		<input type="text" id="LandRegTitleNo"></input>
	</Html>			
	<Javascript>
		<XPath>/ds/EnterVariableData/InterimCharge/landRegTitleNo</XPath>
		<componentName>##label##</componentName>
		<isMandatory>return false;</isMandatory>
		<HintText>Enter Land Registry title number - if known</HintText>
		<enableOn>IsAssetChargedLand.dataBinding</enableOn>
		<isEnabled>return( 'Y' == Services.getValue(IsAssetChargedLand.dataBinding));</isEnabled>
		<logicOn>IsAssetChargedLand.dataBinding</logicOn>
		<logic>
			if( 'Y' != Services.getValue(IsAssetChargedLand.dataBinding))
			{	Services.setValue(LandRegTitleNo.dataBinding, "");
			}
		</logic>
	</Javascript>
</Question>