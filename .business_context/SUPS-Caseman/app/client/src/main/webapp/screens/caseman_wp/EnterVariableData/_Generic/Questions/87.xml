<?xml version="1.0" encoding="UTF-8"?>
<Question xmlns:html="http://www.w3.org/TR/REC-html40" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://eds.com/questionxhtml ..\Question.xsd">
	<Id>87</Id>
	<Label>Date order made</Label>
	<ObjectName>OrderDateMade</ObjectName>
	<Html>	  
	  <script type="text/javascript">WP_DatePickerRenderer.createInline("OrderDateMade", false);</script>
	</Html>
	<Javascript>
		<XPath>/ds/EnterVariableData/Order/date</XPath>
		<mandatoryOn>OrderDateMade.dataBinding</mandatoryOn>
		<isMandatory>return true;</isMandatory>			
		<HintText>Select or enter the date the order was made</HintText>		
		<initialise>Services.setValue(OrderDateMade.dataBinding, CaseManUtils.getSystemDate("/ds/var/form/ReferenceData/SystemDate"));</initialise>
		<validateOn>OrderDateMade.dataBinding</validateOn>
		<validate>
			//date cannot be in the future
			var isFuture = isFutureDate(Services.getValue(OrderDateMade.dataBinding));
			var err = null;
			if( true == isFuture)
			{ 	err = ErrorCode.getErrorCode("CaseMan_dateCannotBeInTheFuture_Msg");				
			}
			return err;
		</validate>
	</Javascript>
</Question>