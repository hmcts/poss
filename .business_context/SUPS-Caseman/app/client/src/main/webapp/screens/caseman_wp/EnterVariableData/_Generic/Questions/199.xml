<?xml version="1.0" encoding="UTF-8"?>
<Question xmlns:html="http://www.w3.org/TR/REC-html40" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://eds.com/questionxhtml ..\Question.xsd">
	<Id>199</Id>
	<Label>Documents relating to damage only</Label>
	<ObjectName>DamageDocs</ObjectName>
	<Html>	
		<input type="checkbox" id="DamageDocs"></input>
	</Html>
	<Javascript>
		<XPath>/ds/EnterVariableData/FastTrack/damageDocs</XPath>
		<HintText>Check box if documents relate to damage only</HintText>
		<!--isMandatory>return true;</isMandatory-->	
		<modelValue>checked: "Y", unchecked: "N"</modelValue>
		<enableOn>IsLimitedDisclosure.dataBinding</enableOn>
		<isEnabled>return('Y' == Services.getValue(IsLimitedDisclosure.dataBinding))</isEnabled>
		<logicOn>IsLimitedDisclosure.dataBinding</logicOn>
		<logic>
			if('Y' != Services.getValue(IsLimitedDisclosure.dataBinding))
			{	Services.setValue(DamageDocs.dataBinding, "N");
			}
		</logic>
		<initialise>Services.setValue(DamageDocs.dataBinding, "N");</initialise>
	</Javascript>
</Question>