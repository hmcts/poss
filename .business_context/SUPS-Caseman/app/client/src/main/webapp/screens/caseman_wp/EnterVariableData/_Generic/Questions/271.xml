<?xml version="1.0" encoding="UTF-8"?>
<Question xmlns:html="http://www.w3.org/TR/REC-html40" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://eds.com/questionxhtml ..\Question.xsd">
	<Id>271</Id>
	<Label>Date by which information is to be filed</Label>
	<ObjectName>InfoFileByDate</ObjectName>
	<Html>	  
		<script type="text/javascript">
			WP_DatePickerRenderer.createInline("InfoFileByDate");
		</script>
	</Html>
	<Javascript>
		<XPath>/ds/EnterVariableData/Allocation/infoFileByDate</XPath>
		<componentName>##label##</componentName>
		<HintText>Enter the date to file the information</HintText>		
		<mandatoryOn>InfoFileByDate.dataBinding</mandatoryOn>
		<isMandatory>return true;</isMandatory>	
		<enableOn>InfoReqdFrom.dataBinding</enableOn>
		<isEnabled>
			var val = Services.getValue(InfoReqdFrom.dataBinding);
			return( 'CLM' == val || 'DEF' == val);
		</isEnabled>
		<logicOn>InfoReqdFrom.dataBinding</logicOn>
		<logic>
			var val = Services.getValue(InfoReqdFrom.dataBinding);
			if( 'CLM' != val &amp;&amp; 'DEF' != val)
			{	Services.setValue(InfoFileByDate.dataBinding, "");
			}
		</logic>
		<validateOn>InfoFileByDate.dataBinding</validateOn>
		<validate>
			//cannot be in past : working day only
			
			var checkDate = Services.getValue(InfoFileByDate.dataBinding); 
			var err = null;
			
			if( false == isFutureDate(checkDate))
			{ 	err = ErrorCode.getErrorCode("CaseMan_dateCannotBeInThePast_Msg");
			}
			else if( isNonWorkingDate(checkDate))
		    {   err = ErrorCode.getErrorCode("CaseMan_dateNonWorkingDay_Msg"); 
		    }
			
			return err;
		</validate>	
		<!--initialise>		  	
		  	loadNonWorkingDays();
		</initialise-->
		<miscCode>
		    InfoFileByDate.weekends = false;
		</miscCode>		
	</Javascript>
</Question>