<!--Question xmlns="http://eds.com/questionxhtml" xmlns:html="http://www.w3.org/TR/REC-html40" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://eds.com/questionxhtml ..\Question.xsd"-->
<Question xmlns:html="http://www.w3.org/TR/REC-html40" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://eds.com/questionxhtml ..\Question.xsd">
	<Id>Q_OtherPartyType10</Id>
	<Label>Other Party Type</Label>
	<ObjectName>OtherPartyType10</ObjectName>
	<Html>
		<input id="OtherPartyType10" type="text" size="70"></input>
	</Html>
	<Javascript>
		<XPath>/ds/var/page/OracleReportForm/OtherPartyType10</XPath>
		<ReportVariableName>SECOND_PARTY_OTHER</ReportVariableName>
		<ReportVariableValue>Services.getValue(OtherPartyType10.dataBinding)</ReportVariableValue>
		<ReportVariableCode>2720</ReportVariableCode>
		<HintText></HintText>
		<mandatoryOn>ServiceToBeDispensedOn.dataBinding</mandatoryOn>
		<isMandatory>
			return !OtherPartyType10.isReadOnly();
		</isMandatory>
		<setDefault></setDefault>
		<validateOn></validateOn>
		<validate></validate>
		<readOnlyOn>ServiceToBeDispensedOn.dataBinding</readOnlyOn>
		<isReadOnly>
			var serviceToBeDispensedOn = Services.getValue(ServiceToBeDispensedOn.dataBinding);
			var valueTest = Services.getValue( REF_DATA_XPATH + "/PartyMakingTheApplicationList/PartyMakingTheApplication[./Description = " + ServiceToBeDispensedOn.dataBinding + "]/Value" );
			if (serviceToBeDispensedOn == "OTH" || valueTest == "OTH")
			{
				return false;
			}
			else
			{
				return true;
			}
		</isReadOnly>
		<maxLength></maxLength>
		<transformToDisplay>
			return (null != value) ? value.toUpperCase() : null;
		</transformToDisplay>
		<transformToModel>
			return (null != value) ? value.toUpperCase() : null;
		</transformToModel>
		<initialise></initialise>
		<logicOn></logicOn>
		<logic></logic>
		<miscCode></miscCode>
		<IsQuestion></IsQuestion>
	</Javascript>
</Question>