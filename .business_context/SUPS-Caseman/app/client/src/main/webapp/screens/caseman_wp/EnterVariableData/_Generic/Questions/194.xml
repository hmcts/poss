<?xml version="1.0" encoding="UTF-8"?>
<Question xmlns:html="http://www.w3.org/TR/REC-html40" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://eds.com/questionxhtml ..\Question.xsd">
	<Id>194</Id>
	<Label>Is a party directed to comply</Label>
	<ObjectName>IsPartyToComply</ObjectName>
	<Html>	
		<input type="checkbox" id="IsPartyToComply"></input>
	</Html>
	<Javascript>
		<XPath>/ds/EnterVariableData/FastTrack/isPartyToComply</XPath>
		<HintText>Check box if a party is directed to comply</HintText>
		<!--isMandatory>return false;</isMandatory-->	
		<modelValue>checked: "Y", unchecked: "N"</modelValue>
		<enableOn>IsLimitedDisclosure.dataBinding</enableOn>
		<isEnabled>return('Y' == Services.getValue(IsLimitedDisclosure.dataBinding))</isEnabled>
		<logicOn>IsLimitedDisclosure.dataBinding</logicOn>
		<logic>
			if('Y' != Services.getValue(IsLimitedDisclosure.dataBinding))
			{	Services.setValue(IsPartyToComply.dataBinding, "N");
			}
		</logic>
	</Javascript>
</Question>