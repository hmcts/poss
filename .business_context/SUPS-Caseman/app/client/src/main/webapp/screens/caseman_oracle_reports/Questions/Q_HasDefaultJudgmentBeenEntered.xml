<?xml version="1.0" encoding="UTF-8"?>
<!--Question xmlns="http://eds.com/questionxhtml" xmlns:html="http://www.w3.org/TR/REC-html40" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://eds.com/questionxhtml ..\Question.xsd"-->
<Question xmlns:html="http://www.w3.org/TR/REC-html40" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://eds.com/questionxhtml ..\Question.xsd">
	<Id>Q_HasDefaultJudgmentBeenEntered</Id>
	<Label>Check box if default Judgment has been entered</Label>
	<ObjectName>HasDefaultJudgmentBeenEntered</ObjectName>
	<Html>
		<input id="HasDefaultJudgmentBeenEntered" type="checkbox"/>
	</Html>
	<Javascript>
		<XPath>/ds/var/page/OracleReportForm/HasDefaultJudgmentBeenEntered</XPath>
		<ReportVariableName>HAS_NOT</ReportVariableName>
		<ReportVariableValue>returnDefault(Services.getValue(HasDefaultJudgmentBeenEntered.dataBinding))</ReportVariableValue>
		<ReportVariableCode>2640</ReportVariableCode>
		<HintText></HintText>
		<mandatoryOn></mandatoryOn>
		<isMandatory>return true;</isMandatory>
		<setDefault></setDefault>
		<validateOn></validateOn>
		<validate></validate>
		<readOnlyOn></readOnlyOn>
		<isReadOnly></isReadOnly>
		<maxLength></maxLength>
		<transformToDisplay></transformToDisplay>
		<transformToModel></transformToModel>
		<initialise></initialise>
		<logicOn></logicOn>
		<logic></logic>
		<miscCode>
			HasDefaultJudgmentBeenEntered.componentName = "Has default judgment been entered";
			HasDefaultJudgmentBeenEntered.modelValue = { checked: 'Y', unchecked: 'N' };
			
			HasDefaultJudgmentBeenEntered.setDefault = function()
			{
				Services.setValue(HasDefaultJudgmentBeenEntered.dataBinding, "N");
			}
			function returnDefault(value)
			{
				//debugger;
				if (value == null)
				{
					return "N";
				}
				else
				{
					return value;
				}
			}			
		</miscCode>
		<IsQuestion></IsQuestion>
	</Javascript>
</Question>