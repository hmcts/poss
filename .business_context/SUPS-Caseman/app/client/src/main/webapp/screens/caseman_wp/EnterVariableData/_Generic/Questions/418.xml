<?xml version="1.0" encoding="UTF-8"?>
<Question xmlns:html="http://www.w3.org/TR/REC-html40" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://eds.com/questionxhtml ..\Question.xsd">
	<Id>418</Id>
	<Label>Title of other party</Label>
	<ObjectName>OtherPartyTitle8</ObjectName>
	<Html>
		<input type="text" id="OtherPartyTitle8"></input>
	</Html>
	
	<Javascript>
		<XPath>/ds/EnterVariableData/SmallTrack/otherPartyTitle8</XPath>
		<HintText>Enter the other party's name</HintText>
		<isMandatory>return true;</isMandatory>
		<enableOn>AllowInspectParty.dataBinding</enableOn>
		<isEnabled>return('OTH' == Services.getValue(AllowInspectParty.dataBinding));</isEnabled>
		<logicOn>AllowInspectParty.dataBinding</logicOn>
		<logic>
			if('OTH' != Services.getValue(AllowInspectParty.dataBinding))
			{	Services.setValue(OtherPartyTitle8.dataBinding, "");
			}
		</logic>
	</Javascript>
</Question>