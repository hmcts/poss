<?xml version="1.0" encoding="UTF-8"?>
<Question xmlns:html="http://www.w3.org/TR/REC-html40" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://eds.com/questionxhtml ..\Question.xsd">
	<Id>235</Id>
	<Label>Other party</Label>
	<ObjectName>SecondPartyOther</ObjectName>
	<Html>	
		<input type="text" id="SecondPartyOther"></input>
	</Html>
	<Javascript>
		<XPath>/ds/EnterVariableData/FastTrack/secondPartyOther</XPath>
		<HintText>Enter the party e.g. claimant, defendant 1 etc.</HintText>
		<isMandatory>return true;</isMandatory>	
		<enableOn>SecondParty.dataBinding</enableOn>
		<isEnabled>return('OTH' == Services.getValue(SecondParty.dataBinding));</isEnabled>
		<logicOn>SecondParty.dataBinding</logicOn>
		<logic>
			if('OTH' != Services.getValue(SecondParty.dataBinding))
			{	Services.setValue(SecondPartyOther.dataBinding, "");
			}
		</logic>
	</Javascript>
</Question>