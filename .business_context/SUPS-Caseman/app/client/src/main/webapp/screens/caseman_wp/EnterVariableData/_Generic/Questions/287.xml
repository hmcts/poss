<?xml version="1.0" encoding="UTF-8"?>
<Question xmlns:html="http://www.w3.org/TR/REC-html40" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://eds.com/questionxhtml ..\Question.xsd">
	<Id>287</Id>
	<Label>Parties to try and agree repairs?</Label>
	<ObjectName>IsPartiesToAgreeRepairs</ObjectName>
	<Html>
		<input type="checkbox" id="IsPartiesToAgreeRepairs"></input>
	</Html>
	
	<Javascript>
		<XPath>/ds/EnterVariableData/SmallTrack/ispartiesToAgreeRepairs</XPath>
		<HintText>Check box if parties are to try to agree cost of repairs.</HintText>
		<modelValue>checked: "Y", unchecked: "N"</modelValue>
		<enableOn>BringOrigDocs.dataBinding, DirectionsTypeReqd.dataBinding</enableOn>
		<isEnabled>
			var val1 = Services.getValue(BringOrigDocs.dataBinding);			
			var val2 = Services.getValue(DirectionsTypeReqd.dataBinding);
			return( val2 == "RTA");
		</isEnabled>
		<logicOn>BringOrigDocs.dataBinding, DirectionsTypeReqd.dataBinding</logicOn>
		<logic>

			var val2 = Services.getValue(DirectionsTypeReqd.dataBinding);
			if('RTA' != val2) 
			{	Services.setValue(IsPartiesToAgreeRepairs.dataBinding, "N");
			}
		</logic>
	</Javascript>
</Question>