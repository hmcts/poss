<?xml version="1.0" encoding="UTF-8"?>
<!--Question xmlns="http://eds.com/questionxhtml" xmlns:html="http://www.w3.org/TR/REC-html40" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://eds.com/questionxhtml ..\Question.xsd"-->
<Question xmlns:html="http://www.w3.org/TR/REC-html40" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://eds.com/questionxhtml ..\Question.xsd">
	<Id>2</Id>
	<Label>Particulars enclosed</Label>
	<ObjectName>ParticularsEnclosed</ObjectName>
	
	<Context screenId="CJR186">
		<isVisible>true</isVisible>
		<Label>Are particulars of claim enclosed?</Label>
	</Context>
	<Context screenId="CJR186A">
		<isVisible>true</isVisible>
		<Label>Are particulars of claim enclosed?</Label>
	</Context>
	
	<Html>
		<input type="checkbox" name="particulars" id="ParticularsEnclosed" value="Y"/>
	</Html>
	<Javascript>
		<XPath>/ds/EnterVariableData/ParticularsEnclosed</XPath>
		<HintText>Check box if particulars of claim are enclosed</HintText>
		<isMandatory>return true;</isMandatory>
		<mandatoryOn>ParticularsEnclosed.dataBinding</mandatoryOn>
		<modelValue>checked: "Y", unchecked: "N"</modelValue>
		
		<Context ScreenId="CJR179">
			<enableOn>ClaimServedBy.dataBinding</enableOn>
			<isEnabled>return('claimant' == Services.getValue(ClaimServedBy.dataBinding));</isEnabled>
			<logicOn>ClaimServedBy.dataBinding</logicOn>		
			<logic>
				if('claimant' != Services.getValue(ClaimServedBy.dataBinding))
				{	
					// A value is only relevant if Claimant is selected so clear the data
					// when this is not the case
					Services.setValue(this.dataBinding, "N");
				}
			</logic>
		</Context>
		<Context ScreenId="CJR186">
			<enableOn>PartyServingClaim.dataBinding</enableOn>
			<isEnabled>return('CLM' == Services.getValue(PartyServingClaim.dataBinding));</isEnabled>
			<logicOn>PartyServingClaim.dataBinding</logicOn>		
			<logic>
				if('CLM' != Services.getValue(PartyServingClaim.dataBinding))
				{	Services.setValue(ParticularsEnclosed.dataBinding, "");
				}
			</logic>
		</Context>
		<Context ScreenId="CJR186A">
			<enableOn>PartyServingClaim.dataBinding</enableOn>
			<isEnabled>return('CLM' == Services.getValue(PartyServingClaim.dataBinding));</isEnabled>
			<logicOn>PartyServingClaim.dataBinding</logicOn>		
			<logic>
				if('CLM' != Services.getValue(PartyServingClaim.dataBinding))
				{	Services.setValue(ParticularsEnclosed.dataBinding, "N");
				}
			</logic>
		</Context>
	</Javascript>
</Question>




















