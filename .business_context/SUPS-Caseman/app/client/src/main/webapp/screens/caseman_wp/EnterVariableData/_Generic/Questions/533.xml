<Question xmlns:html="http://www.w3.org/TR/REC-html40" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://eds.com/questionxhtml ..\Question.xsd">
	<Id>533</Id>
	<Label>Name of hospital</Label>
	<ObjectName>HospitalName</ObjectName>
	<Html>	
		<input type="text" id="HospitalName"></input>
	</Html>			
	<Javascript>
		<XPath>/ds/EnterVariableData/Hospital/hospitalName</XPath>
		<componentName>##label##</componentName>
		<isMandatory>return true;</isMandatory>
		<HintText>Enter full name incl Hospital or Infirmary etc e.g. St Marys Infirmary</HintText>	
		
		<Context ScreenId="CJR104">
			<enableOn>DefRemandorDetnd.dataBinding</enableOn>
			<isEnabled>return( 'R' != Services.getValue(DefRemandorDetnd.dataBinding));</isEnabled>
			<logicOn>DefRemandorDetnd.dataBinding</logicOn>
			<logic>
				if( 'R' == Services.getValue(DefRemandorDetnd.dataBinding))
				{	Services.setValue(HospitalName.dataBinding, "");
				}
			</logic>	
		</Context>		
	</Javascript>
</Question>