<Question xmlns:html="http://www.w3.org/TR/REC-html40" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://eds.com/questionxhtml ..\Question.xsd">
	<Id>581</Id>
	<Label>Was the order made on notice?</Label>
	<ObjectName>OrderOnNotice</ObjectName>
	<Html>	
		<input type="checkbox" id="OrderOnNotice"></input>
	</Html>			
	<Javascript>
		<XPath>/ds/EnterVariableData/Interlocutory/orderOnNotice</XPath>
		<componentName>##label##</componentName>
		<modelValue>checked: "Y", unchecked: "N"</modelValue>
		<HintText>Check box if the order was made on notice</HintText>	
		<enableOn>OrderToProduce.dataBinding</enableOn>
		<isEnabled>return( 'N16' == Services.getValue(OrderToProduce.dataBinding));</isEnabled>
		<logicOn>OrderToProduce.dataBinding</logicOn>
		<logic>
			if( 'N16' != Services.getValue(OrderToProduce.dataBinding))
			{	Services.setValue(OrderOnNotice.dataBinding, "N");
			}
		</logic>		
		<initialise>Services.setValue(OrderOnNotice.dataBinding, "N");</initialise>
	</Javascript>
</Question>