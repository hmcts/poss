	<Id>540</Id>
	<Label>Detention period</Label>
	<ObjectName>DetentionPeriod</ObjectName>
	<Html>
		<input type="text" id="DetentionPeriod" size="5"></input>
		<select id="DetentionPeriodUnits">
			<option value=""></option>
			<option value="D">Days</option>
			<option value="M">Months</option>			
			<option value="Y">Years</option>
		</select>
	</Html>			
	<Javascript>
		<XPath>/ds/EnterVariableData/Hospital/detentionPeriod</XPath>
		<componentName>##label##</componentName>
		<isMandatory>return true;</isMandatory>
		<enableOn>DetentionPeriod.dataBinding</enableOn>
		<isEnabled>return true;</isEnabled>
		<HintText>Select the duration of detention in days, months, years etc e.g. 4 days</HintText>
		<validateOn>DetentionPeriod.dataBinding</validateOn>
		<validate>return WPU.validateInteger(Services.getValue(DetentionPeriod.dataBinding));</validate>
	
