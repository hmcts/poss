<?xml version="1.0" encoding="UTF-8"?>
<Question xmlns:html="http://www.w3.org/TR/REC-html40" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://eds.com/questionxhtml ..\Question.xsd">
	<Id>438</Id>
	<Label>Full name of officer</Label>
	<ObjectName>OfficerFullName</ObjectName>
	<Html>	
		<input type="text" id="OfficerFullName"></input>
	</Html>			
	<Javascript>
		<XPath>/ds/EnterVariableData/DisobedienceArrest/officerFullName</XPath>
		<componentName>##label##</componentName>
		<isMandatory>return true;</isMandatory>
		<HintText>Enter the full name of the officer</HintText>	
		<enableOn>IsAgainstCoOfficer.dataBinding</enableOn>
		<isEnabled>return('Y' == Services.getValue(IsAgainstCoOfficer.dataBinding));</isEnabled>
		<logicOn>IsAgainstCoOfficer.dataBinding</logicOn>
		<logic>
			if('Y' != Services.getValue(IsAgainstCoOfficer.dataBinding))
			{	Services.setValue(OfficerFullName.dataBinding, "");
			}			
		</logic>	
	</Javascript>
</Question>