<Question xmlns:html="http://www.w3.org/TR/REC-html40" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://eds.com/questionxhtml ..\Question.xsd">
	<Id>620</Id>
	<Label>Is sum invested subject to first charge</Label>
	<ObjectName>SubToFirstCharge2</ObjectName>

	<Html>	
		<input type="checkbox" id="SubToFirstCharge2"></input>
	</Html>			
	<Javascript>
		<XPath>/ds/EnterVariableData/Settlement/subToFirstCharge2</XPath>
		<componentName>##label##</componentName>
		<modelValue>checked: "Y", unchecked: "N"</modelValue>
		<HintText>Check box if the sum invested is subject to a first charge</HintText>	
		<enableOn>AppForReceiver.dataBinding</enableOn>
		<isEnabled>return('Y' == Services.getValue(AppForReceiver.dataBinding));</isEnabled>
		<logicOn>AppForReceiver.dataBinding</logicOn>
		<logic>
			if('Y' != Services.getValue(AppForReceiver.dataBinding))
			{	Services.setValue(SubToFirstCharge2.dataBinding, "N");
			}
		</logic>							
	</Javascript>
</Question>