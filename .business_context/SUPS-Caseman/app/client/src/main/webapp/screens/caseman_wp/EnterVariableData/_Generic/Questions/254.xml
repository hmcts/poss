<?xml version="1.0" encoding="UTF-8"?>
<Question xmlns:html="http://www.w3.org/TR/REC-html40" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://eds.com/questionxhtml ..\Question.xsd">
	<Id>254</Id>
	<Label>Number of days for filing</Label>
	<ObjectName>NumFilingDays</ObjectName>
	<Html>	
		<input type="text" size="3" id="NumFilingDays"></input>
	</Html>
	<Javascript>
		<XPath>/ds/EnterVariableData/FastTrack/numFilingDays</XPath>
		<HintText>Enter number of days for filing</HintText>
		<isMandatory>return true;</isMandatory>	
		<enableOn>ExpertsQDirections.dataBinding</enableOn>
		<isEnabled>return('Y' == Services.getValue(ExpertsQDirections.dataBinding));</isEnabled>
		<logicOn>ExpertsQDirections.dataBinding</logicOn>
		<logic>
			if('Y' != Services.getValue(ExpertsQDirections.dataBinding))
			{	Services.setValue(NumFilingDays.dataBinding, "");
			}
		</logic>
		<validateOn>NumFilingDays.dataBinding</validateOn>
		
		<validate>
			var val = Services.getValue(NumFilingDays.dataBinding);
			var err = WPU.validateInteger( val);
			if( null == err )
			{	if( val &lt;= 0)
				{	err = ErrorCode.getErrorCode("CaseMan_negativeAmountEntered_Msg");
				}
			}
			
			return err;
		</validate>
	</Javascript>
</Question>