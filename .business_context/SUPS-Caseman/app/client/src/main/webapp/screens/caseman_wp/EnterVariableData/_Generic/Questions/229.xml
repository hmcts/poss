<?xml version="1.0" encoding="UTF-8"?>
<Question xmlns:html="http://www.w3.org/TR/REC-html40" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://eds.com/questionxhtml ..\Question.xsd">
	<Id>229</Id>
	<Label>Is exchange simultaneous or sequential</Label>
	<ObjectName>SimOrSeqExch</ObjectName>
	<Html>	
		<select id="SimOrSeqExch">
			<option value=""></option>
			<option value="SEQ">Sequential</option>
			<option value="SIM">Simultaneous</option>
		</select>
	</Html>
	<Javascript>
		<XPath>/ds/EnterVariableData/FastTrack/simOrSeqExch</XPath>
		<HintText>Is exchange simultaneous or sequential</HintText>
		<isMandatory>return true;</isMandatory>	
		<enableOn>ExchangeReports.dataBinding</enableOn>
		<isEnabled>return('Y' == Services.getValue(ExchangeReports.dataBinding));</isEnabled>
		<logicOn>ExchangeReports.dataBinding</logicOn>
		<logic>
			if('Y' != Services.getValue(ExchangeReports.dataBinding))
			{	Services.setValue(SimOrSeqExch.dataBinding, "");
			}
		</logic>
	</Javascript>
</Question>
