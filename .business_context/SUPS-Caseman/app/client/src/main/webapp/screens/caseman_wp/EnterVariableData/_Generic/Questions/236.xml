<?xml version="1.0" encoding="UTF-8"?>
<Question xmlns:html="http://www.w3.org/TR/REC-html40" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://eds.com/questionxhtml ..\Question.xsd">
	<Id>236</Id>
	<Label>Date for service</Label>
	<ObjectName>ServiceDate_2</ObjectName>
	<Html>	
		<script type="text/javascript">
			WP_DatePickerRenderer.createInline("ServiceDate_2");
		</script>
	</Html>
	<Javascript>
		<XPath>/ds/EnterVariableData/FastTrack/serviceDate_2</XPath>
		<HintText>Enter date for service in the format DD-MON-YYYY</HintText>
		<isMandatory>return true;</isMandatory>
		<mandatoryOn>ServiceDate_2.dataBinding</mandatoryOn>
		<enableOn>SimOrSeqExch.dataBinding</enableOn>
		<isEnabled>return('SEQ' == Services.getValue(SimOrSeqExch.dataBinding));</isEnabled>	
		<logicOn>SimOrSeqExch.dataBinding</logicOn>
		<logic>
			if('SEQ' != Services.getValue(SimOrSeqExch.dataBinding))
			{	Services.setValue(ServiceDate_2.dataBinding, "");
			}
		</logic>
		<validateOn>ServiceDate_2.dataBinding</validateOn>
		<validate>
			//cannot be in past : working day only
			
			var checkDate = Services.getValue(ServiceDate_2.dataBinding); 
			var err = null;
			
			if( false == isFutureDate(checkDate))
			{ 	err = ErrorCode.getErrorCode("CaseMan_dateCannotBeInThePast_Msg");
			}
			else if( isNonWorkingDate(checkDate))
		    {   err = ErrorCode.getErrorCode("CaseMan_dateNonWorkingDay_Msg"); 
		    }
			
			return err;
		</validate>	
		<!--initialise>		  	
		  	loadNonWorkingDays();
		</initialise-->
		<miscCode>
		    ServiceDate_2.weekends = false;
		</miscCode>	
	</Javascript>
</Question>