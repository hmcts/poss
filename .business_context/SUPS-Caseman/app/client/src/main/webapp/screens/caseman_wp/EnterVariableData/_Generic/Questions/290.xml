<?xml version="1.0" encoding="UTF-8"?>
<Question xmlns:html="http://www.w3.org/TR/REC-html40" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://eds.com/questionxhtml ..\Question.xsd">
	<Id>290</Id>
	<Label>Title of other party</Label>
	<ObjectName>OtherPartyTitle1</ObjectName>
	<Html>
		<input type="text" id="OtherPartyTitle1"></input>
	</Html>
	
	<Javascript>
		<XPath>/ds/EnterVariableData/SmallTrack/otherPartyTitle1</XPath>
		<HintText>Enter the other party's name</HintText>
		<isMandatory>return true;</isMandatory>
		<enableOn>WhoFilesList.dataBinding</enableOn>
		<isEnabled>return('OTH' == Services.getValue(WhoFilesList.dataBinding));</isEnabled>
		<logicOn>WhoFilesList.dataBinding</logicOn>
		<logic>
			if('OTH' != Services.getValue(WhoFilesList.dataBinding))
			{	Services.setValue(OtherPartyTitle1.dataBinding, "");
			}
		</logic>
	</Javascript>
</Question>