<Question xmlns:html="http://www.w3.org/TR/REC-html40" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://eds.com/questionxhtml ..\Question.xsd">
	<Id>644</Id>
	<Label>Fund Number</Label>
	<ObjectName>FundNumber</ObjectName>
	<Html>	
		<input type="text" id="FundNumber"></input>
	</Html>		
	
	<Javascript>
		<XPath>/ds/EnterVariableData/InvestmentSchedule/fundNumber</XPath>
		<componentName>##label##</componentName>
		<isMandatory>return true;</isMandatory>
		<HintText>Enter the Fund Number</HintText>
		<maxLength>50</maxLength>	
		<enableOn>IsFundNumber.dataBinding</enableOn>
		<isEnabled>return('Y' == Services.getValue(IsFundNumber.dataBinding));</isEnabled>
		<logicOn>IsFundNumber.dataBinding</logicOn>		
		<logic>
			if('Y' != Services.getValue(IsFundNumber.dataBinding))
			{	Services.setValue(FundNumber.dataBinding, "");
			}
		</logic>
    	<Context ScreenId="O_9_2">
			<enableOn>FundNumber.dataBinding</enableOn>
			<isEnabled>return true;</isEnabled>
			<logicOn>FundNumber.dataBinding</logicOn>		
			<logic/>
    	</Context>
	</Javascript>
</Question>