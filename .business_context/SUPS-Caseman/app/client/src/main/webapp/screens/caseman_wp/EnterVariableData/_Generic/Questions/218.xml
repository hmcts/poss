<?xml version="1.0" encoding="UTF-8"?>
<Question xmlns:html="http://www.w3.org/TR/REC-html40" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://eds.com/questionxhtml ..\Question.xsd">
	<Id>218</Id>
	<Label>Date for agreement</Label>
	<ObjectName>AgreementDate</ObjectName>
	<Html>	
		<script type="text/javascript">
			WP_DatePickerRenderer.createInline("AgreementDate");
		</script>
	</Html>
	<Javascript>
		<XPath>/ds/EnterVariableData/FastTrack/agreementDate</XPath>
		<HintText>Enter date for agreement in the format DD-MON-YYYY</HintText>
		<isMandatory>return true;</isMandatory>	
		<mandatoryOn>AgreementDate.dataBinding</mandatoryOn>
		<enableOn>IsSingleExpert.dataBinding,IsApplyLiberty.dataBinding</enableOn>
		<isEnabled>		
			return('Y' == Services.getValue(IsSingleExpert.dataBinding) &amp;&amp;
			   		'Y' == Services.getValue(IsApplyLiberty.dataBinding));							
		</isEnabled>
		<logicOn>IsSingleExpert.dataBinding,IsApplyLiberty.dataBinding</logicOn>
		<logic>
			if('Y' != Services.getValue(IsSingleExpert.dataBinding) ||
			   	'Y' != Services.getValue(IsApplyLiberty.dataBinding))
			{	Services.setValue(AgreementDate.dataBinding, "");
			}
		</logic>
		<validateOn>AgreementDate.dataBinding</validateOn>
		<validate>
			//cannot be in past : working day only
			
			var checkDate = Services.getValue(AgreementDate.dataBinding); 
			var err = null;
			
			if( false == isFutureDate(checkDate))
			{ 	err = ErrorCode.getErrorCode("CaseMan_dateCannotBeInThePast_Msg");
			}
			else if( isNonWorkingDate(checkDate))
		    {   err = ErrorCode.getErrorCode("CaseMan_dateNonWorkingDay_Msg"); 
		    }
			
			return err;
		</validate>	
		<!--initialise>		  	
		  	loadNonWorkingDays();
		</initialise-->
		<miscCode>
		    AgreementDate.weekends = false;
		</miscCode>	
	</Javascript>
</Question>