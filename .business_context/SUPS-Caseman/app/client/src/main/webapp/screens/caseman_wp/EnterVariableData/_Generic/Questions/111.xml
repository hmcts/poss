<?xml version="1.0" encoding="UTF-8"?>
<Question xmlns:html="http://www.w3.org/TR/REC-html40" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://eds.com/questionxhtml ..\Question.xsd">
	<Id>111</Id>
	<Label>Service Address Postcode</Label>
	<ObjectName>ServiceAddressPostcode</ObjectName>
	<Html>		
		<input id="ServiceAddressPostcode" type="text" size="8"></input>
	</Html>
	
	<Context screenId="CJR083">
		<isVisible>true</isVisible>
		<Label>Third Party Postcode</Label>
	</Context>
	
	
	<Javascript>
		<XPath>/ds/EnterVariableData/Service/Address/PostCode</XPath>
		<HintText>Enter Service Address PostCode</HintText>
		<isMandatory>return false;</isMandatory>
		<enableOn>ServiceMethod.dataBinding</enableOn>
		<isEnabled>
			var val = Services.getValue(ServiceMethod.dataBinding);
			return( 'DELIV' == val || 'POST' == val || 'OTH' == val );
		</isEnabled>
		<logicOn>ServiceMethod.dataBinding</logicOn>
		<logic>
			var val = Services.getValue(ServiceMethod.dataBinding);
			if( 'DELIV' != val &amp;&amp; 'POST' != val  &amp;&amp; 'OTH' != val)
			{	Services.setValue(ServiceAddressPostcode.dataBinding, "");
			}
		</logic>
		<validateOn>ServiceAddressPostcode.dataBinding</validateOn>
		<validate>return WPU.validatePostcode(Services.getValue(ServiceAddressPostcode.dataBinding));</validate>
		
		<Context ScreenId="O_10_5">
			<enableOn>ServiceAddressPostcode.dataBinding</enableOn>					
			<isEnabled>return true;</isEnabled>
			<logicOn></logicOn>
			<logic></logic>
		</Context>
		
		<Context ScreenId="CJR073">
			<enableOn>HowDocServed.dataBinding</enableOn>					
			<isEnabled>return('NEWS' != Services.getValue(HowDocServed.dataBinding));</isEnabled>
			<logicOn>HowDocServed.dataBinding</logicOn>
			<logic>
				if('NEWS' == Services.getValue(HowDocServed.dataBinding))
				{	Services.setValue(ServiceAddressPostcode.dataBinding, "");
				}
			</logic>
			<isMandatory>return false;</isMandatory>
			<mandatoryOn>ServiceAddress2.dataBinding</mandatoryOn>
		</Context>
		<Context ScreenId="CJR090">
			<enableOn>ServiceAddress1.dataBinding</enableOn>					
			<isEnabled>return null;</isEnabled>
			<logicOn>ServiceAddress1.dataBinding</logicOn>
			<logic></logic>
			<isMandatory>return false;</isMandatory>
			<mandatoryOn>ServiceAddress2.dataBinding</mandatoryOn>
		</Context>
	</Javascript>
</Question>