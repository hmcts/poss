<?xml version="1.0" encoding="UTF-8"?>
<Question xmlns:html="http://www.w3.org/TR/REC-html40" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://eds.com/questionxhtml ..\Question.xsd">
	<Id>251</Id>
	<Label>Number of Experts Reports</Label>
	<ObjectName>ExpertRptTotal</ObjectName>
	<Html>	
		<input type="text" size="3" id="ExpertRptTotal"></input>
	</Html>
	<Javascript>
		<XPath>/ds/EnterVariableData/FastTrack/expertRptTotal</XPath>
		<HintText>Enter number of experts reports</HintText>
		<isMandatory>return true;</isMandatory>	
		<enableOn>IsExpertReport.dataBinding</enableOn>
		<isEnabled>return('Y' == Services.getValue(IsExpertReport.dataBinding));</isEnabled>
		<logicOn>IsExpertReport.dataBinding</logicOn>
		<logic>
			if('Y' != Services.getValue(IsExpertReport.dataBinding))
			{	Services.setValue(ExpertRptTotal.dataBinding, "");
			}
		</logic>
		<validateOn>ExpertRptTotal.dataBinding</validateOn>
		<validate>
			var val = Services.getValue(ExpertRptTotal.dataBinding);
			var err = WPU.validateInteger( val );
			if( null == err )
			{	if( val &lt;= 0 )
				{	err =  ErrorCode.getErrorCode("CaseMan_negativeAmountEntered_Msg"); 
				}
			}	
			return err;
		</validate>
	</Javascript>
</Question>