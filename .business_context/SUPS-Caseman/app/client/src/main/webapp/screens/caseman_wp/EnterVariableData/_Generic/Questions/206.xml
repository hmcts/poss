<?xml version="1.0" encoding="UTF-8"?>
<Question xmlns:html="http://www.w3.org/TR/REC-html40" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://eds.com/questionxhtml ..\Question.xsd">
	<Id>206</Id>
	<Label>Is witness of fact direction required?</Label>
	<ObjectName>IsWitnessOfFact</ObjectName>
	<Html>	
		<input type="checkbox" id="IsWitnessOfFact"></input>
	</Html>
	<Javascript>
		<XPath>/ds/EnterVariableData/FastTrack/isWitnessOfFact</XPath>
		<HintText>Check box if witness of fact direction is required</HintText>	
		<modelValue>checked: "Y", unchecked: "N"</modelValue>
		<Context ScreenId="CJR020">
			<enableOn>TrialDateFixed.dataBinding</enableOn>
			<isEnabled>return(TrialDateFixed.isEnabled());</isEnabled>
			<logicOn>TrialDateFixed.dataBinding</logicOn>
			<logic>
				if(!TrialDateFixed.isEnabled())
				{	Services.setValue(IsWitnessOfFact.dataBinding, "N");
				}
			</logic>
		</Context>
	</Javascript>
</Question>