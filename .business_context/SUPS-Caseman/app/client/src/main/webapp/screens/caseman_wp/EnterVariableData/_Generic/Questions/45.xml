	<Javascript>
		<XPath>/ds/EnterVariableData/JudgmentOrder/Date</XPath>
		<HintText>Enter the date the judgment order was made</HintText>
		<isMandatory>return true;</isMandatory>
		<mandatoryOn>JudgmentOrderDate.dataBinding</mandatoryOn>
		<transformToModel>
		    return transformDateToModel(value);
		</transformToModel>
		<transformToDisplay>
			if (value != null) {
				if (value.search(CaseManValidationHelper.YYYYMMDD_DATE_PATTERN) != -1) {
					return CaseManUtils.convertDateToDisplay(value); } }
			return value;
		</transformToDisplay>
		<validateOn>JudgmentOrderDate.dataBinding</validateOn>
		<validate>		  
		  var inputDate = Services.getValue(JudgmentOrderDate.dataBinding);
		  var isInFuture = isFutureDate(inputDate);
		  var err = null;
		  if (isInFuture == true) {
			err = ErrorCode.getErrorCode("CaseMan_dateCannotBeInTheFuture_Msg"); }
		  return err;		  
		</validate>
		<initialise>Services.setValue(JudgmentOrderDate.dataBinding, WPU.getEventReceiptDate());</initialise>
		
