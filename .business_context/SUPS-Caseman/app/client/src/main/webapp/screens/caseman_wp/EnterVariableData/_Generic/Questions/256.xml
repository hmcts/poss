<?xml version="1.0" encoding="UTF-8"?>
<Question xmlns:html="http://www.w3.org/TR/REC-html40" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://eds.com/questionxhtml ..\Question.xsd">
	<Id>256</Id>
	<Label>Number of days for filing</Label>
	<ObjectName>NumFilingDays_2</ObjectName>
	<Html>	
		<input type="text" size="3" id="NumFilingDays_2"></input>
	</Html>
	<Javascript>
		<XPath>/ds/EnterVariableData/FastTrack/numFilingDays_2</XPath>
		<HintText>Enter number of days for filing</HintText>
		<isMandatory>return true;</isMandatory>	
		<enableOn>ReplyDirections.dataBinding</enableOn>
		<isEnabled>return('Y' == Services.getValue(ReplyDirections.dataBinding));</isEnabled>
		<logicOn>ReplyDirections.dataBinding</logicOn>
		<logic>
			if('Y' != Services.getValue(ReplyDirections.dataBinding))
			{	Services.setValue(NumFilingDays_2.dataBinding, "");
			}
		</logic>
		<validateOn>NumFilingDays_2.dataBinding</validateOn>
		<validate>
			var val = Services.getValue(NumFilingDays_2.dataBinding);
			var err = WPU.validateInteger( val);
			if( null == err )
			{	if( val &lt;= 0)
				{	err = ErrorCode.getErrorCode("CaseMan_negativeAmountEntered_Msg");
				}
			}
			
			return err;
		</validate>
		
		
	</Javascript>
</Question>