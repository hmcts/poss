<?xml version="1.0" encoding="UTF-8"?>
<Question xmlns:html="http://www.w3.org/TR/REC-html40" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://eds.com/questionxhtml ..\Question.xsd">
	<Id>293</Id>
	<Label>Is list to be filed with copy documents?</Label>
	<ObjectName>IsListFiledWithCopy</ObjectName>
	<Html>
		<input type="checkbox" id="IsListFiledWithCopy"></input>
	</Html>
	
	<Javascript>
		<XPath>/ds/EnterVariableData/SmallTrack/isListFiledWithCopy</XPath>
		<HintText>Check box if list is to be filed with copy documents</HintText>
		<modelValue>checked: "Y", unchecked: "N"</modelValue>
		<enableOn>IsComplaintsFiledList.dataBinding</enableOn>
		<isEnabled>return('Y' == Services.getValue(IsComplaintsFiledList.dataBinding));</isEnabled>
		<logicOn>IsComplaintsFiledList.dataBinding</logicOn>
		<logic>
			if('Y' != Services.getValue(IsComplaintsFiledList.dataBinding))
			{	Services.setValue(IsListFiledWithCopy.dataBinding, "N");
			}
		</logic>
	</Javascript>
</Question>