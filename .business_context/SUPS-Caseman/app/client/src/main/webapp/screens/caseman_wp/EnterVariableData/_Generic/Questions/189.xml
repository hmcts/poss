<?xml version="1.0" encoding="UTF-8"?>
<Question xmlns:html="http://www.w3.org/TR/REC-html40" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://eds.com/questionxhtml ..\Question.xsd">
	<Id>189</Id>
	<Label>Which issue</Label>
	<ObjectName>WhichIssue</ObjectName>
	<Html>	
		<input type="text" id="WhichIssue"></input>
	</Html>
	<Javascript>
		<XPath>/ds/EnterVariableData/FastTrack/whichIssue</XPath>
		<HintText>Enter details of this issue</HintText>
		<isMandatory>return true;</isMandatory>	
		<enableOn>SpecificIssueDocs.dataBinding</enableOn>
		<isEnabled>return('Y' == Services.getValue(SpecificIssueDocs.dataBinding));</isEnabled>	
		<logicOn>SpecificIssueDocs.dataBinding</logicOn>
		<logic>
			if('Y' != Services.getValue(SpecificIssueDocs.dataBinding))
			{	Services.setValue(WhichIssue.dataBinding);
			}
		</logic>
	</Javascript>
</Question>