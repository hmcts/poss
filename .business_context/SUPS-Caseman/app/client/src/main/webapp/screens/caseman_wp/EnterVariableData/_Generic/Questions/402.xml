<?xml version="1.0" encoding="UTF-8"?>
<Question xmlns:html="http://www.w3.org/TR/REC-html40" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://eds.com/questionxhtml ..\Question.xsd">
	<Id>402</Id>
	<Label>Directions for photos been given?</Label>
	<ObjectName>PhotoDirnsGiven</ObjectName>
	<Html>
		<input type="checkbox" id="PhotoDirnsGiven"></input>
	</Html>
	
	<Javascript>
		<XPath>/ds/EnterVariableData/SmallTrack/photoDirnsGiven</XPath>
		<HintText>Check box if directions for photographs have been given</HintText>
		<modelValue>checked: "Y", unchecked: "N"</modelValue>
		<enableOn>DirectionsTypeReqd.dataBinding</enableOn>
		<isEnabled>
			var val1 = Services.getValue(DirectionsTypeReqd.dataBinding);
			return('RDDT' == val1);
			

		</isEnabled>
		<logicOn>DirectionsTypeReqd.dataBinding</logicOn>
		<logic>
			var val1 = Services.getValue(DirectionsTypeReqd.dataBinding);
						
			if('RDDT' != val1)
			{	
				Services.setValue(PhotoDirnsGiven.dataBinding, "N");
			}
		</logic>		
	</Javascript>
</Question>