<!--Question xmlns="http://eds.com/questionxhtml" xmlns:html="http://www.w3.org/TR/REC-html40" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://eds.com/questionxhtml ..\Question.xsd"-->
<Question xmlns:html="http://www.w3.org/TR/REC-html40" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://eds.com/questionxhtml ..\Question.xsd">
	<Id>CM_FMT_QUESTION_2</Id>
	<Label>End Date</Label>
	<ObjectName>Params_EndDate_Txt</ObjectName>
	<Html>
	   <script type="text/javascript">
			DatePickerRenderer.createInline("Params_EndDate_Txt", false);
	  </script>
	</Html>
	<Javascript>
		<XPath>/ds/var/page/OracleReportForm/EndDate</XPath>
		<ReportVariableName>P_END_DATE</ReportVariableName>
		<ReportVariableValue>CaseManUtils.convertDateToDisplay(Services.getValue(Params_EndDate_Txt.dataBinding))</ReportVariableValue>
		<HintText>Enter the End Date</HintText>
		<isMandatory>return true;</isMandatory>		
		<validateOn>
			Params_EndDate_Txt.dataBinding
		</validateOn>	
		<setDefault>
		</setDefault>			
		<validate>
			    var endDate = Services.getValue(Params_EndDate_Txt.dataBinding);
			    var endDateObj = CaseManUtils.isBlank(endDate) ? null : CaseManUtils.createDate(endDate);    
			    var ec = null;
			    if (endDateObj != null)
			    {
			    	ec = validateDate(endDateObj);
			    	Params_StartDate_Txt.validate();
			    }
			    return ec;		
		</validate>		
		<miscCode>
			Params_EndDate_Txt.weekends = true;	
		</miscCode>
	</Javascript>
</Question>