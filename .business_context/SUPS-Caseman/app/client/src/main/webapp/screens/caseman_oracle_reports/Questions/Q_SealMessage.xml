<?xml version="1.0" encoding="UTF-8"?>
<!--Question xmlns="http://eds.com/questionxhtml" xmlns:html="http://www.w3.org/TR/REC-html40" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://eds.com/questionxhtml ..\Question.xsd"-->
<Question xmlns:html="http://www.w3.org/TR/REC-html40" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://eds.com/questionxhtml ..\Question.xsd">
	<Id>Q_SealMessage</Id>
	<Label></Label>
	<ObjectName>SealMessage</ObjectName>
	<Html>
		<table><tr><td></td></tr></table>
		<textarea id="SealMessage" cols="75" rows="5" style="overflow:hidden"></textarea>
	</Html>
	<Javascript>
		<XPath>/ds/var/page/OracleReportForm/SealMessage</XPath>
		<ReportVariableName>SEAL</ReportVariableName>
		<ReportVariableValue>"Y"</ReportVariableValue>
		<mandatoryOn></mandatoryOn>
		<isMandatory>return false;</isMandatory>
		<readOnlyOn></readOnlyOn>
		<isReadOnly>return true;</isReadOnly>
		<initialise>
			var order = Services.getValue(OUTPUT_ORDER_XPATH);
			var sealMessage = "Please note that an electronic seal will automatically be applied to this document (" + order + ") prior to printing. Please therefore check that all information is correct before selecting to print this document.";
			Services.setValue(SealMessage.dataBinding, sealMessage);
		</initialise>
		<IsQuestion></IsQuestion>
	</Javascript>
</Question>