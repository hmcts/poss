<?xml version="1.0" encoding="UTF-8"?>
<Question xmlns:html="http://www.w3.org/TR/REC-html40" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://eds.com/questionxhtml ..\Question.xsd">
	<Id>403</Id>
	<Label>Direction regarding video evidence?</Label>
	<ObjectName>VideoEvidenceDirns</ObjectName>
	<Html>
		<input type="checkbox" id="VideoEvidenceDirns"></input>
	</Html>
	
	<Javascript>
		<XPath>/ds/EnterVariableData/SmallTrack/videoEvidenceDirns</XPath>
		<HintText>Check box if direction regarding video evidence have been given</HintText>
		<modelValue>checked: "Y", unchecked: "N"</modelValue>
		<enableOn>DirectionsTypeReqd.dataBinding</enableOn>
		<isEnabled>
			var val1 = Services.getValue(DirectionsTypeReqd.dataBinding);
			return('HW' == val1);
			
		</isEnabled>
		<logicOn>DirectionsTypeReqd.dataBinding</logicOn>
		<logic>
			var val1 = Services.getValue(DirectionsTypeReqd.dataBinding);

			if('HW' != val1)
			{	Services.setValue(VideoEvidenceDirns.dataBinding, "N");
			}
		</logic>		
	</Javascript>
</Question>