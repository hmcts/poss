<?xml version="1.0" encoding="UTF-8"?>
<Question xmlns:html="http://www.w3.org/TR/REC-html40" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://eds.com/questionxhtml ..\Question.xsd">
	<Id>476</Id>
	<Label>Date of interim Third Party order?</Label>
	<ObjectName>ThirdPartyOrderDate</ObjectName>
	<Html>	
		<script type="text/javascript">
			WP_DatePickerRenderer.createInline("ThirdPartyOrderDate");
		</script>
	</Html>			
	<Javascript>
		<XPath>/ds/EnterVariableData/HardshipPayment/thirdPartyOrderDate</XPath>
		<componentName>##label##</componentName>
		<isMandatory>return true;</isMandatory>
		<HintText>Enter the date in the format DD-MON-YYYY</HintText>
		<validateOn>ThirdPartyOrderDate.dataBinding</validateOn>
		<validate>return isWorkingDayInPast(Services.getValue(ThirdPartyOrderDate.dataBinding));</validate>	
		<miscCode>ThirdPartyOrderDate.weekends = false;</miscCode>		
	</Javascript>
</Question>