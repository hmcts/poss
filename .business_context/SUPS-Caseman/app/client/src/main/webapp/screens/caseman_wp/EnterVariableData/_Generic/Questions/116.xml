<?xml version="1.0" encoding="UTF-8"?>
<Question xmlns:html="http://www.w3.org/TR/REC-html40" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://eds.com/questionxhtml ..\Question.xsd">
	<Id>116</Id>
	<Label>Other type of address</Label>
	<ObjectName>OtherAddressType</ObjectName>
	<Html>		
		<input type="text" id="OtherAddressType"></input>
	</Html>
	<Javascript>
		<XPath>/ds/EnterVariableData/Service/otherAddressType</XPath>
		<HintText>Enter the address of other types</HintText>
		<isMandatory>return true;</isMandatory>
		<enableOn>PartyAddressType.dataBinding</enableOn>
		<isEnabled>return('OTH' == Services.getValue(PartyAddressType.dataBinding));</isEnabled>
		<logicOn>PartyAddressType.dataBinding</logicOn>
		<logic>
			if('OTH' != Services.getValue(PartyAddressType.dataBinding))
			{	Services.setValue(OtherAddressType.dataBinding,"");
			}
		</logic>
	</Javascript>
</Question>