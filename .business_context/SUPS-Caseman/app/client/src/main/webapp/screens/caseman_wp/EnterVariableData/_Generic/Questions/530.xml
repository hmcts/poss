<Question xmlns:html="http://www.w3.org/TR/REC-html40" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://eds.com/questionxhtml ..\Question.xsd">
	<Id>530</Id>
	<Label>Has individual been named?</Label>
	<ObjectName>IsNamedIndividual</ObjectName>
	<Html>	
		<input type="checkbox" id="IsNamedIndividual"></input>
	</Html>			
	<Javascript>
		<XPath>/ds/EnterVariableData/Guardianship/isNamedIndividual</XPath>
		<componentName>##label##</componentName>
		<modelValue>checked: "Y", unchecked: "N"</modelValue>
		<HintText>Check box if the individual has  been named</HintText>
		<initialise>Services.setValue(IsNamedIndividual.dataBinding, "N");			
		</initialise>			
	</Javascript>
</Question>