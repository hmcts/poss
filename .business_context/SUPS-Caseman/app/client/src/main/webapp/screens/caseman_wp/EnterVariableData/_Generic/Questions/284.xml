<?xml version="1.0" encoding="UTF-8"?>
<Question xmlns:html="http://www.w3.org/TR/REC-html40" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://eds.com/questionxhtml ..\Question.xsd">
	<Id>284</Id>
	<Label>Are documents to be served and filed?</Label>
	<ObjectName>IsServeFileDocs</ObjectName>
	<Html>
		<input type="checkbox" id="IsServeFileDocs"></input>
	</Html>
	
	<Javascript>
		<XPath>/ds/EnterVariableData/SmallTrack/isServeFileDocs</XPath>
		<HintText>Check box if documents are to be served and filed at court</HintText>
		<modelValue>checked: "Y", unchecked: "N"</modelValue>
		<enableOn>DirectionsTypeReqd.dataBinding</enableOn>
		<isEnabled>
		var dtr = Services.getValue(DirectionsTypeReqd.dataBinding);

		return( "" != dtr &amp;&amp; 'SPEC' != dtr);
		</isEnabled>
		<logicOn>DirectionsTypeReqd.dataBinding</logicOn>
		<logic>
			if('SPEC' == Services.getValue(DirectionsTypeReqd.dataBinding))
			{	Services.setValue(IsServeFileDocs.dataBinding, "N");
			}
		</logic>
	</Javascript>
</Question>