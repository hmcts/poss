	<Id>169</Id>
	<Label>Are further directions given?</Label>
	<ObjectName>FurtherDirections</ObjectName>
	<Html>	
		<input type="checkbox" id="FurtherDirections"></input>
	</Html>
	<Javascript>
		<XPath>/ds/EnterVariableData/FastTrack/furtherDirections</XPath>
		<HintText>Check box if further directions are given</HintText>		
		<modelValue>checked: "Y", unchecked: "N"</modelValue>
		<isEnabled>return true;</isEnabled>
		<initialise>Services.setValue(FurtherDirections.dataBinding, "N");</initialise>
	</Javascript>
