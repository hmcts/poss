<Question xmlns:html="http://www.w3.org/TR/REC-html40" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://eds.com/questionxhtml ..\Question.xsd">
	<Id>413</Id>
	<Label>Title of other party</Label>
	<ObjectName>OtherPartyTitle7</ObjectName>
	<Html>
		<input type="text" id="OtherPartyTitle7"></input>
	</Html>
	
	<Javascript>
		<XPath>/ds/EnterVariableData/SmallTrack/otherPartyTitle7</XPath>
		<HintText>Enter the other party's name</HintText>
		<mandatoryOn>WhoIsServed.dataBinding</mandatoryOn>		
		<isMandatory>return true;</isMandatory>		
		<enableOn>WhoIsServed.dataBinding</enableOn>
		<isEnabled>return('OTH' == Services.getValue(WhoIsServed.dataBinding));</isEnabled>
		<logicOn>WhoIsServed.dataBinding</logicOn>
		<logic>
			if('OTH' != Services.getValue(WhoIsServed.dataBinding))
			{	Services.setValue(OtherPartyTitle7.dataBinding, "");
			}
		</logic>
	</Javascript>
