	<Id>25</Id>
	<Label>Hearing attendees</Label>
	<ObjectName>HearingAttendees</ObjectName>
	<Html>	  
		<script type="text/javascript">HearingAttendeesRenderer.createInline("HearingAttendees" );</script>	
	</Html>
		<Javascript>
		<XPath>/ds/EnterVariableData/Hearing/Attendees</XPath>
		<componentName>Hearing attendees</componentName>
		<HintText>Select hearing attendees from list</HintText>
		<isMandatory>return false;</isMandatory>
		
		<Context ScreenId="CJR083">
			<enableOn>IsNewN79AsReqd.dataBinding</enableOn>
			<isEnabled>
				if(IsNewN79AsReqd.isEnabled())
				{  	if( 'Y' == Services.getValue(IsNewN79AsReqd.dataBinding))
					{	return true;
					}
					return false;
				}
				return true;
			</isEnabled>		
			<logicOn>IsNewN79AsReqd.dataBinding</logicOn>
			<logic>
				if( IsNewN79AsReqd.isEnabled() &amp;&amp; 'Y' != Services.getValue(IsNewN79AsReqd.dataBinding))
				{	Services.setValue(HearingAttendees.dataBinding, "");
				}
			</logic>
		</Context>
        
        		
		<Context ScreenId="O_10_7">
			<isMandatory>return false;</isMandatory>
		</Context>
		
