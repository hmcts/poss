<?xml version="1.0" encoding="UTF-8"?>
<Question xmlns:html="http://www.w3.org/TR/REC-html40" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://eds.com/questionxhtml ..\Question.xsd">
	<Id>405</Id>
	<Label>Have special directions been given?</Label>
	<ObjectName>IsSpecialDirns</ObjectName>
	<Html>
		<input type="checkbox" id="IsSpecialDirns"></input>
	</Html>
	
	<Javascript>
		<XPath>/ds/EnterVariableData/SmallTrack/isSpecialDirns</XPath>
		<HintText>Check box if special directions required</HintText>
		<modelValue>checked: "Y", unchecked: "N"</modelValue>
		<enableOn>DirectionsTypeReqd.dataBinding</enableOn>
		<isEnabled>
			var val1 = Services.getValue(DirectionsTypeReqd.dataBinding);
			return('SPEC' != val1 &amp;&amp; 'SD' != val1);
		</isEnabled>
		<logicOn>DirectionsTypeReqd.dataBinding</logicOn>
		<logic>
			var val1 = Services.getValue(DirectionsTypeReqd.dataBinding);
			
			if('SPEC' == val1 || 'SD' == val1)
			{	Services.setValue(IsSpecialDirns.dataBinding, "N");
			}
		</logic>
	</Javascript>
</Question>