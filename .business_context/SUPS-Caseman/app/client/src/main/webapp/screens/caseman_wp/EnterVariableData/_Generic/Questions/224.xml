<?xml version="1.0" encoding="UTF-8"?>
<Question xmlns:html="http://www.w3.org/TR/REC-html40" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://eds.com/questionxhtml ..\Question.xsd">
	<Id>224</Id>
	<Label>Is there date for filing Experts Report?</Label>
	<ObjectName>IsExpertsReportDate</ObjectName>
	<Html>	
		<input type="checkbox" id="IsExpertsReportDate"></input>
	</Html>
	<Javascript>
		<XPath>/ds/EnterVariableData/FastTrack/isExpertsReportDate</XPath>
		<HintText>Check box if there is a date for filing expert's report</HintText>
		<isMandatory>return true;</isMandatory>	
		<modelValue>checked: "Y", unchecked: "N"</modelValue>
		<enableOn>IsSingleExpert.dataBinding</enableOn>
		<isEnabled>return('Y' == Services.getValue(IsSingleExpert.dataBinding));</isEnabled>
		<logicOn>IsSingleExpert.dataBinding</logicOn>
		<logic>
			if('Y' != Services.getValue(IsSingleExpert.dataBinding))
			{	Services.setValue(IsExpertsReportDate.dataBinding, "N");
			}
		</logic>
	</Javascript>
</Question>