<?xml version="1.0" encoding="UTF-8"?>
<Question xmlns:html="http://www.w3.org/TR/REC-html40" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://eds.com/questionxhtml ..\Question.xsd">
	<Id>137</Id>
	<Label>Affidavit postcode</Label>
	<ObjectName>AffidavitAddLn6</ObjectName>
	<Html>		
	<input id="AffidavitAddLn6" type="text" size="8"></input>
	</Html>
	<Javascript>
      <XPath>/ds/EnterVariableData/Affidavit/Address/PostCode</XPath>
      <componentName>Affidavit Address Postcode</componentName>
		<HintText>Enter deponent postcode</HintText>
        <mandatoryOn>AffidavitAddLn6.dataBinding</mandatoryOn> 
         <isMandatory>return false;</isMandatory>     
        <isEnabled>return true;</isEnabled>  
		<validate>
			var value = Services.getValue(AffidavitAddLn6.dataBinding);
	
			if(!CaseManValidationHelper.validatePostCode(value)) {
				return ErrorCode.getErrorCode("CaseMan_invalidPostcodeFormat_Msg");
			}
			return null;					
		</validate>
	</Javascript>
</Question>