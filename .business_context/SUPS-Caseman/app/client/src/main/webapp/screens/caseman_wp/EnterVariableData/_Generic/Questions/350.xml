<?xml version="1.0" encoding="UTF-8"?>
<Question xmlns:html="http://www.w3.org/TR/REC-html40" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://eds.com/questionxhtml ..\Question.xsd">
	<Id>350</Id>
	<Label>Date costs to be paid</Label>
	<ObjectName>DateCostPaid</ObjectName>
	<Html>
		<script type="text/javascript">
			WP_DatePickerRenderer.createInline("DateCostPaid");
		</script>
	</Html>
	<Context screenId="N33"><isVisible>false</isVisible></Context>				
	<Javascript>
		<XPath>/ds/EnterVariableData/PossessionOrder/dateCostPaid</XPath>
		<componentName>##label##</componentName>
		<isMandatory>return true;</isMandatory>
		<HintText>Enter the date costs must be paid by in the format DD-MMM-YYYY</HintText>	
		<validateOn>DateCostPaid.dataBinding</validateOn>
		<validate>return isWorkingDayInFuture(Services.getValue(DateCostPaid.dataBinding));</validate>	
		<enableOn>CostType2.dataBinding</enableOn>
		<isEnabled>return('F' == Services.getValue(CostType2.dataBinding));</isEnabled>
		<logicOn>CostType2.dataBinding</logicOn>
		<logic>
			if('F' != Services.getValue(CostType2.dataBinding))
			{	Services.setValue(DateCostPaid.dataBinding, "");
			}
		</logic>
		<miscCode>DateCostPaid.weekends = false;</miscCode>
	</Javascript>
</Question>