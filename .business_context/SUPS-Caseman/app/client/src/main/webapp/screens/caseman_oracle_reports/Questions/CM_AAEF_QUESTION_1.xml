<!--Question xmlns="http://eds.com/questionxhtml" xmlns:html="http://www.w3.org/TR/REC-html40" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://eds.com/questionxhtml ..\Question.xsd"-->
<Question xmlns:html="http://www.w3.org/TR/REC-html40" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://eds.com/questionxhtml ..\Question.xsd">
	<Id>CM_AAEF_QUESTION_1</Id>
	<Label>Start Date</Label>
	<ObjectName>StartDate</ObjectName>
	<Html>
		<script type="text/javascript">
			DatePickerRenderer.createInline("StartDate", true);
		</script>
	</Html>
	<Javascript>
		<XPath>/ds/var/page/OracleReportForm/StartDate</XPath>
		<ReportVariableName>P_START_DATE</ReportVariableName>
		<ReportVariableValue>CaseManUtils.convertDateToDisplay(Services.getValue(StartDate.dataBinding))</ReportVariableValue>
		<HintText>Enter the Start Date</HintText>
		<isMandatory>return false;</isMandatory>
		<initialise></initialise>
		<setDefault>
		</setDefault>		
		<validateOn>StartDate.dataBinding, EndDate.dataBinding</validateOn>
		<validate>
				var ec = validateStartDate(StartDate, EndDate);
			    return ec;
		</validate>
		<miscCode>
			Status_RunReportButton.validationList = ["StartDate", "EndDate"];
			StartDate.weekends = true;
		</miscCode>
	</Javascript>
</Question>