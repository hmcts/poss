<Question xmlns:html="http://www.w3.org/TR/REC-html40" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://eds.com/questionxhtml ..\Question.xsd">
	<Id>9018</Id>
	<Label>Order to be served on Official Receiver</Label>
	<ObjectName>servedOnOR</ObjectName>
	<Html>
		<input type="checkbox" id="servedOnOR"></input>
	</Html>
	<Javascript>
        <XPath>/ds/EnterVariableData/servedOnOR</XPath>
        <HintText>Check box if order is to be served on Official Receiver</HintText>
		<modelValue>checked: "Y", unchecked: "N"</modelValue>	
        <isEnabled>return true;</isEnabled>
        <enableOn>servedOnOR.dataBinding</enableOn>
        <initialise>
        // Default: No
        Services.setValue(servedOnOR.dataBinding, "N");
        </initialise>        
	</Javascript>
