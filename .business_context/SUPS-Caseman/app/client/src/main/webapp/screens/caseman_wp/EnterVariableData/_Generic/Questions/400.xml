<?xml version="1.0" encoding="UTF-8"?>
<Question xmlns:html="http://www.w3.org/TR/REC-html40" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://eds.com/questionxhtml ..\Question.xsd">
	<Id>400</Id>
	<Label>Sketch plans and photos required?</Label>
	<ObjectName>SketchPlansPhotosReqd</ObjectName>
	<Html>
		<input type="checkbox" id="SketchPlansPhotosReqd"></input>
	</Html>
	
	<Javascript>
		<XPath>/ds/EnterVariableData/SmallTrack/sketchPlansPhotosReqd</XPath>
		<HintText>Check box if sketch plans and photographs are required</HintText>
		<modelValue>checked: "Y", unchecked: "N"</modelValue>

		<enableOn>DirectionsTypeReqd.dataBinding</enableOn>
		<isEnabled>
			var val1 = Services.getValue(DirectionsTypeReqd.dataBinding);
			return('RTA' == val1);
		</isEnabled>
		<logicOn>DirectionsTypeReqd.dataBinding</logicOn>
		<logic>
			var val1 = Services.getValue(DirectionsTypeReqd.dataBinding);
			if('RTA' != val1)
			{ 	
				Services.setValue(SketchPlansPhotosReqd.dataBinding, "N"); 
			}			
		</logic>
	</Javascript>
</Question>