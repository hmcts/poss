<?xml version="1.0" encoding="UTF-8"?>
<!--Question xmlns="http://eds.com/questionxhtml" xmlns:html="http://www.w3.org/TR/REC-html40" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://eds.com/questionxhtml ..\Question.xsd"-->
<Question xmlns:html="http://www.w3.org/TR/REC-html40" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://eds.com/questionxhtml ..\Question.xsd">
	<Id>Q_OrderMadeByDistrictJudge</Id>
	<Label>Check box if Order has been made by a District Judge</Label>
	<ObjectName>OrderMadeByDistrictJudge</ObjectName>
	<Html>
		<input id="OrderMadeByDistrictJudge" type="checkbox"/>
	</Html>
	<Javascript>
		<XPath>/ds/var/page/OracleReportForm/OrderMadeByDistrictJudge</XPath>
		<ReportVariableName>REPORT_VALUE_2</ReportVariableName>
		<ReportVariableValue>returnDefault(Services.getValue(OrderMadeByDistrictJudge.dataBinding))</ReportVariableValue>
		<ReportVariableCode>2190</ReportVariableCode>
		<HintText></HintText>
		<isMandatory>return true;</isMandatory>
		<initialise></initialise>
		<setDefault>
			Services.setValue(OrderMadeByDistrictJudge.dataBinding, "N");
		</setDefault>		
		<validateOn>
		</validateOn>
		<validate>
		</validate>
		<miscCode>
			OrderMadeByDistrictJudge.modelValue = {checked: 'Y', unchecked: 'N'};
			function returnDefault(value)
			{
				//debugger;
				if (value == null)
				{
					return "N";
				}
				else
				{
					return value;
				}
			}			
		</miscCode>
	</Javascript>
</Question>