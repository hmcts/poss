<Question xmlns:html="http://www.w3.org/TR/REC-html40" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://eds.com/questionxhtml ..\Question.xsd">
	<Id>173</Id>
	<Label>Other party</Label>
	<ObjectName>DocsFiledByOther</ObjectName>
	<Html>	
		<input type="text" id="DocsFiledByOther"></input>
	</Html>
	<Javascript>
		<XPath>/ds/EnterVariableData/FastTrack/docsFiledByOther</XPath>
		<HintText>Enter the party or parties</HintText>
		<isMandatory>return true;</isMandatory>	
		<enableOn>DocsFiledBy.dataBinding</enableOn>
		<isEnabled>return('OTH' == Services.getValue(DocsFiledBy.dataBinding));</isEnabled>
		<logicOn>DocsFiledBy.dataBinding</logicOn>
		<logic>
			if('OTH' != Services.getValue(DocsFiledBy.dataBinding))
			{	Services.setValue(DocsFiledByOther.dataBinding, "");
			}		
		</logic>
		
		<Context ScreenId="CJR060">
			<HintText>Enter the party or parties e.g. claimant, defendant 1 etc</HintText>
		</Context>
	</Javascript>
</Question>