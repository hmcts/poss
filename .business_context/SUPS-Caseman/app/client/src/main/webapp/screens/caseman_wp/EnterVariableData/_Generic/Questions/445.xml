<?xml version="1.0" encoding="UTF-8"?>
<Question xmlns:html="http://www.w3.org/TR/REC-html40" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://eds.com/questionxhtml ..\Question.xsd">
	<Id>445</Id>
	<Label>Date of service of N79A</Label>
	<ObjectName>N79AServiceDate</ObjectName>
	<Html>	
		<script type="text/javascript">
			WP_DatePickerRenderer.createInline("N79AServiceDate");
		</script>
	</Html>			
	<Javascript>
		<XPath>/ds/EnterVariableData/DisobedienceArrest/n79AServiceDate</XPath>
		<componentName>##label##</componentName>
		<isMandatory>return true;</isMandatory>
		<HintText>Enter date of service of N79A, in format DD-MON-YYYY</HintText>	
		<validateOn>N79AServiceDate.dataBinding</validateOn>
		<validate>
			var future = isFutureDate(Services.getValue(N79AServiceDate.dataBinding));
			var err = null;
			if( future )
			{	err = ErrorCode.getErrorCode("CaseMan_dateCannotBeInTheFuture_Msg");
			}
			return err;
		</validate>
	</Javascript>
</Question>