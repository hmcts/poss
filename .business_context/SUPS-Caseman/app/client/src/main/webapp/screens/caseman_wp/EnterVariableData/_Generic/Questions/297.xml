<?xml version="1.0" encoding="UTF-8"?>
<Question xmlns:html="http://www.w3.org/TR/REC-html40" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://eds.com/questionxhtml ..\Question.xsd">
	<Id>297</Id>
	<Label>Title of other  party</Label>
	<ObjectName>OtherPartyTitle3</ObjectName>
	<Html>
		<input type="text" id="OtherPartyTitle3"></input>
	</Html>
	
	<Javascript>
		<XPath>/ds/EnterVariableData/SmallTrack/otherPartyTitle3</XPath>
		<HintText>Enter the other party's name</HintText>
		<isMandatory>return true;</isMandatory>
		<enableOn>WhoFilesList2.dataBinding</enableOn>
		<isEnabled>return('OTH' == Services.getValue(WhoFilesList2.dataBinding));</isEnabled>
		<logicOn>WhoFilesList2.dataBinding</logicOn>
		<logic>
			if('OTH' != Services.getValue(WhoFilesList2.dataBinding))
			{	Services.setValue(OtherPartyTitle3.dataBinding, "");
			}
		</logic>
	</Javascript>
</Question>