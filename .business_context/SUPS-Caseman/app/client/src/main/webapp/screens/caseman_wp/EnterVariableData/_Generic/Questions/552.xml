<Question xmlns:html="http://www.w3.org/TR/REC-html40" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://eds.com/questionxhtml ..\Question.xsd">
	<Id>552</Id>
	<Label>Defendant brought before court immediately?</Label>
	<ObjectName>IsDefBeforeCourt</ObjectName>
	<Html>	
		<input type="checkbox" id="IsDefBeforeCourt"></input>
	</Html>			
	<Javascript>
		<XPath>/ds/EnterVariableData/ArrestWarrent/isDefBeforeCourt</XPath>
		<componentName>##label##</componentName>
		<modelValue>checked: "Y", unchecked: "N"</modelValue>
		<initialise>Services.setValue(IsDefBeforeCourt.dataBinding,"N")</initialise>
		<HintText>Check box if defendant is to be brought before the court immediately</HintText>			
	</Javascript>
</Question>