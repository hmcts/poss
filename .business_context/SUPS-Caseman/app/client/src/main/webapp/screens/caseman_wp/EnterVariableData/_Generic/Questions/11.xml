			<miscCode>
				function hearingFieldsEnabled()
				{
					var blnEnabled = true;
					var owningCourt = WPU.getCaseOwningCourt();
					var consideredApp =  Services.getValue(WhoConsidApp2.dataBinding);
					if (( owningCourt == "390" || owningCourt == "391" ) &amp;&amp; consideredApp == "C" )
					{
						blnEnabled = false;
					}
					return blnEnabled;
				}
