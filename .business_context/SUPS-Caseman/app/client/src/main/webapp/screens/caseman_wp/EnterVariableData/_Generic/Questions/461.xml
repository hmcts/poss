<?xml version="1.0" encoding="UTF-8"?>
<Question xmlns:html="http://www.w3.org/TR/REC-html40" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://eds.com/questionxhtml ..\Question.xsd">
	<Id>461</Id>
	<Label>Date of affidavit of expenses</Label>
	<ObjectName>AffidavitExpensesDate</ObjectName>
	<Html>	
		<script type="text/javascript">
			WP_DatePickerRenderer.createInline("AffidavitExpensesDate");
		</script>
	</Html>			
	<Javascript>
		<XPath>/ds/EnterVariableData/SuspCOforDisobedience/affidavitExpensesDate</XPath>
		<componentName>##label##</componentName>
		<isMandatory>return true;</isMandatory>
		<HintText>Enter the date affidavit sworn, in format DD-MMM-YYYY</HintText>	
		<validateOn>AffidavitExpensesDate.dataBinding</validateOn>
		<validate>
			var future = isFutureDate(Services.getValue(AffidavitExpensesDate.dataBinding));
			var err = null;
			if( future )
			{	err = ErrorCode.getErrorCode("CaseMan_dateCannotBeInTheFuture_Msg");
			}
			return err;
		</validate>			
		
		<Context ScreenId="CJR083">
			<enableOn>IsNewN79AsReqd.dataBinding</enableOn>
			<isEnabled>
				if(IsNewN79AsReqd.isEnabled())
				{  	if( 'Y' == Services.getValue(IsNewN79AsReqd.dataBinding))
					{	return true;
					}
					return false;
				}
				return true;
			</isEnabled>
			<logicOn>IsNewN79AsReqd.dataBinding</logicOn>
			<logic>
				if( IsNewN79AsReqd.isEnabled() &amp;&amp; 'Y' != Services.getValue(IsNewN79AsReqd.dataBinding))
				{	Services.setValue(AffidavitExpensesDate.dataBinding, "");
				}
			</logic>
		</Context>		
	</Javascript>
</Question>