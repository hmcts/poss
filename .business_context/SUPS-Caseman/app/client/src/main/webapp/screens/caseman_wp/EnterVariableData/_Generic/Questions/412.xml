<?xml version="1.0" encoding="UTF-8"?>
<Question xmlns:html="http://www.w3.org/TR/REC-html40" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://eds.com/questionxhtml ..\Question.xsd">
	<Id>412</Id>
	<Label>Who is to be served?</Label>
	<ObjectName>WhoIsServed</ObjectName>
	<Html>
		<select id="WhoIsServed">
			<option value=""></option>
			<option value="CLM">Claimant</option>
			<option value="DEF">Defendant</option>
			<option value="OTH">Other</option>
		</select>
	</Html>
	
	<Javascript>
		<XPath>/ds/EnterVariableData/SmallTrack/whoIsServed</XPath>
		<HintText>Who is to be served with list/details</HintText>
		<isMandatory>return true;</isMandatory>
		<enableOn>IsPartyToClarify.dataBinding</enableOn>
		<isEnabled>return('Y' == Services.getValue(IsPartyToClarify.dataBinding));</isEnabled>
		<logicOn>IsPartyToClarify.dataBinding</logicOn>
		<logic>
			if('Y' != Services.getValue(IsPartyToClarify.dataBinding))
			{	Services.setValue(WhoIsServed.dataBinding, "");
			}
		</logic>
	</Javascript>
</Question>