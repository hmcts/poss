<Question xmlns:html="http://www.w3.org/TR/REC-html40" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://eds.com/questionxhtml ..\Question.xsd">
	<Id>505</Id>
	<Label>Date money to be paid </Label>
	<ObjectName>PayMoneyDate</ObjectName>
	<Html>	
		<script type="text/javascript">
			WP_DatePickerRenderer.createInline("PayMoneyDate");
		</script>
	</Html>			
	<Javascript>
		<XPath>/ds/EnterVariableData/FinalThirdPartyDebt/payMoneyDate</XPath>
		<componentName>##label##</componentName>
		<isMandatory>return true;</isMandatory>
		<HintText>Enter the date in the format DD-MMM-YYYY</HintText>	
		<validateOn>PayMoneyDate.dataBinding</validateOn>
		<validate>return isInFuture(Services.getValue(PayMoneyDate.dataBinding));</validate>		
	</Javascript>
</Question>