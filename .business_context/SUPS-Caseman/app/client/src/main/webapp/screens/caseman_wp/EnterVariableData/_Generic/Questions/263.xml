<?xml version="1.0" encoding="UTF-8"?>
<Question xmlns:html="http://www.w3.org/TR/REC-html40" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://eds.com/questionxhtml ..\Question.xsd">
	<Id>263</Id>
	<Label>Listing Questionnaire Direction Made</Label>
	<ObjectName>IsLQADirnMade</ObjectName>
	<Html>	
		<input type="checkbox" id="IsLQADirnMade"></input>
	</Html>
	<Javascript>
		<XPath>/ds/EnterVariableData/FastTrack/isLQADirnMade</XPath>
		<HintText>Check box if Listing Questionnaire direction is made</HintText>
		<isMandatory>return true;</isMandatory>	
		<modelValue>checked: "Y", unchecked: "N"</modelValue>
		<Context ScreenId="CJR020">
			<enableOn>TrialDateFixed.dataBinding</enableOn>
			<isEnabled>return(TrialDateFixed.isEnabled());</isEnabled>
			<logicOn>TrialDateFixed.dataBinding</logicOn>
			<logic>
				if(!TrialDateFixed.isEnabled())
				{	Services.setValue(IsLQADirnMade.dataBinding, "N");
				}
			</logic>
		</Context>
	</Javascript>
</Question>