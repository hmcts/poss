<?xml version="1.0" encoding="UTF-8"?>
<Question xmlns:html="http://www.w3.org/TR/REC-html40" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://eds.com/questionxhtml ..\Question.xsd">
	<Id>313</Id>
	<Label>Entitlement to interest</Label>
	<ObjectName>InterestEntitlement</ObjectName>
	<Html>		
		<input type="checkbox" id="InterestEntitlement"></input>
	</Html>
	<Context screenId="CJR038"><isVisible>false</isVisible></Context>
	<Javascript>
		<XPath>/ds/EnterVariableData/DefaultCostsCert/interestEntitlement</XPath>
		<HintText>Check box if there is an entitlement to interest</HintText>						
		<modelValue>checked: "Y", unchecked: "N"</modelValue>
		
		<Context ScreenId="CJR037">
			<enableOn>WhenSumPayable.dataBinding</enableOn>
			<isEnabled>return(null != Services.getValue(WhenSumPayable.dataBinding));</isEnabled>
			<logicOn>WhenSumPayable.dataBinding</logicOn>
			<logic>
				if('FD' != Services.getValue(WhenSumPayable.dataBinding))
				{	Services.setValue(InterestEntitlement.dataBinding, "N");
				}
			</logic>
		</Context>
	</Javascript>
</Question>