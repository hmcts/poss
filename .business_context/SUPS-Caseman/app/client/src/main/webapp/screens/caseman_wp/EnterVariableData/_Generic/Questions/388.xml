<?xml version="1.0" encoding="UTF-8"?>
<Question xmlns:html="http://www.w3.org/TR/REC-html40" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://eds.com/questionxhtml ..\Question.xsd">
	<Id>388</Id>
	<Label>Name of Officer</Label>
	<ObjectName>OfficerName</ObjectName>
	<Html>	
		<input type="text" id="OfficerName"></input>
	</Html>			
	<Javascript>
		<XPath>/ds/EnterVariableData/AttendForQuestion/officerName</XPath>
		<componentName>##label##</componentName>
		<isMandatory>return true;</isMandatory>
		<HintText>Enter the name of the Officer of the judgment debtor company</HintText>	
		<enableOn>QuestionWho.dataBinding</enableOn>
		<isEnabled>
			var val = Services.getValue(QuestionWho.dataBinding);
			return('COM' == val || 'CORP' == val);
		</isEnabled>
		<logicOn>QuestionWho.dataBinding</logicOn>
		<logic>
			var val = Services.getValue(QuestionWho.dataBinding);
			if('COM' != val &amp;&amp; 'CORP' != val)
			{	Services.setValue(OfficerName.dataBinding, "");
			}
		</logic>
	</Javascript>
</Question>