<?xml version="1.0" encoding="UTF-8"?>
<Question xmlns:html="http://www.w3.org/TR/REC-html40" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://eds.com/questionxhtml ..\Question.xsd">
	<Id>335</Id>
	<Label>Start date for daily payments</Label>
	<ObjectName>DailyPaymentStartDate</ObjectName>
	<Html>
		<script type="text/javascript">
			WP_DatePickerRenderer.createInline("DailyPaymentStartDate");
		</script>
	</Html>
	
	<Context screenId="CJR053"><isVisible>false</isVisible></Context>
	<Context screenId="CJR055"><isVisible>false</isVisible></Context>
	
	<Javascript>
		<XPath>/ds/EnterVariableData/InterimCosts/PossessionOrder/dailyPaymentStartDate</XPath>
		<componentName>##label##</componentName>
		<HintText>Enter the date daily payments are to start</HintText>
		<isMandatory>return true;</isMandatory>
		<validateOn>DailyPaymentStartDate.dataBinding</validateOn>
		<validate>
			var err = null;
			if( false == isFutureDate(Services.getValue(DailyPaymentStartDate.dataBinding)))
			{	err = ErrorCode.getErrorCode("CaseMan_dateCannotBeInThePast_Msg");
			}
			return err;
		</validate>
		
		<Context ScreenId="CJR050">
			<enableOn>HasAddDailyPayments.dataBinding</enableOn>
			<isEnabled>return('Y' == Services.getValue(HasAddDailyPayments.dataBinding));</isEnabled>
			<logicOn>HasAddDailyPayments.dataBinding</logicOn>
			<logic>
				if('Y' != Services.getValue(HasAddDailyPayments.dataBinding))
				{	Services.setValue(DailyPaymentStartDate.dataBinding, "");
				}
			</logic>
			<validate></validate>
		</Context>
	</Javascript>
</Question>  