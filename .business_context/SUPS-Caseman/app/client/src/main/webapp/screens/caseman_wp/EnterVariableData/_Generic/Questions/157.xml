<?xml version="1.0" encoding="UTF-8"?>
<Question xmlns:html="http://www.w3.org/TR/REC-html40" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://eds.com/questionxhtml ..\Question.xsd">
	<Id>157</Id>
	<Label>Specialist list at RCJ</Label>
	<ObjectName>RCJSpecialistList</ObjectName>
	<Html>
		<input type="text" id="RCJSpecialistList"></input>
	</Html>
	<Javascript>
		<XPath>/ds/EnterVariableData/Transfer/rCJSpecialistList</XPath>		
		<HintText>Enter the specialist list of RCJ</HintText>
		<isMandatory>return false;</isMandatory>
		<enableOn>CaseTransferedTo.dataBinding</enableOn>
		<isEnabled>
			return('RCJ' == Services.getValue(CaseTransferedTo.dataBinding));
		</isEnabled>
		<logicOn>CaseTransferedTo.dataBinding</logicOn>
		<logic>
			if('RCJ' != Services.getValue(CaseTransferedTo.dataBinding))
			{	Services.setValue(RCJSpecialistList.dataBinding, "");
			}
		</logic>
	</Javascript>
</Question>