<?xml version="1.0" encoding="UTF-8"?>
<Question xmlns:html="http://www.w3.org/TR/REC-html40" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://eds.com/questionxhtml ..\Question.xsd">
	<Id>683</Id>
	<Label>Email Address</Label>
	<ObjectName>EmailAddress</ObjectName>
	<Html>
	   <input type="text" id="EmailAddress"></input>
	</Html>
	<Javascript>
		<XPath>/ds/EnterVariableData/Solicitor/ContactDetails/emailAddress</XPath>
		<isMandatory>return false;</isMandatory>
		<mandatoryOn>EmailAddress.dataBinding</mandatoryOn>	
		<HintText>Enter Email Address</HintText>	
		<validateOn>EmailAddress.dataBinding</validateOn>
		<validate>
			return WPU.validateEmailAddress(Services.getValue(EmailAddress.dataBinding));
		</validate>		
		<enableOn>NewAddressForService.dataBinding</enableOn>
		<isEnabled>return('ACK' == Services.getValue(NewAddressForService.dataBinding));</isEnabled>
		<logicOn>NewAddressForService.dataBinding</logicOn>
		<logic>
			if('ACK' != Services.getValue(NewAddressForService.dataBinding))
			{	Services.setValue(EmailAddress.dataBinding, "");
			}
			else if( null != solNode )
			{	var emailNode = solNode.selectSingleNode("./ContactDetails/EmailAddress")
				if( null != emailNode)
				{ Services.setValue(EmailAddress.dataBinding, XML.getNodeTextContent(emailNode ));			   
				}
			}
		</logic>
		<readOnlyOn>NewAddressForService.dataBinding</readOnlyOn>
		<isReadOnly>return areAddressFieldsReadOnly();</isReadOnly>
	</Javascript>
</Question>