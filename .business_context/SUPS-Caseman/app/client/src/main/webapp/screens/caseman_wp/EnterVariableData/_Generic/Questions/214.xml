<?xml version="1.0" encoding="UTF-8"?>
<Question xmlns:html="http://www.w3.org/TR/REC-html40" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://eds.com/questionxhtml ..\Question.xsd">
	<Id>214</Id>
	<Label>Other party</Label>
	<ObjectName>PartyToInformOther</ObjectName>
	<Html>	
		<input type="text" id="PartyToInformOther"></input>
	</Html>
	<Javascript>
		<XPath>/ds/EnterVariableData/FastTrack/partyToInformOther</XPath>
		<HintText>Enter the party or parties e.g. claimant, defendant 1 etc</HintText>
		<isMandatory>return true;</isMandatory>	
		<enableOn>PartyToInform.dataBinding</enableOn>
		<isEnabled>return('OTH' == Services.getValue(PartyToInform.dataBinding));</isEnabled>
		<logicOn>PartyToInform.dataBinding</logicOn>
		<logic>
			if('OTH' != Services.getValue(PartyToInform.dataBinding))
			{	Services.setValue(PartyToInformOther.dataBinding, "");
			}
		</logic>
	</Javascript>
</Question>