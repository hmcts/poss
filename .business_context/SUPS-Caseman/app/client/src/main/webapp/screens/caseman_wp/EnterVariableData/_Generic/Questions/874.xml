<?xml version="1.0" encoding="UTF-8"?>
<Question xmlns:html="http://www.w3.org/TR/REC-html40" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://eds.com/questionxhtml ..\Question.xsd">
	<Id>874</Id>
	<Label>Other Judge Description</Label>
	<ObjectName>OtherJudgeDesc</ObjectName>
	<Html>
		<input id="OtherJudgeDesc" type="text" maxlength="70"></input>
	</Html>
	
	<Javascript>
		<XPath>/ds/EnterVariableData/OtherJudgeDesc</XPath>
		<HintText>Other description of judge to appear in output</HintText>
		<maxLength>100</maxLength>
		<isMandatory>return true;</isMandatory>
		<enableOn>JudgeTitle.dataBinding</enableOn>
		<isEnabled>
			var blnEnabled = false;
			var judgeTitle = Services.getValue(JudgeTitle.dataBinding);
			if ( judgeTitle == 'Other' ) { blnEnabled = true; }
			return blnEnabled;
		</isEnabled>
		<logicOn>JudgeTitle.dataBinding</logicOn>
		<logic>
			var judgeTitle = Services.getValue(JudgeTitle.dataBinding);
			if ( judgeTitle != 'Other' ) { Services.setValue(OtherJudgeDesc.dataBinding, ""); }
		</logic>
	</Javascript>
</Question>