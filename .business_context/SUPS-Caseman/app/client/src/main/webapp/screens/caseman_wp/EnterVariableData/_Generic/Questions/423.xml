<?xml version="1.0" encoding="UTF-8"?>
<Question xmlns:html="http://www.w3.org/TR/REC-html40" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://eds.com/questionxhtml ..\Question.xsd">
	<Id>423</Id>
	<Label>'Unless Order' on Inspection Directions?</Label>
	<ObjectName>UOInspectDirns</ObjectName>
	<Html>
		<input type="checkbox" id="UOInspectDirns"></input>
	</Html>
	
	<Javascript>
		<XPath>/ds/EnterVariableData/SmallTrack/uOInspectDirns</XPath>
		<HintText>Check box if 'Unless Order' is attached to this part of the directions</HintText>
		<modelValue>checked: "Y", unchecked: "N"</modelValue>	
		<enableOn>IsInspectDirns.dataBinding</enableOn>
		<isEnabled>return('Y' == Services.getValue(IsInspectDirns.dataBinding));</isEnabled>
		<logicOn>IsInspectDirns.dataBinding</logicOn>
		<logic>
			if('Y' != Services.getValue(IsInspectDirns.dataBinding))
			{	Services.setValue(UOInspectDirns.dataBinding, "N");
			}
		</logic>	
	</Javascript>
</Question>