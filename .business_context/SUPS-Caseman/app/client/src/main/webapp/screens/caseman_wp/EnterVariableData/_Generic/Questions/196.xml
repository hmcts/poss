<?xml version="1.0" encoding="UTF-8"?>
<Question xmlns:html="http://www.w3.org/TR/REC-html40" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://eds.com/questionxhtml ..\Question.xsd">
	<Id>196</Id>
	<Label>Other party</Label>
	<ObjectName>PartyToComplyOther</ObjectName>
	<Html>	
		<input type="text" id="PartyToComplyOther"></input>
	</Html>
	<Javascript>
		<XPath>/ds/EnterVariableData/FastTrack/partyToComplyOther</XPath>
		<HintText>Enter the party or parties</HintText>
		<isMandatory>return true;</isMandatory>	
		<enableOn>PartyToComply.dataBinding</enableOn>
		<isEnabled>return('OTH' == Services.getValue(PartyToComply.dataBinding));</isEnabled>
		<logicOn>PartyToComply.dataBinding</logicOn>
		<logic>
			if('OTH' != Services.getValue(PartyToComply.dataBinding))
			{	Services.setValue(PartyToComplyOther.dataBinding, "");				
			}
		</logic>
		<Context ScreenId="CJR060">
			<HintText>Enter the party or parties. e.g. claimant, defendant 1 etc</HintText>
	</Context>
	</Javascript>
</Question>