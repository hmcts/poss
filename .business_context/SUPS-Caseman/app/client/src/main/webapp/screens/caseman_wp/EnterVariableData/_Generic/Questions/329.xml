<?xml version="1.0" encoding="UTF-8"?>
<Question xmlns:html="http://www.w3.org/TR/REC-html40" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://eds.com/questionxhtml ..\Question.xsd">
	<Id>329</Id>
	<Label>What is the date of possession?</Label>
	<ObjectName>PossessionDate</ObjectName>
	<Html>
		<script type="text/javascript">
			WP_DatePickerRenderer.createInline("PossessionDate");
		</script>
	</Html>
	
	<Context screenId="CJR055"><isVisible>false</isVisible></Context>
	
	<Javascript>
		<XPath>/ds/EnterVariableData/InterimCosts/PossessionOrder/possessionDate</XPath>
		<componentName>##label##</componentName>
		<HintText>Enter the possession date</HintText>
		<isMandatory>return true;</isMandatory>		
		<validateOn>PossessionDate.dataBinding</validateOn>
		<validate>
			var isValid = isFutureDate(Services.getValue(PossessionDate.dataBinding));
			var err = null;
			if( false == isValid )
			{	err = ErrorCode.getErrorCode("CaseMan_dateCannotBeInThePast_Msg");
			}
			return err;
		</validate>	
		<Context ScreenId="CJR052">					
			<validate></validate>
		</Context>
		<Context ScreenId="CJR051">					
			<validate>
				return isWorkingDayInFuture(Services.getValue(PossessionDate.dataBinding));
			</validate>
			<initialise>loadNonWorkingDays();</initialise>
			<miscCode>PossessionDate.weekends = false;</miscCode>
		</Context>	
		<Context ScreenId="CJR053">					
			<validate>
				return isWorkingDayInFuture(Services.getValue(PossessionDate.dataBinding));
			</validate>
			<initialise>loadNonWorkingDays();</initialise>
			<miscCode>PossessionDate.weekends = false;</miscCode>
		</Context>
		<Context ScreenId="CJR055">					
			<validate>
				return isWorkingDayInFuture(Services.getValue(PossessionDate.dataBinding));
			</validate>
			<initialise>loadNonWorkingDays();</initialise>
			<miscCode>PossessionDate.weekends = false;</miscCode>
		</Context>
		<Context ScreenId="CJR054">
			<HintText>Enter the possession date in the format DD-MMM-YYYY</HintText>
			<validate>return isWorkingDayInFuture(Services.getValue(PossessionDate.dataBinding));</validate>
			<miscCode>PossessionDate.weekends = false;</miscCode>
		</Context>		
	</Javascript>
</Question>     
     
    

