<?xml version="1.0" encoding="UTF-8"?>
<Question xmlns:html="http://www.w3.org/TR/REC-html40" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://eds.com/questionxhtml ..\Question.xsd">
	<Id>401</Id>
	<Label>Are photos of the work required?</Label>
	<ObjectName>PhotosWorkReqd</ObjectName>
	<Html>
		<input type="checkbox" id="PhotosWorkReqd"></input>
	</Html>
	
	<Javascript>
		<XPath>/ds/EnterVariableData/SmallTrack/photosWorkReqd</XPath>
		<HintText>Check box if photographs of the work is required?</HintText>
		<modelValue>checked: "Y", unchecked: "N"</modelValue>
		<enableOn>DirectionsTypeReqd.dataBinding</enableOn>
		<isEnabled>
			var val1 = Services.getValue(DirectionsTypeReqd.dataBinding);
			return('BDCON' == val1);
		</isEnabled>
		<logicOn>DirectionsTypeReqd.dataBinding</logicOn>
		<logic>
			var val1 = Services.getValue(DirectionsTypeReqd.dataBinding);

			if('BDCON' != val1)
			{	Services.setValue(PhotosWorkReqd.dataBinding, "N");
			}
		</logic>
	</Javascript>
</Question>