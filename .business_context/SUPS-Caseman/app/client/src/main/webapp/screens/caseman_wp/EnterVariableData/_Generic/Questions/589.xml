<Question xmlns:html="http://www.w3.org/TR/REC-html40" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://eds.com/questionxhtml ..\Question.xsd">
	<Id>589</Id>
	<Label>Deponent postcode</Label>
	<ObjectName>DeponentPostCode</ObjectName>
	<Html>	
		<input type="text" id="DeponentPostCode" size="8"></input>
	</Html>			
	<Javascript>
		<XPath>/ds/EnterVariableData/ExamDeponent/Deponent/Address/PostCode</XPath>
		<componentName>##label##</componentName>
		<isMandatory>return false;</isMandatory>
		<HintText>Enter the postcode of the deponent address</HintText>			
		<validateOn>DeponentPostCode.dataBinding</validateOn>
		<validate>return WPU.validatePostcode(Services.getValue(DeponentPostCode.dataBinding));</validate>
	</Javascript>
</Question>