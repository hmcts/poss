<?xml version="1.0" encoding="UTF-8"?>
<Question xmlns:html="http://www.w3.org/TR/REC-html40" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://eds.com/questionxhtml ..\Question.xsd">
	<Id>468</Id>
	<Label>Reason for N79a?</Label>
	<ObjectName>N79aReason</ObjectName>
	<Html>	
		<select id="N79aReason">
			<option value=""></option>
			<option value="D">Did not attend</option>
			<option value="R">Refused to be sworn</option>
			<option value="AQ">Refused to answer all questions</option>
			<option value="SQ">Refused to answer single question</option>
		</select>
	</Html>			
	<Javascript>
		<XPath>/ds/EnterVariableData/SuspCOforDisobedience/n79aReason</XPath>
		<componentName>##label##</componentName>
		<isMandatory>return true;</isMandatory>
		<HintText>Select reason for N79a</HintText>		
		
		<Context ScreenId="CJR083">
			<enableOn>IsNewN79AsReqd.dataBinding</enableOn>
			<isEnabled>
				if(IsNewN79AsReqd.isEnabled())
				{  	if( 'Y' == Services.getValue(IsNewN79AsReqd.dataBinding))
					{	return true;
					}
					return false;
				}
				return true;
			</isEnabled>
			<logicOn>IsNewN79AsReqd.dataBinding</logicOn>
			<logic>
				if( IsNewN79AsReqd.isEnabled() &amp;&amp; 'Y' != Services.getValue(IsNewN79AsReqd.dataBinding))
				{	Services.setValue(N79aReason.dataBinding, "");
				}
			</logic>
		</Context>		
	</Javascript>
</Question>