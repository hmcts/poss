<Question xmlns:html="http://www.w3.org/TR/REC-html40" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://eds.com/questionxhtml ..\Question.xsd">
	<Id>841</Id>
	<Label>Enter creditor name</Label>
	<ObjectName>EntCreditorName</ObjectName>
	<Html>
		<input id="EntCreditorName" type="text"></input>
	</Html>
	<Javascript>
		<XPath>/ds/EnterVariableData/EntCreditorName</XPath>
		<componentName>##label##</componentName>
		<HintText>Enter the name of the creditor requesting review</HintText>
		<isMandatory>return true;</isMandatory>
		<mandatoryOn>EntCreditorName.dataBinding</mandatoryOn>
		<enableOn>WhoReqRev.dataBinding</enableOn>
		<isEnabled>return( 'CRED' == Services.getValue( WhoReqRev.dataBinding ));</isEnabled>
	</Javascript>
</Question>