<?xml version="1.0" encoding="UTF-8"?>
<Question xmlns:html="http://www.w3.org/TR/REC-html40" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://eds.com/questionxhtml ..\Question.xsd">
	<Id>289</Id>
	<Label>Who is to file this list?</Label>
	<ObjectName>WhoFilesList</ObjectName>
	<Html>
		<select id="WhoFilesList">
			<option value=""></option>
			<option value="CLM">Claimant</option>
			<option value="DEF">Defendant</option>
			<option value="OTH">Other</option>
		</select>
	</Html>
	
	<Javascript>
		<XPath>/ds/EnterVariableData/SmallTrack/whoFilesList</XPath>
		<HintText>Who is to file this list - list available</HintText>
		<mandatoryOn>WhoFilesList.dataBinding</mandatoryOn>
		<isMandatory>return true;</isMandatory>
		<enableOn>IsComplaintsFiledList.dataBinding</enableOn>
		<isEnabled>return('Y' == Services.getValue(IsComplaintsFiledList.dataBinding));</isEnabled>
		<logicOn>IsComplaintsFiledList.dataBinding</logicOn>
		<logic>
			if('Y' != Services.getValue(IsComplaintsFiledList.dataBinding))
			{	Services.setValue(WhoFilesList.dataBinding, "");
			}
		</logic>
	</Javascript>
</Question>