<Question xmlns:html="http://www.w3.org/TR/REC-html40" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://eds.com/questionxhtml ..\Question.xsd">
	<Id>594</Id>
	<Label>Who attended for the Defendant</Label>
	<ObjectName>AttendedForDef</ObjectName>
	<Html>	
		<select id="AttendedForDef">
			<option value=""></option>
			<option value="CSL">Counsel</option>
			<option value="SOLS">Solicitors</option>
		</select>
	</Html>			
	<Javascript>
		<XPath>/ds/EnterVariableData/Settlement/attendedForDef</XPath>
		<componentName>##label##</componentName>
		<isMandatory>return false;</isMandatory>
		<HintText>Select who attended for the Defendant</HintText>	
		<enableOn>WasDefRep.dataBinding</enableOn>
		<isEnabled>return('Y' == Services.getValue(WasDefRep.dataBinding));</isEnabled>
		<logicOn>WasDefRep.dataBinding</logicOn>
		<logic>
			if('Y' != Services.getValue(WasDefRep.dataBinding))
			{	Services.setValue(AttendedForDef.dataBinding, "");
			}
		</logic>			
	</Javascript>
</Question>