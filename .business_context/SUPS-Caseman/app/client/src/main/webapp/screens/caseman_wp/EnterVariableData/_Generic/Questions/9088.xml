<?xml version="1.0" encoding="UTF-8"?>
<Question xmlns:html="http://www.w3.org/TR/REC-html40" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://eds.com/questionxhtml ..\Question.xsd">
	<Id>9088</Id>
	<Label>Date power of arrest ordered</Label>
	<ObjectName>PowerOfArrestDate</ObjectName>
	<Html>
		<script type="text/javascript">WP_DatePickerRenderer.createInline("PowerOfArrestDate", false);</script>
	</Html>
	<Javascript>
        <XPath>/ds/EnterVariableData/powerOfArrestDate</XPath>
		<HintText>Enter the date of power of arrest ordered</HintText>
		<isEnabled>return true;</isEnabled>   
		
	    <Context ScreenId="O_2_6">
			<initialise>Services.setValue(PowerOfArrestDate.dataBinding, WPU.getEventReceiptDate());</initialise>
            <validate>
	            // Date picker: error message “The value does not conform to a valid date format of DD-MMM-YYYY”.
	            // Validation: Date cannot be in the future      
	          	return isInPast(Services.getValue(PowerOfArrestDate.dataBinding),"false");					
			</validate>
            <mandatoryOn>PowerOfArrestDate.dataBinding</mandatoryOn>                
			<isMandatory>return true;</isMandatory>
		</Context>		
        
	</Javascript>
</Question>