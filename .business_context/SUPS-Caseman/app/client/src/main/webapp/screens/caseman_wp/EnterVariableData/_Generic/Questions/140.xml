<?xml version="1.0" encoding="UTF-8"?>
<Question xmlns:html="http://www.w3.org/TR/REC-html40" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://eds.com/questionxhtml ..\Question.xsd">
	<Id>140</Id>
	<Label>Documents to be produced</Label>
	<ObjectName>ProduceDocs</ObjectName>
	<Html>		
		<textarea id="ProduceDocs" cols="30" rows="3"></textarea>
	</Html>
	
	<Javascript>
		<XPath>/ds/EnterVariableData/Service/produceDocs</XPath>
		<HintText>Enter the documents to be produced.</HintText>
		<isMandatory>return false;</isMandatory>
		<enableOn>WProduceDocs.dataBinding</enableOn>
		<isEnabled>return('Y' == Services.getValue(WProduceDocs.dataBinding));</isEnabled>
		<logicOn>WProduceDocs.dataBinding</logicOn>
		<logic>
			if('Y' != Services.getValue(WProduceDocs.dataBinding))
			{	Services.setValue(ProduceDocs.dataBinding,"");
			}
		</logic>
		<transformToModel>return WPU.encodeLineBreaks( this, value );</transformToModel>
		<transformToDisplay>return WPU.decodeLineBreaks( this, value );</transformToDisplay>
				
		<Context ScreenId="CJR170">
			<isMandatory>return true;</isMandatory>
		</Context>
	</Javascript>
</Question>