<Question xmlns:html="http://www.w3.org/TR/REC-html40" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://eds.com/questionxhtml ..\Question.xsd">
	<Id>549</Id>
	<Label>Place of safety postcode</Label>
	<ObjectName>POSPostCode</ObjectName>
	<Html>	
		<input type="text" id="POSPostCode" size="8"></input>
	</Html>			
	<Javascript>
		<XPath>/ds/EnterVariableData/Hospital/placeOfSafety/Address/PostCode</XPath>
		<componentName>##label##</componentName>
		<isMandatory>return false;</isMandatory>
		<HintText>Enter the Place of Safety post code</HintText>	
		<enableOn>IsPlaceOfSafetyId.dataBinding</enableOn>
		<isEnabled>return( 'Y' == Services.getValue(IsPlaceOfSafetyId.dataBinding));</isEnabled>
		<logicOn>IsPlaceOfSafetyId.dataBinding</logicOn>
		<logic>
			if( 'Y' != Services.getValue(IsPlaceOfSafetyId.dataBinding))
			{	Services.setValue(POSPostCode.dataBinding, "");
			}
		</logic>	
		<validateOn>POSPostCode.dataBinding</validateOn>
		<validate>return WPU.validatePostcode(Services.getValue(POSPostCode.dataBinding));</validate>
		
	</Javascript>
</Question>