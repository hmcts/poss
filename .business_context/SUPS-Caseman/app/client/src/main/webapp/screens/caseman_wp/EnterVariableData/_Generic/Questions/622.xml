	<Id>622</Id>
	<Label>Is right to claim further costs waived</Label>
	<ObjectName>FurtherClaimWaived</ObjectName>
 
	<Html>	
		<input type="checkbox" id="FurtherClaimWaived"></input>
	</Html>			
	<Javascript>
