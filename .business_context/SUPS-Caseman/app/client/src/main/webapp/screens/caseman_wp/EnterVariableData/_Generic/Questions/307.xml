<?xml version="1.0" encoding="UTF-8"?>
<Question xmlns:html="http://www.w3.org/TR/REC-html40" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://eds.com/questionxhtml ..\Question.xsd">
	<Id>307</Id>
	<Label>Title of other party</Label>
	<ObjectName>TitleOfOtherParty</ObjectName>
	<Html>
		<input type="text" id="TitleOfOtherParty"></input>
	</Html>
	
	<Javascript>
		<XPath>/ds/EnterVariableData/SmallTrack/titleOfOtherParty</XPath>
		<HintText>Enter the party's name</HintText>
		<isMandatory>return true;</isMandatory>
		<enableOn>WhoPaysLossDamage.dataBinding</enableOn>
		<isEnabled>return('OTH' == Services.getValue(WhoPaysLossDamage.dataBinding));</isEnabled>
		<logicOn>WhoPaysLossDamage.dataBinding</logicOn>
		<logic>
			if('OTH' != Services.getValue(WhoPaysLossDamage.dataBinding))
			{	Services.setValue(TitleOfOtherParty.dataBinding, "");
			}
		</logic>
	</Javascript>
</Question>