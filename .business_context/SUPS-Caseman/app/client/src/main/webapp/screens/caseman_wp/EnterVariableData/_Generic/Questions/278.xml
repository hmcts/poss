<?xml version="1.0" encoding="UTF-8"?>
<Question xmlns:html="http://www.w3.org/TR/REC-html40" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://eds.com/questionxhtml ..\Question.xsd">
	<Id>278</Id>
	<Label>Enter the division of RCJ</Label>
	<ObjectName>DivisionRCJ</ObjectName>
	<Html>
		<input type="text" id="DivisionRCJ"></input>
	</Html>
	<Javascript>
		<XPath>/ds/EnterVariableData/MultiTrackAllocation/divisionRCJ</XPath>
		<componentName>##label##</componentName>
		<HintText>Enter the division name of Royal Court of Justice</HintText>				
		<mandatoryOn>DivisionRCJ.dataBinding</mandatoryOn>
		<isMandatory>return true;</isMandatory>
		<enableOn>ClaimTransferTo.dataBinding</enableOn>
		<isEnabled>return('RCJ' == Services.getValue(ClaimTransferTo.dataBinding));</isEnabled>
		<logicOn>ClaimTransferTo.dataBinding</logicOn>
		<logic>
			if('RCJ' != Services.getValue(ClaimTransferTo.dataBinding))
			{	Services.setValue(DivisionRCJ.dataBinding, "");
			}
		</logic>
	</Javascript>
</Question>