<?xml version="1.0" encoding="UTF-8"?>
<Question xmlns:html="http://www.w3.org/TR/REC-html40" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://eds.com/questionxhtml ..\Question.xsd">
	<Id>203</Id>
	<Label>Latest date for delivery</Label>
	<ObjectName>LatestDeliveryDate</ObjectName>
	<Html>	
		<script type="text/javascript">
			WP_DatePickerRenderer.createInline("LatestDeliveryDate");
		</script>
	</Html>
	<Javascript>
		<XPath>/ds/EnterVariableData/FastTrack/latestDeliveryDate</XPath>
		<HintText>Enter latest date for delivery in the format DD-MON-YYYY</HintText>
		<mandatoryOn>LatestDeliveryDate.dataBinding</mandatoryOn>
		<isMandatory>return true;</isMandatory>	
		<enableOn>IsDeliveryListDate.dataBinding</enableOn>
		<isEnabled>return('Y' == Services.getValue(IsDeliveryListDate.dataBinding));</isEnabled>
		<logicOn>IsDeliveryListDate.dataBinding</logicOn>
		<logic>
			if('Y' != Services.getValue(IsDeliveryListDate.dataBinding))
			{	Services.setValue(LatestDeliveryDate.dataBinding);			
			}
		</logic>
		<validateOn>LatestDeliveryDate.dataBinding</validateOn>
		<validate>
			//cannot be in past : working day only
			
			var checkDate = Services.getValue(LatestDeliveryDate.dataBinding); 
			var err = null;
			
			if( false == isFutureDate(checkDate))
			{ 	err = ErrorCode.getErrorCode("CaseMan_dateCannotBeInThePast_Msg");
			}
			else if( isNonWorkingDate(checkDate))
		    {   err = ErrorCode.getErrorCode("CaseMan_dateNonWorkingDay_Msg"); 
		    }
			
			return err;
		</validate>	
		<!--initialise>		  	
		  	loadNonWorkingDays();
		</initialise-->
		<miscCode>
		    LatestDeliveryDate.weekends = false;
		</miscCode>	
	</Javascript>
</Question>