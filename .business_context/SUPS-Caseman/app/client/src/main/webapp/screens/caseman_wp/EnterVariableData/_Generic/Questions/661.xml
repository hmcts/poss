<Question xmlns:html="http://www.w3.org/TR/REC-html40" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://eds.com/questionxhtml ..\Question.xsd">
	<Id>661</Id>
	<Label>Beneficiary postcode</Label>
	<ObjectName>BeneficiaryPostCode</ObjectName>
	<Html>	
		<input type="text" id="BeneficiaryPostCode" size="8"></input>
	</Html>		
	
	<Javascript>
		<XPath>/ds/EnterVariableData/InvestmentSchedule/Beneficiary/Address/PostCode</XPath>
		<componentName>##label##</componentName>
		<isMandatory>return false;</isMandatory>
		<HintText>Enter the postcode of Beneficiary address</HintText>	
       
		<validateOn>BeneficiaryPostCode.dataBinding</validateOn>		
		<validate>return WPU.validatePostcode(Services.getValue(BeneficiaryPostCode.dataBinding));</validate>		
	</Javascript>
</Question>