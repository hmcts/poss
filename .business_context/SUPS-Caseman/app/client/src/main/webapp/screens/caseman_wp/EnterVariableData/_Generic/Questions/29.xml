<Question xmlns:html="http://www.w3.org/TR/REC-html40" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://eds.com/questionxhtml ..\Question.xsd">
	<Id>29</Id>
	<Label>Other party making application</Label>
	<ObjectName>OtherApplicationParty</ObjectName>
	<Html>
		<input id="OtherApplicationParty"></input>		
	</Html>
	<Javascript>
		<XPath>/ds/EnterVariableData/OtherApplicationParty</XPath>
		<HintText>Enter the details about other application party</HintText>
		<enableOn>ApplicationParty.dataBinding</enableOn>
		<isEnabled>return ('APP' == Services.getValue(ApplicationParty.dataBinding));</isEnabled>
		<mandatoryOn>ApplicationParty.dataBinding</mandatoryOn>
		<isMandatory>return true;</isMandatory>
		<logicOn>ApplicationParty.dataBinding</logicOn>
		<logic>
			if('APP' != Services.getValue(ApplicationParty.dataBinding))
			{	Services.setValue(OtherApplicationParty.dataBinding);
			}
		</logic>
