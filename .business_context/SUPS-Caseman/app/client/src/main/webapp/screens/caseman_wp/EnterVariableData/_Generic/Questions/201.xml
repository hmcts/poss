<?xml version="1.0" encoding="UTF-8"?>
<Question xmlns:html="http://www.w3.org/TR/REC-html40" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://eds.com/questionxhtml ..\Question.xsd">
	<Id>201</Id>
	<Label>Details of documents</Label>
	<ObjectName>DocDetails</ObjectName>
	<Html>	
		<input type="text" id="DocDetails"></input>
	</Html>
	<Javascript>
		<XPath>/ds/EnterVariableData/FastTrack/docDetails</XPath>
		<HintText>Enter details of documents</HintText>
		<isMandatory>return true;</isMandatory>	
		<enableOn>IsDocsSpecified.dataBinding</enableOn>	
		<isEnabled>return('Y' == Services.getValue(IsDocsSpecified.dataBinding));</isEnabled>
		<logicOn>IsDocsSpecified.dataBinding</logicOn>
		<logic>
			if('Y' != Services.getValue(IsDocsSpecified.dataBinding))
			{	Services.setValue(DocDetails.dataBinding, "");
			}
		</logic>
	
	
	</Javascript>
</Question>