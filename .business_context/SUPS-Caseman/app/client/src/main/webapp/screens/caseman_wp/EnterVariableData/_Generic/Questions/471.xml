<?xml version="1.0" encoding="UTF-8"?>
<Question xmlns:html="http://www.w3.org/TR/REC-html40" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://eds.com/questionxhtml ..\Question.xsd">
	<Id>471</Id>
	<Label>Details of requirement</Label>
	<ObjectName>RequirementDtls</ObjectName>
	<Html>	
		<input type="text" id="RequirementDtls"></input>
	</Html>			
	<Javascript>
		<XPath>/ds/EnterVariableData/SuspCOforDisobedience/requirementDtls</XPath>
		<componentName>##label##</componentName>
		<isMandatory>return true;</isMandatory>
		<HintText>Enter text of requirement, in full</HintText>	
		<enableOn>HasOtherComplianceReq.dataBinding</enableOn>
		<isEnabled>return('Y' == Services.getValue(HasOtherComplianceReq.dataBinding));</isEnabled>
		<logicOn>HasOtherComplianceReq.dataBinding</logicOn>
		<logic>
			if('Y' != Services.getValue(HasOtherComplianceReq.dataBinding))
			{	Services.setValue(RequirementDtls.dataBinding, "");
			}
		</logic>		
	</Javascript>
</Question>