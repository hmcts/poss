<Question xmlns:html="http://www.w3.org/TR/REC-html40" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://eds.com/questionxhtml ..\Question.xsd">
	<Id>573</Id>
	<Label>Paragraph numbers to which Power of arrest apply</Label>
	<ObjectName>POAParaNums</ObjectName>
	<Html>	
		<input type="text" id="POAParaNums"></input>
	</Html>			
	<Javascript>
		<XPath>/ds/EnterVariableData/Interlocutory/pOAParaNums</XPath>
		<componentName>##label##</componentName>
		<isMandatory>return true;</isMandatory>
		<HintText>Enter the paragraph numbers to which Power of Arrest clause apply</HintText>	
		<enableOn>POAApply.dataBinding</enableOn>
		<isEnabled>return('Y' == Services.getValue(POAApply.dataBinding));</isEnabled>
		<logicOn>POAApply.dataBinding</logicOn>
		<logic>
			if('Y' != Services.getValue(POAApply.dataBinding))
			{	Services.setValue(POAParaNums.dataBinding, "");
			}
		</logic>					
	</Javascript>
</Question>