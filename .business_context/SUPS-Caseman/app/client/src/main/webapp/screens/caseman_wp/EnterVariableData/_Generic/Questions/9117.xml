<?xml version="1.0" encoding="UTF-8"?>
<Question xmlns:html="http://www.w3.org/TR/REC-html40" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://eds.com/questionxhtml ..\Question.xsd">
	<Id>9117</Id>
	<Label>Date of issue of proceedings</Label>
	<ObjectName>ProceedingDate</ObjectName>
	<Html>
		<script type="text/javascript">WP_DatePickerRenderer.createInline("ProceedingDate", false);</script>
	</Html>
	<Javascript>
     	<XPath>/ds/EnterVariableData/ProceedingDate</XPath>
		<HintText>Enter the date of proceedings</HintText>
		<isEnabled>return true;</isEnabled> 
		<isMandatory>return true;</isMandatory>
		<mandatoryOn>ProceedingDate.dataBinding</mandatoryOn>
    	<!-- //
        Date picker: error message “The value does not conform to a valid date format of DD-MMM-YYYY”.
        Validation: Date cannot be in the future //-->
		<validate>
			return isInPast(Services.getValue(ProceedingDate.dataBinding),"false"); 
		</validate>
	</Javascript>
</Question>