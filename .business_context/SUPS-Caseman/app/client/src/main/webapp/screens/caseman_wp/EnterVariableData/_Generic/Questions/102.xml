<?xml version="1.0" encoding="UTF-8"?>
<Question xmlns:html="http://www.w3.org/TR/REC-html40" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://eds.com/questionxhtml ..\Question.xsd">
	<Id>102</Id>
	<Label>Name of person handed to or left with</Label>
	<ObjectName>LeftWithName</ObjectName>
	<Html>		
		<input type="text" id="LeftWithName"></input>
	</Html>
	<Javascript>
		<XPath>/ds/EnterVariableData/Service/leftWithName</XPath>
		<HintText>Enter the full name of the person who received the document</HintText>
		<mandatoryOn>ServiceMethod.dataBinding</mandatoryOn>
		<isMandatory>
		  return( 'HAND' == Services.getValue(ServiceMethod.dataBinding));		
		</isMandatory>
		<enableOn>ServiceMethod.dataBinding</enableOn>
		<isEnabled>
		  return( 'HAND' == Services.getValue(ServiceMethod.dataBinding));		
		</isEnabled>
		<logicOn>ServiceMethod.dataBinding</logicOn>
		<logic>
			if( 'HAND' != Services.getValue(ServiceMethod.dataBinding))
			{	Services.setValue(LeftWithName.dataBinding, "");
			}
		</logic>
	</Javascript>
</Question>