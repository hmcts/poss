<?xml version="1.0" encoding="UTF-8"?>
<Question xmlns:html="http://www.w3.org/TR/REC-html40" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://eds.com/questionxhtml ..\Question.xsd">
	<Id>469</Id>
	<Label>Specific question details</Label>
	<ObjectName>SpecificQDtls</ObjectName>
	<Html>	
		<input type="text" id="SpecificQDtls"></input>
	</Html>			
	<Javascript>
		<XPath>/ds/EnterVariableData/SuspCOforDisobedience/specificQDtls</XPath>
		<componentName>##label##</componentName>
		<isMandatory>return true;</isMandatory>
		<HintText>Enter details of question not answered</HintText>		
		<enableOn>N79aReason.dataBinding</enableOn>
		<isEnabled>return('SQ' == Services.getValue(N79aReason.dataBinding));</isEnabled>
		<logicOn>N79aReason.dataBinding</logicOn>
		<logic>
			if('SQ' != Services.getValue(N79aReason.dataBinding))
			{	Services.setValue(SpecificQDtls.dataBinding, "");
			}
		</logic>	
	</Javascript>
</Question>