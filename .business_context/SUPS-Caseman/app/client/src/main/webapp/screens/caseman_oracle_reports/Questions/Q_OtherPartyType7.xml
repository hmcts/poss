<Question xmlns:html="http://www.w3.org/TR/REC-html40" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://eds.com/questionxhtml ..\Question.xsd">
	<Id>Q_OtherPartyType7</Id>
	<Label>Other Party Type</Label>
	<ObjectName>OtherPartyType7</ObjectName>
	<Html>
		<input id="OtherPartyType7" type="text" size="70"></input>
	</Html>
	<Javascript>
		<XPath>/ds/var/page/OracleReportForm/OtherPartyType7</XPath>
		<ReportVariableName>PARTY_OTHER</ReportVariableName>
		<ReportVariableValue>Services.getValue(OtherPartyType7.dataBinding)</ReportVariableValue>
		<ReportVariableCode>2570</ReportVariableCode>
		<HintText></HintText>
		<mandatoryOn>PartyMakingTheApplication2.dataBinding</mandatoryOn>
		<isMandatory>
			return !OtherPartyType7.isReadOnly();
		</isMandatory>
		<setDefault></setDefault>
		<validateOn></validateOn>
		<validate></validate>
		<readOnlyOn>PartyMakingTheApplication2.dataBinding</readOnlyOn>
		<isReadOnly>
			var partyMakingTheApplication = Services.getValue(PartyMakingTheApplication2.dataBinding);
			var valueTest = Services.getValue( REF_DATA_XPATH + "/PartyMakingTheApplicationList/PartyMakingTheApplication[./Description = " + PartyMakingTheApplication2.dataBinding + "]/Value" );
			if (partyMakingTheApplication == "OTH" || valueTest == "OTH")
			{
				return false;
			}
			else
			{
				return true;
			}
		</isReadOnly>
		<maxLength></maxLength>
		<transformToDisplay>
			return (null != value) ? value.toUpperCase() : null;
		</transformToDisplay>
		<transformToModel>
			return (null != value) ? value.toUpperCase() : null;
		</transformToModel>
		<initialise></initialise>
		<logicOn></logicOn>
		<logic></logic>
		<miscCode></miscCode>
		<IsQuestion></IsQuestion>
	</Javascript>
