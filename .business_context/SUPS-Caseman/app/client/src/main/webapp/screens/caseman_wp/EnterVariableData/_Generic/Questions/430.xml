	<Id>430</Id>
	<Label>Enter details of 'Unless Order'</Label>
	<ObjectName>UODetails3</ObjectName>
	<Html>
		<input type="text" id="UODetails3"></input>
	</Html>
	
	<Javascript>
		<XPath>/ds/EnterVariableData/SmallTrack/uODetails3</XPath>
		<HintText>Enter details in full of 'Unless Order'</HintText>
		<isMandatory>return true;</isMandatory>
		<enableOn>UOOtherItems.dataBinding</enableOn>
		<isEnabled>return('Y' == Services.getValue(UOOtherItems.dataBinding));</isEnabled>
		<logicOn>UOOtherItems.dataBinding</logicOn>
		<logic>
			if('Y' != Services.getValue(UOOtherItems.dataBinding))
			{	Services.setValue(UODetails3.dataBinding, "");
			}
		</logic>
	</Javascript>
