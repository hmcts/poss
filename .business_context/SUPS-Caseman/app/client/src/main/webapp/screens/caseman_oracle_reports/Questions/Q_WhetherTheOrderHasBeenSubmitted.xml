<?xml version="1.0" encoding="UTF-8"?>
<!--Question xmlns="http://eds.com/questionxhtml" xmlns:html="http://www.w3.org/TR/REC-html40" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://eds.com/questionxhtml ..\Question.xsd"-->
<Question xmlns:html="http://www.w3.org/TR/REC-html40" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://eds.com/questionxhtml ..\Question.xsd">
	<Id>Q_WhetherTheOrderHasBeenSubmitted</Id>
	<Label>Check box if Draft Order has been submitted</Label>
	<ObjectName>WhetherTheOrderHasBeenSubmitted</ObjectName>
	<Html>
		<input id="WhetherTheOrderHasBeenSubmitted" type="checkbox"/>
	</Html>
	<Javascript>
		<XPath>/ds/var/page/OracleReportForm/WhetherTheOrderHasBeenSubmitted</XPath>
		<ReportVariableName>DRAFT_ORDER</ReportVariableName>
		<ReportVariableValue>returnDefault(Services.getValue(WhetherTheOrderHasBeenSubmitted.dataBinding))</ReportVariableValue>
		<ReportVariableCode>2070</ReportVariableCode>
		<HintText></HintText>
		<isMandatory>return true;</isMandatory>
		<initialise></initialise>
		<setDefault>
			Services.setValue(WhetherTheOrderHasBeenSubmitted.dataBinding, "NS");
		</setDefault>		
		<validateOn>
		</validateOn>
		<validate>
		</validate>
		<miscCode>
			WhetherTheOrderHasBeenSubmitted.modelValue = {checked: 'SA', unchecked: 'NS'};
			function returnDefault(value)
			{
				//debugger;
				if (value == null)
				{
					return "NS";
				}
				else
				{
					return value;
				}
			}
		</miscCode>
	</Javascript>
</Question>