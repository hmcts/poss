	</Html>
	<Javascript>
		<XPath>/ds/EnterVariableData/article</XPath>		
		<mandatoryOn>Article.dataBinding</mandatoryOn>	
		<isMandatory>				
			return true;
		</isMandatory>
		<HintText>Select the article the application was made under</HintText>
		<initialise>WPU.loadProtocolAndArticles();</initialise>
		<miscCode>		 
			Article.srcData = "/ds/var/app/wp/Articles";
			Article.rowXPath = "Article";
			Article.keyXPath = "id";
			Article.columns = [{xpath: "label", sort: "numerical"}];
			Article.multipleSelection = true;			
		</miscCode>
	</Javascript>
</Question>