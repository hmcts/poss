<?xml version="1.0" encoding="UTF-8"?>
<Question xmlns:html="http://www.w3.org/TR/REC-html40" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://eds.com/questionxhtml ..\Question.xsd">
	<Id>288</Id>
	<Label>List of complaints to be filed?</Label>
	<ObjectName>IsComplaintsFiledList</ObjectName>
	<Html>
		<input type="checkbox" id="IsComplaintsFiledList"></input>
	</Html>
	
	<Javascript>
		<XPath>/ds/EnterVariableData/SmallTrack/isComplaintsFiledList</XPath>
		<HintText>Check box if list of items of work complained about to be filed.</HintText>
		<modelValue>checked: "Y", unchecked: "N"</modelValue>	
		<enableOn>DirectionsTypeReqd.dataBinding</enableOn>
		<isEnabled>
	
			var val2 = Services.getValue(DirectionsTypeReqd.dataBinding);
			return('BDCON' == val2 );
		</isEnabled>
		<logicOn>DirectionsTypeReqd.dataBinding</logicOn>
		<logic>
			
			var val2 = Services.getValue(DirectionsTypeReqd.dataBinding);
			if('BDCON' != val2 )
			{	Services.setValue(IsComplaintsFiledList.dataBinding, "N");
			}
		</logic>	
	</Javascript>
</Question>