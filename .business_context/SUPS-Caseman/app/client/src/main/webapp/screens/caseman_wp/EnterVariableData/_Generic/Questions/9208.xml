<Question xmlns:html="http://www.w3.org/TR/REC-html40" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://eds.com/questionxhtml ..\Question.xsd">
	<Id>669</Id>
	<Label>Payment date due</Label>
	<ObjectName>PaymentDueDate</ObjectName>
	<Html>	
		<script type="text/javascript">
			WP_DatePickerRenderer.createInline("PaymentDueDate");
		</script>
	</Html>		
	
	<Javascript>
		<XPath>/ds/EnterVariableData/paymentDueDate</XPath>
		<componentName>##label##</componentName>
        <HintText>Enter the date of payment due</HintText>  
		<mandatoryOn>PaymentDueDate.dataBinding</mandatoryOn>
         <isMandatory>return true;</isMandatory>
		<isEnabled>return true</isEnabled>

		
		<validateOn>PaymentDueDate.dataBinding</validateOn>
		<validate>
			//Date picker: error message “The value does not conform to a valid date format of DD-MMM-YYYY”.
			//Validation: Date cannot be in the past
		      return isInFuture(Services.getValue(PaymentDueDate.dataBinding));
		</validate>
		      		      
	</Javascript>
</Question>