<?xml version="1.0" encoding="UTF-8"?>
<Question xmlns:html="http://www.w3.org/TR/REC-html40" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://eds.com/questionxhtml ..\Question.xsd">
	<Id>300</Id>
	<Label>List to be filed with copy documents?</Label>
	<ObjectName>ListFiledWithCopyDocs</ObjectName>
	<Html>
		<input type="checkbox" id="ListFiledWithCopyDocs"></input>
	</Html>
	
	<Javascript>
		<XPath>/ds/EnterVariableData/SmallTrack/listFiledWithCopyDocs</XPath>
		<HintText>Check box if list is to be filed with copy documents</HintText>
		<modelValue>checked: "Y", unchecked: "N"</modelValue>
		<enableOn>IsWorkMaterialsFiledList.dataBinding</enableOn>
		<isEnabled>return('Y' == Services.getValue(IsWorkMaterialsFiledList.dataBinding));</isEnabled>
		<logicOn>IsWorkMaterialsFiledList.dataBinding</logicOn>
		<logic>
			if('Y' != Services.getValue(IsWorkMaterialsFiledList.dataBinding))
			{	Services.setValue(ListFiledWithCopyDocs.dataBinding, "N");
			}
		</logic>
	</Javascript>
</Question>