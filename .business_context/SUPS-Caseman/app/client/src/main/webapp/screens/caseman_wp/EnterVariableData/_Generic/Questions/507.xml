<Question xmlns:html="http://www.w3.org/TR/REC-html40" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://eds.com/questionxhtml ..\Question.xsd">
	<Id>507</Id>
	<Label>Is the asset to be charged land?</Label>
	<ObjectName>IsAssetChargedLand</ObjectName>
	<Html>	
		<input type="checkbox" id="IsAssetChargedLand"></input>
	</Html>			
	<Javascript>
		<XPath>/ds/EnterVariableData/InterimCharge/isAssetChargedLand</XPath>
		<componentName>##label##</componentName>
		<modelValue>checked: "Y", unchecked: "N"</modelValue>
		<HintText>Check box if the asset to be charged is land, else N</HintText>			
	</Javascript>
</Question>