<?xml version="1.0" encoding="UTF-8"?>
<Question xmlns:html="http://www.w3.org/TR/REC-html40" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://eds.com/questionxhtml ..\Question.xsd">
	<Id>456</Id>
	<Label>Is new set of N79A's required?</Label>
	<ObjectName>IsNewN79AsReqd</ObjectName>
	<Html>	
		<input type="checkbox" id="IsNewN79AsReqd"></input>
	</Html>			
	<Javascript>
		<XPath>/ds/EnterVariableData/SuspCOforDisobedience/isNewN79AsReqd</XPath>
		<componentName>##label##</componentName>
		<modelValue>checked: "Y", unchecked: "N"</modelValue>
		<HintText>Check box if you wish to produce a new set of N79A documents</HintText>
		<initialise>
			eventid= Services.getValue("/ds/var/app/WPData/WordProcessing/Event/StandardEventId");
			if (451 == eventid)	Services.setValue(IsNewN79AsReqd.dataBinding, "Y");	
			else Services.setValue(IsNewN79AsReqd.dataBinding, "N");	
		</initialise>
		<miscCode>
			var eventid = null;
		</miscCode>
		<isEnabled>
			if( 451 == eventid ) return false;
			return true;
		</isEnabled>		
	</Javascript>
</Question>