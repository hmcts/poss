<?xml version="1.0" encoding="UTF-8"?>
<Question xmlns:html="http://www.w3.org/TR/REC-html40" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://eds.com/questionxhtml ..\Question.xsd">
	<Id>190</Id>
	<Label>Date of service of copies</Label>
	<ObjectName>CopyServiceDate</ObjectName>
	<Html>	
		<script type="text/javascript">
			WP_DatePickerRenderer.createInline("CopyServiceDate");
		</script>
	</Html>
	<Javascript>
		<XPath>/ds/EnterVariableData/FastTrack/copyServiceDate</XPath>
		<HintText>Enter date of service of copies in the format DD-MON-YYYY</HintText>
		<mandatoryOn>CopyServiceDate.dataBinding</mandatoryOn>
		<isMandatory>return true;</isMandatory>	
		<enableOn>ByServiceCopies.dataBinding</enableOn>
		<isEnabled>return('Y' == Services.getValue(ByServiceCopies.dataBinding));</isEnabled>
		<logicOn>ByServiceCopies.dataBinding</logicOn>
		<logic>
			if('Y' != Services.getValue(ByServiceCopies.dataBinding))
			{	Services.setValue(CopyServiceDate.dataBinding, "");
			}
		</logic>	
		<validateOn>CopyServiceDate.dataBinding</validateOn>
		<validate>
			//cannot be in past : working day only
			
			var checkDate = Services.getValue(CopyServiceDate.dataBinding); 
			var err = null;
			
			if( false == isFutureDate(checkDate))
			{ 	err = ErrorCode.getErrorCode("CaseMan_dateCannotBeInThePast_Msg");
			}
			else if( isNonWorkingDate(checkDate))
		    {   err = ErrorCode.getErrorCode("CaseMan_dateNonWorkingDay_Msg"); 
		    }
			
			return err;
		</validate>	
		<!--initialise>		  	
		  	loadNonWorkingDays();
		</initialise-->
		<miscCode>
		    CopyServiceDate.weekends = false;
		</miscCode>	
	</Javascript>
</Question>