<?xml version="1.0" encoding="UTF-8"?>
<Question xmlns:html="http://www.w3.org/TR/REC-html40" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://eds.com/questionxhtml ..\Question.xsd">
	<Id>308</Id>
	<Label>Parties to try and agree nature of costs?</Label>
	<ObjectName>PartiesAgressCostNature2</ObjectName>
	<Html>
		<input type="checkbox" id="PartiesAgressCostNature2"></input>
	</Html>
	
	<Javascript>
		<XPath>/ds/EnterVariableData/SmallTrack/partiesAgressCostNature2</XPath>
		<HintText>Check box if parties are to try and agree nature and cost of repairs and replacements?</HintText>
		<modelValue>checked: "Y", unchecked: "N"</modelValue>
		<enableOn>DirectionsTypeReqd.dataBinding</enableOn>
		<isEnabled>
			var val1 = Services.getValue(DirectionsTypeReqd.dataBinding);
			return( 'RDDT' == val1);
			<!--return( LossDamageItemsFiled.isEnabled() ||(('Y' != val1 || 'HW' != val2 ) &amp;&amp; !IsPartiesToAgreeRepairs.isEnabled() &amp;&amp; !PartiesAgreeCostNature.isEnabled()));-->
		</isEnabled>
		<logicOn>DirectionsTypeReqd.dataBinding</logicOn>
		<logic>
			var val1 = Services.getValue(DirectionsTypeReqd.dataBinding);
			if(val1 != 'RDDT')
			{	Services.setValue(PartiesAgressCostNature2.dataBinding, "N");
			}
		</logic>	
	</Javascript>
</Question>