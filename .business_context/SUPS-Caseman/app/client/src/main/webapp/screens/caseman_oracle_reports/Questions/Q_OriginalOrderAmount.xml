<?xml version="1.0" encoding="UTF-8"?>
<!--Question xmlns="http://eds.com/questionxhtml" xmlns:html="http://www.w3.org/TR/REC-html40" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://eds.com/questionxhtml ..\Question.xsd"-->
<Question xmlns:html="http://www.w3.org/TR/REC-html40" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://eds.com/questionxhtml ..\Question.xsd">
	<Id>Q_OriginalOrderAmount</Id>
	<Label>Enter Original Order Amount</Label>
	<ObjectName>OriginalOrderAmount</ObjectName>
	<Html>
		<input id="DefaultCurrency" type="text" size="1"></input>
		<input id="OriginalOrderAmount" type="text" size="8"></input>
	</Html>
	<Javascript>
		<XPath>/ds/var/page/OracleReportForm/OriginalOrderAmount</XPath>
		<ReportVariableName>AMT_AO</ReportVariableName>
		<ReportVariableCode>12535</ReportVariableCode>
		<TableName></TableName>
		<KeyName></KeyName>
		<ColumnName></ColumnName>
		<FieldType></FieldType>
		<ReportVariableValue>Services.getValue(OriginalOrderAmount.dataBinding)</ReportVariableValue>
		<ReportVariableCode>111</ReportVariableCode>
		<HintText>Enter the amount of the AO as registered</HintText>
		<maxLength>8</maxLength>
		<mandatoryOn></mandatoryOn>
		<isMandatory>return true;</isMandatory>
		<setDefault></setDefault>
		<validateOn></validateOn>
		<validate>
			var value = Services.getValue(this.dataBinding);
			if (!CaseManUtils.isBlank(value)) {
				if (!CaseManValidationHelper.validateFloatNumber(value))
				{
					return ErrorCode.getErrorCode("CaseMan_Reports_Enter_Number");
				}
				if (value &lt; 0)
				{
					return ErrorCode.getErrorCode("CaseMan_Reports_Enter_Number");
				}
				//return CaseManValidationHelper.validatePattern(value, CaseManValidationHelper.NUMERIC_PATTERN, "CaseMan_Reports_Enter_Number");
			}
			else 
			{
				return null;
			}
		</validate>
		<readOnlyOn></readOnlyOn>
		<isReadOnly></isReadOnly>
		<maxLength></maxLength>
		<transformToDisplay></transformToDisplay>
		<transformToModel></transformToModel>
		<initialise></initialise>
		<logicOn></logicOn>
		<logic></logic>
		<miscCode></miscCode>
		<IsQuestion></IsQuestion>
	</Javascript>
</Question>