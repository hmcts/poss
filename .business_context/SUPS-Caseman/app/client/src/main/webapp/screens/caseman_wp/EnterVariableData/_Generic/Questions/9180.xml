<?xml version="1.0" encoding="UTF-8"?>
<Question xmlns:html="http://www.w3.org/TR/REC-html40" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://eds.com/questionxhtml ..\Question.xsd">
	<Id>9180</Id>
	<Label>Date of Bailiff visit</Label>
	<ObjectName>BailiffVisitDate</ObjectName>
	<Html>
		<script type="text/javascript">WP_DatePickerRenderer.createInline("BailiffVisitDate", false);</script>
	</Html>
	<Javascript>
		<XPath>/ds/EnterVariableData/bailiffVisitDate</XPath>
		<HintText>Select date of Bailiff visit</HintText>
		<isEnabled>return true</isEnabled>
		<validate>
			//Date picker: error message “The value does not conform to a valid date format of DD-MMM-YYYY”.
			//Validation: Date cannot be in the future
            
            return isInPast(Services.getValue(BailiffVisitDate.dataBinding),"false");
		</validate>
		<mandatoryOn>BailiffVisitDate.dataBinding</mandatoryOn>
		<isMandatory>return true;</isMandatory>		
		
				
	</Javascript>
</Question>