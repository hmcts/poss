<?xml version="1.0" encoding="UTF-8"?>
<Question xmlns:html="http://www.w3.org/TR/REC-html40" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://eds.com/questionxhtml ..\Question.xsd">
	<Id>232</Id>
	<Label>Other party</Label>
	<ObjectName>FirstPartyOther</ObjectName>
	<Html>	
		<input type="text" id="FirstPartyOther"></input>
	</Html>
	<Javascript>
		<XPath>/ds/EnterVariableData/FastTrack/firstPartyOther</XPath>
		<HintText>Enter the party</HintText>
		<isMandatory>return true;</isMandatory>	
		<enableOn>FirstParty.dataBinding</enableOn>
		<isEnabled>return('OTH' == Services.getValue(FirstParty.dataBinding));</isEnabled>
		<logicOn>FirstParty.dataBinding</logicOn>
		<logic>
			if('OTH' != Services.getValue(FirstParty.dataBinding))
			{	Services.setValue(FirstPartyOther.dataBinding, "");
			}
		</logic>
		
		<Context ScreenId="CJR060">
			<HintText>Enter the party e.g. claimant, defendant 1 etc.</HintText>
		</Context>
	</Javascript>
</Question>