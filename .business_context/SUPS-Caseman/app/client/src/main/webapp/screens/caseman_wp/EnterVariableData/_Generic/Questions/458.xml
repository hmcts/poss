<?xml version="1.0" encoding="UTF-8"?>
<Question xmlns:html="http://www.w3.org/TR/REC-html40" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://eds.com/questionxhtml ..\Question.xsd">
	<Id>458</Id>
	<Label>Affidavit of service by whom?</Label>
	<ObjectName>AffidavitOfServiceBy</ObjectName>
	<Html>	
		<input type="text" id="AffidavitOfServiceBy"></input>
	</Html>			
	<Javascript>
		<XPath>/ds/EnterVariableData/SuspCOforDisobedience/affidavitOfServiceBy</XPath>
		<componentName>##label##</componentName>
		<isMandatory>return true;</isMandatory>
		<HintText>Enter the name of the person swearing the affidavit</HintText>
		<enableOn>N39ServedBy.dataBinding</enableOn>
		<isEnabled>return('A' == Services.getValue(N39ServedBy.dataBinding));</isEnabled>
		<logicOn>N39ServedBy.dataBinding</logicOn>
		<logic>
			if('A' != Services.getValue(N39ServedBy.dataBinding))
			{	Services.setValue(AffidavitOfServiceBy.dataBinding, "");
			}
		</logic>			
	</Javascript>
</Question>