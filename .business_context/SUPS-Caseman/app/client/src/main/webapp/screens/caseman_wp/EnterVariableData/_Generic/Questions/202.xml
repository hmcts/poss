<?xml version="1.0" encoding="UTF-8"?>
<Question xmlns:html="http://www.w3.org/TR/REC-html40" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://eds.com/questionxhtml ..\Question.xsd">
	<Id>202</Id>
	<Label>Is there a date for delivery of lists?</Label>
	<ObjectName>IsDeliveryListDate</ObjectName>
	<Html>	
		<input type="checkbox" id="IsDeliveryListDate"></input>
	</Html>
	<Javascript>
		<XPath>/ds/EnterVariableData/FastTrack/isDeliveryListDate</XPath>
		<HintText>Check box if there is a date for delivery of documents</HintText>
		<!--isMandatory>return true;</isMandatory-->	
		<modelValue>checked: "Y", unchecked: "N"</modelValue>
		<enableOn>IsDisclosureOrdered.dataBinding</enableOn>
		<isEnabled>return('Y' == Services.getValue(IsDisclosureOrdered.dataBinding));</isEnabled>
		<logicOn>IsDisclosureOrdered.dataBinding</logicOn>
		<logic>
			if('Y' != Services.getValue(IsDisclosureOrdered.dataBinding))
			{	Services.setValue(IsDeliveryListDate.dataBinding, "N");
			}
		</logic>
	</Javascript>
</Question>