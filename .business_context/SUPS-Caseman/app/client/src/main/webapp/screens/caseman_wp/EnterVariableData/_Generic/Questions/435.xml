<?xml version="1.0" encoding="UTF-8"?>
<Question xmlns:html="http://www.w3.org/TR/REC-html40" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://eds.com/questionxhtml ..\Question.xsd">
	<Id>435</Id>
	<Label>What profession is the expert?</Label>
	<ObjectName>ExpertProfession</ObjectName>
	<Html>
		<input type="text" id="ExpertProfession"></input>
	</Html>
	
	<Javascript>
		<XPath>/ds/EnterVariableData/SmallTrack/expertProfession</XPath>
		<HintText>Enter profession of expert e.g. a doctor</HintText>
		<isMandatory>return true;</isMandatory>
		<enableOn>IsExpertEvidenceNec.dataBinding</enableOn>
		<isEnabled>return('Y' == Services.getValue(IsExpertEvidenceNec.dataBinding));</isEnabled>
		<logicOn>IsExpertEvidenceNec.dataBinding</logicOn>
		<logic>
			if('Y' != Services.getValue(IsExpertEvidenceNec.dataBinding))
			{	Services.setValue(ExpertProfession.dataBinding, "");
			}
		</logic>
	</Javascript>
</Question>