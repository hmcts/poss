<Question xmlns:html="http://www.w3.org/TR/REC-html40" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://eds.com/questionxhtml ..\Question.xsd">
	<Id>542</Id>
	<Label>Interim place of safety identified?</Label>
	<ObjectName>IsPlaceOfSafetyId</ObjectName>
	<Html>	
		<input type="checkbox" id="IsPlaceOfSafetyId"></input>
	</Html>			
	<Javascript>
		<XPath>/ds/EnterVariableData/Hospital/isPlaceOfSafetyId</XPath>
		<componentName>##label##</componentName>
		<modelValue>checked: "Y", unchecked: "N"</modelValue>
		<HintText>Check box if an Interim place of safety has  been identified for the defendant</HintText>	
		
		<Context ScreenId="CJR104">
			<enableOn>DefRemandorDetnd.dataBinding</enableOn>
			<isEnabled>return( 'R' != Services.getValue(DefRemandorDetnd.dataBinding));</isEnabled>
			<logicOn>DefRemandorDetnd.dataBinding</logicOn>
			<logic>
				if( 'R' == Services.getValue(DefRemandorDetnd.dataBinding))
				{	Services.setValue(IsPlaceOfSafetyId.dataBinding, "N");
				}
			</logic>	
		</Context>				
	</Javascript>
</Question>