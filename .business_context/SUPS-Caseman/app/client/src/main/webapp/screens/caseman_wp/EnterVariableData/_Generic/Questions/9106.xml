<?xml version="1.0" encoding="UTF-8"?>
<Question xmlns:html="http://www.w3.org/TR/REC-html40" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://eds.com/questionxhtml ..\Question.xsd">
	<Id>9106</Id>
	<Label>Date of award</Label>
	<ObjectName>DateofAward</ObjectName>
	<Html>
		<script type="text/javascript">WP_DatePickerRenderer.createInline("DateofAward", false);</script>
	</Html>
	<Javascript>
     <XPath>/ds/EnterVariableData/DateofAward</XPath>
		<HintText>Enter the date of award</HintText>
      
		<validate>
          //Date picker: error message “The value does not conform to a valid date format of DD-MMM-YYYY”.
            //Validation: Date cannot be in the future 
          return isInPast(Services.getValue(DateofAward.dataBinding),"false"); 
		</validate>	
		<isMandatory>return true;</isMandatory>	
        <mandatoryOn>DateofAward.dataBinding</mandatoryOn> 
        <isEnabled>return true;</isEnabled> 
	</Javascript>
</Question>