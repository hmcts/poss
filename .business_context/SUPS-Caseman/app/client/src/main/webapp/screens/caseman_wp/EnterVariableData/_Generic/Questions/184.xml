<?xml version="1.0" encoding="UTF-8"?>
<Question xmlns:html="http://www.w3.org/TR/REC-html40" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://eds.com/questionxhtml ..\Question.xsd">
	<Id>184</Id>
	<Label>Party to serve documents</Label>
	<ObjectName>PartyDocsServe</ObjectName>
	<Html>	
		<select id="PartyDocsServe">
			<option value=""></option>
			<option value="ALL">All parties</option>
			<option value="CLM">The claimant</option>
			<option value="DEF">The defendant</option>
			<option value="OTH">Other</option>
		</select>
	</Html>
	<Javascript>
		<XPath>/ds/EnterVariableData/FastTrack/partyDocsServe</XPath>
		<HintText>Enter party to serve documents</HintText>
		<isMandatory>return true;</isMandatory>	
		<enableOn>ByServiceCopies.dataBinding</enableOn>
		<isEnabled>return('Y' == Services.getValue(ByServiceCopies.dataBinding));</isEnabled>
		<logicOn>ByServiceCopies.dataBinding</logicOn>
		<logic>
			if('Y' != Services.getValue(ByServiceCopies.dataBinding))
			{	Services.setValue(PartyDocsServe.dataBinding, "");
			}
		</logic>
		
		<Context ScreenId="CJR060">
			<HintText>Select the party to serve documents</HintText>
		</Context>
	</Javascript>
</Question>


    
    
    
    
