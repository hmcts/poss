<?xml version="1.0" encoding="UTF-8"?>
<Question xmlns:html="http://www.w3.org/TR/REC-html40" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://eds.com/questionxhtml ..\Question.xsd">
	<Id>9016</Id>
	<Label>Report delivered by date</Label>
	<ObjectName>ReportDeliveredDate</ObjectName>
	<Html>
		<script type="text/javascript">WP_DatePickerRenderer.createInline("ReportDeliveredDate", false);</script>
	</Html>
	<Javascript>
        <XPath>/ds/EnterVariableData/ReportDeliveredDate</XPath>
		<HintText>Select the report delivery date</HintText>
		<isMandatory>return true;</isMandatory>
	    <isEnabled>return true;</isEnabled>
        <enabledOn>ReportDeliveredDate.dataBinding</enabledOn>
 		<validateOn>ReportDeliveredDate.dataBinding</validateOn>      
        <validate>
            //Validation: Date cannot be in the past
            var checkDate = Services.getValue(ReportDeliveredDate.dataBinding); 
			var err = null;
			if( false == isFutureDate(checkDate))
			{ 	err = ErrorCode.getErrorCode("CaseMan_dateCannotBeInThePast_Msg");
			}				
			return err;
		</validate>
	</Javascript>			
</Question>