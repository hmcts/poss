					Services.setValue(CostAmount.dataBinding, "");
				}				
			</logic>
		</Context>
		<Context ScreenId="CJR051">
			<enableOn>HasCostOrder.dataBinding</enableOn>
			<isEnabled>return('Y' == Services.getValue(HasCostOrder.dataBinding));</isEnabled>
			<logicOn>HasCostOrder.dataBinding</logicOn>
			<logic>
				if('Y' != Services.getValue(HasCostOrder.dataBinding))
				{	Services.setValue(CostAmount.dataBinding, "0.00");
				}
				else {
					Services.setValue(CostAmount.dataBinding, "");
				}				
			</logic>
		</Context>
		<Context ScreenId="CJR052">
			<enableOn>CostType2.dataBinding</enableOn>
			<isEnabled>return('F' == Services.getValue(CostType2.dataBinding));</isEnabled>
			<logicOn>CostType2.dataBinding</logicOn>
			<logic>
				if('F' != Services.getValue(CostType2.dataBinding))
				{	Services.setValue(CostAmount.dataBinding, "0.00");
				}
				else {
					Services.setValue(CostAmount.dataBinding, "");
				}
			</logic>
		</Context>
		<Context ScreenId = "CO28">
			<HintText>Enter optional full Costs text as required to be printed</HintText>
		</Context>
