<Question xmlns:html="http://www.w3.org/TR/REC-html40" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://eds.com/questionxhtml ..\Question.xsd">
	<Id>608</Id>
	<Label>Defendant to pay direct to other party</Label>
	<ObjectName>PayDirctToOtherParty</ObjectName>

	<Html>	
		<input type="checkbox" id="PayDirctToOtherParty"></input>
	</Html>			
	<Javascript>
		<XPath>/ds/EnterVariableData/Settlement/payDirctToOtherParty</XPath>
		<componentName>##label##</componentName>
		<modelValue>checked: "Y", unchecked: "N"</modelValue>
		<HintText>Check box if the Defendant is to pay direct to the other party</HintText>	
		<enableOn>ClaimFor.dataBinding</enableOn>
		<isEnabled>return('ACC' == Services.getValue(ClaimFor.dataBinding));</isEnabled>
		<logicOn>ClaimFor.dataBinding</logicOn>
		<logic>
			if('ACC' != Services.getValue(ClaimFor.dataBinding))
			{	Services.setValue(PayDirctToOtherParty.dataBinding, "N");
			}
		</logic>			
	</Javascript>
</Question>