<?xml version="1.0" encoding="UTF-8"?>
<Question xmlns:html="http://www.w3.org/TR/REC-html40" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://eds.com/questionxhtml ..\Question.xsd">
	<Id>428</Id>
	<Label>Details of items to be brought to court</Label>
	<ObjectName>BroughtItemsDetails</ObjectName>
	<Html>
		<input type="text" id="BroughtItemsDetails"></input>
	</Html>
	
	<Javascript>
		<XPath>/ds/EnterVariableData/SmallTrack/broughtItemsDetails</XPath>
		<HintText>Enter details of items to be taken to the hearing</HintText>
		<isMandatory>return true;</isMandatory>
		<enableOn>BroughtToHearing.dataBinding</enableOn>
		<isEnabled>return('Y' == Services.getValue(BroughtToHearing.dataBinding));</isEnabled>
		<logicOn>BroughtToHearing.dataBinding</logicOn>
		<logic>
			if('Y' != Services.getValue(BroughtToHearing.dataBinding))
			{	Services.setValue(BroughtItemsDetails.dataBinding, "");
			}
		</logic>
	</Javascript>
</Question>