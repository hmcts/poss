<?xml version="1.0" encoding="UTF-8"?>
<Question xmlns:html="http://www.w3.org/TR/REC-html40" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://eds.com/questionxhtml ..\Question.xsd">
	<Id>188</Id>
	<Label>Documents relating to specific issue?</Label>
	<ObjectName>SpecificIssueDocs</ObjectName>
	<Html>	
		<input type="checkbox" id="SpecificIssueDocs"></input>
	</Html>
	<Javascript>
		<XPath>/ds/EnterVariableData/FastTrack/specificIssueDocs</XPath>
		<HintText>Check box if documents are relating to a specific issue</HintText>
		<!--isMandatory>return false;</isMandatory-->	
		<modelValue>checked: "Y", unchecked: "N"</modelValue>
		<enableOn>ByServiceCopies.dataBinding</enableOn>
		<isEnabled>return('Y' == Services.getValue(ByServiceCopies.dataBinding));</isEnabled>
		<logicOn>ByServiceCopies.dataBinding</logicOn>
		<logic>
			if('Y' != Services.getValue(ByServiceCopies.dataBinding))
			{	Services.setValue(SpecificIssueDocs.dataBinding,"N");
			}
		</logic>
	</Javascript>
</Question>