		<Context ScreenId="CJR051">
			<enableOn>PaymentsOnAccount.dataBinding</enableOn>
			<isEnabled>return false;</isEnabled>
			<logicOn>PaymentsOnAccount.dataBinding</logicOn>
			<logic></logic>
		</Context>
		<Context ScreenId="CJR052">
			<enableOn>HasCostOrder.dataBinding, CostType2.dataBinding</enableOn>
			<isEnabled>return('Y' == Services.getValue(HasCostOrder.dataBinding) 
								&amp;&amp;  'A' == Services.getValue( CostType2.dataBinding ));</isEnabled>
			<logicOn>HasCostOrder.dataBinding, CostType2.dataBinding</logicOn>
			<logic>
				if('Y' != Services.getValue(HasCostOrder.dataBinding) ||
						'A' != Services.getValue( CostType2.dataBinding ))
				{	Services.setValue(PaymentsOnAccount.dataBinding, "N");
				}
			</logic>
		</Context>
		<Context ScreenId="CJR053">
			<enableOn>PaymentsOnAccount.dataBinding</enableOn>
