	<Javascript>
		<XPath>/ds/EnterVariableData/InterimCosts/PossessionOrder/paymentsOnAccount</XPath>
		<componentName>##label##</componentName>
		<HintText>Check box if there Is a payment to be made on account of costs</HintText>
		<modelValue>checked: "Y", unchecked: "N"</modelValue>
		<enableOn>CostType.dataBinding</enableOn>
		<isEnabled>
			var val = Services.getValue(CostType.dataBinding);
			return( 'F' == val || 'A' == val);
		</isEnabled>
		<logicOn>CostType.dataBinding</logicOn>
		<logic>		
			var val = Services.getValue(CostType.dataBinding);
			if( 'F' != val &amp;&amp; 'A' != val)		
			{	Services.setValue(PaymentsOnAccount.dataBinding);
			}
		</logic>
		<Context ScreenId="N32_2">
			<enableOn>PaymentsOnAccount.dataBinding</enableOn>
			<isEnabled>return false;</isEnabled>
			<logicOn>PaymentsOnAccount.dataBinding</logicOn>
