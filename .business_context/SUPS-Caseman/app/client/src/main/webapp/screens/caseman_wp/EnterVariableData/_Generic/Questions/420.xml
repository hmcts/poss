	</Html>
	
	<Javascript>
		<XPath>/ds/EnterVariableData/SmallTrack/otherPartyTitle9</XPath>
		<HintText>Enter the party's name</HintText>
		<isMandatory>return true;</isMandatory>
		<enableOn>PartyToInspect.dataBinding</enableOn>
