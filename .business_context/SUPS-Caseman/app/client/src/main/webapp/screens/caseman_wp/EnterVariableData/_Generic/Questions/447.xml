<?xml version="1.0" encoding="UTF-8"?>
<Question xmlns:html="http://www.w3.org/TR/REC-html40" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://eds.com/questionxhtml ..\Question.xsd">
	<Id>447</Id>
	<Label>Details of failure to comply</Label>
	<ObjectName>FailureComplyDtls</ObjectName>
	<Html>	
		<input type="text" id="FailureComplyDtls"></input>
	</Html>			
	<Javascript>
		<XPath>/ds/EnterVariableData/DisobedienceArrest/failureComplyDtls</XPath>
		<componentName>##label##</componentName>
		<isMandatory>return true;</isMandatory>
		<HintText>Enter details in full of failure to comply</HintText>	
		<enableOn>N79AComptemptDtls.dataBinding</enableOn>
		<isEnabled>return( 'A' == Services.getValue(N79AComptemptDtls.dataBinding));</isEnabled>
		<logicOn>N79AComptemptDtls.dataBinding</logicOn>
		<logic>
			if( 'A' != Services.getValue(N79AComptemptDtls.dataBinding))
			{	Services.setValue(FailureComplyDtls.dataBinding, "");
			}
		</logic>
	</Javascript>
</Question>