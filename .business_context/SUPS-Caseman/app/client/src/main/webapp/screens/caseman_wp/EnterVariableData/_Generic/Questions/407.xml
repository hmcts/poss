<?xml version="1.0" encoding="UTF-8"?>
<Question xmlns:html="http://www.w3.org/TR/REC-html40" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://eds.com/questionxhtml ..\Question.xsd">
	<Id>407</Id>
	<Label>Who must clarify their case?</Label>
	<ObjectName>WhoClarifiesCase</ObjectName>
	<Html>
		<select id="WhoClarifiesCase">
			<option value=""></option>
			<option value="CLM">Claimant</option>
			<option value="DEF">Defendant</option>
			<option value="OTH">Other</option>
		</select>
	</Html>
	
	<Javascript>
		<XPath>/ds/EnterVariableData/SmallTrack/whoClarifiesCase</XPath>
		<HintText>Which party must clarify their case</HintText>
		<isMandatory>return true;</isMandatory>
		<enableOn>IsPartyToClarify.dataBinding</enableOn>
		<isEnabled>return('Y' == Services.getValue(IsPartyToClarify.dataBinding));</isEnabled>
		<logicOn>IsPartyToClarify.dataBinding</logicOn>
		<logic>
			if('Y' != Services.getValue(IsPartyToClarify.dataBinding))
			{	Services.setValue(WhoClarifiesCase.dataBinding, "");
			}
		</logic>
	</Javascript>
</Question>