<?xml version="1.0" encoding="UTF-8"?>
<Question xmlns:html="http://www.w3.org/TR/REC-html40" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://eds.com/questionxhtml ..\Question.xsd">
	<Id>813</Id>
	<Label>CO debt status</Label>
	<ObjectName>CODebtStatus</ObjectName>
	<Html>
		<input id="CODebtStatus" type="text"></input>
	</Html>
	<Javascript>
		<XPath>/ds/EnterVariableData/CODebtStatus</XPath>
		<componentName>##label##</componentName>
		<HintText></HintText>
		<isReadOnly>return true;</isReadOnly>
		<isMandatory>return false;</isMandatory>
		<mandatoryOn>CODebtStatus.dataBinding</mandatoryOn>
		<initialise>
			var DebtSequence = WPU.GetDebtSequence();
			var DebtStatus = WPU.GetDebtStatus(DebtSequence);
			Services.setValue(CODebtStatus.dataBinding, DebtStatus);			
		</initialise>
	</Javascript>
</Question>