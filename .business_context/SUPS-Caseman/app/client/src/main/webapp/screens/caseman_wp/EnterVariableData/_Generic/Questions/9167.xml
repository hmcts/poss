<?xml version="1.0" encoding="UTF-8"?>
<Question xmlns:html="http://www.w3.org/TR/REC-html40" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://eds.com/questionxhtml ..\Question.xsd">
	<Id>9167</Id>
	<Label>Type of process you are returning</Label>
	<ObjectName>ReturnProcessType</ObjectName>	
	<Html>	
		<input id="ReturnProcessType" type="text" size="35"></input>
	</Html>
	<Javascript>
		<XPath>/ds/EnterVariableData/returnProcessType</XPath>
		<HintText>Enter the type of process you are returning</HintText>
        <Context ScreenId="L_5_1">

                <mandatoryOn>RequestFor.dataBinding</mandatoryOn>
                <isMandatory>return ("OTH" == Services.getValue(RequestFor.dataBinding))</isMandatory>
                <enableOn>RequestFor.dataBinding</enableOn>
                <isEnabled>return ("OTH" == Services.getValue(RequestFor.dataBinding))</isEnabled>
                <logicOn>RequestFor.dataBinding</logicOn>
                <logic>
                    if("OTH" != Services.getValue(RequestFor.dataBinding))
                    {   
                        Services.setValue(ReturnProcessType.dataBinding, "");
                     }
                </logic>        
        </Context>

		

	</Javascript>
</Question>