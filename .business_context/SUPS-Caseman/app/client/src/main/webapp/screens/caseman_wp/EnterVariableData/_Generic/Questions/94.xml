<?xml version="1.0" encoding="UTF-8"?>
<Question xmlns:html="http://www.w3.org/TR/REC-html40" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://eds.com/questionxhtml ..\Question.xsd">
	<Id>94</Id>
	<Label></Label>
	<ObjectName>AdditionalCopies</ObjectName>
	<Html>	   		
			<input type="text" id="AdditionalCopies" size="3" value="0" style="visibility: hidden; height: 0px;"/>		
	</Html>
	<Context screenId="CJR041"><isVisible>false</isVisible></Context>
	<Context screenId="CJR043"><isVisible>false</isVisible></Context>
	<Context screenId="CJR065A"><isVisible>false</isVisible></Context>
	<Context screenId="CJR049"><isVisible>false</isVisible></Context>
	<Context screenId="CJR042"><isVisible>false</isVisible></Context>
	
		<Javascript>
		<XPath>/ds/EnterVariableData/Print/additionalcopies</XPath>
		<componentName>Additional</componentName>
		<HintText>The number of additional copies to print</HintText>
		<isMandatory>return false;</isMandatory>
		<mandatoryOn>AdditionalCopies.dataBinding</mandatoryOn>
		<isEnabled>return false;</isEnabled>
		<logicOn>JudgmentRegistered.dataBinding</logicOn>
		<logic>		 
		  		
		  if( 'true' == Services.getValue(JudgmentRegistered.dataBinding))
		  {  Services.setValue(AdditionalCopies.dataBinding, 1);
		  }
		  else
		  {  Services.setValue(AdditionalCopies.dataBinding, 0);
		  }
		</logic>
	</Javascript>
</Question>