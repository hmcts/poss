<?xml version="1.0" encoding="UTF-8"?>
<Question xmlns:html="http://www.w3.org/TR/REC-html40" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://eds.com/questionxhtml ..\Question.xsd">
	<Id>270</Id>
	<Label>Is this further information</Label>
	<ObjectName>IsFurtherInfo</ObjectName>
	<Html>	  
		<input type="checkbox" id="IsFurtherInfo"></input>
	</Html>
	<Javascript>
		<XPath>/ds/EnterVariableData/Allocation/isFurtherInfo</XPath>
		<componentName>##label##</componentName>
		<HintText>Check box if this is further information</HintText>				
		<modelValue>checked: "Y", unchecked: "N"</modelValue>
		<enableOn>InfoReqdFrom.dataBinding</enableOn>
		<isEnabled>
			var val = Services.getValue(InfoReqdFrom.dataBinding);
			return( 'CLM' == val || 'DEF' == val);
		</isEnabled>
		<logicOn>InfoReqdFrom.dataBinding</logicOn>
		<logic>
			var val = Services.getValue(InfoReqdFrom.dataBinding);
			if( 'CLM' != val &amp;&amp; 'DEF' != val)
			{	Services.setValue(IsFurtherInfo.dataBinding, "N");
			}
		</logic>
	</Javascript>
</Question>