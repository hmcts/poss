<?xml version="1.0" encoding="UTF-8"?>
<Question xmlns:html="http://www.w3.org/TR/REC-html40" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://eds.com/questionxhtml ..\Question.xsd">
	<Id>257</Id>
	<Label>Direction on Request for Information?</Label>
	<ObjectName>RFIDirn</ObjectName>
	<Html>	
		<input type="checkbox" id="RFIDirn"></input>
	</Html>
	<Javascript>
		<XPath>/ds/EnterVariableData/FastTrack/fFIDirn</XPath>
		<HintText>Check box if there is direction on request for information</HintText>
		<isMandatory>return true;</isMandatory>	
		<modelValue>checked: "Y", unchecked: "N"</modelValue>
		<Context ScreenId="CJR020">
			<enableOn>TrialDateFixed.dataBinding</enableOn>
			<isEnabled>return(TrialDateFixed.isEnabled());</isEnabled>
			<logicOn>TrialDateFixed.dataBinding</logicOn>
			<logic>
				if(!TrialDateFixed.isEnabled())
				{	Services.setValue(RFIDirn.dataBinding, "N");
				}
			</logic>
		</Context>
	</Javascript>
</Question>