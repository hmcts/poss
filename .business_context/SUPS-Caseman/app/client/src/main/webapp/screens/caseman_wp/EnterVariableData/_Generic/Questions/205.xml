<?xml version="1.0" encoding="UTF-8"?>
<Question xmlns:html="http://www.w3.org/TR/REC-html40" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://eds.com/questionxhtml ..\Question.xsd">
	<Id>205</Id>
	<Label>Latest date for request</Label>
	<ObjectName>LatestReqDate</ObjectName>
	<Html>	
		<script type="text/javascript">
			WP_DatePickerRenderer.createInline("LatestReqDate");
		</script>		
	</Html>
	<Javascript>
		<XPath>/ds/EnterVariableData/FastTrack/latestReqDate</XPath>
		<HintText>Enter latest date for request in the format DD-MON-YYYY</HintText>
		<isMandatory>return true;</isMandatory>
		<mandatoryOn>LatestReqDate.dataBinding</mandatoryOn>	
		<enableOn>InspectDirectionReq.dataBinding</enableOn>
		<isEnabled>return('Y' == Services.getValue(InspectDirectionReq.dataBinding));</isEnabled>
		<logicOn>InspectDirectionReq.dataBinding</logicOn>
		<logic>
			if('Y' != Services.getValue(InspectDirectionReq.dataBinding))
			{	Services.setValue(LatestReqDate.dataBinding);			
			}
		</logic>
		<validateOn>LatestReqDate.dataBinding</validateOn>
		<validate>
			//cannot be in past : working day only
			
			var checkDate = Services.getValue(LatestReqDate.dataBinding); 
			var err = null;
			
			if( false == isFutureDate(checkDate))
			{ 	err = ErrorCode.getErrorCode("CaseMan_dateCannotBeInThePast_Msg");
			}
			else if( isNonWorkingDate(checkDate))
		    {   err = ErrorCode.getErrorCode("CaseMan_dateNonWorkingDay_Msg"); 
		    }
			
			return err;
		</validate>	
		<!--initialise>		  	
		  	loadNonWorkingDays();
		</initialise-->
		<miscCode>
		    LatestReqDate.weekends = false;
		</miscCode>	
	</Javascript>
</Question>