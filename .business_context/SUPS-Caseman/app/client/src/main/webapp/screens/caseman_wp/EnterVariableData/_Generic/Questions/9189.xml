<?xml version="1.0" encoding="UTF-8"?>
<Question xmlns:html="http://www.w3.org/TR/REC-html40" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://eds.com/questionxhtml ..\Question.xsd">
	<Id>9189</Id>
	<Label>Words to follow Dear</Label>
	<ObjectName>WordsFollowingDear</ObjectName>
	<Html>
	  <input id="WordsFollowingDear" type="text" size="70" ></input>
	</Html>

	<Javascript>
		<XPath>/ds/EnterVariableData/wordsFollowingDear</XPath>
		<HintText>Enter word to follow Dear</HintText>
		<isMandatory>return true;</isMandatory> 
		<mandatoryOn>Salutation.dataBinding</mandatoryOn>
		<enableOn>Salutation.dataBinding</enableOn>
		<isEnabled>return ("OTH" == Services.getValue(Salutation.dataBinding));</isEnabled>
		<logicOn>Salutation.dataBinding</logicOn>
		<logic>
			if("OTH" != Services.getValue(Salutation.dataBinding))
			{	
				Services.setValue(WordsFollowingDear.dataBinding, "");
			}
		</logic>
	</Javascript>	
</Question>