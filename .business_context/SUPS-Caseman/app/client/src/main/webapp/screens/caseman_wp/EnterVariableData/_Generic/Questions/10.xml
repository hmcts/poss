	<Context screenId="CJR061">
		<isVisible>true</isVisible>
		<Label>Has a further hearing been specified?</Label>
	</Context>
	
	<Javascript>	
		<XPath>/ds/EnterVariableData/Hearing/isListed</XPath>
		<modelValue>checked: "Y", unchecked: "N"</modelValue>
		<HintText>Check box if the hearing details are listed</HintText>
		<logicOn>HearingListed.dataBinding</logicOn>
		<logic>
			var val = Services.getValue(HearingListed.dataBinding);
			
			if(val != 'Y')
			{ Services.setValue(HearingDate.dataBinding, "");
			  Services.setValue(HearingTime.dataBinding, "");
			  Services.setValue(VenueCode.dataBinding, "");
			}
		</logic>
		<mandatoryOn>HearingListed.dataBinding</mandatoryOn>
		<isMandatory>return false;</isMandatory>
		
		<Context ScreenId="CJR061">
			<HintText>Check box if another hearing has been scheduled</HintText>
		</Context>
	</Javascript>

