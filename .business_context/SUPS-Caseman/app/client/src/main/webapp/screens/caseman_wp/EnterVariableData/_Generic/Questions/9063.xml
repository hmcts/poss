<Question xmlns:html="http://www.w3.org/TR/REC-html40" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://eds.com/questionxhtml ..\Question.xsd">
	<Id>9063</Id>
	<Label>Date of statutory demand</Label>
	<ObjectName>StatutoryDemandDate</ObjectName>
	<Html>
		<script type="text/javascript">WP_DatePickerRenderer.createInline("StatutoryDemandDate", false);</script>
	</Html>
	<Javascript>
        <XPath>/ds/EnterVariableData/StatutoryDemandDate</XPath>
		<HintText>Select the statutory demand date</HintText>
 		<validate>
             // Date picker: error message “The value does not conform to a valid date format of DD-MMM-YYYY”.
            // Validation: Date cannot be in the future
		    return isInPast(Services.getValue(StatutoryDemandDate.dataBinding),"false");
        </validate>
         <mandatoryOn>StatutoryDemandDate.dataBinding</mandatoryOn>
		<isMandatory>return true;</isMandatory>
        <isEnabled>return true;</isEnabled> 
	</Javascript>
</Question>