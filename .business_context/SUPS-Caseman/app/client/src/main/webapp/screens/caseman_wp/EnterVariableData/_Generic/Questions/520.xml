<Question xmlns:html="http://www.w3.org/TR/REC-html40" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://eds.com/questionxhtml ..\Question.xsd">
	<Id>520</Id>
	<Label>Does Bank of England hold securities?</Label>
	<ObjectName>HasBofESecurities</ObjectName>
	<Html>	
		<input type="checkbox" id="HasBofESecurities"></input>
	</Html>			
	<Javascript>
		<XPath>/ds/EnterVariableData/FinalChargeOrder/hasBofESecurities</XPath>
		<componentName>##label##</componentName>
		<modelValue>checked: "Y", unchecked: "N"</modelValue>
		<HintText>Check box if the Bank of England holds the securities</HintText>	
		<enableOn>IsChargedLandDebtorsAdd.dataBinding, IsAssetChargedLand.dataBinding</enableOn>
		<isEnabled>return( 'Y' != Services.getValue(IsChargedLandDebtorsAdd.dataBinding) &amp;&amp;
						'Y' != Services.getValue(IsAssetChargedLand.dataBinding));
		</isEnabled>
		<logicOn>IsChargedLandDebtorsAdd.dataBinding</logicOn>
		<logic>
			if( 'Y' == Services.getValue(IsChargedLandDebtorsAdd.dataBinding) ||
						'Y' == Services.getValue(IsAssetChargedLand.dataBinding))
			{	Services.setValue(HasBofESecurities.dataBinding, "N");
			}
		</logic>		
	</Javascript>
</Question>