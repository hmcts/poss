	<!-- Compile all of the source for a given bean (both generated ejb
         and any other provided in the src directory) -->
	<macrodef name="macro__compile_bean_source">
		<attribute name="bean-name" />
		<attribute name="bean-base-src-dir" />
		<attribute name="app-package" />
		<attribute name="bean-package" />

		<sequential>
			<echo>
            [srcbasedir] Compiling source for bean @{bean-name}
            bean-base-src-dir: @{bean-base-src-dir}
            application_jars: ${application_jars}
            app-package:    @{app-package}/@{bean-name}*.java
            bean-package:   @{bean-package}/**/*.java 
                to
                ${application_exp_jars}/@{bean-name}                  
            </echo>
			<javac sourcepath="" srcdir="@{bean-base-src-dir}" destdir="${application_exp_jars}/@{bean-name}" debug="${compile.debug}" source="${compile.source}" verbose="${compile.verbose}" target="${compile.target}">
				<classpath>
					<path refid="project_path" />
					<fileset dir="${application_jars}">
						<include name="**/*.jar" />
					</fileset>
					<pathelement location="${application_exp_jars}/common_application" />
					<pathelement location="${application_out_of_date_bin}" />
				</classpath>
				<include name="@{app-package}/@{bean-name}*.java" />
				<include name="@{bean-package}/**/*.java" />
				<exclude name="**/framework/**.java" />
			</javac>
		</sequential>
	</macrodef>

	<!-- Build the jar for the service, producing @{bean-name}.jar -->
	<macrodef name="macro__build_service_jar">
		<attribute name="bean-name" />
		<attribute name="bean-package" />
		<attribute name="bean-package-base-dir" />
		<sequential>
			<echo level="verbose" message="Building the jar for the service, producing @{bean-name}.jar" />
			<echo level="verbose">including what should be XML from: 
                bean-package-base-dir: @{bean-package-base-dir}</echo>
			<echo>bean-package: @{bean-package}/**/*</echo>
			<echo>application.lib: ${application.lib}</echo>
			<if>
				<isset property="application.lib" />
				<then>
					<delete dir="${application_gen_src}/@{bean-name}/META-INF" />
					<mkdir dir="${application_gen_src}/@{bean-name}/META-INF" />
					<copy tofile="${application_gen_src}/@{bean-name}/META-INF/TEMP-MANIFEST.MF" file="${jar_manifest}" />
					<echo level="verbose">modifying manifest for @{bean-name}: ${application.lib}</echo>
					<for param="jarfile">
						<path>
							<fileset dir="${application.lib}">
								<include name="*.jar" />
							</fileset>
						</path>
						<sequential>
							<property name="regex" value="(.*\${file.separator})(.*)" />
							<propertyregex property="jarfilename" override="true" input="@{jarfile}" regexp="${regex}" replace="\2" casesensitive="true" />
							<echo file="${application_gen_src}/@{bean-name}/META-INF/TEMP-MANIFEST.MF" append="true"> ${jarfilename}</echo>
						</sequential>
					</for>
				</then>
			</if>
			<var unset="true" name="jar-class-path" />
			<loadfile property="jar-class-path" srcfile="${application_gen_src}/@{bean-name}/META-INF/TEMP-MANIFEST.MF"/>
			<echo>updating manifest: ${application_gen_src}/@{bean-name}/META-INF/MANIFEST.MF</echo>
			<if>
				<not>
					<isset property="version" />
				</not>
				<then>
					<property name="version" value="${frwk.version}" />
				</then>
			</if>
			<manifest file="${application_gen_src}/@{bean-name}/META-INF/MANIFEST.MF">
				<attribute name="Class-Path" value="${jar-class-path}" />
				<section name="@{bean-package}">
					<attribute name="Implementation-Title" value="@{bean-name}" />
					<attribute name="Implementation-Version" value="${application.name} ${version} - FRWK: ${frwk.version}" />
					<attribute name="Implementation-Vendor" value="Electronic Data Systems (EDS)" />
				</section>
			</manifest>
			<echo>including files from 
                    @{bean-package-base-dir}/@{bean-name}      
                    ${application_exp_jars}/@{bean-name}
            </echo>
			<jar destfile="${application_jars}/@{bean-name}.jar" manifest="${application_gen_src}/@{bean-name}/META-INF/MANIFEST.MF" update="false">
				<fileset dir="@{bean-package-base-dir}">
					<include name="@{bean-package}/**/*" />
					<exclude name="**/*.java" />
				</fileset>
				<fileset dir="${application_exp_jars}/@{bean-name}">
					<include name="@{bean-package}/**/*.class" />
					<include name="**/@{bean-name}*.class" />
					<include name="META-INF/**" />
				</fileset>
			</jar>
			<delete file="${application_gen_src}/@{bean-name}/META-INF/TEMP-MANIFEST.MF"/>
		</sequential>
	</macrodef>

