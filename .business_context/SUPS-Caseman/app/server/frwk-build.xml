		<property name="frwk.regex" value="(.*)ServerFramework_Release_(.*)" />
		<propertyregex property="frwk.version" override="true" input="${release.label}" regexp="${frwk.regex}" replace="\2" casesensitive="false" />
		<echo>Searching ${release.label} for ${frwk.regex} and frwk.version = ${frwk.version}</echo>
		
		<loadfile property="jar-class-path" srcfile="${jar_manifest}"/>
		<loadfile property="war-class-path" srcfile="${war_manifest}"/>

		<echo level="verbose">
        Using Project Base:    ${application.base}
        Using Properties File: ${application.base}/application.properties
        application.base is:   ${application.base}
        application.name is:   ${application.name}
        application_src:       ${application_src} 
        jboss.server.dir is:   ${jboss.server.dir}
        oas.server.dir is:     ${oas.server.dir}
        application.build is:  ${application.build}
        application.lib is:    ${application.lib}
        application.bin is:    ${application.bin}
        custom.path is:        ${custom.path}
        Using Async is:        ${using.async}
        EJB Interfaces:        ${ejb.interfaces}     
        release.lib:           ${release.lib}
        service_uri_prefix     ${application.service.uri.prefix} 
        release.label		   ${release.label}
		frwk.version		   ${frwk.version}
        </echo>

	</target>

