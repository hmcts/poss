	<!-- Takes the ${bean_name}Bean.java generated by genbeans and produces
         all of the required ejb files and various deployment descriptors -->
	<macrodef name="macro__generate_ejb_source_JBOSS">
		<attribute name="bean-name" />
		<attribute name="app-package" />

		<sequential>
			<echo level="verbose">Generating source for bean @{bean-name}</echo>
			<ejbdoclet destdir="${application_gen_src}/@{bean-name}" mergeDir="${application.build}/wsconfig" excludedtags="@version,@author" addedtags="@xdoclet-generated at ${TODAY}" ejbspec="2.1" verbose="on">

				<fileset dir="${application_gen_src}">
					<include name="@{app-package}/@{bean-name}Bean.java" />
				</fileset>
				<remoteinterface pattern="{0}Remote" />
				<localinterface pattern="{0}" />
				<homeinterface />
				<localhomeinterface />
				<service-endpoint pattern="{0}Service" />
				<deploymentdescriptor destdir="${application_exp_jars}/@{bean-name}/META-INF" />
				<jboss version="4.0" securityDomain="java:/jaas/other" preferredRelationMapping="relation-table" datasource="java:/DefaultDS" datasourcemapping="Hypersonic SQL" destdir="${application_exp_jars}/@{bean-name}/META-INF" unauthenticatedPrincipal="nobody" />
			</ejbdoclet>

			<!-- TODO - check the template for hardcoded items -->
			<wseedoclet wsdlFile="META-INF/wsdl/@{bean-name}.wsdl" jaxrpcMappingFile="META-INF/jaxrpc-mapping.xml" wseeSpec="1.1" destdir="${application_exp_jars}/@{bean-name}" verbose="true">

				<fileset dir="${application_gen_src}">
					<include name="@{app-package}/@{bean-name}Bean.java" />
				</fileset>

				<wsdl templateFile="${release_templates}/wsdl/SUPS_wsdl.template" />

				<deploymentdescriptor name="@{bean-name}" destDir="${application_exp_jars}/@{bean-name}/META-INF" />

				<jaxrpc-mapping />

			</wseedoclet>

		</sequential>
	</macrodef>

	<!-- Takes the ${bean_name}Bean.java generated by genbeans and produces
