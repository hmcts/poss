		<taskdef name="genmdbs" classname="uk.gov.dca.db.async.MDBDeploymentTask" classpathref="project_path" />
		<taskdef name="convertServiceDirToBeanName" classname="uk.gov.dca.db.impl.ConvertServiceDirToBeanName" classpathref="project_path" />
		<taskdef name="ejbdoclet" classname="xdoclet.modules.ejb.EjbDocletTask" classpathref="project_path" />
