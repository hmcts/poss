<project name="SUPS_Serverside_Build" default="build-app__clean_build_deploy">

	<target name="build-app__clean_build_deploy" depends="_init-properties,
                 _clean,
                 _init-dirs, 
    			 _define-tasks,                
                 _call-external-script,
                 _incremental-gen-compile,
                 _deploy" />

	<target name="build-app__clean_build_deploy_no_external" depends="_init-properties,
                 _clean,
                 _init-dirs, 
    			 _define-tasks,
                 _incremental-gen-compile,
                 _deploy" />

	<target name="_incremental-gen-compile" depends="_incremental_compile_all_application_source,
        _create_initial_ear,
        _genbeans-src,
    	_create-update-conf-jar,
        _create-update-common-jar,


        _genmdbs,
        _build_content_war,
        _build_invoker_war,        
    	_configure_wordprocessing_ear,
        _generate-compile-and-build-jars,
        
        _update-application-name-wsdl,
        _update_ear_with_jars,
        _update_ear_with_ws_for_oas" />

	<target name="deploy" depends="build-app__build_deploy" />
	<target name="build-ear-image" depends="build-app__build" />

	<target name="build-app__build_deploy" depends="   _init-properties,
                    _init-dirs, _define-tasks,
                    _call-external-script,  
                    _incremental-gen-compile, _deploy" />

	<target name="build-app__build_deploy_no_external" depends="   _init-properties,
                    _init-dirs, _define-tasks,
                    _incremental-gen-compile, _deploy" />

	<target name="build-app__build" depends="   _init-properties,      
                    _init-dirs, _define-tasks,
                    _call-external-script,
                    _incremental-gen-compile" />

	<target name="build-app__build_no_external" depends="   _init-properties,      
                        _init-dirs, _define-tasks,
                        _incremental-gen-compile" />

	<target name="build-app__deploy" depends="   _init-properties,
                    _deploy
                 " />

	<target name="_setup_generate-compile-and-build-jars_properties">
		<!-- Setup default values for paramters-->
		<property name="product_name" value="${application.name}" />
	</target>

	<!-- Generates the new directories and copies in files -->
	<target name="_init-dirs" depends="_init-properties">
		<mkdir dir="${application.build}" />
		<mkdir dir="${application_jars}" />
		<mkdir dir="${application_exp_jars}" />
		<mkdir dir="${application_gen_src}" />
		<mkdir dir="${application_conf_src}" />
		<mkdir dir="${application_wsconfig}" />
		<mkdir dir="${application_ear}" />
		<mkdir dir="${application_async_metainf}" />
		<mkdir dir="${application_war_webinf}" />
		<mkdir dir="${application.base}/empty" />
		<mkdir dir="${application_out_of_date_bin}" />
		<mkdir dir="${application_dist}" />
		<mkdir dir="${application_dist}/OAS" />
		<mkdir dir="${application_temp_lib}" />
	</target>

	<!-- "public" clean task -->
	<target name="clean" depends="_init-properties,_clean" description="also removes the dist directory">
		<delete dir="${application_dist}/OAS" />
	</target>

	<!-- Deletes all files created by the build process in the target directory -->
	<target name="_clean">
		<delete dir="${application.build}" />
		<delete dir="${application_jars}" />
		<delete dir="${application_exp_jars}" />
		<delete dir="${application_gen_src}" />
		<delete dir="${application_wsconfig}" />
		<delete dir="${application_ear}" />
		<delete dir="${application_out_of_date_bin}" />
	</target>

	<!--  
		Creates the ear and adds all of the pre-built jars to it
        TODO - add framework jars which should already be compiled
    -->
	<target name="_create_initial_ear">
		<delete file="${application_ear}/${application.name}.ear" failonerror="true" />
        <var name="framework_jar_path" unset="true" />
        <property name="framework_jar_path" value="${release.lib}/SUPS-OAS/${framework.jar}" />
        <property name="authorisation_jar_path" value="${release.lib}/SUPS-OAS/Authorisation.jar" />
        <echo level="verbose">Using OAS version of the framework; ${framework_jar_path}</echo>

        <if>
            <not>
                <isset property="version" />
            </not>
            <then>
                <if>
                    <available file="${application.conf}/version.properties" type="file" />
                    <then>
                        <property file="${application.conf}/version.properties"/>
                    </then>
                    <else>
                        <echo>Didn't find ${application.conf}/version.properties</echo>
                        <property name="version" value="${frwk.version}" />
                    </else>
                </if>
            </then>
        </if>

        <delete dir="${application_ear_metainf}/META-INF" failonerror="false"/>
        <mkdir dir="${application_ear_metainf}/META-INF"/>
        <if>
            <isset property="application.lib" />
            <then>
                <copy tofile="${application_ear_metainf}/META-INF/TEMP-MANIFEST.MF" file="${jar_manifest}" />
                <echo level="verbose">modifying manifest for @{bean-name}: ${application.lib}</echo>
                <for param="jarfile">
                    <path>
                        <fileset dir="${application.lib}">
                            <include name="*.jar" />
                        </fileset>
                    </path>
                    <sequential>
                        <property name="regex" value="(.*\${file.separator})(.*)" />
                        <propertyregex property="jarfilename" override="true" input="@{jarfile}" regexp="${regex}" replace="\2" casesensitive="true" />
                        <echo file="${application_ear_metainf}/META-INF/TEMP-MANIFEST.MF" append="true"> ${jarfilename}</echo>
                    </sequential>
                </for>
            </then>
        </if>
        <var unset="true" name="jar-class-path" />
        <loadfile property="jar-class-path" srcfile="${application_ear_metainf}/META-INF/TEMP-MANIFEST.MF"/>
        <manifest file="${application_ear_metainf}/META-INF/MANIFEST.MF">
            <attribute name="Class-Path" value="${jar-class-path}" />
            <section name="${application.name}">
                <attribute name="Implementation-Title" value="${application.name}" />
                <attribute name="Implementation-Version" value="${version} - FRWK: ${frwk.version}" />
                <attribute name="Implementation-Vendor" value="Electronic Data Systems (EDS)" />
            </section>
        </manifest>
        <jar destfile="${application_ear}/${application.name}.ear" update="false" manifest="${application_ear_metainf}/META-INF/MANIFEST.MF">
            <fileset file="${framework_jar_path}" />
            <fileset file="${authorisation_jar_path}" />

            <fileset refid="commons-jars" />
            <fileset refid="jdom-jars" />
            <fileset refid="fop-jars" />
            <fileset refid="rhino-jars" />
            <fileset refid="jcifs-jars" />
            <fileset refid="fw-common-jars" />
            <fileset refid="concurrent-backport-jars" />
            <fileset dir="${application_wsconfig}">
                <include name="framework.config.properties" />
            </fileset>

            <fileset dir="${application.lib}">
                <include name="*.jar" />
                <exclude name="**/SUPS-JBOSS/${framework.jar}" />
                <exclude name="**/SUPS-JBOSS/Authorisation.jar" />
            </fileset>
        </jar>

        <delete file="${application_ear_metainf}/META-INF/TEMP-MANIFEST.MF"/>
	</target>

	<!-- Invokes the custom ant task genbeans which takes the abstract
         source from the source directory and generates the bean file
         (including xdoclet tags).
    -->
	<target name="_genbeans-src">
		<echo level="verbose">
            application_src: ${application_src}
            checking for: ${application_src}/uk/gov/dca/${application.name}/${sups_config_file}</echo>
		<if>
			<available file="${application_src}/uk/gov/dca/${application.name}/${sups_config_file}" type="file" />
			<then>
				<property name="application_config_file" value="uk/gov/dca/${application.name}/${sups_config_file}" />
			</then>
			<else>
				<property name="application_config_file" value="uk/gov/dca/db/${sups_config_file}" />
			</else>
		</if>

		<echo level="verbose">Using config file application_config_file: ${application_config_file}</echo>
		<genbeans destdir="${application_gen_src}" rootDir="${application_src}" wsConfigDestDir="${application_wsconfig}" packageName="uk.gov.dca.${application.name}" projectConfig="${project_config_file}" frameworkConfig="${application_config_file}">

		</genbeans>
	</target>


	<target name="_genmdbs" if="using.async">
		<genmdbs verbose="true" root="${application_src}" packageName="uk.gov.dca.${application.name}" projectConfig="${project_config_file}">

			<ejbjar src="${release_templates}/ejb-jar.xml" dest="${application_async_metainf}/ejb-jar.xml" />
			<jboss src="${release_templates}/jboss.xml" dest="${application_async_metainf}/jboss.xml" />
			<orion src="${release_templates}/orion-ejb-jar.xml" dest="${application_async_metainf}/orion-ejb-jar.xml" />
		</genmdbs>
		<echo>updating manifest: ${application_gen_src}/@{bean-name}/META-INF/MANIFEST.MF</echo>
		<delete file="${application_async_metainf}/MANIFEST.MF" failonerror="false"/>
		<mkdir dir="${application_async_metainf}"/>
		<manifest file="${application_async_metainf}/MANIFEST.MF">
			<attribute name="Class-Path" value="${jar-class-path}" />
			<section name="uk/gov/dca/db/async">
				<attribute name="Implementation-Title" value="async" />
				<attribute name="Implementation-Version" value="${application.name} ${version}" />
				<attribute name="Implementation-Vendor" value="Electronic Data Systems (EDS)" />
			</section>
		</manifest>
		<jar destfile="${application_jars}/async.jar" manifest="${application_async_metainf}/MANIFEST.MF">
			<metainf dir="${application_async_metainf}">
				<include name="ejb-jar.xml" />
				<include name="jboss.xml" />
				<include name="orion-ejb-jar.xml" />
			</metainf>
			<zipfileset src="${release.lib}/SUPS-OAS/${framework.jar}">
				<include name="uk/gov/dca/db/async/AsyncProcessorMDB.class" />
			</zipfileset>
		</jar>
	</target>

	<target name="_build_content_war" unless="no-build-content-war">
		<delete file="${application_war_webinf}/web.xml" />
		<copy todir="${application_war_webinf}" overwrite="true">
			<fileset dir="${release_resources}/web/content">
				<include name="web.xml" />
				<include name="jboss-web.xml" />
			</fileset>
			<fileset dir="${release_resources}/web">
				<include name="jboss-web.xml" />
			</fileset>
			<filterset>
				<filter token="project_config" value="${project_config_path}" />
				<filter token="APPLICATION_NAME" value="${application.name}" />
			</filterset>
		</copy>
		<!-- generate a nice WAR MANIFEST.MF -->
		<var unset="true" name="war-class-path" />
		<loadfile property="war-class-path" srcfile="${war_manifest}"/>
		<echo>updating manifest: ${application_gen_src}/WAR-META-INF/MANIFEST.MF</echo>
		<if>
			<not>
				<isset property="version" />
			</not>
			<then>
				<property name="version" value="${frwk.version}" />
			</then>
		</if>
		<delete dir="${application_gen_src}/CONTENT-META-INF" failonerror="false"/>
		<mkdir dir="${application_gen_src}/CONTENT-META-INF"/>
		<manifest file="${application_gen_src}/CONTENT-META-INF/MANIFEST.MF">
			<attribute name="Class-Path" value="${war-class-path}" />
			<section name="uk/gov/dca/db/content/web">
				<attribute name="Implementation-Title" value="ContentServlet" />
				<attribute name="Implementation-Version" value="${application.name} ${version} - FRWK: frwk.regex" />
				<attribute name="Implementation-Vendor" value="Electronic Data Systems (EDS)" />
			</section>
		</manifest>

		<war destfile="${application_jars}/sups-content-${application.name}.war" webxml="${application_war_webinf}/web.xml" manifest="${application_gen_src}/CONTENT-META-INF/MANIFEST.MF">
			<webinf dir="${application_war_webinf}">
				<include name="jboss-web.xml" />
			</webinf>
			<classes src="${release.lib}/SUPS-OAS/${framework.jar}">
				<include name="uk/gov/dca/db/content/web/ContentServlet.class" />
			</classes>
		</war>
	</target>

	<target name="_build_invoker_war">
		<delete file="${application_war_webinf}/web.xml" />
		<copy todir="${application_war_webinf}" overwrite="true">
			<fileset dir="${release_resources}/web/invoker">
				<include name="web.xml" />
			</fileset>
			<fileset dir="${release_resources}/web">
				<include name="jboss-web.xml" />
			</fileset>
			<filterset>
				<filter token="project_config" value="${project_config_path}" />
				<filter token="APPLICATION_NAME" value="${application.name}" />
				<filter token="SERVICE_CONFIG_DIRECTORY" value="${service_config_directory}" />
			</filterset>
		</copy>

		<loadfile property="webxml-remote-ejb-refs" srcfile="${application.build}/wsconfig/uk/gov/dca/${application.name}/webxml-remote-ejb-refs.xml" />
		<loadfile property="webxml-local-ejb-refs" srcfile="${application.build}/wsconfig/uk/gov/dca/${application.name}/webxml-local-ejb-refs.xml" />

		<replace dir="${application_war_webinf}" includes="web.xml" token="&lt;!--REMOTE_EJB_REFS--&gt;" value="${webxml-remote-ejb-refs}" />

		<replace dir="${application_war_webinf}" includes="web.xml" token="&lt;!--LOCAL_EJB_REFS--&gt;" value="${webxml-local-ejb-refs}" />

		<!-- generate a nice WAR MANIFEST.MF -->
		<var unset="true" name="war-class-path" />
		<loadfile property="war-class-path" srcfile="${war_manifest}"/>
		<echo>updating manifest: ${application_gen_src}/WAR-META-INF/MANIFEST.MF</echo>
		<if>
			<not>
				<isset property="version" />
			</not>
			<then>
				<property name="version" value="${frwk.version}" />
			</then>
		</if>
		<delete dir="${application_gen_src}/INVOKER-META-INF" failonerror="false"/>
		<mkdir dir="${application_gen_src}/INVOKER-META-INF"/>
		<manifest file="${application_gen_src}/INVOKER-META-INF/MANIFEST.MF">
			<attribute name="Class-Path" value="${war-class-path}" />
			<section name="uk/gov/dca/db/content/web">
				<attribute name="Implementation-Title" value="InvokerServlet RequestDispatcher" />
				<attribute name="Implementation-Version" value="${application.name} ${version} - FRWK: ${frwk.version}" />
				<attribute name="Implementation-Vendor" value="Electronic Data Systems (EDS)" />
			</section>
		</manifest>
		
		<war destfile="${application_jars}/sups-invoker-${application.name}.war" webxml="${application_war_webinf}/web.xml" manifest="${application_gen_src}/INVOKER-META-INF/MANIFEST.MF">
			<webinf dir="${application_war_webinf}">
				<include name="jboss-web.xml" />
			</webinf>
			<classes src="${release.lib}/SUPS-OAS/${framework.jar}">
				<include name="uk/gov/dca/db/invoke/**/*.*" />
			</classes>
			<classes src="${release.lib}/SUPS-OAS/${framework.jar}">
				<include name="uk/gov/dca/db/heartbeat/**/*.*" />
			</classes>
			<classes src="${release.lib}/SUPS-OAS/${framework.jar}">
				<include name="uk/gov/dca/db/check/**/*.*" />
			</classes>
			<lib dir="${application_jars}">
				<include name="conf.jar" />
			</lib>
		</war>
	</target>

	<target name="_generate-compile-and-build-jars">
		<!-- Check the source of each bean to determine whether or not it should
             be rebuilt -->
		<for param="beandir">
			<path>
				<dirset dir="${application_src}/uk/gov/dca/${application.name}">
					<include name="*_service" />
				</dirset>
			</path>
			<sequential>
				<!-- remove the following two properties -->
				<var name="bean_name" value="" unset="true" />
				<var name="bean_src_dir_name" value="" unset="true" />
				<!-- The following convenience method creates two properties 
                     from a given directory path:
                       bean_name is the name of the ejb (eg Cases)
                       bean_src_dir_name : (eg cases_service)  -->
				<convertServiceDirToBeanName dirName="@{beandir}" />

				<echo level="verbose">Processing @{beandir}</echo>

				<ProcessServiceBeans bean-name="${bean_name}" bean-src-dir-name="${bean_src_dir_name}" application-name="${application.name}" application-src="${application_src}" application-gen-src="${application_gen_src}" beandir="@{beandir}" />

				<var name="bean_name" value="" unset="true" />
				<var name="bean_src_dir_name" value="" unset="true" />

			</sequential>
		</for>
	</target>


	<macrodef name="ProcessServiceBeans">
		<attribute name="bean-name" />
		<attribute name="bean-src-dir-name" />
		<attribute name="application-name" />
		<attribute name="application-src" />
		<attribute name="application-gen-src" />
		<attribute name="beandir" />

		<sequential>
			<echo level="verbose"> 
                loaded bean_name: @{bean-name}; bean-src-dir-name: @{bean-src-dir-name} 
            </echo>

			<!-- Check to see if any files have changed - if they have
                 rebuild the whole jar -->
			<outofdate outputsources="outofdatesources" outputtargets="outofdatetargets">
				<sourcefiles>
					<fileset dir="@{beandir}">
						<include name="**/*" />
					</fileset>
					<fileset dir="${application_out_of_date_bin}">
						<include name="uk/gov/dca/@{application-name}" />
						<include name="uk/gov/dca/common" />
					</fileset>
				</sourcefiles>
				<targetfiles>
					<path>
						<pathelement location="${application_jars}/common_application.jar" />
						<pathelement location="${application_jars}/@{bean-name}.jar" />
					</path>
				</targetfiles>
				<mapper type="glob" from="*.class" to="*.java" />
				<sequential>
					<!-- Create the directories required and copy in
                         MANIFEST.MF file -->
					<delete file="${application_jars}/@{bean-name}.jar" />
					<delete dir="${application_exp_jars}/@{bean-name}" />
					<mkdir dir="${application_exp_jars}/@{bean-name}" />
					<copy todir="${application_exp_jars}/@{bean-name}">
						<fileset dir="${release_resources}">
							<include name="META-INF/MANIFEST.MF" />
						</fileset>
					</copy>
					<copy todir="${application_exp_jars}/@{bean-name}/META-INF">
						<fileset dir="${framework_conf}">
							<include name="framework.config.properties" />
						</fileset>
						<filterset>
							<filter token="APPLICATION_NAME" value="${application.name}" />
							<filter token="PROJECT_CONFIG" value="${project_config_path}" />
							<filter token="FRAMEWORK_CONFIG" value="${application_config_file}" />
						</filterset>
					</copy>

					<!-- Create the rest of the ejb files using ${bean_name)Bean.java
                         and Xdoclet -->
                    <var name="ejb.interfaces" value="both" />
                    <macro__generate_ejb_source_OAS bean-name="@{bean-name}" app-package="uk/gov/dca/@{application-name}" />

					<!-- Compile all java source for the bean -->
					<macro__compile_bean_source bean-name="@{bean-name}" bean-base-src-dir="@{application-src}:@{application-gen-src}/@{bean-name}:@{application-gen-src}" app-package="uk/gov/dca/@{application-name}" bean-package="uk/gov/dca/@{application-name}/@{bean-src-dir-name}" />

					<!-- Builds all files into a jar of name ${bean_name}.jar -->
					<macro__build_service_jar bean-name="@{bean-name}" bean-package="uk/gov/dca/@{application-name}/@{bean-src-dir-name}" bean-package-base-dir="@{application-src}" />

				</sequential>
			</outofdate>
		</sequential>

	</macrodef>


	<!-- Move all of the jars into the ear - also generate application.xml for
         the META-INF directory -->
	<target name="_update_ear_with_jars">
		<!-- Copy in the required files -->
		<echo>ear_application_xml_file: ${ear_application_xml_file}</echo>
		<delete file="${application_ear_metainf}/META-INF/application.xml" />
		<copy tofile="${application_ear_metainf}/META-INF/application.xml" overwrite="true" file="${ear_application_xml_file}">
			<filterset>
				<filter token="APPLICATION_NAME" value="${application.name}" />
				<filter token="$${application.name}" value="${application.name}" />
			</filterset>
		</copy>
		<copy todir="${application_ear_metainf}/META-INF" overwrite="true">
			<filterset>
				<filter token="APPLICATION_NAME" value="${application.name}" />
				<filter token="$${application.name}" value="${application.name}" />
			</filterset>
			<fileset dir="${release_resources}/META-INF/ear">
				<include name="*" />
				<exclude name="application.xml" />
			</fileset>
			<fileset dir="${release_resources}/META-INF/OAS/ear">
				<include name="*" />
			</fileset>
		</copy>

		<!-- 
            First update the file application.xml with all of the jar files
        -->
		<for param="jarfile">
			<path>
				<fileset dir="${application_jars}">
					<include name="*.jar" />
					<exclude name="conf.jar" />
					<exclude name="common_application.jar" />
				</fileset>
			</path>
			<sequential>
				<!-- get the jar file name -->
				<property name="regex" value="(.*\${file.separator})(.*)" />
				<propertyregex property="jarfilename" override="true" input="@{jarfile}" regexp="${regex}" replace="\2" casesensitive="true" />

				<echo file="${application_ear_metainf}/META-INF/application.xml" append="true">&lt;module&gt;&lt;ejb&gt;${jarfilename}&lt;/ejb&gt;&lt;/module&gt;</echo>
			</sequential>
		</for>
		<echo file="${application_ear_metainf}/META-INF/application.xml" append="true">&lt;/application&gt;</echo>

		<replace dir="${application_ear_metainf}/META-INF" includes="application.xml" token="@APPLICATION_SERVICE_URI_PREFIX@" value="${application.service.uri.prefix}" />

		<!-- Add jars and application.xml to the ear -->
		<jar destfile="${application_ear}/${application.name}.ear" update="true">
			<fileset dir="${application_jars}">
				<include name="*.jar" />
				<include name="*.war" />
			</fileset>
			<!-- Add  application.xml and app server specific files to ear.-->
			<fileset dir="${application_ear_metainf}">
				<include name="**/*" />
				<exclude name="**/${framework.jar}" />
				<exclude name="**/Authentication.jar" />
			</fileset>
		</jar>
	</target>


	<!-- Build the jar conf.jar -->
	<target name="_create-update-conf-jar">
		<mkdir dir="${application_gen_src}/conf_temp" />
		<copy todir="${application_gen_src}/conf_temp">
			<fileset dir="${framework_conf}">
				<exclude name="**/${sups_config_file}" />
			</fileset>
			<filterset>
				<!-- 
            		configure properties the applications may need access to 
            		These properties are found in the file:
            			
            			framework.config.properties
            	-->
				<filter token="APPLICATION_NAME" value="${application.name}" />
				<filter token="PROJECT_CONFIG" value="${project_config_path}" />
				<filter token="FRAMEWORK_CONFIG" value="${application_config_file}" />
			</filterset>
		</copy>
		<copy todir="${application_gen_src}/conf_temp">
			<fileset dir="${framework_src}/services">
				<include name="**/${project_config_file}" />
				<include name="**/${sups_config_file}" />
			</fileset>
		</copy>
		<if>
			<equals arg1="${disable.bean.warming}" arg2="true" />
			<then>
				<propertyfile file="${application_gen_src}/conf_temp/service-method-registry.properties" comment="placeholder property file for bean warming" />
			</then>
			<else>
				<copy todir="${application_gen_src}/conf_temp">
					<fileset dir="${application_wsconfig}">
						<include name="service-method-registry.properties" />
					</fileset>
				</copy>
			</else>
		</if>
		<!-- 
                 don't rely on newer than functionality of the copy target,
                 force the application conf files to be the default 
            -->
		<if>
			<available file="${application.conf}" type="dir" />
			<then>
				<copy todir="${application_gen_src}/conf_temp" overwrite="true">
