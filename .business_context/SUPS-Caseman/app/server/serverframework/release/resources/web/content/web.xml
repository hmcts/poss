<?xml version="1.0" encoding="UTF-8"?>

<!DOCTYPE web-app PUBLIC "-//Sun Microsystems, Inc.//DTD Web Application 2.3//EN" "http://java.sun.com/dtd/web-app_2_3.dtd">

<web-app>
   <distributable/>

   <servlet>
      <servlet-name>ContentServlet</servlet-name>
      <display-name>Content Servlet</display-name>
      <servlet-class>uk.gov.dca.db.content.web.ContentServlet</servlet-class>
      <init-param>
      	<param-name>uk.gov.dca.db.SupsConfig</param-name>
      	<param-value>@project_config@</param-value>
      </init-param>
      <load-on-startup>1</load-on-startup>
   </servlet>

   <servlet-mapping>
      <servlet-name>ContentServlet</servlet-name>
      <url-pattern>/ContentServlet</url-pattern>
   </servlet-mapping>

	<ejb-ref>
		<ejb-ref-name>SecurityService</ejb-ref-name>
		<ejb-ref-type>Session</ejb-ref-type>
		<home>
			uk.gov.dca.db.security.SecurityServiceHome
		</home>
		<remote>
			uk.gov.dca.db.security.SecurityServiceRemote
		</remote>
		<ejb-link>SecurityService</ejb-link>
	</ejb-ref>
	
   <ejb-local-ref >
      <ejb-ref-name>ejb/SecurityServiceLocal</ejb-ref-name>
      <ejb-ref-type>Session</ejb-ref-type>
      <local-home>uk.gov.dca.db.security.SecurityServiceLocalHome</local-home>
      <local>uk.gov.dca.db.security.SecurityService</local>
      <ejb-link>SecurityService</ejb-link>
   </ejb-local-ref>

</web-app>
