<?xml version="1.0" encoding="UTF-8"?>
<DBMapDef>
	<DataSource id="java:SupsDS"/>
	<Tables>
		<Table alias="C" name="CASES"/>
		<Table alias="P" name="PARTIES"/>
		<Table alias="A" name="ADDRESSES"/>
		<Table alias="CTS" name="COURTS"/>
		<Table alias="CPR" name="CASE_PARTY_ROLES"/>
	</Tables>
	<Mapping>
		<Case adminCourtCode="${c.admin_crt_code}">
			<CaseId>${C.CASE_NUMBER}</CaseId>
			<CaseType>${C.CASE_TYPE}</CaseType>
			<CaseImported></CaseImported>
			<DistrictRegistryDivision></DistrictRegistryDivision>
			<Parties>
				<ClaimantParties>
					<Claimant number="${CPR.CASE_PARTY_NO}">
						<Id>${P.PARTY_ID}</Id>
						<Name>${P.PERSON_REQUESTED_NAME}</Name>
						<ContactDetails>
							<Contact>
								<Address>
									<Id>${A.ADDR_SEQ}</Id>
									<Type>${A.ADDR_type}</Type>
									<Line>${A.ADDR_1}</Line>
									<Line>${A.ADDR_2}</Line>
									<Line>${A.ADDR_3}</Line>
									<Line>${A.ADDR_4}</Line>
									<Line>${A.ADDR_5}</Line>
									<PostalCode>${A.POSTCODE}</PostalCode>
									<Reference>${A.REFERENCE}</Reference>
									<CreatedBy>${A.USERNAME}</CreatedBy>
									<ValidFrom>${A.VALID_FROM}</ValidFrom>
									<ValidTo>${A.VALID_TO}</ValidTo>
									<DXNumber>${A.DX}</DXNumber>
								</Address>
								<TelephoneNumber>${A.TEL_NO}</TelephoneNumber>
								<Reference>${A.REFERENCE}</Reference>
							</Contact>
						</ContactDetails>
						<Solicitor>										
							<Id>${P.PARTY_ID}</Id>
							<Name>${P.PERSON_REQUESTED_NAME}</Name>
							<ContactDetails>
								<Contact>
									<Address>
										<Id>${A.ADDR_SEQ}</Id>
										<Type>${A.ADDR_type}</Type>
										<Line>${A.ADDR_1}</Line>
										<Line>${A.ADDR_2}</Line>
										<Line>${A.ADDR_3}</Line>
										<Line>${A.ADDR_4}</Line>
										<Line>${A.ADDR_5}</Line>
										<PostalCode>${A.POSTCODE}</PostalCode>
										<Reference>${A.REFERENCE}</Reference>
										<CreatedBy>${A.USERNAME}</CreatedBy>
										<ValidFrom>${A.VALID_FROM}</ValidFrom>
										<ValidTo>${A.VALID_TO}</ValidTo>
										<DXNumber>${A.DX}</DXNumber>
									</Address>					
									<TelephoneNumber>${A.TEL_NO}</TelephoneNumber>
									<Reference>${A.REFERENCE}</Reference>
								</Contact>
							</ContactDetails>
							<NotificationDate></NotificationDate>
						</Solicitor>
						<SolicitorPayee></SolicitorPayee>
					</Claimant>
			</ClaimantParties>
			<DefendantParties>
				<Defendant number="${CPR.CASE_PARTY_NO}">
					<Id>${P.PARTY_ID}</Id>
					<Name>${P.PERSON_REQUESTED_NAME}</Name>
					<ContactDetails>
						<Contact>
							<Address>
								<Id>${A.ADDR_SEQ}</Id>
								<Type>${A.ADDR_type}</Type>
								<Line>${A.ADDR_1}</Line>
								<Line>${A.ADDR_2}</Line>
								<Line>${A.ADDR_3}</Line>
								<Line>${A.ADDR_4}</Line>
								<Line>${A.ADDR_5}</Line>
								<PostalCode>${A.POSTCODE}</PostalCode>
								<Reference>${A.REFERENCE}</Reference>
								<CreatedBy>${A.USERNAME}</CreatedBy>
								<ValidFrom>${A.VALID_FROM}</ValidFrom>
								<ValidTo>${A.VALID_TO}</ValidTo>
								<DXNumber>${A.DX}</DXNumber>
							</Address>
							<TelephoneNumber>${A.TEL_NO}</TelephoneNumber>
							<Reference>${A.REFERENCE}</Reference>
						</Contact>
					</ContactDetails>
					<Solicitor>										
						<Id>${P.PARTY_ID}</Id>
						<Name>${P.PERSON_REQUESTED_NAME}</Name>
						<ContactDetails>
							<Contact>
								<Address>
									<Id>${A.ADDR_SEQ}</Id>
									<Type>${A.ADDR_type}</Type>
									<Line>${A.ADDR_1}</Line>
									<Line>${A.ADDR_2}</Line>
									<Line>${A.ADDR_3}</Line>
									<Line>${A.ADDR_4}</Line>
									<Line>${A.ADDR_5}</Line>
									<PostalCode>${A.POSTCODE}</PostalCode>
									<Reference>${A.REFERENCE}</Reference>
									<CreatedBy>${A.USERNAME}</CreatedBy>
									<ValidFrom>${A.VALID_FROM}</ValidFrom>
									<ValidTo>${A.VALID_TO}</ValidTo>
									<DXNumber>${A.DX}</DXNumber>
								</Address>					
								<TelephoneNumber>${A.TEL_NO}</TelephoneNumber>
								<Reference>${A.REFERENCE}</Reference>
							</Contact>
						</ContactDetails>
						<NotificationDate></NotificationDate>
					</Solicitor>
					<SolicitorPayee></SolicitorPayee>
					<DateOfService></DateOfService>
				</Defendant>
			</DefendantParties>
		</Parties>
		<Details></Details>
			<OwningCourt>
				<Id>${CTS.CODE}</Id>
				<Name>${CTS.NAME}</Name>
			</OwningCourt>
			<Status>${C.STATUS}</Status>
			<HearingDetails>
				<Type></Type>
				<Date></Date>
				<Time></Time>	
				<Location>
					<Id></Id>
					<Name></Name>
					<Address>
						<Line></Line>
						<Line></Line>
						<Line></Line>
						<Line></Line>
						<Line></Line>
						<PostalCode></PostalCode>
					</Address>
					<TelephoneNumber></TelephoneNumber>
				</Location>
			</HearingDetails>
			<DetailsOfClaim>
				<AmountClaimed></AmountClaimed>
				<CourtFee></CourtFee>
				<SolicitorsCosts></SolicitorsCosts>
				<Total></Total>
				<DateRequestReceived></DateRequestReceived>
				<DateOfIssue></DateOfIssue>
			</DetailsOfClaim>
			<Variables>
				<ClaimantIndex></ClaimantIndex>
				<DefendantIndex></DefendantIndex>
			</Variables>
		</Case>
	</Mapping>
</DBMapDef>