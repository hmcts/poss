<?xml version="1.0" encoding="UTF-8"?>
<service-method>
	<pipeline>
		<LinkedQuery>
			<QueryDef location="uk/gov/dca/test_project/linked_service/query_def.xml"/>
			<QueryExtension pivotNode="/Cases/Case">
				<Param name="param.pageSize" xpath="/params/param[@name='pageSize']"/>
				<Param name="param.pageNumber" xpath="/params/param[@name='pageNumber']"/>
				<Paged pageNumber="${param.pageNumber}"
					pageSize="${param.pageSize}"/>
			</QueryExtension>
		</LinkedQuery>
	</pipeline>
	<Security roles="user"/>
</service-method>