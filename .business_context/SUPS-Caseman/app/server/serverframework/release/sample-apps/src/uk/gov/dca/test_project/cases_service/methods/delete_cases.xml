<?xml version="1.0" encoding="UTF-8"?>
<service-method>
	<pipeline>
		<Update>
			<QueryDef location="uk/gov/dca/test_project/cases_service/cases_query_def.xml"/>
			<DataSource xpath="/params/param[@name='cases']"/>
			<QueryExtension pivotNode="/Cases/Case">
				<CheckExists table="c" fields="case_number" onExist="delete" onNotExist="fail"/>
			</QueryExtension>
		</Update>
	</pipeline>
	<Security roles="user"/>
</service-method>