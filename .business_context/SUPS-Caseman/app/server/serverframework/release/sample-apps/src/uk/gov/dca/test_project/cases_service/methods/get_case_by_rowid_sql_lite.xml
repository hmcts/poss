<?xml version="1.0" encoding="UTF-8"?>
<service-method>
	<pipeline>
                <SQLLite> 
                        <DataSource id="java:SupsDS"/> 
                        <Param name="params.rowId" xpath="/params/param[@name='rowId']"/> 
                        <SQL> 
                                SELECT CASE_NUMBER
                                FROM CASES 
                                WHERE ROWID=${params.rowId} 
                        </SQL> 
                </SQLLite> 
	</pipeline>
	<Dependencies>
		<Dependency serviceName="Test"/> 
	</Dependencies>
	<Security roles="user"/>
</service-method>