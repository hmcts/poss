<?xml version="1.0" encoding="UTF-8"?>
<service-method>
	<pipeline>
		<XSDValidate>
			<Schema location="uk/gov/dca/test_project/cases_service/xml_schemas/get_case_params.xsd"/>
		</XSDValidate>
		<Query>
			<QueryDef location="uk/gov/dca/test_project/cases_service/query_def.xml"/>
			<QueryExtension pivotNode="/Case">
				<Param name="param.caseNumber" xpath="/params/param[@name='caseNumber']"/>
				<Constraint>c.case_number = ${param.caseNumber}</Constraint>
			</QueryExtension>
		</Query>
	</pipeline>
	<Security roles="user"/>
</service-method>