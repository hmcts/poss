<?xml version="1.0" encoding="UTF-8"?>
<service-method>
	<pipeline>
		<LinkedQuery>
			<QueryDef location="uk/gov/dca/test_project/linked_service/query_def_linked_sql.xml"/>
			<QueryExtension pivotNode="/Cases/Case">
				<Param name="param.caseNumber" xpath="/params/param[@name='caseNumber']"/>
				<Constraint>c.case_number = ${param.caseNumber}</Constraint>
			</QueryExtension>
		</LinkedQuery>
	</pipeline>
	<Security roles="user"/>
</service-method>