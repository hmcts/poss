<?xml version="1.0" encoding="UTF-8"?>
<service-method>
	<pipeline>
		<Update>
			<QueryDef location="uk/gov/dca/test_project/cases_service/query_def.xml"/>
			<DataSource xpath="/params/param[@name='case']"/>
			<QueryExtension pivotNode="/Case">
				<CheckExists table="c" fields="case_number" onNotExist="fail"/>
			</QueryExtension>
		</Update>
		<Java>
			<Source class="uk.gov.dca.test_project.cases_service.classes.SystemExceptionInitiator"/>
		</Java>
	</pipeline>
	<Security roles="user"/>
</service-method>