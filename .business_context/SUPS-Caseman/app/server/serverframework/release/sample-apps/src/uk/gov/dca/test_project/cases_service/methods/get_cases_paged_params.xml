<?xml version="1.0" encoding="UTF-8"?>
<service-method>
	<pipeline>
		<Query>
			<QueryDef location="uk/gov/dca/test_project/cases_service/cases_query_def.xml"/>
			<QueryExtension pivotNode="/Cases/Case">
				<Param name="param.pageNumber" xpath="/params/param[@name='pageNumber']"/>
				<Param name="param.pageSize" xpath="/params/param[@name='pageSize']"/>
				
				<Paged pageNumber="${param.pageNumber}" pageSize="${param.pageSize}"/>
				<OrderBy>C.CASE_NUMBER</OrderBy>
			</QueryExtension>
		</Query>
	</pipeline>
	<Security roles="user"/>
</service-method>