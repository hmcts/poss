<?xml version="1.0" encoding="UTF-8"?>
<service-method>
	<pipeline>
		<Query>
			<QueryDef location="uk/gov/dca/test_project/cases_service/cases_query_def.xml"/>
			<QueryExtension pivotNode="/Cases/Case">
				<Param name="param.caseNumber" xpath="/params/param[@name='caseNumber']"/>
				<Param name="param.caseType" xpath="/params/param[@name='caseType']"/>
				<Param name="param.adminCourtCode" xpath="/params/param[@name='adminCourtCode']"/>
				<Constraint condition="/params/param[@name='caseNumber']">C.CASE_NUMBER = ${param.caseNumber}</Constraint>
				<Constraint condition="/params/param[@name='caseType']">C.CASE_TYPE = ${param.caseType}</Constraint>
				<Constraint condition="/params/param[@name='adminCourtCode']">C.ADMIN_CRT_CODE = ${param.adminCourtCode}</Constraint>
			</QueryExtension>
		</Query>
	</pipeline>
	<Security roles="user"/>
</service-method>