<?xml version="1.0" encoding="UTF-8"?>
<service-method>
	<pipeline>
		<Update>
			<QueryDef location="uk/gov/dca/test_project/cases_service/query_def.xml"/>
			<DataSource xpath="/params/param[@name='case']"/>
			<QueryExtension pivotNode="/Case">
				<CheckExists table="c" fields="case_number" onNotExist="fail"
					condition="./FailFlag = 'true'" onConditionTrue="fail" onConditionFalse="continue"/>
			</QueryExtension>
		</Update>
	</pipeline>
	<Security roles="user"/>
</service-method>