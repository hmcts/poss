		<!-- *** update the following value to specify the database schema to validate against *** -->
		<item id="validation:schema" class="uk.gov.dca.db.impl.StringConfigurationItem">FWK_UT01</item>
		<!-- *** Comment out the following line or change the value to 'active' to activate security *** -->
		<item id="security:status" class="uk.gov.dca.db.impl.StringConfigurationItem">active</item>
		<item id="security:forceSSL" class="uk.gov.dca.db.impl.BooleanConfigurationItem">true</item>
		
		<!-- *** update the following value to specify your application name.  
				This is used to sepearate your logs in the production environment. *** -->
