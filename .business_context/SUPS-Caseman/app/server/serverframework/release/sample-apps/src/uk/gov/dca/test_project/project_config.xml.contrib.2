		<item id="application:serviceprefix" class="uk.gov.dca.db.impl.StringConfigurationItem">/test_project</item>
		<item id="application:webprefix" class="uk.gov.dca.db.impl.StringConfigurationItem">/sample-apps</item>
		 
		<item id="java:AsyncDS" class="uk.gov.dca.db.impl.JNDIConfigurationItem">java:SupsDS</item>
		
		<!-- Example Queue configuration for OAS -->

		<item id="TestQueue" class="uk.gov.dca.db.impl.QueueConfigurationItem">
			<factory>jms/QueueConnectionFactory</factory>
			<jndi-name>jms/sups_test_queue</jndi-name>
			<min-pool-size>10</min-pool-size>
			<max-pool-size>10</max-pool-size>
		</item>
		
		<item id="ReportHigh" class="uk.gov.dca.db.impl.AQConfigurationItem">
			<factory>java:comp/resource/reportingAQ/QueueConnectionFactories/myQCF</factory>
			<jndi-name>java:comp/resource/reportingAQ/Queues/q1_report_high</jndi-name>
		</item>
		
		<item id="uk.gov.dca.fw.reportConfig" 
			class="uk.gov.dca.db.impl.PropertyConfigurationItem">fw01</item>
		
		<item id="uk.gov.dca.fw.dictionaryLocation" 
