<?xml version="1.0" encoding="UTF-8"?>
<service-method>
	<pipeline>
		<SQLLite>
			<DataSource id="java:SupsDS"/>
			<Param name="params.name" xpath="/params/param[@name='name']"/>
			<SQL type="insert">
				INSERT INTO MY_TABLE (NAME) VALUES (${params.name})
			</SQL>
		</SQLLite>
	</pipeline>
	<Security roles="user"/>
</service-method>