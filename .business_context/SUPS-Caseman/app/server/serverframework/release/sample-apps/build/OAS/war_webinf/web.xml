<?xml version="1.0" encoding="UTF-8"?>

<!DOCTYPE web-app PUBLIC "-//Sun Microsystems, Inc.//DTD Web Application 2.3//EN" "http://java.sun.com/dtd/web-app_2_3.dtd">

<web-app>
	<distributable />

   <servlet>
      <servlet-name>RequestDispatcherServlet</servlet-name>
      <display-name>Request Dispatcher Servlet</display-name>
      <servlet-class>uk.gov.dca.db.invoke.server.RequestDispatcher</servlet-class>
      <load-on-startup>2</load-on-startup>
      <init-param>
      	<param-name>serviceConfigLocation</param-name>      	
      	<param-value>${service_config_directory}</param-value>      	
      </init-param>
   </servlet>
   
   <servlet>
      <servlet-name>KeepAliveServlet</servlet-name>
      <display-name>KeepAlive Servlet</display-name>
      <servlet-class>uk.gov.dca.db.heartbeat.KeepAliveServlet</servlet-class>
      <load-on-startup>1</load-on-startup>
   </servlet>

   <servlet>
      <servlet-name>FrameworkCheckServlet</servlet-name>
      <display-name>Framework Check Servlet</display-name>
      <servlet-class>uk.gov.dca.db.check.web.CheckServlet</servlet-class>
      <load-on-startup>3</load-on-startup>
   </servlet>

	<servlet-mapping>
		<servlet-name>RequestDispatcherServlet</servlet-name>
		<url-pattern>/InvokerServlet</url-pattern>
	</servlet-mapping>

   <servlet-mapping>
      <servlet-name>KeepAliveServlet</servlet-name>
      <url-pattern>/KeepAliveServlet</url-pattern>
   </servlet-mapping>

   <servlet-mapping>
      <servlet-name>FrameworkCheckServlet</servlet-name>
      <url-pattern>/FrameworkCheckServlet</url-pattern>
   </servlet-mapping>


