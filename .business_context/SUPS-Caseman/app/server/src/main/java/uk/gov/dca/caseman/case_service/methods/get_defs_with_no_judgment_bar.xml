<service-method>
	<pipeline>
		<Query>
			<QueryDef location="uk/gov/dca/caseman/case_service/query_def_defs_with_no_judgment_bar.xml"/>
			<QueryExtension pivotNode="/Case/Parties/Party">
				<Param name="param.caseNumber" xpath="/params/param[@name = 'caseNumber']"/>
				<Constraint>CPR.CASE_NUMBER = ${param.caseNumber}</Constraint>		
			</QueryExtension>
		</Query>
	</pipeline>
	<Security roles="user"/>
</service-method>


