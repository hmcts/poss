<?xml version="1.0" encoding="UTF-8"?>
<!--
	Service: Court
	Method:  getCourtDetails()
	File:    get_court_details.xml
	Author:  Ian Stainer (Valtech)
	Created: 16 November 2005
	Description: 
		Retrieves the details for the gien court.
-->
<service-method>
	<pipeline>
		<SQLLite format-output="true"
				 resultset-element="Court"
				 row-element="CourtDetails"
				 field-name-as="element" >			
			<DataSource id="java:OracleDS"/>
			<Param name="param.courtId" xpath="/params/param[@name = 'courtId']"/>
			<SQL>												
				SELECT  code as "Code",
						name as "Name"
				FROM    courts
				WHERE	code = ${param.courtId}
			</SQL>
		</SQLLite>		
	</pipeline>
	<Security roles="viewOnly medium high wcSuper scSuper bmsSuper aeSuper dmSuper admin cpSuper ccbcMan ccbcUser ccbcSGB2 ccbcTape"/>		
</service-method>