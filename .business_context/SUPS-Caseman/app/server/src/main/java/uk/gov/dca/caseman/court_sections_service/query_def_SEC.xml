<?xml version="1.0" encoding="UTF-8"?>
<QueryDef>
	<DBMapDef location="uk/gov/dca/caseman/court_sections_service/map_SEC.xml"/>
	<Query pivotNode="/ds/CourtDetails" tables="CR">
	    <LinkedJoin type="root" key="CR.CODE">
	    	<Join/>
	    </LinkedJoin>
	</Query>
	<Query pivotNode="/ds/CourtDetails/Sections/Section" tables="CR SE">
	    <LinkedJoin type="query" key="SE.ADMIN_COURT_CODE SE.SECTION_NAME">
	    	<Parent key="CR.CODE" tables="CR"/>
			<Join>
		 		SE.ADMIN_COURT_CODE = CR.CODE
      		</Join>
	    </LinkedJoin>
	</Query>
</QueryDef>
