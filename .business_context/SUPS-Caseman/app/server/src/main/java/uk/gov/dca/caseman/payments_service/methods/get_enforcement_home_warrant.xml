<?xml version="1.0" encoding="UTF-8"?>
<!--
	Service: Payments
	Method: getEnforcementHomeWarrant()
	File: get_enforcement_home_warrant.xml
	Author: Steve Blair
	Description:
		Get Home Warrant details for Suitors Cash. Called from getEnforcement.
-->
<service-method>
	<pipeline>
		<Query>
			<QueryDef location="uk/gov/dca/caseman/payments_service/query_def_enforcement/home_warrant.xml" />
			<QueryExtension pivotNode="/Enforcement">
				<Param name="param.warrantNumber" xpath="/params/param[@name = 'warrantNumber']" />
				<Param name="param.issuingCourt" xpath="/params/param[@name = 'issuingCourt']" />
			</QueryExtension>
		</Query>
	</pipeline>
	<Security roles="viewOnly medium high wcSuper scSuper bmsSuper aeSuper dmSuper"/>
</service-method>