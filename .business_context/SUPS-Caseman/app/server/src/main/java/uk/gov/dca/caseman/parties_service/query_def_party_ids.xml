<?xml version="1.0" encoding="UTF-8"?>
<QueryDef>
	<DBMapDef location="uk/gov/dca/caseman/parties_service/map_party_ids.xml" />
	<Query pivotNode="/Parties/Party" tables="C">
		<SQL type="select">
			SELECT C.PARTY_ID AS "C_PARTY_ID" FROM CASE_PARTY_ROLES C
			WHERE C.CASE_NUMBER = ${param.caseNumber}
		</SQL>
		<Modify notModifiable="true" />
	</Query>
</QueryDef>