<?xml version="1.0" encoding="UTF-8"?>
<!--
	Service: Payments
	Method: getEnforcementCase()
	File: get_enforcement_case.xml
	Author: Steve Blair
	Description:
		Get Case details for Suitors Cash. Called from getEnforcement.
-->
<service-method>
	<pipeline>
		<Query>
			<QueryDef location="uk/gov/dca/caseman/payments_service/query_def_enforcement/case.xml" />
			<QueryExtension pivotNode="/Enforcement">
				<Param name="param.caseNumber" xpath="/params/param[@name = 'caseNumber']" />
			</QueryExtension>
		</Query>
	</pipeline>
	<Security roles="viewOnly medium high wcSuper scSuper bmsSuper aeSuper dmSuper"/>
</service-method>