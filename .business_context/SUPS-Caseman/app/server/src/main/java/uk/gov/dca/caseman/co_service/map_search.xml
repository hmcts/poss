<?xml version="1.0" encoding="UTF-8"?>
<DBMapDef>
  <DataSource id="java:OracleDS"/>
  <Tables>
    <Table alias="CO" name="CONSOLIDATED_ORDERS"/>
	<Table alias="GA"  name="GIVEN_ADDRESSES"/>
  </Tables>
  <Mapping>
	<Results>
      <CoRecord>
		<CONumber>${CO.CO_NUMBER}</CONumber>
		<OldCONumber>${CO.OLD_NUMBER}</OldCONumber>
		<Status>${CO.CO_STATUS}</Status>
		<Debtor>
			<PartyName>${CO.DEBTOR_NAME}</PartyName>
			<ContactDetails>
				<Address>
					<Line>${GA.ADDRESS_LINE1}</Line>
				</Address>
			</ContactDetails>
		</Debtor>
      </CoRecord>
	</Results>
  </Mapping>
</DBMapDef>


