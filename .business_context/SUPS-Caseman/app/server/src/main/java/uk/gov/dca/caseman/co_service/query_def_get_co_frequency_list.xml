<?xml version="1.0" encoding="UTF-8"?>
<!--
	Service: Co
	Method:  getCoFrequencyList()
	File:    query_def_get_co_frequency_list.xml
	Author:  Phil Haferer (EDS)
	Created: 01 September 2005
	Description: 
		Retrieve the list of Consolidated Order Frequencies.
-->
<QueryDef>
  <DBMapDef location="uk/gov/dca/caseman/co_service/map_get_co_frequency_list.xml"/>
  <Query pivotNode="/COFrequency/Frequency" tables="REF">
    <Join>
		REF.RV_DOMAIN = 'CONSOLIDATED_ORDERS.FREQUENCY'         
    </Join>
    <Modify notModifiable="true"/>
  </Query>
</QueryDef>
