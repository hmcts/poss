<?xml version="1.0" encoding="UTF-8"?>
<!--
	Service: Codedparty
	Method:  getCodedPartiesShortNew()
	File:    map_short_new.xml
	Author:  Phil Haferer
	Created: 11/07/2006
	Description: 
		Map used as a summary list of Coded Parties for both Local and National lists.

	Change History:
	12-Jul-2006 Phil Haferer: Modified to use the copy of the name and address in CODED_PARTIES table to improve performance.
	            (TD 3949: Performance: Wildcard search on Coded Party name).
-->
<DBMapDef>
  <DataSource id="java:OracleDS"/>
  <Tables>
    <Table alias="CP" name="CODED_PARTIES"/>
  </Tables>
  <Mapping>
    <CodedParties>
    	<CodedParty>
    		<Code>${CP.CODE}</Code>
    		<Name>${CP.PERSON_REQUESTED_NAME}</Name>	
			<Line>${CP.ADDRESS_LINE1}</Line>
			<Line>${CP.ADDRESS_LINE2}</Line>
    	</CodedParty>
    </CodedParties>	
  </Mapping>
</DBMapDef>