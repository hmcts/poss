<?xml version="1.0" encoding="UTF-8"?>
<DBMapDef>
	<DataSource id="java:OracleDS"/>
	
	<Tables>
		<Table alias="T" name="TAPES"/>	
		<Table alias="TFI" name="TAPE_FILES" />	
	</Tables>
	
	<Mapping>
			<ReturnedTape>
				<LibraryNumber>${T.SEQNO}</LibraryNumber>
				<Degaussed>${T.DEGAUSSED}</Degaussed>
				<DateReturned>${T.DATE_RETD_CUST}</DateReturned>
				<Comments>${T.COMMENTS}</Comments>
				<TapeFiles>
					<TapeFile>
						<OrderSeq>${TFI.ORDERSEQ}</OrderSeq>
						<NumberOfRecords>${TFI.NO_RECORDS}</NumberOfRecords>
						<Fees>${TFI.FEES}</Fees>
						<Comments>${TFI.OUTPUTS}</Comments>
					</TapeFile>
				</TapeFiles>
			</ReturnedTape>
	</Mapping>
</DBMapDef>