<?xml version="1.0" encoding="UTF-8"?>
<!--
	Service: Co
	Method:  getCoHeader()
	File:    query_def_get_co_header.xml
	Author:  Phil Haferer (EDS)
	Created: 08 September 2005
	Description: 
		Retrieves summary details for a Consolidated Order, 
		together with the associated Allowed Debts.
-->
<QueryDef>
  <DBMapDef location="uk/gov/dca/caseman/co_service/map_get_co_header.xml"/>
  <Query pivotNode="/ds/MaintainCO" tables="CO CRT CRTTRAN">
	<Join>
		    CRT.CODE     =    CO.ADMIN_COURT_CODE
		AND CRTTRAN.CODE (+)= CO.COURT_OF_TRANSFER
	</Join>
  </Query>
</QueryDef>
