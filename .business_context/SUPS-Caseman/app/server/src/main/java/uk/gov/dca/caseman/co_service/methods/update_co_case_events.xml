<?xml version="1.0" encoding="UTF-8"?>
<!--
	Service: Co
	Method:  updateCo()
	File:    update_co_case_events.xml
	Author:  Steve Blair
	Created: 26 June 2006
	Description: 
		Fires a CO or CO_case event depending upon existance of case in SUPS.
-->
<service-method>
	<pipeline>
		<Java callStyle="new">
			<Source class="uk.gov.dca.caseman.co_service.java.UpdateCoCaseEventsCustomProcessor" />
		</Java>
	</pipeline>
	<Dependencies>
		<Dependency serviceName="Case" />
		<Dependency serviceName="CaseEvent" />		
		<Dependency serviceName="CoEvent" />		
	</Dependencies>		
	<Security roles="medium high wcSuper scSuper bmsSuper aeSuper dmSuper cpSuper" />		
</service-method>