<?xml version="1.0" encoding="UTF-8"?>
<!--
	v1.0 Chris Hutt 27/9/2005
	Returns a list of parties associated with the case
	against whom an active judgment which is a candidate for redetermination exists.
	This is determined as follows:
		ACTIVE: 						JUDGMENTS.STATUS -  'VARIED' or NULL.
		AVAILABLE FOR REDETERMINATION:  JUDGMENT_TYPE of 'Judges' and unregistered (ie SENT_TO_RTL is null). 
		
	InfavourOf parties also returned
	
-->
<service-method>
	<pipeline>
		<NewQuery>
			<QueryDef location="uk/gov/dca/caseman/judgment_service/query_def_parties_with_judgment_for_redetermination.xml"/>
			<QueryExtension pivotNode="/JudgmentsForRedetermination/Judgment">
				<Param name="param.caseNumber" xpath="/params/param[@name = 'caseNumber']"/>
				<Constraint>JDG.CASE_NUMBER = ${param.caseNumber}</Constraint>		
			</QueryExtension>
		</NewQuery>
	</pipeline>
	<Security roles="user"/>
</service-method>


