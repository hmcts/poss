<?xml version="1.0" encoding="UTF-8"?>
<!--
	Service: Payout
	Method:  getPayoutRunningStatus()
	File:    get_payout_running_status.xml
	Author:  Mark Hallam (EDS)
	Created: 9th December 2005
	Description: 
		Determine whether the payout or dividend payout is currently being run.
-->
<service-method>
	<pipeline>
		<SQLLite format-output="true"
				 resultset-element="ds"
				 row-element="PayoutRunning"
				 field-name-as="element" >
			<DataSource id="java:OracleDS"/>
				<Param name="param.adminCourtCode" xpath="/params/param[@name='adminCourtCode']"/>
			
			<SQL>
				
			   	SELECT RD.REPORT_TYPE                AS "reportType"
        		,      RD.ADMIN_COURT_CODE    AS "adminCourtCode"   
  				FROM REPORT_DATA RD
  				WHERE RD.REPORT_TYPE IN ('PAY', 'DIV')
				AND RD.ADMIN_COURT_CODE = ${param.adminCourtCode}
  				
  				
			</SQL>
		</SQLLite>
	</pipeline>
	<Security roles="viewOnly medium high wcSuper scSuper bmsSuper aeSuper dmSuper edsAdmin"/>	
</service-method>