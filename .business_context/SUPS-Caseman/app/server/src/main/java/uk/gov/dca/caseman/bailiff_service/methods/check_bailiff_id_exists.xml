<?xml version="1.0" encoding="UTF-8"?>
<!--
	Service: Bailiff
	Method:  checkBailiffIdExists()
	File:    query_def_bailiff_id_exists.xml
	Description: Checks if a Bailiff ID exists on the database.

	Change History:
	25-May-2006 Phil Haferer (EDS): Updated the Security Roles.
                TD 3437: BAILIFF EFFECTIVENESS REPORT: Oracle Reports UC053: Error when specifying specific Bailiff ID.
    04/08/2006 - Chris Vincent: fixed defect 4141 by adding security role ccbcMan to the service.
	27-Sep-2006 Phil Haferer (EDS): Added W.CURRENTLY_OWNED_BY to SQL statement.
                (TD CASEMAN 5320: NO Error Message displayed).
-->
<service-method>
	<pipeline>
		<Query>
			<QueryDef location="uk/gov/dca/caseman/bailiff_service/query_def_bailiff_id_exists.xml"/>
			<QueryExtension pivotNode="/BailiffFound">
				<Param name="param.currentlyOwnedBy" xpath="/params/param[@name = 'currentlyOwnedBy']"/>
				<Param name="param.bailiffId"        xpath="/params/param[@name = 'bailiffId']"/>
			</QueryExtension>
		</Query>
	</pipeline>
	<Security roles="medium high wcSuper scSuper bmsSuper aeSuper dmSuper cpSuper ccbcMan"/>
</service-method>