<?xml version="1.0" encoding="UTF-8"?>
<!--
	Service: Obligation
	Method:  getObligations()
	File:    get_obligations
	Author:  Ian Stainer
	Created: 08/02/2005
	Description: 
        Returns the existing obligations for the given case.
-->
<service-method>
	<pipeline>
		<NewQuery>
			<QueryDef location="uk/gov/dca/caseman/obligation_service/query_def_get_obligations.xml"/>
			<QueryExtension pivotNode="/ds/MaintainObligations">
				<Param name="param.caseNumber" xpath="/params/param[@name = 'caseNumber']"/>
				<Constraint>C.CASE_NUMBER = ${param.caseNumber}</Constraint>
			</QueryExtension>
		</NewQuery>
	</pipeline>
	<Security roles="viewOnly medium high wcSuper scSuper bmsSuper aeSuper dmSuper cpSuper ccbcMan ccbcUser ccbcSGB2"/> 	
</service-method>