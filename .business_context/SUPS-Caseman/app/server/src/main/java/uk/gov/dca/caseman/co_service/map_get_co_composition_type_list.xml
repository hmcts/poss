<?xml version="1.0" encoding="UTF-8"?>
<!--
	Service: Co
	Method:  getCoCompositionTypeList()
	File:    get_co_composition_type_list.xml
	Author:  Phil Haferer (EDS)
	Created: 01 September 2005
	Description: 
		Retrieve the list of Consolidated Order Composition Types.
-->
<DBMapDef>
	<DataSource id="java:OracleDS"/>
	<Tables>
		<Table alias="REF"  name="CCBC_REF_CODES"/>		
	</Tables>
	<Mapping>
		<COCompTypes>
			<CompType>
				<Value>${REF.RV_LOW_VALUE}</Value>
				<Description>${REF.RV_MEANING}</Description>
			</CompType>
		</COCompTypes>
	</Mapping>
</DBMapDef>
