<DBMapDef>
<DataSource id="java:OracleDS"/>
<Tables>
<Table alias="WFT" name="WINDOW_FOR_TRIAL"/>
<Table alias="WFE" name="WFT_EXCLUSIONS"/>
</Tables>
  <Mapping>
	  <WindowsForTrial>
	     <Event>
  	        <CaseEventSeq></CaseEventSeq>
  	        <Details></Details>
	    </Event>
	    <WindowForTrial>
		<CaseNumber>${WFT.WFT_CASE_NUMBER}</CaseNumber>
		<CurrentCourtCode>${WFT.WFT_CURRENT_COURT}</CurrentCourtCode>
		<!--DatesSet>${WFT.DATES_SET}</DatesSet-->
		<WFTId>${WFT.WFT_ID}</WFTId>
		<Track>${WFT.WFT_TRACK}</Track>
		<DatesExist></DatesExist>
		<StartDate>${WFT.WFT_START_DATE}</StartDate>
		<EndDate>${WFT.WFT_END_DATE}</EndDate>
		<Days>${WFT.WFT_ESTIMATED_DAYS}</Days>
		<Hours>${WFT.WFT_ESTIMATED_HOURS}</Hours>
		<Mins>${WFT.WFT_ESTIMATED_MINS}</Mins>
		<WFTStatus>${WFT.WFT_STATUS}</WFTStatus>
		<StatusDate>${WFT.WFT_OUTCOME_DATE}</StatusDate>
		<Judge>${WFT.WFT_JUDGES_NAME}</Judge>
		<ReasonForAdjournment>${WFT.WFT_REASON_FOR_ADJ}</ReasonForAdjournment>
		<CMCDate>${WFT.WFT_CASE_MANAGE_CONF_DATE}</CMCDate>
		<CMCFlag>${WFT.WFT_CASE_MANAGE_CONF_FLAG}</CMCFlag>
		<Notes>${WFT.WFT_NOTES}</Notes>				
		<Dates>					
		  <Date>
		    <Value>${WFE.WFE_EXCLUSION_DATE}</Value>
		    <Excluded></Excluded>
		  </Date>
		</Dates>				
	    </WindowForTrial>
	  </WindowsForTrial>		
  </Mapping>
</DBMapDef>