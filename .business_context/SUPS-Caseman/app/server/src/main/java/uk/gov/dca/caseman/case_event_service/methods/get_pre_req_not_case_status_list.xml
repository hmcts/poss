<?xml version="1.0" encoding="UTF-8"?>
<!--
	Service: CaseEvent
	Method:  getPreReqNotCaseStatusList
	Author:  Chris Hutt (EDS) 
	Created: 19 March 2007
	Description: 
		List of case statuses which a case cannot have if specified events are to be entered
-->
<service-method>
	<pipeline>
		<Query>
			<QueryDef location="uk/gov/dca/caseman/case_event_service/query_def_get_pre_req_not_case_status_list.xml"/>
			<QueryExtension pivotNode="/PreRequisiteNotCaseStatuses/Status">
				<Param name="param.eventId" xpath="/params/param[@name = 'eventId']"/>
				<Constraint>CCBC.RV_LOW_VALUE = ${param.eventId}</Constraint>
			</QueryExtension>
		</Query>
	</pipeline>
	<Security roles="user"/>
</service-method>

