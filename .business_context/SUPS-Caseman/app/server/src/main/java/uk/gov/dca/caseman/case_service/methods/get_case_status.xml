<service-method>
	<pipeline>
		<Query>
			<QueryDef location="uk/gov/dca/caseman/case_service/query_def_casestatus.xml"/>
			<DataSource xpath="/params/param[@name='caseNumber']"/>
			<QueryExtension pivotNode="/Case">
				<Param name="param.caseNumber" xpath="/params/param[@name = 'caseNumber']"/>
				<Constraint>C.CASE_NUMBER = ${param.caseNumber}</Constraint>
			</QueryExtension>
		</Query>
	</pipeline>
	<Security roles="user"/>
</service-method>

