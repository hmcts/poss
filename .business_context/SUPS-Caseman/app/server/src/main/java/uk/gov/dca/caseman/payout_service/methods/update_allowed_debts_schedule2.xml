<?xml version="1.0" encoding="UTF-8"?>
<!--
	Service: Payout
	Method:  updateAllowedDebtsSchedule2()
	File:    update_allowed_debts_schedule2.xml
	Author:  A Bonnar (EDS)
	Created: 6th March 2006
	Description: 
		Method to implement update the Allowed Debts, setting status = LIVE

    Change History:
    06-Apr-2006 Phil Haferer: Removed Admin Court Code from WHERE clause, as it was not required.
-->
<service-method>
	<pipeline>
		<SQLLite output="input">
			<DataSource id="java:OracleDS"/>
			<Param name="param.coNumber"          xpath="/params/param[@name='coNumber']"/>
			<Param name="param.status"            xpath="/params/param[@name='status']"/>
			<SQL type="update" tables="ALLOWED_DEBTS">
				UPDATE ALLOWED_DEBTS AD
				SET    AD.DEBT_STATUS           = ${param.status}
				WHERE  AD.DEBT_STATUS           = 'SCHEDULE2'
				AND    AD.DEBT_CO_NUMBER        = ${param.coNumber}
			</SQL>
		</SQLLite>
	</pipeline>
	<Security roles="viewOnly medium high wcSuper scSuper bmsSuper aeSuper dmSuper edsAdmin"/>		
</service-method>
