<?xml version="1.0" encoding="UTF-8"?>
<!--
	Service: WarrantReturn
	Method:  getWarrantReturnForMcol()
	File:    get_warrant_return_for_mcol.xml
	Author:  Chris Vincent (EDS)
	Created: 05 July 2007
	Description: 
		Return the details of the warrant return linked to a case event.  The details returned are for 
		use by MCOL.
-->
<service-method>
	<pipeline>
		<SQLLite format-output="true"
				 resultset-element="ds"
				 row-element="WarrantReturn"
				 field-name-as="element" >
			<DataSource id="java:OracleDS"/>
			<Param name="param.warrantReturnId" xpath="/params/param[@name = 'warrantReturnId']"/>
			<SQL>
				SELECT WR.WARRANT_RETURNS_ID     AS "WarrantReturnId"
				,      WR.RETURN_CODE 		     AS "ReturnCode"
				,      WR.ADDITIONAL_INFORMATION AS "AdditionalInformation"
				FROM   WARRANT_RETURNS WR
				WHERE  WR.WARRANT_RETURNS_ID = ${param.warrantReturnId}
			</SQL>
		</SQLLite>
	</pipeline>
	<Security roles="viewOnly medium high wcSuper scSuper bmsSuper aeSuper dmSuper cpSuper"/>					
</service-method>
