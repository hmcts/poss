<QueryDef>
	<DBMapDef location="uk/gov/dca/caseman/payments_service/map_check_outstanding_payments_exist.xml" />
	<Query pivotNode="/OutstandingPaymentsExist" tables="PY">
		<SQL type="select">
			SELECT DECODE(COUNT(*),0,'false','true') AS "OUTSTANDING_PAYMENTS"
			FROM   PAYMENTS PY
			WHERE  PY.PASSTHROUGH = 'N' AND
				PY.RD_DATE IS NULL AND
				PY.PAYOUT_DATE IS NULL AND
				PY.ENFORCEMENT_PARENT = ${param.caseNumber}
		</SQL>
		<Modify notModifiable="true" />
	</Query>
</QueryDef>