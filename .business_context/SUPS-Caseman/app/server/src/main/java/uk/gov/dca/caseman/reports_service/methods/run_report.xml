<?xml version="1.0" encoding="UTF-8"?>
<!--
	Service: Reports
	Method:  runReport()
	File:    run_report.xml
	Author:  Alex Peterson (Valtech)
	Created: 18 April 2005
	Description: 
		Calls RunReport pipeline method (mapped to RunReportService.java in sups_config.xml) 
		to submit a report to SUPSReporting. Called by RequestReport.java.
-->
<service-method>
	<pipeline>
		<RunReport>
			<!-- Configuration parameters not used
			<ReportParam>reportParamValue</ReportParam>
			<Parameter name="courtCode" xpath="params/param[@name='courtCode']"/>
			-->
		</RunReport>
	</pipeline>
	<Dependencies>
		<Dependency serviceName="Reports"/>
		<Dependency serviceName="Court"/>
		<Dependency serviceName="SystemDate"/>
		<Dependency serviceName="SystemData"/>
	</Dependencies>		
	<Security roles="viewOnly medium high wcSuper scSuper bmsSuper aeSuper dmSuper edsAdmin cpSuper ccbcMan ccbcUser ccbcSGB2"/>	
	<Transaction type="RequiresNew" />
</service-method>