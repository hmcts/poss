<?xml version="1.0" encoding="UTF-8"?>
<!--
	Service: WindowForTrial
	Method:  getWftStatusList()
	File:    get_wft_status_list.xml
	Author:  
	Created: 
	Description: 
        List of Statuses for a Window for Trial 
-->
<service-method>
	<pipeline>
		<Query>
			<QueryDef location="uk/gov/dca/caseman/window_for_trial_service/query_def_wft_status_list.xml"/>
			<QueryExtension pivotNode="/WFTStatuses/Status">
				<Constraint>CCBC.RV_DOMAIN = 'WFT_STATUS'</Constraint>
			</QueryExtension>
		</Query>
	</pipeline>
	<Security roles="viewOnly medium high wcSuper scSuper bmsSuper aeSuper dmSuper cpSuper ccbcMan ccbcUser ccbcSGB2"/> 			
</service-method>