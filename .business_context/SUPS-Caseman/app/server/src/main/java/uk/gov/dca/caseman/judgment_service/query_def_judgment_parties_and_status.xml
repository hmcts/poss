<QueryDef>
	<DBMapDef location="uk/gov/dca/caseman/judgment_service/map_judgment_parties_and_status.xml"/>
	<Query pivotNode="/Case" tables="C JDG">
		<Join>
		</Join>
		<Modify notModifiable="true"/>
	</Query>	

	<Query pivotNode="/Case/Judgments/Judgment" tables="JDG">
	   	<Join>
	   		JDG.CASE_NUMBER = ${C.CASE_NUMBER}
	   	</Join>
	   	<Alias name="JDG.PARTY_KEY" select="JDG.AGAINST_PARTY_ROLE_CODE || '_' || JDG.AGAINST_CASE_PARTY_NO"/>
        <Modify notModifiable="true"/>
	</Query>

	<Query pivotNode="/Case/Judgments/Judgment/InFavourOf/Parties/Party" tables="IFP">
	   	<Join>
	   		IFP.JUDG_SEQ = ${JDG.JUDG_SEQ} 
	   	</Join>
	   	<Alias name="IFP.PARTY_KEY" select="IFP.PARTY_ROLE_CODE || '_' || IFP.CASE_PARTY_NO"/>
        <Modify notModifiable="true"/>
	</Query>

</QueryDef>


             