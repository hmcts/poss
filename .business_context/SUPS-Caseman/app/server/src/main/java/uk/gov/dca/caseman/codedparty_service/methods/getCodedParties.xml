<?xml version="1.0" encoding="UTF-8"?>
<!--
	Service: Codedparty
	Method:  getCodedParties()
	File:    getCodedParties.xml
	Author:  
	Created: 
	Description: 
		Retrieves a list of Coded Parties containing the full party and address details.
-->
<service-method>
	<pipeline>
		<Query>
  			<QueryDef location="uk/gov/dca/caseman/codedparty_service/query_def.xml"/>
			<QueryExtension pivotNode="/CodedParties/CodedParty">
				<Param name="param.adminCourtCode" xpath="/params/param[@name = 'adminCourtCode']"/>
				<Constraint>
					   CP.ADMIN_COURT_CODE = ${param.adminCourtCode}
					OR CP.ADMIN_COURT_CODE = 0
				</Constraint>
			</QueryExtension>
		</Query>
  	</pipeline>
	<Security roles="user"/>
</service-method>

