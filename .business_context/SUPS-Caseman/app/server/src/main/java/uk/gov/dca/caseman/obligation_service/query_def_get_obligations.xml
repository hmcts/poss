<?xml version="1.0" encoding="UTF-8"?>
<QueryDef>
	<DBMapDef location="uk/gov/dca/caseman/obligation_service/map_get_obligations.xml"/>
	<Query pivotNode="/ds" tables="O">
		<SQL type="select">
			SELECT 'EXISTING' AS "STATUS", 'C' AS "EVENTTYPE" 
			FROM DUAL
	    </SQL>
		<Modify notModifiable="true"/>
	</Query>
	<Query pivotNode="/ds/MaintainObligations" tables="C CT">
		<LinkedJoin type="root" key="C.CASE_NUMBER">
			<Join>
				CT.CODE = C.ADMIN_CRT_CODE
			</Join>
		</LinkedJoin>
		<Modify notModifiable="true"/>
	</Query>
	<Query pivotNode="/ds/MaintainObligations/Parties/Party" tables="CPR PR P">
		<LinkedJoin type="query" key="P.PARTY_ID CPR.PARTY_ROLE_CODE CPR.CASE_PARTY_NO">
			<Parent key="C.CASE_NUMBER" tables="C"/>
			<Join>
				CPR.CASE_NUMBER     =  C.CASE_NUMBER   AND
				CPR.PARTY_ROLE_CODE != 'SOLICITOR'        AND
				CPR.PARTY_ROLE_CODE =  PR.PARTY_ROLE_CODE AND
				CPR.PARTY_ID        =  P.PARTY_ID
			</Join>
		</LinkedJoin>
		<OrderBy>CPR.PARTY_ROLE_CODE, CPR.CASE_PARTY_NO</OrderBy>
		<Modify notModifiable="true"/>
	</Query>
	<Query pivotNode="/ds/MaintainObligations/Obligations/Obligation" tables="CE O OT">
		<LinkedJoin type="query" key="O.OBLIGATION_SEQ">
			<Parent key="C.CASE_NUMBER" tables="C"/>
			<Join>
				O.CASE_NUMBER = C.CASE_NUMBER AND
				CE.CASE_NUMBER = O.CASE_NUMBER AND
				O.EVENT_SEQ = CE.EVENT_SEQ AND	
				O.OBLIGATION_TYPE = OT.OBLIGATION_TYPE
   			</Join>
		</LinkedJoin>
   		<OrderBy>O.DELETE_FLAG</OrderBy>
		<Modify notModifiable="true"/>
	</Query>
