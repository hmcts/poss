<?xml version="1.0" encoding="UTF-8"?>
<!--
	Service: Ae
	Method:  WarrantSearchAe()
	File:    warrantsearch_ae.xml
	Author:  Chris Vincent
	Created: 
	Description: 
		Returns a list of AE Events so that the Create Home Warrants screen can determine
		whether or not the Case loaded has a live AE which is required for warrants of
		type EXECUTION.
-->
<service-method>
	<pipeline>
		<Query>
			<QueryDef location="uk/gov/dca/caseman/ae_service/query_def_warrantaesearch.xml"/>
			<QueryExtension pivotNode="/Results/AERecord">
				<Param name="param.caseNumber" xpath="/params/param[@name = 'caseNumber']"/>													
				<Constraint>
					AEA.CASE_NUMBER = ${param.caseNumber}
				</Constraint>
			</QueryExtension>
		</Query>
	</pipeline>
    <Security roles="medium high wcSuper scSuper bmsSuper aeSuper dmSuper cpSuper ccbcMan ccbcUser"/>   		
</service-method>