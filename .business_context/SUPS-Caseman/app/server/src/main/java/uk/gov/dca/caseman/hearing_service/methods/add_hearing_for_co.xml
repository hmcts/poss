<?xml version="1.0" encoding="UTF-8"?>
<service-method>
	<pipeline>
		<Update>
			<QueryDef location="uk/gov/dca/caseman/hearing_service/query_def_hearing_for_co.xml"/>
			<DataSource xpath="/params/param[@name='HearingID']"/>
			<QueryExtension pivotNode="/ds/MaintainHearing/Hearings/Hearing">
				<CheckExists table="H" fields="hrg_seq" onNotExist="add" onExist="update"/>
			</QueryExtension>
		</Update>
			<Java>
			     <!-- 
				 The co event will needs to be inserted after the eventId has been generated for a new hearing
				 because the hrg_seq is a FK on CO_EVENTS
			     -->
			<Source class="uk.gov.dca.caseman.hearing_service.java.InsertCoEvent200CreateHearingCustomProcessor"/>
		</Java>
	</pipeline>
	<Dependencies>
		<Dependency serviceName="CoEvent"/>								
	</Dependencies>		
	<Transaction type="RequiresNew" />
	<Security roles="medium high wcSuper scSuper bmsSuper aeSuper dmSuper"/>
</service-method>
