<?xml version="1.0" encoding="UTF-8"?>
<!--
	Service: Co Dividends
	Method:  getCoDividends()
	File:    get_co_dividends.xml
	Author:  Tim Connor (Valtech)
	Created: 18 October 2005
	Description: 
		Retrieves the list of dividends for a Consolidated Order
	Amendments:
		CPV (26/05/2006): Added cpSuper role to the list of roles - Defect 3463
-->
<service-method>
	<pipeline>
		<NewQuery>
			<QueryDef location="uk/gov/dca/caseman/co_dividend_service/query_def_get_co_dividends.xml"/>
			<QueryExtension pivotNode="/ds/MaintainCO/Dividends/Dividend">
				<Param name="param.coNumber" xpath="/params/param[@name = 'coNumber']"/>
				<Constraint>D.DIV_CO_NUMBER = ${param.coNumber}</Constraint>
			</QueryExtension>
 		</NewQuery>	
	</pipeline>
	<Security roles="viewOnly medium high wcSuper scSuper bmsSuper aeSuper dmSuper cpSuper"/>	
</service-method>