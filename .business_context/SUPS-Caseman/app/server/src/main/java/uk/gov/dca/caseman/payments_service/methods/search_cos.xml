<?xml version="1.0" encoding="UTF-8"?>
<!--
	Service: Payments
	Method: searchCos()
	File: search_cos.xml
	Author: Steve Blair
	Description:
		Pulls a summary of a co and associated CAEO warrants matching search criteria.
-->
<service-method>
	<pipeline>
		<Query>
			<QueryDef location="uk/gov/dca/caseman/payments_service/query_def_search_cos.xml" />
			<QueryExtension pivotNode="/SearchResults/Enforcement">
				<Param name="param.coNumber" xpath="/params/param[@name = 'coNumber']" />
			</QueryExtension>
		</Query>
	</pipeline>
	<Security roles="medium high wcSuper scSuper bmsSuper aeSuper dmSuper cpSuper" />
</service-method>