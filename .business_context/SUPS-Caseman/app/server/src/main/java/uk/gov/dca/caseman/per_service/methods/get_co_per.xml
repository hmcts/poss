<?xml version="1.0" encoding="UTF-8"?>
<!--
	Service: Per
	Method:  getCoPer()
	File:    get_per.xml
	Author:  Phil Haferer (EDS), Ian Stainer (Valtech)
	Created: 01 July 2005
	Description: 
		Retrieve consolidated orders protected earnings rate details.
-->
<service-method>
	<pipeline>
		<Query>
			<QueryDef location="uk/gov/dca/caseman/per_service/query_def_get_co_per.xml"/>
			<QueryExtension pivotNode="/ds/CalculatePER">
				<Param name="param.coNumber" xpath="/params/param[@name = 'coNumber']"/>
				<Constraint>CO.CO_NUMBER = ${param.coNumber}</Constraint>
			</QueryExtension>
		</Query>			
		<Transform>		
			<Template location="uk/gov/dca/caseman/per_service/transforms/get_per.xsl"/>
		</Transform>		
	</pipeline>
	<Security roles="viewOnly medium high wcSuper scSuper bmsSuper aeSuper dmSuper cpSuper"/>				
</service-method>
