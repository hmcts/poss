<?xml version="1.0" encoding="UTF-8"?>
<!--
	v1.0 Chris Hutt 27/4/2007
	Returns judgment (along with a list of parties associated with the judgment)
	for the purposes of issuing an event 600
-->
<service-method>
	<pipeline>
		<Query>
			<QueryDef location="uk/gov/dca/caseman/judgment_service/query_def_judgment_for_600.xml"/>
			<QueryExtension pivotNode="/Case">
				<Param name="param.caseNumber" xpath="/params/param[@name = 'caseNumber']"/>
				<Constraint>C.CASE_NUMBER = ${param.caseNumber}</Constraint>		
			</QueryExtension>
		</Query>
	</pipeline>
	<Security roles="viewOnly medium high wcSuper scSuper bmsSuper aeSuper dmSuper cpSuper ccbcMan ccbcUser ccbcSGB2"/>
</service-method>


