<?xml version="1.0" encoding="UTF-8"?>
<!--
	Service: Co
	Method:  transferCo()
	File:    transfer_co.xml
	Author:  Phil Haferer (EDS)
	Created: 11 October 2005
	Description: 
		Marks a Consolidated Order for transfer to another court.
-->
<service-method>
	<pipeline>
		<SQLLite output="input">
			<DataSource id="java:OracleDS"/>
			<Param name="param.coNumber" xpath="/params/param[@name='coNumber']"/>
			<Param name="param.courtCode" xpath="/params/param[@name='courtCode']"/>
			<SQL type="update" tables="CO">
				UPDATE CONSOLIDATED_ORDERS CO
				SET    CO.COURT_OF_TRANSFER = ${param.courtCode}
				,      CO.CO_STATUS = 'TRANSFERRED'
				WHERE  CO.CO_NUMBER = ${param.coNumber}
			</SQL>
		</SQLLite>
	</pipeline>
	<Security roles="user"/>
</service-method>
