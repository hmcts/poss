<?xml version="1.0" encoding="UTF-8"?>
<service-method>
	<pipeline>		
		<Query>
  			<QueryDef location="uk/gov/dca/caseman/ae_service/query_def_enforcement_letter.xml"/>			
			<QueryExtension pivotNode="/AENumber/EnforcementLetter">
				<Constraint>E.YEAR_VALUE = TO_CHAR(SYSDATE, 'YYYY')</Constraint>
			</QueryExtension>			
  	    </Query>
	</pipeline>
	<Security roles="user"/>
</service-method>




