<?xml version="1.0" encoding="UTF-8"?>
<!--
	Service: Codedparty
	Method:  getCodedPartiesShortNew()
	File:    getCodedPartiesShortNew.xml
	Author:  Phil Haferer
	Created: 11/07/2006
	Description: 
		Retrieves a list of Coded Parties based on a wildcard search on name and an admin court code

	Change History:
	12-Jul-2006 Phil Haferer: Modified to use the copy of the name in CODED_PARTIES table to improve performance.
	            (TD 3949: Performance: Wildcard search on Coded Party name).
-->
<service-method>
	<pipeline>
		<Query>
  			<QueryDef location="uk/gov/dca/caseman/codedparty_service/query_def_short_new.xml"/>
		  	<QueryExtension pivotNode="/CodedParties/CodedParty">				
				<Param name="param.adminCourtCode" xpath="/params/param[@name = 'adminCourtCode']"/>
				<Param name="param.partyName" xpath="/params/param[@name = 'partyName']"/>
				<Param name="param.pageNumber" xpath="/params/param[@name = 'pageNumber']"/>		
				<Param name="param.pageSize" xpath="/params/param[@name = 'pageSize']"/>				

				<Paged pageNumber="${param.pageNumber}" pageSize="${param.pageSize}"/>																													
				<OrderBy>CP.CODE</OrderBy>
				<Constraint>
					( 
						( 
							CP.ADMIN_COURT_CODE = ${param.adminCourtCode} OR
							CP.ADMIN_COURT_CODE = 0
						) AND
						( 
							${param.partyName} IS NULL OR 
							CP.PERSON_REQUESTED_NAME LIKE UPPER( ${param.partyName} ) 
						)
					)
				</Constraint>
			</QueryExtension>		
		</Query>
  	</pipeline>
	<Security roles="viewOnly medium high wcSuper scSuper bmsSuper aeSuper dmSuper cpSuper ccbcMan ccbcUser ccbcSGB2"/>	
</service-method>