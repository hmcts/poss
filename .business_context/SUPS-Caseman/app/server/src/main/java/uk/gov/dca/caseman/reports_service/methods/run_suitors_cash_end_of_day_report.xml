<?xml version="1.0" encoding="UTF-8"?>
<!--
	Service: Reports
	Method:  runSuitorsCashEndOfDayReport()
	File:    run_end_of_day_report.xml
	Author:  Mark Hallam (EDS)
	Created: 16 November 2005
	Description: 
		Calls the Custom Processor that builds the XML that is eventually passed to reports service.
-->
<service-method>
	<pipeline> 
		<Java callStyle="new">
			<Source class="uk.gov.dca.caseman.reports_service.classes.SuitorsCashEndOfDayReportCustomProcessor"/>
		</Java>
	</pipeline>
	<Dependencies>
		<Dependency serviceName="SuitorsCashStartOfDay"/>	
	</Dependencies>		
	<Security roles="viewOnly medium high wcSuper scSuper bmsSuper aeSuper dmSuper edsAdmin cpSuper"/>		
</service-method>