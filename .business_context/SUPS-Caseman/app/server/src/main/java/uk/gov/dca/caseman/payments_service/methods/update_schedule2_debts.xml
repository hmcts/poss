<?xml version="1.0" encoding="UTF-8"?>
<!--
	Service: Payments
	Method: updateSchedule2Debts()
	File: update_schedule2_debts.xml
	Author: Tony White
	Description:
		Updates the status of any schedule2 debts on a CO to LIVE.
-->
<service-method>
	<pipeline>		
		<Update>
			<QueryDef location="uk/gov/dca/caseman/payments_service/query_def_get_schedule2_debts.xml" />
			<DataSource xpath="/params/param[@name='debts']" />
			<QueryExtension pivotNode="/Debts/Debt">
				<CheckExists table="AD" fields="DEBT_SEQ" onNotExist="fail" onExist="update" />
			</QueryExtension>
		</Update>		
	</pipeline>	
	<Security roles="medium high wcSuper scSuper bmsSuper aeSuper dmSuper" />
</service-method>