<?xml version="1.0" encoding="UTF-8"?>
<!--
	Service: CasemanAsync
	Method:  cancel()
	File:    cancel.xml
	Author:  Anoop Sehdev (Valtech)
	Created: 25 April 2006
	Description: 
		Calls AsyncCancel pipeline method in order to cancel jobs that were submitted 
