<?xml version="1.0" encoding="UTF-8"?>
<!--
	Service: Case
	Method:  getDefCount
	Author:  Chris Hutt (EDS) 
	Created: 7th October 2005
	Description: 
		Use SQLLite to retrieve count of defendants associated with a case 
		
	Change History:          
-->
<!-- service-method visibility="local" -->
<service-method>
	<pipeline>
		<SQLLite format-output="true"
				 resultset-element="ds"
				 row-element="Case"
				 field-name-as="element" >
			<DataSource id="java:OracleDS"/>
			<Param name="param.caseNumber" xpath="/params/param[@name='caseNumber']"/>
			<SQL>
				SELECT
						COUNT(*) As "NumberOfDefendants"
				FROM 	CASE_PARTY_ROLES CPR 
				WHERE 	CPR.CASE_NUMBER = ${param.caseNumber}
				AND 	CPR.PARTY_ROLE_CODE IN ('DEFENDANT' , 'PT 20 DEF')
			</SQL>
		</SQLLite>
  	</pipeline>
	<Security roles="viewOnly medium high wcSuper scSuper bmsSuper aeSuper dmSuper"/>		
</service-method>
