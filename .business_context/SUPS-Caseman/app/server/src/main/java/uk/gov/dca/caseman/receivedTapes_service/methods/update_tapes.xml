<?xml version="1.0" encoding="UTF-8"?>
<service-method>
	<pipeline>
		<Update>
  			<QueryDef location="uk/gov/dca/caseman/receivedTapes_service/modify_tape_query_def.xml"/>
			<DataSource xpath="/params/param[@name='Tapes']"/>
  				<QueryExtension pivotNode="/ReceivedTapes/ReceivedTape">
  					<CheckExists table="T" fields="SEQNO" onNotExist="fail" onExist="update" useOptimisticLock="true"/>
  				</QueryExtension>
  				<QueryExtension  pivotNode="/ReceivedTapes/ReceivedTape/TapeFiles/TapeFile" >
  					<CheckExists condition="./Removed = 'Y'" onConditionTrue="skip" onConditionFalse="continue" table="TFI" fields="ORDERSEQ" onNotExist="add" onExist="update" useOptimisticLock="true"/>
  				</QueryExtension>	
  				<QueryExtension  pivotNode="/ReceivedTapes/ReceivedTape/TapeFiles/TapeFile/Remove" >
  					<CheckExists condition="./Removed = 'Y'" onConditionTrue="continue" onConditionFalse="skip" table="TFI" fields="ORDERSEQ" onNotExist="skip" onExist="delete" useOptimisticLock="false"/>
  				</QueryExtension>
		</Update>
		
  	</pipeline>
	<Security roles="ccbcMan ccbcTape"/>
</service-method>
