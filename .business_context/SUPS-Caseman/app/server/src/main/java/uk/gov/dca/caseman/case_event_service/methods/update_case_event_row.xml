<?xml version="1.0" encoding="UTF-8"?>
<!--
	Service: CaseEvent
	Method:  updateCaseEventRow()
	File:    update_case_event_row.xml
	Description: 
	Change History:
		04/12/2012 - Chris Vincent: Added dependency to WpOutput service.  Trac 4761
		18/10/2013 - Chris Vincent, Trac 4997.  Added dependencies for Warrant, WarrantReturns
					 and SystemDate as part of CCBC SDT
-->
<service-method>
	<pipeline>
		<Update>
			<!-- Note: This method only updates the CASE_EVENTS.DELETED_FLAG. -->
			<QueryDef location="uk/gov/dca/caseman/case_event_service/query_def_update_case_event_row.xml"/>
			<DataSource xpath="/params/param name='caseEvent'"/>
			<QueryExtension pivotNode="/CaseEvent">
				<CheckExists table="CE" fields="EVENT_SEQ" onNotExist="fail" onExist="update"/>
			</QueryExtension>
		</Update>
		<Java callStyle="new">
			<Source class="uk.gov.dca.caseman.case_event_service.java.UpdateCaseEventUpdatesCustomProcessor"/>
		</Java>
	</pipeline>
	<Dependencies>
		<Dependency serviceName="WpOutput"/>
		<Dependency serviceName="Warrant"/>
		<Dependency serviceName="WarrantReturns"/>
		<Dependency serviceName="SystemDate"/>
	</Dependencies>
	<Security roles="user"/>
</service-method>
