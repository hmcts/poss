<?xml version="1.0" encoding="UTF-8"?>
<!--
	Service: Codedparty
	Method:  getNatCodedPartyShort()
	File:    query_def_ncp_short.xml
	Author:  Chris Hutt
	Description:
		This method is used to determine whether or not a particular National Coded Party 
		Code is already exists.

	Change History:
	V1.0: Chris Hutt       03/02/05 
	V1.1: Chris Hutt	   19/10/2005 - returning empty dom when nothing selected .... pivot node refined
	07-Dec-2005 Phil Haferer (EDS): Changed the service to look up the Code in the CODED_PARTIES
			    table, rather than the NATIONAL_CODED_PARTIES tables, so that this service 
			    can be used test for the existing of the Non CPC National Coded Parties.
				Also, added 'notModifiable="true"' to prevent unnecessary SCN being returned.
-->
<QueryDef>
  <DBMapDef location="uk/gov/dca/caseman/codedparty_service/map_ncp_short.xml"/>
  <Query pivotNode="/CodedParty/Code" tables="CP">
	<Join/>
	<Modify notModifiable="true"/>
  </Query>
</QueryDef>