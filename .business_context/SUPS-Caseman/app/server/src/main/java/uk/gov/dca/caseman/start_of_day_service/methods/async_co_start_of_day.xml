<?xml version="1.0" encoding="UTF-8"?>
<!--
	Service: StartOfDay
	Method:  asyncCoStartOfDay()
	File:    async_co_start_of_day.xml
	Author:  Kevin Gichohi (EDS)
	Created: 19 April 2006
	Description: 
		Asynchronously calls the method that calls the Custom Processor that builds the XML that is eventually passed to reports service.
-->
<service-method>
	<pipeline>
		<AsyncCall service="Reports" method="runCoStartOfDayReports">
			<Destination name="AsyncQueue"/>
		</AsyncCall>
	</pipeline>
	<Dependencies>
		<Dependency serviceName="Reports"/>	
	</Dependencies>
	<Security roles="viewOnly medium high wcSuper scSuper bmsSuper aeSuper dmSuper edsAdmin cpSuper"/>
</service-method>