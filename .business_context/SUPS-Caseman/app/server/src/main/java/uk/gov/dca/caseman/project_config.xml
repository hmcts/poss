			<factory>jms/QueueConnectionFactory</factory>
			<jndi-name>jms/caseman_async_queue</jndi-name>
			<min-pool-size>15</min-pool-size>
			<max-pool-size>15</max-pool-size>
		</item>
		
		<!--  These are used to check for the invoker servlet -->
		<item id="application:serviceprefix" class="uk.gov.dca.db.impl.StringConfigurationItem">/caseman</item>
