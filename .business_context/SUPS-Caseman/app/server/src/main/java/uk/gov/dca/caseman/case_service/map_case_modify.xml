<?xml version="1.0" encoding="UTF-8"?>
<!-- 
Change History:
28/01/2013 - Added PreferredCourtCode (Trac 4764) and Track (Trac 4763) nodes.  
-->
<DBMapDef>
  <DataSource id="java:OracleDS"/>
  <Tables>
    <Table alias="C" name="CASES"/>
    <Table alias="H" name="HEARINGS"/>    
    <Table alias="GA" name="GIVEN_ADDRESSES"/>
    <Table alias="CPR2CPR" name="CPR_TO_CPR_RELATIONSHIP"/>
  </Tables>  
  <Mapping>
    <ds>
	<ManageCase>
		<CaseNumber>${C.CASE_NUMBER}</CaseNumber>
		<CaseType>${C.CASE_TYPE}</CaseType>
		<InsolvencyNumber>${C.INSOLVENCY_NUMBER}</InsolvencyNumber>
		<CaseStatus></CaseStatus>
		<OwningCourtCode>${C.ADMIN_CRT_CODE}</OwningCourtCode>
		<OwningCourt></OwningCourt>
		<CourtDivision></CourtDivision>
		<CreditorCode>${C.CRED_CODE}</CreditorCode>
		<CaseDetails>${C.BRIEF_DETAILS_OF_CLAIM}</CaseDetails>
		<PreferredCourtCode>${C.PREF_COURT_CODE}</PreferredCourtCode>
		<Track>${C.TRACK}</Track>
		<ParticularsOfClaimPresent></ParticularsOfClaimPresent>
		<ParticularsOfClaimDetails>${C.PARTICULARS_OF_CLAIM}</ParticularsOfClaimDetails>
		<DetailsOfClaimPresent></DetailsOfClaimPresent>
		<DetailsOfClaim>
			<DateRequestReceived>${C.RECEIPT_DATE}</DateRequestReceived>
			<AmountClaimedCurrency>${C.AMOUNT_CLAIMED_CURRENCY}</AmountClaimedCurrency>			
			<AmountClaimed>${C.AMOUNT_CLAIMED}</AmountClaimed>
			<CourtFeeCurrency>${C.COURT_FEE_CURRENCY}</CourtFeeCurrency>
			<CourtFee>${C.COURT_FEE}</CourtFee>
			<SolicitorsCostsCurrency>${C.SOLICITORS_COSTS_CURRENCY}</SolicitorsCostsCurrency>			
			<SolicitorsCosts>${C.SOLICITORS_COSTS}</SolicitorsCosts>
			<TotalCurrency>${C.TOTAL_CURRENCY}</TotalCurrency>					
			<Total>${C.TOTAL}</Total>
			<DateOfIssue>${C.DATE_OF_ISSUE}</DateOfIssue>			
		</DetailsOfClaim>
		<HearingDetails>
			<Id>${H.HRG_SEQ}</Id>
			<VenueCode>${H.CRT_CODE}</VenueCode>
			<VenueName>${H.VENUE}</VenueName>
			<TypeOfHearing>${H.HRG_TYPE}</TypeOfHearing>
			<Date>${H.HRG_DATE}</Date>
			<Time>${H.HRG_TIME}</Time>
			<Address>
				<AddressId>${H.ADDRESS_ID}</AddressId>
			</Address>
		</HearingDetails>
		<OtherPossessionAddressPresent></OtherPossessionAddressPresent>
		<OtherPossessionAddress>
			<Address>
				<AddressId>${GA.ADDRESS_ID}</AddressId>
				<Line>${GA.ADDRESS_LINE1}</Line>
				<Line>${GA.ADDRESS_LINE2}</Line>
				<Line>${GA.ADDRESS_LINE3}</Line>
				<Line>${GA.ADDRESS_LINE4}</Line>
				<Line>${GA.ADDRESS_LINE5}</Line>
				<PostCode>${GA.POSTCODE}</PostCode>
				<CreatedBy>${GA.UPDATED_BY}</CreatedBy>
			</Address>
		</OtherPossessionAddress>
	</ManageCase>
    </ds>  
</Mapping>
</DBMapDef>
