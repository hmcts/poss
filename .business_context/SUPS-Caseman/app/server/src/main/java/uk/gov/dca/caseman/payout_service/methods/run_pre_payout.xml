<?xml version="1.0" encoding="UTF-8"?>
<!--
	Service: Payout
	Method:  runPrePayout()
	File:    run_pre_payout.xml
	Author:  Mark Hallam (EDS)
	Created: 11th January 2006
	Description: 
		Calls the Custom Processor that builds the XML that is eventually passed to reports service.
-->
<service-method>
	<pipeline> 
		<Java callStyle="new">
			<Source class="uk.gov.dca.caseman.payout_service.classes.RunPrePayoutCustomProcessor"/>
		</Java>
	</pipeline>
	<Dependencies>
		<Dependency serviceName="Reports"/>	
	</Dependencies>		
	<Security roles="viewOnly medium high wcSuper scSuper bmsSuper aeSuper dmSuper edsAdmin cpSuper"/>		
</service-method>