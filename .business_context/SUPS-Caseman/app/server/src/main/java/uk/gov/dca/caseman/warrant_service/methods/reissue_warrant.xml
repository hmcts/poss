<?xml version="1.0" encoding="UTF-8"?>
<!--
	This is a simple service which is used to mark a warrant as re-issued, and create a final warrant return
	(warrant reissued) for the warrant.
-->
<service-method visibility="local">
	<pipeline>
		<Java callStyle="new">
			<Source class="uk.gov.dca.caseman.warrant_service.java.InsertWarrantReturn158CustomProcessor"/>
		</Java>		
		<SQLLite>
			<DataSource id="java:OracleDS"/>
			<Param name="param.warrantID" xpath="/params/param[@name = 'warrantID']"/>
			<SQL type="update">
				UPDATE WARRANTS
				SET RE_ISSUE_DATE = SYSDATE
				WHERE WARRANT_ID = ${param.warrantID}
			</SQL>	
		</SQLLite>
	</pipeline>
	<Security roles="user"/>
</service-method>




