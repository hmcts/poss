<service-method>
	<pipeline>
		<Query>
			<QueryDef location="uk/gov/dca/caseman/window_for_trial_service/query_def_wft_status.xml"/>
			<QueryExtension pivotNode="/WindowsForTrial/WindowForTrial">
				<Param name="param.caseNumber" xpath="/params/param[@name = 'caseNumber']"/>
				<Constraint>WFT.WFT_CASE_NUMBER = ${param.caseNumber}</Constraint>		
			</QueryExtension>
		</Query>
	</pipeline>
	<Security roles="user"/>
</service-method>


