<?xml version="1.0" encoding="UTF-8"?>
<!--
	Service: Case
	Method:  getCaseTrack
	Author:  Chris Vincent 
	Created: 15 January 2013
	Description: 
		Use SQLLite to return the value of the track field on the case
-->
<service-method>
	<pipeline>
		<SQLLite format-output="true" 
				 resultset-element="ds"
				 row-element="Case" 
				 field-name-as="element">
			<DataSource id="java:OracleDS"/>
			<Param name="param.caseNumber" xpath="/params/param[@name = 'caseNumber']"/>
			<SQL>
				SELECT track AS "Track"
				FROM cases
				WHERE case_number = ${param.caseNumber}
			</SQL>
		</SQLLite>
	</pipeline>
	<Security roles="viewOnly medium high wcSuper scSuper bmsSuper aeSuper dmSuper cpSuper ccbcMan ccbcUser ccbcSGB2"/>
</service-method>
