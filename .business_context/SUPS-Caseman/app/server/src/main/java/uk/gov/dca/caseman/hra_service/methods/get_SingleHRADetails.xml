<?xml version="1.0" encoding="UTF-8"?>
<!--
	Service: Hra
	Method:  getSingleHRADetails()
	File:    get_singloeHRADetails.xml
	Author:  David Turner
	Created: 22 march 2005
	Description: 
		Retrieve HRA details for a specified case
-->
<service-method>
	<pipeline>
		<NewQuery>
			<QueryDef location="uk/gov/dca/caseman/hra_service/query_def_hra.xml"/>
			<QueryExtension pivotNode="/ds/HumanRightsAct/Cases/Case">
				<Param name="param.CaseNumber" xpath="/params/param[@name = 'CaseNumber']"/>				
				<Constraint>CE.CASE_NUMBER =${param.CaseNumber} and CE.EVENT_SEQ = ED.EVENT_SEQ </Constraint>
			</QueryExtension>
		</NewQuery>
	</pipeline>
	<Security roles="wcSuper scSuper bmsSuper aeSuper dmSuper cpSuper ccbcMan ccbcUser ccbcSGB2"/>		
</service-method>