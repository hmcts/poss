<?xml version="1.0" encoding="UTF-8"?>
<!--
	Service: Ae
	Method:  updateCaseAe()
	File:    update_case_ae.xml
	Author:  pz9j2w
	Created: 24 Aug 2005
	Description:
		Updates the AE along with party and address details
-->
<service-method>
	<pipeline>
		<Update>
			<QueryDef location="uk/gov/dca/caseman/ae_service/query_def_update_case_ae.xml"/>			
			<DataSource xpath="/params/param[@name='AEDetails']"/>
		</Update>
	</pipeline>
	<Dependencies>
		<Dependency serviceName="AeEvent"/>	
		<Dependency serviceName="CaseEvent"/>
		<Dependency serviceName="Obligation"/>	
		<Dependency serviceName="Case"/>	
		<Dependency serviceName="UserCourt"/>			
	</Dependencies>
    <Security roles="medium high wcSuper scSuper bmsSuper aeSuper dmSuper cpSuper"/>   		
</service-method>