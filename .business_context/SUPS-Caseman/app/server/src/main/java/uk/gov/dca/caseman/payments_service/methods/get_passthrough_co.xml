<?xml version="1.0" encoding="UTF-8"?>
<!--
	Service: Payments
	Method:  getPassthroughCo()
	File:    get_passthrough_co.xml

	Change History:
	26-Jun-2006 Phil Haferer: TD 3751: Performance: getPassthroughCo() includes an unnecessary LIKE clause.
	    Replaced LIKE clauses with =.
-->
<service-method>
	<pipeline>
		<Query>
			<QueryDef location="uk/gov/dca/caseman/payments_service/query_def_passthrough_co.xml" />
			<QueryExtension pivotNode="/Co">
				<Param name="param.coNumber" xpath="/params/param[@name = 'coNumber']" />
				<Constraint>CO.CO_NUMBER = ${param.coNumber}</Constraint>
			</QueryExtension>			
		</Query>
	</pipeline>
	<Security roles="medium high wcSuper scSuper bmsSuper aeSuper dmSuper" />
</service-method>