<?xml version="1.0" encoding="UTF-8"?>
<!--
	Service: WarrantReturnCodes
	Method:  getWarrantReturnCodes()
	File:    getWarrantReturnCodes.xml
	Author:  Tun Shwe
	Created: 
	Description: 
		Reference data service which returns a list of Warrant Return Codes based upon a 
		court code parameter passed in.
	Change History
		01/08/2006 - Chris Vincent fixed defect 4111 by adding security roles to the service.
    15/08/2006 - Chris Hutt TD4259 - strange looking sql to ensure non CCBC users get 'global' codes (court 0)
									 while CCBC users get their own codes.
    25/8/06    - chris Hutt - non 335 courts need national on local codes
-->
<service-method>
	<pipeline>
		<Query>
			<QueryDef location="uk/gov/dca/caseman/warrant_return_codes_service/query_def_get.xml"/>
			<QueryExtension pivotNode="/ds/WarrantReturnCodes/WarrantReturnCode">
				<Param name="param.courtCode" xpath="/params/param[@name = 'courtCode']"/>				
				<Constraint>
					RC.CURRENT_RETURN = 'Y' AND
					(
						( '335' != ${param.courtCode}
						  AND (RC.ADMIN_COURT_CODE = '0' OR RC.ADMIN_COURT_CODE = ${param.courtCode} ) )
						OR 
						( '335' = ${param.courtCode}
						  AND RC.ADMIN_COURT_CODE = '335'	)
					)
				</Constraint>
			</QueryExtension>
		</Query>
	</pipeline>
	<Security roles="medium high scSuper bmsSuper aeSuper dmSuper cpSuper wcSuper ccbcMan"/>
</service-method>
