<?xml version="1.0" encoding="UTF-8"?>
<!--
	Service: Hearing
	Method:  addHearingCO()
	File:    add_hearingCO.xml
	Author:  Troy Baines
	Created: 20 November 2004
	Description: 
        Inserts a hearing record for a consolidated order
-->
<service-method>
	<pipeline>
		<Update>
			<QueryDef location="uk/gov/dca/caseman/hearing_service/query_def_modifyCO.xml"/>
			<DataSource xpath="/params/param[@name='HearingID']"/>
			<QueryExtension pivotNode="/ds/MaintainHearing/Hearings/Hearing">
				<CheckExists table="H" fields="hrg_seq" onNotExist="add" onExist="fail"/>
			</QueryExtension>
		</Update>
	</pipeline>
	<Security roles="medium high wcSuper scSuper bmsSuper aeSuper dmSuper cpSuper"/>
</service-method>
