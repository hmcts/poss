<?xml version="1.0" encoding="UTF-8"?>
<!--
	Service: CaseEvent
	Method:  getEventWarrantReturnCode
	Author:  Chris Vincent 
	Created: 25 February 2015
	Description: 
		Use SQLLite to return the warrant return code for the event
-->
<service-method>
	<pipeline>
		<SQLLite format-output="true" 
				 resultset-element="ds"
				 row-element="WarrantReturn" 
				 field-name-as="element">
			<DataSource id="java:OracleDS"/>
			<Param name="param.warrantReturnId" xpath="/params/param[@name = 'warrantReturnId']"/>
			<SQL>
				SELECT RETURN_CODE AS "ReturnCode"
				FROM WARRANT_RETURNS
				WHERE WARRANT_RETURNS_ID = ${param.warrantReturnId}
			</SQL>
		</SQLLite>
	</pipeline>
	<Security roles="viewOnly medium high wcSuper scSuper bmsSuper aeSuper dmSuper cpSuper ccbcMan ccbcUser ccbcSGB2"/>
</service-method>