<?xml version="1.0" encoding="UTF-8"?>
<DBMapDef>
  <DataSource id="java:OracleDS"/>
  <Tables>
    <Table alias="C"   name="CASES"/>
    <Table alias="CPR" name="CASE_PARTY_ROLES"/>
    <Table alias="P"   name="PARTIES"/>
    <Table alias="CP"   name="CODED_PARTIES"/>
    <Table alias="GA" name="GIVEN_ADDRESSES"/>
    <Table alias="PR" name="PARTY_ROLES"/>
    
    <Table alias="CT" name="COURTS"/>
	<Table alias="J" name="JUDGMENTS"/>
	<Table alias="CCBC" name="CCBC_REF_CODES"/>
	<Table alias="IP" name="INFAVOUR_PARTIES"/>

	<Table alias="A" name="AE_APPLICATIONS" />
	<Table alias="F" name="FEES_PAID" />
	<Table alias="PY" name="PAYMENTS" />
	
	<Table alias="E" name="AE_EVENTS" />
  </Tables> 
   
  <Mapping>
  	<ds>
	  <Case>
	    <CaseNumber>${C.CASE_NUMBER}</CaseNumber>
	    <CaseType>${C.CASE_TYPE}</CaseType>
	    <CaseStatus>${C.STATUS}</CaseStatus>
	    <OwningCourtCode>${C.ADMIN_CRT_CODE}</OwningCourtCode>	    
	    <Parties>
	    	<Party>	    		
	        	<PartyId>${P.PARTY_ID}</PartyId>
		        <PersonRequestedName>${P.PERSON_REQUESTED_NAME}</PersonRequestedName>
	    	    <TypeCode>${P.PARTY_TYPE_CODE}</TypeCode>
	    	    <PartyRoleCode>${CPR.PARTY_ROLE_CODE}</PartyRoleCode>
	    	    <CasePartyNumber>${CPR.CASE_PARTY_NO}</CasePartyNumber>	  
	    	    <CodedParty>
	    	    	<PartyId>${CP.PARTY_ID}</PartyId>
	    	    	<Code>${CP.CODE}</Code>
	    	    </CodedParty> 	  
	        	<ContactDetails>
	        	  <TelephoneNumber>${P.TEL_NO}</TelephoneNumber>
				  <FaxNumber>${P.FAX_NUMBER}</FaxNumber>
				  <EmailAddress>${P.EMAIL_ADDRESS}</EmailAddress>
				  <PreferredCommunicationMethod>${CPR.PREFERRED_COMMUNICATION_METHOD}</PreferredCommunicationMethod>
				  <WelshIndicator>${CPR.WELSH_INDICATOR}</WelshIndicator>
	        	  <Addresses>
			          <Address>
		    	        <AddressId>${GA.ADDRESS_ID}</AddressId>
		    	        <SurrogateId>${GA.ADDRESS_ID}</SurrogateId>
		    	        <TypeCode>${GA.ADDRESS_TYPE_CODE}</TypeCode>
		        	    <Line>${GA.ADDRESS_LINE1}</Line>
		            	<Line>${GA.ADDRESS_LINE2}</Line>
			            <Line>${GA.ADDRESS_LINE3}</Line>
		    	        <Line>${GA.ADDRESS_LINE4}</Line>
		        	    <Line>${GA.ADDRESS_LINE5}</Line>
		            	<PostCode>${GA.POSTCODE}</PostCode>
		            	<DateFrom>${GA.VALID_FROM}</DateFrom>
			            <DateTo>${GA.VALID_TO}</DateTo>
			            <Reference>${GA.REFERENCE}</Reference>
				        <CaseNumber>${GA.CASE_NUMBER}</CaseNumber>
	        			<PartyRoleCode>${GA.PARTY_ROLE_CODE}</PartyRoleCode>
				        <CasePartyNo>${GA.CASE_PARTY_NO}</CasePartyNo>
				        <CreatedBy>${GA.UPDATED_BY}</CreatedBy>
			          </Address>
		          </Addresses>          
	    	    </ContactDetails>		    	    
     		</Party>
	    </Parties>
		<Judgments>
			<Judgment>
				<PartyId>${P.PARTY_ID}</PartyId>
				<PartyRoleCode>${J.AGAINST_PARTY_ROLE_CODE}</PartyRoleCode>
				<PartyAgainstName>${P.PERSON_REQUESTED_NAME}</PartyAgainstName>
				<CasePartyNumber>${J.AGAINST_CASE_PARTY_NO}</CasePartyNumber>
				<Status>${J.STATUS}</Status>
				<JudgmentId>${J.JUDG_SEQ}</JudgmentId>
				<SurrogateId>${J.JUDG_SEQ}</SurrogateId>
				<InFavourParties>
					<Party>
						<JudgmentSequence>${IP.JUDG_SEQ}</JudgmentSequence>
						<PartyId>${P.PARTY_ID}</PartyId>
						<PartyRoleCode>${IP.PARTY_ROLE_CODE}</PartyRoleCode>
						<CasePartyNumber>${IP.CASE_PARTY_NO}</CasePartyNumber>
						<Name>${P.PERSON_REQUESTED_NAME}</Name>
						<CaseNumber>${IP.CASE_NUMBER}</CaseNumber>
					</Party>
				</InFavourParties>
			</Judgment>
		</Judgments>
		<AEApplications>
			<AEApplication>
				<AENumber>${A.AE_NUMBER}</AENumber>
				<AEType>${A.AE_TYPE}</AEType>
				<DateOfReceipt>${A.DATE_OF_RECEIPT}</DateOfReceipt>
				<DateOfCreation>${A.DATE_OF_CREATION}</DateOfCreation>
				<DateOfIssue>${A.DATE_OF_ISSUE}</DateOfIssue>
				<AmountOfAE>${A.AMOUNT_OF_AE}</AmountOfAE>
				<Occupation>${A.DEBTOR_OCCUPATION}</Occupation>
				<PayrollNo>${A.PAYROLL_NUMBER}</PayrollNo>
				<NamedEmployer>${A.NAMED_EMPLOYER}</NamedEmployer>
				<AEFee>${A.AE_FEE}</AEFee>
				<CAPSSequence>${A.CAPS_SEQUENCE}</CAPSSequence>
				<CourtCode>${A.ISSUING_CRT_CODE}</CourtCode>
				<JudgementSeq>${A.JUDG_SEQ}</JudgementSeq>
				<AmountOfAECurrency>${A.AMOUNT_OF_AE_CURRENCY}</AmountOfAECurrency>
				<AEFeeCurrency>${A.AE_FEE_CURRENCY}</AEFeeCurrency>
				<CaseNumber>${A.CASE_NUMBER}</CaseNumber>
				<PartyAgainstPartyRoleCode>${A.PARTY_AGAINST_PARTY_ROLE_COD}</PartyAgainstPartyRoleCode>
				<PartyAgainstCasePartyNumber>${A.PARTY_AGAINST_CASE_PARTY_NO}</PartyAgainstCasePartyNumber>
				<PartyAgainstRequestedName>${PARTY_AGAINST_NAME}</PartyAgainstRequestedName>
				<PartyForPartyRoleCode>${A.PARTY_FOR_PARTY_ROLE_CODE}</PartyForPartyRoleCode>
				<PartyForCasePartyNumber>${A.PARTY_FOR_CASE_PARTY_NO}</PartyForCasePartyNumber>
				<PartyForRequestedName>${PARTY_FOR_NAME}</PartyForRequestedName>
				<DebtorsEmployersPartyId>${A.DEBTORS_EMPLOYERS_PARTY_ID}</DebtorsEmployersPartyId>				
				<TotalFees>
					<TotalFee>${TOTAL_FEE}</TotalFee>					
				</TotalFees>
				<OtherFees>
					<OtherFee>${OTHER_FEE}</OtherFee>
				</OtherFees>
				<Employer>	    		
			    	<PartyId>${P.PARTY_ID}</PartyId>
			        <PersonRequestedName>${P.PERSON_REQUESTED_NAME}</PersonRequestedName>
				    <TypeCode>${P.PARTY_TYPE_CODE}</TypeCode>  	  
			    	<ContactDetails>
			    	  <TelephoneNumber>${P.TEL_NO}</TelephoneNumber>
					  <FaxNumber>${P.FAX_NUMBER}</FaxNumber>
					  <EmailAddress>${P.EMAIL_ADDRESS}</EmailAddress>
					  <DebtorsEmplPrefCommsMethod>${P.PREFERRED_COM_METHOD}</DebtorsEmplPrefCommsMethod>
        			  <DebtorsEmplWelshindicator>${P.WELSH_INDICATOR}</DebtorsEmplWelshindicator>
			    	  <Addresses>
				          <Address>
			    	        <AddressId>${GA.ADDRESS_ID}</AddressId>
			    	        <SurrogateId>${GA.ADDRESS_ID}</SurrogateId>
			    	        <TypeCode>${GA.ADDRESS_TYPE_CODE}</TypeCode>
			        	    <Line>${GA.ADDRESS_LINE1}</Line>
			            	<Line>${GA.ADDRESS_LINE2}</Line>
				            <Line>${GA.ADDRESS_LINE3}</Line>
			    	        <Line>${GA.ADDRESS_LINE4}</Line>
			        	    <Line>${GA.ADDRESS_LINE5}</Line>
			            	<PostCode>${GA.POSTCODE}</PostCode>
			            	<DateFrom>${GA.VALID_FROM}</DateFrom>
				            <DateTo>${GA.VALID_TO}</DateTo>
				            <Reference>${GA.REFERENCE}</Reference>
					        <PartyId>${GA.PARTY_ID}</PartyId>
					        <CreatedBy>${GA.UPDATED_BY}</CreatedBy>					           			
				          </Address>
			          </Addresses>          
				    </ContactDetails>		    	    
				</Employer>
				<Events>
					<Event>
						<EventId>${E.STD_EVENT_ID}</EventId>
						<EventSeq>${E.AE_EVENT_SEQ}</EventSeq>
					</Event>
				</Events>
			</AEApplication>
		</AEApplications>
	  </Case>
	 </ds>
	</Mapping>
</DBMapDef>