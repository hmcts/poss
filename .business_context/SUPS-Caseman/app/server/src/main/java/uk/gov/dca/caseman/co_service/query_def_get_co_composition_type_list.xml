<?xml version="1.0" encoding="UTF-8"?>
<!--
	Service: Co
	Method:  getCoCompositionTypeList()
	File:    query_def_get_co_composition_type_list.xml
	Author:  Phil Haferer (EDS)
	Created: 01 September 2005
	Description: 
		Retrieve the list of Consolidated Order Composition Types.
-->
<QueryDef>
  <DBMapDef location="uk/gov/dca/caseman/co_service/map_get_co_composition_type_list.xml"/>
  <Query pivotNode="/COCompTypes/CompType" tables="REF">
    <Join>
		REF.RV_DOMAIN = 'CONSOLIDATED_ORDERS.COMP_TYPE'
    </Join>
    <Modify notModifiable="true"/>
  </Query>
</QueryDef>
