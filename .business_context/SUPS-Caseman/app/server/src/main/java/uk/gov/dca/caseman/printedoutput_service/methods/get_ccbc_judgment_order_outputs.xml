<?xml version="1.0" encoding="UTF-8"?>
<!--
	Service: Printedoutput
	Method:  getCcbcJudgmentOrderOutputs()
	File:    get_ccbc_judgment_order_outputs.xml
	Author:  Chris Vincent
	Created: 03/10/2007
	Description: 
        Sister service to getJudgmentOrderOutputs which looks for events 230 and 240 associated with
		a judgment.  This is a CCBC specific service which extends the query to look for event 250
		as well as 230 and 240.  UCT_Group2 Defect 1413.
-->
<service-method>
	<pipeline>
		<NewQuery>
  			<QueryDef location="uk/gov/dca/caseman/printedoutput_service/queryGJOOCCBC_def.xml"/>
			<QueryExtension pivotNode="/ds/JudgmentOrderOutput">
				<Param name="param.caseNumber"      xpath="/params/param[@name = 'caseNumber']"/>
				<Param name="param.casePartyNumber" xpath="/params/param[@name = 'casePartyNumber']"/>
				<Param name="param.casePartyRole"   xpath="/params/param[@name = 'casePartyRole']"/>
				<Param name="param.judgmentId"      xpath="/params/param[@name = 'judgmentId']"/>								
			</QueryExtension>					
  		</NewQuery>
  	</pipeline>
	<Security roles="viewOnly medium high wcSuper scSuper bmsSuper aeSuper dmSuper cpSuper ccbcMan ccbcUser ccbcSGB2"/>
</service-method>