<?xml version="1.0" encoding="UTF-8"?>
<!--
	v1.0 Chris Hutt 10/2/2005
	Returns a list of defendants associated with the case
	against whom NO active judgment exists.
	This is determined by value of JUDGMENTS.STATUS - a judgment is deemed to be 
	active if set to 'VARIED' or NULL.
	
-->
<service-method>
	<pipeline>
		<Query>
			<QueryDef location="uk/gov/dca/caseman/judgment_service/query_def_defs_with_no_active_judgment.xml"/>
			<QueryExtension pivotNode="/Case/Parties/Party">
				<Param name="param.caseNumber" xpath="/params/param[@name = 'caseNumber']"/>
				<Constraint>CPR.CASE_NUMBER = ${param.caseNumber}</Constraint>		
			</QueryExtension>
		</Query>
	</pipeline>
	<Security roles="user"/>
</service-method>


