<?xml version="1.0" encoding="UTF-8"?>
<service-method>
	<pipeline>
		<Query>
			<QueryDef location="uk/gov/dca/caseman/rejectedCases_service/rejected_cases_query_def.xml"/>
			
			<QueryExtension pivotNode="/RejectedCases/RejectedCase">
				<Param name="param.CredCode" xpath="/params/param[@name='Creditor_Code']"/>
				<Param name="param.CaseNumber" xpath="/params/param[@name='Case_Number']"/>
				<Param name="param.ClaimantName" xpath="/params/param[@name='Claimant_Name']"/>
				<Param name="param.DefendantName" xpath="/params/param[@name='Defendant_Name']"/>
			
				<Constraint condition="/params/param[@name='Creditor_Code']!=''"  generator="uk.gov.dca.caseman.common.java.sql.LikeEqualsSQLGenerator" param="param.CredCode" column="RC.CRED_CODE" />
				<Constraint condition="/params/param[@name='Case_Number']!=''"  generator="uk.gov.dca.caseman.common.java.sql.LikeEqualsSQLGenerator" param="param.CaseNumber" column="RC.CASE_NUMBER" />
				<Constraint condition="/params/param[@name='Claimant_Name']!=''"  generator="uk.gov.dca.caseman.common.java.sql.LikeEqualsSQLGenerator" param="param.ClaimantName" column="RC.CLAIMANT_DETAILS_1" />
				<Constraint condition="/params/param[@name='Defendant_Name']!=''"  generator="uk.gov.dca.caseman.common.java.sql.LikeEqualsSQLGenerator" param="param.DefendantName" column="RC.DEFENDANT_1_NAME" />
				
				<OrderBy>RC.CRED_CODE </OrderBy>
			</QueryExtension>
		</Query>
	  	<Transform>
			<Template location="uk/gov/dca/caseman/rejectedCases_service/transforms/get_defendants.xsl"/>
		</Transform>
	</pipeline>
	<Security roles="ccbcMan ccbcUser"/>
</service-method>
