<?xml version="1.0" encoding="UTF-8"?>
<DBMapDef>
  <DataSource id="java:OracleDS"/>
  <Tables>
    <Table alias="WR" name="WARRANT_RETURNS"/>
  </Tables>
  <Mapping>
    <ds>
      <WarrantReturns>
        <WarrantEvents>
          <WarrantEvent>
            <WarrantID>${WR.WARRANT_ID}</WarrantID>
            <WarrantReturnsID>${WR.WARRANT_RETURNS_ID}</WarrantReturnsID>
            <Code>${WR.RETURN_CODE}</Code>
            <ReturnDate>${WR.WARRANT_RETURN_DATE}</ReturnDate>
            <CourtCode>${WR.RETURN_CODE_COURT_CODE}</CourtCode>
            <ReturnText>${RC.RETURN_CODE_SUMMARY}</ReturnText>
            <AdditionalDetails>${WR.ADDITIONAL_INFORMATION}</AdditionalDetails>
            <Notice>${WR.NOTICE_REQUIRED}</Notice>
            <Defendant>${WR.DEFENDANT_ID}</Defendant>
            <Verified>${WR.VERIFICATION_DATE}</Verified>
            <Error>${WR.ERROR_INDICATOR}</Error>
            <AppointmentDate>${WR.APPOINTMENT_DATE}</AppointmentDate>
            <AppointmentTime>${WR.APPOINTMENT_TIME}</AppointmentTime>
            <CreatedBy>${WR.CREATED_BY}</CreatedBy>
            <ExecutedBy>${WR.ADMIN_COURT_CODE}</ExecutedBy>
            <ReceiptDate>${WR.RECEIPT_DATE}</ReceiptDate>
            <ToTransfer>${WR.TO_TRANSFER}</ToTransfer>
			<CaseNumber/><!-- Used to create a case event for home warrants -->
			<CoNumber/>
            <LocalNumber/><!-- Used to create a BMS task for foreign warrants -->
          </WarrantEvent>
        </WarrantEvents>
      </WarrantReturns>
    </ds>
  </Mapping>
</DBMapDef>


