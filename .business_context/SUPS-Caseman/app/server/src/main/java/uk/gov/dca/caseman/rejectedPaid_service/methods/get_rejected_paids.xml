<?xml version="1.0" encoding="UTF-8"?>
<service-method>
	<pipeline>
		<Query>
			<QueryDef location="uk/gov/dca/caseman/rejectedPaid_service/rejected_paids_query_def.xml"/>
			
			<QueryExtension pivotNode="/RejectedPaids/RejectedPaid">
				<Param name="param.CreditorCode" xpath="/params/param[@name='Creditor_Code_Query']"/>
				<Constraint condition="/params/param[@name='Creditor_Code_Query'] != ''" >
					RP.CRED_CODE = ${param.CreditorCode}
				</Constraint>
				
				<Param name="param.CaseNumber" xpath="/params/param[@name='Case_Number_Query']"/>
				<Constraint condition="/params/param[@name='Case_Number_Query']!= ''" >
					RP.CASE_NUMBER = ${param.CaseNumber}
				</Constraint>
				<Param name="param.FileSequence" xpath="/params/param[@name='File_Seq_Query']"/>
				<Constraint condition="/params/param[@name='File_Seq_Query'] != ''" >
					RP.CUST_FILE_SEQUENCE = ${param.FileSequence}
				</Constraint>
								
				<Param name="param.pageNumber" xpath="/params/param[@name='pageNumber']"/>
				<Param name="param.pageSize" xpath="/params/param[@name='pageSize']"/>
				
				<Paged pageNumber = "${param.pageNumber}" pageSize = "${param.pageSize}" />
				
				<OrderBy>RP.CRED_CODE</OrderBy>
				
			</QueryExtension>

		</Query>
	</pipeline>
	<Security roles="ccbcMan ccbcUser"/>
</service-method>
