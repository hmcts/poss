<?xml version="1.0" encoding="UTF-8"?>
<service-method>
	<pipeline>
		<Query>
			<QueryDef location="uk/gov/dca/caseman/case_service/query_def_ae.xml"/>
			<QueryExtension pivotNode="/Case">
				<Param name="param.caseNumber" xpath="/params/param[@name = 'caseNumber']"/>
				<Constraint>C.CASE_NUMBER like ${param.caseNumber}</Constraint>
			</QueryExtension>			
		</Query>
	</pipeline>
	<Security roles="user"/>
</service-method>
