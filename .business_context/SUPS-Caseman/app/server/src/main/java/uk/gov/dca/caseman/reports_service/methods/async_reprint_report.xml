<?xml version="1.0" encoding="UTF-8"?>
<!--
	Service: Reports
	Method:  asyncReprintReport.xml()
	File:    async_reprint_report.xml
	Author:  Chris Vincent
	Created: 14 Jan 2015
	Description: 
		Calls reprintReport method in Asynchronous mode using AsyncCall pipeline method.
-->
<service-method>
	<pipeline>
		<AsyncCall service="Reports" method="reprintReport">
			<Destination name="AsyncQueue"/>
		</AsyncCall>
	</pipeline>
	<Dependencies>
		<Dependency serviceName="Reports"/>	
	</Dependencies>
	<Security roles="viewOnly medium high wcSuper scSuper bmsSuper aeSuper dmSuper edsAdmin cpSuper"/>
</service-method>