<?xml version="1.0" encoding="UTF-8"?>
<DBMapDef>
	<DataSource id="java:OracleDS"/>
	<Tables>
		<Table alias="C" name="COURTS"/>
		<Table alias="CA" name="CASES"/>
		<Table alias="P" name="PARTIES"/>
		<Table alias="CPR" name="CASE_PARTY_ROLES"/>
		<Table alias="H" name="HEARINGS"/>
		<Table alias="GA" name="GIVEN_ADDRESSES"/>
		<Table alias="CCBC1" name="CCBC_REF_CODES"/>
		<Table alias="CCBC2" name="CCBC_REF_CODES"/>
		<Table alias="PR"  name="PARTY_ROLES"/>
	</Tables>
	<Mapping>
		<ds>
			<MaintainHearing>
				<CaseNumber>${CA.CASE_NUMBER}</CaseNumber>
				<OwningCourtCode>${CA.ADMIN_CRT_CODE}</OwningCourtCode>
				<OwningCourt>${C.NAME}</OwningCourt>
				<CaseType>${CA.CASE_TYPE}</CaseType>
				<Parties>
					<Party>
						<PartyType>${CPR.PARTY_ROLE_CODE}</PartyType>
						<PartyTypeDescription>${PR.PARTY_ROLE_DESCRIPTION}</PartyTypeDescription>
						<Number>${CPR.CASE_PARTY_NO}</Number>
						<Name>${P.PERSON_REQUESTED_NAME}</Name>
					</Party>
				</Parties>
				<Hearings>
					<Hearing>
						<HearingID>${H.HRG_SEQ}</HearingID>
						<SurrogateId>${H.HRG_SEQ}</SurrogateId>
						<VenueCode>${H.CRT_CODE}</VenueCode>
						<VenueName>${H.VENUE}</VenueName>
						<TypeOfHearingCode>${H.HRG_TYPE}</TypeOfHearingCode>
						<TypeOfHearing>${CCBC1.RV_MEANING}</TypeOfHearing>
						<Date>${H.HRG_DATE}</Date>
						<Day/>
						<Time>${H.HRG_TIME}</Time>
						<Address>
							<AddressId>${H.ADDRESS_ID}</AddressId>
							<Line>${GA.ADDRESS_LINE1}</Line>
							<Line>${GA.ADDRESS_LINE2}</Line>
							<Line>${GA.ADDRESS_LINE3}</Line>
							<Line>${GA.ADDRESS_LINE4}</Line>
							<Line>${GA.ADDRESS_LINE5}</Line>
							<PostCode>${GA.POSTCODE}</PostCode>
						</Address>
						<DXNumber>${C.DX_NUMBER}</DXNumber>
						<TelephoneNumber>${C.TEL_NO}</TelephoneNumber>
						<FaxNumber>${C.FAX_NO}</FaxNumber>
						<HoursAllowed>${H.HOURS_ALLOWED}</HoursAllowed>
						<MinsAllowed>${H.MINS_ALLOWED}</MinsAllowed>
						<DateOfRequestToList>${H.RECEIPT_DATE}</DateOfRequestToList>
						<HearingOutcomeCode>${H.HRG_OUTCOME}</HearingOutcomeCode>
						<HearingOutcome>${CCBC2.RV_MEANING}</HearingOutcome>/>
					</Hearing>
				</Hearings>
				<OwningCourtAddressDetail>
					<Address>
						<AddressId>${GA.ADDRESS_ID}</AddressId>
						<Line>${GA.ADDRESS_LINE1}</Line>
						<Line>${GA.ADDRESS_LINE2}</Line>
						<Line>${GA.ADDRESS_LINE3}</Line>
						<Line>${GA.ADDRESS_LINE4}</Line>
						<Line>${GA.ADDRESS_LINE5}</Line>
						<PostCode>${GA.POSTCODE}</PostCode>
					</Address>
					<DXNumber>${C.DX_NUMBER}</DXNumber>
					<TelephoneNumber>${C.TEL_NO}</TelephoneNumber>
					<FaxNumber>${C.FAX_NO}</FaxNumber>
				</OwningCourtAddressDetail>
			</MaintainHearing>
		</ds>
	</Mapping>
</DBMapDef>
