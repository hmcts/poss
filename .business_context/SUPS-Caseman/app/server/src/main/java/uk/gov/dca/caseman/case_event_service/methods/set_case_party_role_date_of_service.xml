<?xml version="1.0" encoding="UTF-8"?>
<service-method>
	<pipeline>
		<Update>
			<QueryDef location="uk/gov/dca/caseman/case_event_service/query_def_set_case_party_role_date_of_service.xml"/>
			<DataSource xpath="/params/param"/>
			<QueryExtension pivotNode="/CasePartyRole">
