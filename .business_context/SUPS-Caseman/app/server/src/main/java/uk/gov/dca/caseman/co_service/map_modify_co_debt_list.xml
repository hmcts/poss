<?xml version="1.0" encoding="UTF-8"?>
<!--
	Service: Co
	Method:  addCo()
	File:    map_modify_co_debt_list.xml
	Author:  Phil Haferer (EDS)
	Created: 17 August 2005
	Description: 
		The 'Mapping' for retrieve the list of Debts associated with a Consolidated Order.
	
	Change History:
	18-10-2005 Phil Haferer: Creditor/Payee mapped into the ALLOWED_DEBTS table (as well as PARTIES).
	11-01-2006 Phil Haferer: Comms Method and Welsh Indicator for Creditor/Payee mapped into the ALLOWED_DEBTS.
-->
<DBMapDef>
	<DataSource id="java:OracleDS"/>
	<Tables>
		<Table alias="AD"  name="ALLOWED_DEBTS"/>
		<Table alias="P"   name="PARTIES"/>
		<Table alias="GA"  name="GIVEN_ADDRESSES"/>
	</Tables>
	<Mapping>
		<ds>
			<MaintainCO>
				<Debts>
					<Debt>
						<DebtSeq>${AD.DEBT_SEQ}</DebtSeq>
						<DebtSurrogateId></DebtSurrogateId>
						<DebtAmountAllowed>${AD.DEBT_AMOUNT_ALLOWED}</DebtAmountAllowed>
						<DebtAmountAllowedCurrency>${AD.DEBT_AMOUNT_ALLOWED_CURRENCY}</DebtAmountAllowedCurrency>
						<DebtAmountOriginal>${AD.DEBT_AMOUNT_ORIGINAL}</DebtAmountOriginal>
						<DebtAmountOriginalCurrency>${AD.DEBT_AMOUNT_ORIGINAL_CURRENCY}</DebtAmountOriginalCurrency>
						<CasemanDebt>${AD.CASEMAN_DEBT}</CasemanDebt>
						<DebtStatus>${AD.DEBT_STATUS}</DebtStatus>
						<DebtCaseNumber>${AD.DEBT_CASE_NUMBER}</DebtCaseNumber>
						<PartyRoleCode>${AD.DEFT_PARTY_ROLE_CODE}</PartyRoleCode>
						<CasePartyNumber>${AD.DEFT_CASE_PARTY_NO}</CasePartyNumber>
						<DebtAdminCourtCode>${AD.DEBT_ADMIN_COURT_CODE}</DebtAdminCourtCode>
						<CreditorReference>${AD.DEBT_CREDITOR_REFERENCE}</CreditorReference>
						<CPCreditorId>${AD.CP_CREDITOR_ID}</CPCreditorId>
						<CreditorCommMethod>${AD.CREDITOR_PREF_COMM_METHOD}</CreditorCommMethod>
						<CreditorTranslationToWelsh>${AD.CREDITOR_WELSH_INDICATOR}</CreditorTranslationToWelsh>					
						<Creditor>
							<Party>
								<CPCode>${CP.CODE}</CPCode>
								<PartyId>${P.PARTY_ID}</PartyId>
								<Name>${P.PERSON_REQUESTED_NAME}</Name> 
								<DX>${P.DX_NUMBER}</DX>
								<TelNo>${P.TEL_NO}</TelNo>
								<FaxNo>${P.FAX_NUMBER}</FaxNo>
								<Email>${P.EMAIL_ADDRESS}</Email>
								<Reference/>
							</Party>
							<Address>
								<Status/>
								<AddressSurrogateId></AddressSurrogateId>
								<AddressId>${GA.ADDRESS_ID}</AddressId>
								<Line>${GA.ADDRESS_LINE1}</Line>
								<Line>${GA.ADDRESS_LINE2}</Line>
								<Line>${GA.ADDRESS_LINE3}</Line>
								<Line>${GA.ADDRESS_LINE4}</Line>
								<Line>${GA.ADDRESS_LINE5}</Line>
								<PostCode>${GA.POSTCODE}</PostCode>
								<CreatedBy>${GA.UPDATED_BY}</CreatedBy>
								<ValidFrom>${GA.VALID_FROM}</ValidFrom>
								<ValidTo>${GA.VALID_TO}</ValidTo>
							</Address>
							<AddressHistory>
								<Address>
									<Status/>
									<AddressSurrogateId></AddressSurrogateId>
									<AddressId>${GA.ADDRESS_ID}</AddressId>
									<Line>${GA.ADDRESS_LINE1}</Line>
									<Line>${GA.ADDRESS_LINE2}</Line>
									<Line>${GA.ADDRESS_LINE3}</Line>
									<Line>${GA.ADDRESS_LINE4}</Line>
									<Line>${GA.ADDRESS_LINE5}</Line>
									<PostCode>${GA.POSTCODE}</PostCode>
									<CreatedBy>${GA.UPDATED_BY}</CreatedBy>
									<ValidFrom>${GA.VALID_FROM}</ValidFrom>
									<ValidTo>${GA.VALID_TO}</ValidTo>
								</Address>
							</AddressHistory>
						</Creditor>
						<AddressUnknown>${AD.ADDRESS_UNKNOWN}</AddressUnknown>
						<PayeeReference>${AD.DEBT_PAYEE_REFERENCE}</PayeeReference>
						<CPPayeeId>${AD.CP_PAYEE_ID}</CPPayeeId>
						<PayeeCommMethod>${AD.PAYEE_PREF_COMM_METHOD}</PayeeCommMethod>
						<PayeeTranslationToWelsh>${AD.PAYEE_WELSH_INDICATOR}</PayeeTranslationToWelsh>					
						<Payee>
							<Party>
								<CPCode>${CP.CODE}</CPCode>
								<PartyId>${P.PARTY_ID}</PartyId>
								<Name>${P.PERSON_REQUESTED_NAME}</Name> 
								<DX>${P.DX_NUMBER}</DX>
								<TelNo>${P.TEL_NO}</TelNo>
								<FaxNo>${P.FAX_NUMBER}</FaxNo>
								<Email>${P.EMAIL_ADDRESS}</Email>
								<Reference/>
							</Party>
							<Address>
								<Status/>
								<AddressSurrogateId></AddressSurrogateId>
								<AddressId>${GA.ADDRESS_ID}</AddressId>
								<Line>${GA.ADDRESS_LINE1}</Line>
								<Line>${GA.ADDRESS_LINE2}</Line>
								<Line>${GA.ADDRESS_LINE3}</Line>
								<Line>${GA.ADDRESS_LINE4}</Line>
								<Line>${GA.ADDRESS_LINE5}</Line>
								<PostCode>${GA.POSTCODE}</PostCode>
								<CreatedBy>${GA.UPDATED_BY}</CreatedBy>
								<ValidFrom>${GA.VALID_FROM}</ValidFrom>
								<ValidTo>${GA.VALID_TO}</ValidTo>
							</Address>
							<AddressHistory>
								<Address>
									<Status/>
									<AddressSurrogateId></AddressSurrogateId>
									<AddressId>${GA.ADDRESS_ID}</AddressId>
									<Line>${GA.ADDRESS_LINE1}</Line>
									<Line>${GA.ADDRESS_LINE2}</Line>
									<Line>${GA.ADDRESS_LINE3}</Line>
									<Line>${GA.ADDRESS_LINE4}</Line>
									<Line>${GA.ADDRESS_LINE5}</Line>
									<PostCode>${GA.POSTCODE}</PostCode>
									<CreatedBy>${GA.UPDATED_BY}</CreatedBy>
									<ValidFrom>${GA.VALID_FROM}</ValidFrom>
									<ValidTo>${GA.VALID_TO}</ValidTo>
								</Address>
							</AddressHistory>
						</Payee>
						<DebtPayeeIndicator>${AD.DEBT_PAYEE_INDICATOR}</DebtPayeeIndicator>
					</Debt>
				</Debts>
			</MaintainCO>
		</ds>
	</Mapping>
</DBMapDef>
