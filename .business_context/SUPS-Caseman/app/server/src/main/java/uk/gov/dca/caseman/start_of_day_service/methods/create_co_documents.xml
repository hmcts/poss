<?xml version="1.0" encoding="UTF-8"?>
<!--
	Service: StartOfDay
	Method:  createAeDocuments()
	File:    create_co_documents.xml
	Author:  Chris Hutt
	Created: 6 dec 2005
	Description: 
		Calls Customprocessor to create reports associated with the CO StartOfDay
-->
<service-method>
	<pipeline>  
		<Java>
			<Source class="uk.gov.dca.caseman.reports_service.classes.CreateCoDocumentsCustomProcessor"/>
		</Java>         
	</pipeline>
	<Dependencies>
		<Dependency serviceName="Reports"/>
		<Dependency serviceName="SystemData"/>
	</Dependencies>	
	<Security roles="viewOnly medium high wcSuper scSuper bmsSuper aeSuper dmSuper edsAdmin"/>
</service-method>