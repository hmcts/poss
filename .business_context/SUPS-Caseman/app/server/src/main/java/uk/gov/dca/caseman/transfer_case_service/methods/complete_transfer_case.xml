<?xml version="1.0" encoding="UTF-8"?>
<!--
	Service: TransferCase
	Method:  completeTransferCase()
	File:    complete_transfer_case.xml
	Author:  Phil Haferer (EDS)
	Created: 27 July 2005
	Description: 
		Complete Transfer the specified Case from one SUPS Court to another.
-->
<service-method>
	<pipeline>
		<Query>
			<QueryDef location="uk/gov/dca/caseman/transfer_case_service/query_def_get_transfer_case.xml"/>
			<QueryExtension pivotNode="/TransferCase">
				<Param name="param.caseNumber" xpath="/params/param[@name = 'caseNumber']"/>
			</QueryExtension>
		</Query>
		<Java>
			<Source class="uk.gov.dca.caseman.transfer_case_service.java.LaunchCompleteTransferCaseCustomProcessor"/>
		</Java>		
	</pipeline>
	<Dependencies>
		<Dependency serviceName="CaseEvent"/>
	</Dependencies>
	<Security roles="medium high wcSuper scSuper bmsSuper aeSuper dmSuper cpSuper ccbcMan ccbcUser ccbcSGB2"/>
</service-method>