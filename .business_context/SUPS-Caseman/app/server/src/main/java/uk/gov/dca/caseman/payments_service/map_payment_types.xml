<?xml version="1.0" encoding="UTF-8"?>
<!--
	Service: Payments
	Method: getPaymentTypes()
	File: map_payment_types.xml
	Author: Steve Blair
-->
<DBMapDef>
	<DataSource id="java:OracleDS" />
	<Tables>
		<Table alias="CRC" name="CCBC_REF_CODES" />
	</Tables>
	<Mapping>
		<PaymentTypes>
			<PaymentType>
				<Display>${CRC.RV_MEANING}</Display>
				<Code>${CRC.RV_LOW_VALUE}</Code>
			</PaymentType>
		</PaymentTypes>
	</Mapping>
</DBMapDef>