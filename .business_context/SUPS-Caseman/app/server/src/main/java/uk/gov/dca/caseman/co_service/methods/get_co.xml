<?xml version="1.0" encoding="UTF-8"?>
<!--
	Service: Co
	Method:  getCo()
	File:    get_co.xml
	Author:  Phil Haferer (EDS)
	Created: 04 August 2005
	Description: 
		Retrieve details for a Consolidated Order.
-->
<service-method>
	<pipeline>
		<Query>
			<QueryDef location="uk/gov/dca/caseman/co_service/query_def_get_co.xml"/>
			<QueryExtension pivotNode="/ds/MaintainCO">
				<Param name="param.coNumber" xpath="/params/param[@name = 'coNumber']"/>
			</QueryExtension>
		</Query>
		<Java callStyle="new">
			<Source class="uk.gov.dca.caseman.co_service.java.GetCoDebtListCustomProcessor"/>
		</Java>
	</pipeline>
	<Security roles="viewOnly medium high wcSuper scSuper bmsSuper aeSuper dmSuper cpSuper"/>		
</service-method>