<?xml version="1.0" encoding="UTF-8"?>
<!--
	Service: PrintedOutput
	Method:  getPrintOptions
	File:    get_print_options.xml
	Author:  Anoop Sehdev
	Created: 02-Jun-2006
	Description: 
		Retrieve value of WP_OUTPUT.PDF_SOURCE given the value of outputID.
-->
<service-method>
	<pipeline>
		<SQLLite format-output="true"
				 resultset-element="ds"
				 row-element="Report"
				 field-name-as="element" >
			<DataSource id="java:OracleDS"/>
			<Param name="param.outputID" xpath="/params/param[@name='outputID']"/>
			<SQL>
				SELECT WPO.PDF_SOURCE AS "PDF_SOURCE" FROM WP_OUTPUT WPO WHERE WPO.OUTPUT_ID = ${param.outputID}
			</SQL>
		</SQLLite>
	</pipeline>
	<Security roles="viewOnly medium high wcSuper scSuper bmsSuper aeSuper dmSuper"/>
</service-method>