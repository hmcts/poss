<?xml version="1.0" encoding="UTF-8"?>
<!--
Service: JudgmentRefdata
	Method:  getJudgmentDeterminationPeriods()
	File:    get_judgment_determinationperiods.xml
	Author:  Troy Baines
	Created: 20 November 2004
	Description: 
        Retrieves the list of determination periods for the judgment window
-->
<service-method>
	<pipeline>
		<Query>
			<QueryDef location="uk/gov/dca/caseman/judgment_refdata_service/query_def_determination_period.xml"/>
			<QueryExtension pivotNode="/JudgmentPeriods/Period">
				<Constraint>CRC.RV_DOMAIN = 'DETERMINATION_PERIOD'</Constraint>
			</QueryExtension>
		</Query>
	</pipeline>
	<Security roles="viewOnly medium high wcSuper scSuper bmsSuper aeSuper dmSuper cpSuper ccbcMan ccbcUser ccbcSGB2"/>
</service-method>
