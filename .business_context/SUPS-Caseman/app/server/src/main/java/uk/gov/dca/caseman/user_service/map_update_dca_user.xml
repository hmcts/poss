<?xml version="1.0" encoding="UTF-8"?>
<!--
    Change History:
	05-Feb-2008 Chris Vincent: Added PrinterCourtCode for CaseMan Defect 6181
-->
<DBMapDef>
	<DataSource id="java:OracleDS"/>
	<Tables>
		<Table alias="DU" name="DCA_USER"/>
	</Tables>
	<Mapping>
		<ds>
			<MaintainUser>		
				<UserId>${DU.USER_ID}</UserId>
				<Title>${DU.TITLE}</Title>
				<Forenames>${DU.FORENAMES}</Forenames>
				<Surname>${DU.SURNAME}</Surname>
				<UserShortName>${DU.USER_SHORT_NAME}</UserShortName>
				<Extension>${DU.EXTENSION}</Extension>
				<PrinterCourtCode>${DU.PRINTER_COURT_CODE}</PrinterCourtCode>
				<DefaultPrinter>${DU.USER_DEFAULT_PRINTER}</DefaultPrinter>
				<ActiveUser>${DU.ACTIVE_USER_FLAG}</ActiveUser>
				<SectionForPrintouts>${DU.SECTION_FOR_PRINTOUTS}</SectionForPrintouts>				
			</MaintainUser>
		</ds>
	</Mapping>
</DBMapDef>