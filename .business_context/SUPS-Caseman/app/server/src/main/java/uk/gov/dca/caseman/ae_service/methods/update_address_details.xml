<?xml version="1.0" encoding="UTF-8"?>
<service-method>
	<pipeline>
		<Update>
			<QueryDef location="uk/gov/dca/caseman/ae_service/query_def_update_addresses.xml"/>
			<DataSource xpath="/params/param[@name='AddressDetails']"/>
			<QueryExtension pivotNode="/Addresses/Address">
				<CheckExists table="GA" fields="ADDRESS_ID" onNotExist="add" onExist="update"/>
			</QueryExtension>
		</Update>
	</pipeline>
	<Security roles="user"/>
</service-method>
