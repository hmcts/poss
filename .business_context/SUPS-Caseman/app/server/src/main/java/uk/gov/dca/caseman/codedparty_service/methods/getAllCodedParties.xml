<?xml version="1.0" encoding="UTF-8"?>
<!--
	Service: Codedparty
	Method:  getAllCodedParties()
	File:    getAllCodedParties.xml
	Author:  
	Created: 
	Description: 
		Retrieves a list of National & Local Coded Parties containing the full party and address details.
	Change History:
		20/09/2011 - Chris Vincent, added search for CCBC National Coded Parties in range 7000-9999.  Trac 4553.
-->
<service-method>
	<pipeline>
		<Query>
  			<QueryDef location="uk/gov/dca/caseman/codedparty_service/query_def.xml"/>
			<QueryExtension pivotNode="/CodedParties/CodedParty">
				<Param name="param.adminCourtCode" xpath="/params/param[@name = 'adminCourtCode']"/>
				<Constraint>
					CP.ADMIN_COURT_CODE = ${param.adminCourtCode} OR
					CP.ADMIN_COURT_CODE = 0 OR
				    (CP.ADMIN_COURT_CODE = 335 AND CP.CODE BETWEEN 1500 AND 1999) OR
					(CP.ADMIN_COURT_CODE = 335 AND CP.CODE BETWEEN 7000 AND 9999)
				</Constraint>
			</QueryExtension>
		</Query>
  	</pipeline>
	<Security roles="medium high wcSuper scSuper bmsSuper aeSuper dmSuper cpSuper" />
</service-method>