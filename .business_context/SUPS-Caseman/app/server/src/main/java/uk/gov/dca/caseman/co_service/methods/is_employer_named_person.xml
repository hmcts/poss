<?xml version="1.0" encoding="UTF-8"?>
<!--
	Service: Co
	Method:  isEmployerNamedPerson
	Author:  Chris Hutt (EDS) 
	Created: 2 dec 2005
	Description: 
		Use SQLLite to determine whether an Employer Named Person (a contact) has been persisted 
-->
<service-method>
	<pipeline>
		<SQLLite format-output="true"
				 resultset-element="ds"
				 row-element="CO"
				 field-name-as="element" >
			<DataSource id="java:OracleDS"/>
			<Param name="param.coNumber" xpath="/params/param[@name='coNumber']"/>
			<SQL>
				SELECT  
						DECODE(COUNT(*),0,'false','true') AS "EmployersNamedPersonExists"
				FROM 	CONSOLIDATED_ORDERS CO 
				WHERE	CO.CO_NUMBER =  ${param.coNumber}
				AND 	CO.NAMED_EMPLOYER IS NOT NULL
			</SQL>
		</SQLLite>
  	</pipeline>
	<Security roles="user"/>
</service-method>
