<?xml version="1.0" encoding="UTF-8"?>
<!--
	Service: Court
	Method:  updateCourt
	File:    update_court.xml
	Author:  Chris Vincent (EDS)
	Created: 24 November 2005
	Description: Updates the details of a particular court, possibly adding new addresses
-->
<service-method>
	<pipeline>
		<Update>
			<QueryDef location="uk/gov/dca/caseman/court_service/query_def_update_court.xml"/>
			<DataSource xpath="/params/param[@name='courtDetails']"/>
			<QueryExtension pivotNode="/Court">
				<Field name="P.CRT_CODE" xpath="Code"/>
				<CheckExists table="CT" fields="CODE" onNotExist="fail" onExist="update"/>
				<CheckExists table="P" fields="CRT_CODE" onNotExist="fail" onExist="update"/>
			</QueryExtension>
			<QueryExtension pivotNode="/Court/ContactDetails/Addresses/Address">
				<Field name="GA.ADDRESS_ID" sequenceTable="ADDR_SEQUENCE"/>
				<CheckExists table="GA" fields="ADDRESS_ID" onNotExist="add" onExist="update"/>
			</QueryExtension>
		</Update>
	</pipeline>
	<Security roles="edsAdmin"/>		
</service-method>