<?xml version="1.0" encoding="UTF-8"?>
<!-- 
	Service: Printedoutput
	Method:  getOutstandingOutputs()
	File:    get_outstanding_outputs.xml
	Author:  Chris Hutt
	Created: 23 Nov 2004
	Description: 
		Retrieves outstanding WP outputs for specified case/user

	Change History
    	Chris Hutt 11 may 07. Privot nodes combined to ensure that cases with no output are not returned
    	Chris Hutt 23 jan 08. TD Caseman 6496 : As part of performance improvement retrieval is now handled through
    	                      a custom processor which calls a amended version of the original version of this
    	                      service method called getOutstandingOutputsForUser().
    	Phil Barton Dec 08    Restore performance change made by Valtech.
        Mark Groen 05 Aug 09  Remove  <Constraint>CE.CASE_NUMBER LIKE ${param.caseNumber}</Constraint> and
                              <Param name="param.caseNumber" xpath="/params/param[@name = 'caseNumber']"/>
                              as % entered by the user no need to use thi sconstraint.  A new service is used for full
                              case number searches.
--> 
<service-method>
    <pipeline>
        <NewQuery>
            <QueryDef location="uk/gov/dca/caseman/printedoutput_service/query_def.xml"/>
                <QueryExtension pivotNode="/Cases/Case">
                    <Param name="param.userName" xpath="/params/param[@name = 'userId']"/>
                    <Constraint>WPO.USER_ID = ${param.userName}</Constraint>
                </QueryExtension>
        </NewQuery>
    </pipeline>
	<Security roles="viewOnly medium high wcSuper scSuper bmsSuper aeSuper dmSuper cpSuper ccbcMan ccbcUser ccbcSGB2"/>
</service-method>