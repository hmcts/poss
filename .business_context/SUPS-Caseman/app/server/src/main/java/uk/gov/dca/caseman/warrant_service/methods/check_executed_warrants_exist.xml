<?xml version="1.0" encoding="UTF-8"?>
<!-- 
	Service: Warrant
	Method:  checkExecutedWarrantsExist()
	File:    check_executed_warrants_exist.xml
	Author:  Alex Peterson
	Created: 28 August 2005
	Description: 
		Checks the number of existing executed warrants
	
Change History
	01/08/2006 - Chris Vincent fixed defect 4111 by adding security roles to the service.
	04/08/2006 - Chris Vincent: fixed defect 4141 by adding security role ccbcMan to the service.
-->
<service-method>
	<pipeline>
		<Query>
			<QueryDef location="uk/gov/dca/caseman/warrant_service/query_def_executed_warrants_exist.xml"/>
			<QueryExtension pivotNode="/ExecutedWarrantsFound">
				<Param name="param.owningCourtCode" xpath="/params/param[@name = 'owningCourtCode']"/>
				<Param name="param.issueDate" xpath="/params/param[@name = 'issueDate']"/>
			</QueryExtension>
		</Query>
	</pipeline>
	<Security roles="medium high wcSuper scSuper bmsSuper aeSuper dmSuper cpSuper ccbcMan"/>
</service-method>