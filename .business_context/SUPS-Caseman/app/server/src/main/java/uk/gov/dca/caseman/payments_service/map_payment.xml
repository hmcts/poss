<?xml version="1.0" encoding="UTF-8"?>
<!--
	Service: Payments
	Method: getPayment(), createPayment(), updatePayment(), updateOverpayment()
	File: map_payment.xml
	Author: Steve Blair

    Change History
    TRAC Ticket 707.
    17-06-2009 Mark Groen - Incorporate changes defined by Chris Vincent re scalabilty for Navigate to View Payments
    and Transfer Case. Added <EnforcementParent>${P.ENFORCEMENT_PARENT}</EnforcementParent>
-->
<DBMapDef>
	<DataSource id="java:OracleDS" />
	<Tables>
		<Table alias="P" name="PAYMENTS" />
		<Table alias="CP" name="CODED_PARTIES" />
		<Table alias="CT" name="COURTS" />
	</Tables>
	<Mapping>
		<Payment>
			<TransactionNumber>${P.TRANSACTION_NUMBER}</TransactionNumber>
			<EnforcementNumber>${P.SUBJECT_NO}</EnforcementNumber>
			<EnforcementType>${P.PAYMENT_FOR}</EnforcementType>
            <EnforcementParent>${P.ENFORCEMENT_PARENT}</EnforcementParent>
            <Amount>${P.AMOUNT}</Amount>
			<AmountCurrency>${P.AMOUNT_CURRENCY}</AmountCurrency>
			<PaymentType>${P.PAYMENT_TYPE}</PaymentType>
			<RetentionType>${P.RETENTION_TYPE}</RetentionType>
			<OverpaymentAmount>${P.OVERPAYMENT_AMOUNT}</OverpaymentAmount>
			<OverpaymentAmountCurrency>${P.OVERPAYMENT_AMOUNT_CURRENCY}</OverpaymentAmountCurrency>
			<AmountNowDue>${AMOUNT_NOW_DUE}</AmountNowDue>
			<CounterPayment>${P.COUNTER_PAYMENT}</CounterPayment>
			<PaymentDate>${P.DATE_ENTERED}</PaymentDate>
			<ReleaseDate>${P.RELEASE_DATE}</ReleaseDate>
			<PayoutDate>${P.PAYOUT_DATE}</PayoutDate>
			<RDDate>${P.RD_DATE}</RDDate>
			<Notes>${P.NOTES}</Notes>
			<Lodgment>
				<Name>${P.LODGMENT_NAME}</Name>
				<PartyRole>${P.LODGMENT_PARTY_ROLE_CODE}</PartyRole>
				<CasePartyNumber>${P.LODGMENT_CASE_PARTY_NO}</CasePartyNumber>
				<Address>
					<Line>${P.LODGMENT_ADDR1}</Line>
					<Line>${P.LODGMENT_ADDR2}</Line>
					<Line>${P.LODGMENT_ADDR3}</Line>
					<Line>${P.LODGMENT_ADDR4}</Line>
					<Line>${P.LODGMENT_ADDR5}</Line>
					<PostCode>${P.LODGMENT_POSTCODE}</PostCode>
					<Reference>${P.LODGMENT_REFERENCE}</Reference>
				</Address>
			</Lodgment>
			<PONumber1>${P.PAYABLE_ORDER_NUMBER_1}</PONumber1>
			<PONumber2>${P.PAYABLE_ORDER_NUMBER_2}</PONumber2>
			<POTotal>${P.PO_TOTAL}</POTotal>
			<POTotalCurrency>${P.PO_TOTAL_CURRENCY}</POTotalCurrency>
			<ReceiptRequired>${P.RECEIPT_REQUIRED}</ReceiptRequired>
			<BailiffKnowledge>${P.BAILIFF_KNOWLEDGE}</BailiffKnowledge>
			<EnforcementCourt>${P.ENFORCEMENT_COURT_CODE}</EnforcementCourt>
			<AdminCourt>${P.ADMIN_COURT_CODE}</AdminCourt>
			<IssuingCourt>${P.ISSUING_COURT}</IssuingCourt>
			<IssuingCourtName>${CT.NAME}</IssuingCourtName>
			<VerificationReportID>${P.VERIFICATION_REPORT_ID}</VerificationReportID>
			<CreatedBy>${P.CREATED_BY}</CreatedBy>
			<Payee>
				<Name>${P.PAYEE_NAME}</Name>
				<Code>${CP.CODE}</Code>
				<PartyID>${P.PAYEE_ID}</PartyID>
				<Address>
					<Line>${P.PAYEE_ADDR_1}</Line>
					<Line>${P.PAYEE_ADDR_2}</Line>
					<Line>${P.PAYEE_ADDR_3}</Line>
					<Line>${P.PAYEE_ADDR_4}</Line>
					<Line>${P.PAYEE_ADDR_5}</Line>
					<PostCode>${P.PAYEE_POSTCODE}</PostCode>
					<Reference>${P.PAYEE_REFERENCE}</Reference>
				</Address>
				<DX>${P.PAYEE_REP_DX}</DX>
			</Payee>
			<Overpayee>
				<Name>${P.OVERPAYEE_NAME}</Name>
				<Address>
					<Line>${P.OVERPAYEE_ADDR1}</Line>
					<Line>${P.OVERPAYEE_ADDR2}</Line>
					<Line>${P.OVERPAYEE_ADDR3}</Line>
					<Line>${P.OVERPAYEE_ADDR4}</Line>
					<Line>${P.OVERPAYEE_ADDR5}</Line>
					<PostCode>${P.OVERPAYEE_POSTCODE}</PostCode>
				</Address>
			</Overpayee>
			<Passthrough>${P.PASSTHROUGH}</Passthrough>
			<Error>${P.ERROR_INDICATOR}</Error>
			<RelatedTransactionNumber>${P.RELATED_TRANSACTION_NUMBER}</RelatedTransactionNumber>
			<RelatedAdminCourt>${P.RELATED_ADMIN_COURT_CODE}</RelatedAdminCourt>
			<AOPassthroughTransactionNumber>${AO_TRANS_NO}</AOPassthroughTransactionNumber>
			<PayoutReportID>${P.PAYOUT_REPORT_ID}</PayoutReportID>
			<DebtSeq>${P.ALD_DEBT_SEQ}</DebtSeq>
			<!--Used as parameters for creating & updating payments -->
			<OldRetentionType />
			<OldAmount />
			<OldError />
			<ReportNumber />
			<ReportType />
		</Payment>
	</Mapping>
</DBMapDef>