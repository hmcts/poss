<?xml version="1.0" encoding="UTF-8"?>
<!--
	Service: Court
	Method:  getCourts()
	File:    get_courts.xml
	Author:  Troy Baines
	Created: 10 November 2004
	Description: 
        Retrieves List of Courts including full name, short name, address, valid dates and in use flag
-->
<service-method>
	<pipeline>
		<NewQuery>
			<QueryDef location="uk/gov/dca/caseman/court_service/query_def.xml"/>
			<QueryExtension pivotNode="/Courts/Court">
				<OrderBy>CT.CODE</OrderBy>
			</QueryExtension>
		</NewQuery>
	</pipeline>
	<Security roles="viewOnly medium high wcSuper scSuper bmsSuper aeSuper dmSuper cpSuper ccbcMan ccbcUser ccbcSGB2"/>
</service-method>
