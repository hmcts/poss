	<DataSource id="java:OracleDS"/>
	<Tables>
		<Table alias="TC" name="TASK_COUNTS"/>
	</Tables>
	<Mapping>
		<ds>
			<Task>
				<TaskNumber>${TC.TASK_NUMBER}</TaskNumber>
				<AgeCategory>${TC.AGE_CATEGORY}</AgeCategory>
				<TaskDate>${TC.TASK_DATE}</TaskDate>
