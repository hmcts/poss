<?xml version="1.0" encoding="UTF-8"?>
<!--
	Service: Case
	Method:  getCaseForBms()
	Author:   Chris Hutt (EDS) 
	Created:  3 April 07
-->
<service-method>
	<pipeline>
		<Query>
			<QueryDef location="uk/gov/dca/caseman/case_service/query_def_get_case_for_bms.xml"/>
			<QueryExtension pivotNode="/Case">
				<Param name="param.caseNumber" xpath="/params/param[@name = 'caseNumber']"/>
				<Constraint>C.CASE_NUMBER = ${param.caseNumber}</Constraint>
			</QueryExtension>
		</Query>
	</pipeline>
	<Security roles="user"/>
</service-method>
