<?xml version="1.0" encoding="UTF-8"?>
<!--
	Service: Co
	Method:  isDividendDeclared
	Author:  Chris Hutt (EDS) 
	Created: 19 July 2005
	Description: 
		Use SQLLite to determine whether a dividend has been declared on a consolidated order 
-->
<service-method>
	<pipeline>
		<SQLLite format-output="true"
				 resultset-element="ds"
				 row-element="CO"
				 field-name-as="element" >
			<DataSource id="java:OracleDS"/>
			<Param name="param.coNumber" xpath="/params/param[@name='coNumber']"/>
			<SQL>
				SELECT  
						DECODE(COUNT(*),0,'false','true') AS "DividendDeclared"
				FROM 	DIVIDENDS D
				WHERE 	D.DIV_CO_NUMBER = ${param.coNumber}
			</SQL>
		</SQLLite>
  	</pipeline>
	<Security roles="user"/>
</service-method>


