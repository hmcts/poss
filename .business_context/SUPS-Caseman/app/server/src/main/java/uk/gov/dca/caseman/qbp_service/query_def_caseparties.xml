		GA.ADDRESS_LINE2 LIKE NVL(UPPER (${param.address2}), GA.ADDRESS_LINE2 )AND 
        GA.VALID_TO IS NULL AND 
       (CPR.PARTY_ROLE_CODE &lt;&gt; 'SOLICITOR' OR 
        EXISTS
            (SELECT NULL 
             FROM   CPR_TO_CPR_RELATIONSHIP CPR2CPRB
             WHERE  CPR2CPRB.CPR_B_CASE_NUMBER     = CPR.CASE_NUMBER
             AND    CPR2CPRB.CPR_B_PARTY_ROLE_CODE = CPR.PARTY_ROLE_CODE
