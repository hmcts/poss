<?xml version="1.0" encoding="UTF-8"?>
<!-- 
    Service: Qbp
    Method:  getCaseParties()
    File:    query_def_caseparties.xml
    
	13/12/2004 CJHutt 
		For coded parties the address is not case related . test Director defect 113
	13/04/2005 P E Haferer
		For change to relationship to addresses, and to exclude unused Solicitors.
	5/4/2006 G Miller
		Updates to remove full table scan on CPR ( a bit filthy) Defect #2953 
	25/08/2006 P E Haferer
		Correction to clause which excludes unused Solicitors.
		Removed usage of GIVEN_ADDRESSES.PARTY_ID for identifying non-coded parties.
		(TD CASEMAN 4835: Query By Party: Fails to find some Solicitors).
			
	Chris Hutt 	26 sept 2007 
			    Inclusion of params in query changes to avoid OR's and NULL tests by use of NVL 
			    (in response to a performance requirement.
			    
	Chris Hutt 	28 sept 2007 
			    Performance: joins to GIVEN_ADDRESSES improved of first union to avoid full table scan
-->
<QueryDef>
	<DBMapDef location="uk/gov/dca/caseman/qbp_service/map_caseparties.xml"/>
	

	<Query pivotNode="/PartyQueryResults/PartyQueryResult" tables="CPR PR P GA C CT CP">
		<!--
		<SQL type="select">
