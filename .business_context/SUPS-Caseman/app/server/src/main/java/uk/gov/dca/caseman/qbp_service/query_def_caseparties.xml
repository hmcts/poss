		CPR.CASE_NUMBER AS "CPR.CASE_NUMBER", 
		CP.ADDRESS_LINE1 AS "GA.ADDRESS_LINE1", 
		CP.ADDRESS_LINE2 AS "GA.ADDRESS_LINE2", 
		CP.PERSON_REQUESTED_NAME AS "P.PERSON_REQUESTED_NAME", 
		PR.PARTY_ROLE_DESCRIPTION AS "PR.PARTY_ROLE_DESCRIPTION"
	FROM CASES C, CODED_PARTIES CP, CASE_PARTY_ROLES CPR, PARTY_ROLES PR 
	WHERE PR.PARTY_ROLE_CODE = CPR.PARTY_ROLE_CODE AND 
		C.CASE_NUMBER = CPR.CASE_NUMBER AND 
		CP.ADDRESS_LINE1 LIKE NVL(UPPER (${param.address1}), CP.ADDRESS_LINE1 )AND
		CP.ADDRESS_LINE2 LIKE NVL(UPPER (${param.address2}), CP.ADDRESS_LINE2 )AND 
        CP.PARTY_ID = CPR.PARTY_ID AND
       (CPR.PARTY_ROLE_CODE &lt;&gt; 'SOLICITOR' OR 
        EXISTS
        (SELECT NULL 
         FROM   CPR_TO_CPR_RELATIONSHIP CPR2CPRB
         WHERE  CPR2CPRB.CPR_B_CASE_NUMBER     = CPR.CASE_NUMBER
         AND    CPR2CPRB.CPR_B_PARTY_ROLE_CODE = CPR.PARTY_ROLE_CODE
         AND    CPR2CPRB.CPR_B_CASE_PARTY_NO   = CPR.CASE_PARTY_NO
         AND    CPR2CPRB.DELETED_FLAG          = 'N'
        )
       ) AND 
	  (	C.ADMIN_CRT_CODE = ${param.owningCourtCode} AND	  
	   	CPR.CASE_NUMBER LIKE NVL(UPPER (${param.caseNumber}), CPR.CASE_NUMBER )AND
		CP.PERSON_REQUESTED_NAME LIKE NVL(UPPER (${param.partyName}), CP.PERSON_REQUESTED_NAME )AND		
		CPR.PARTY_ROLE_CODE LIKE NVL(UPPER (${param.partyType}), CPR.PARTY_ROLE_CODE )
      )
	ORDER BY 2,6,5,1,3,4
) )
WHERE R&lt;(${param.pageNumber}*${param.pageSize})+1 AND R>(${param.pageNumber}-1)*${param.pageSize}
        </SQL>
        -->
		<Modify notModifiable="true"/>	
	</Query>
	

</QueryDef>