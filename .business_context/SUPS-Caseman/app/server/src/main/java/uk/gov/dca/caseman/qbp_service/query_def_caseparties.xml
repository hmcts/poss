	(SELECT null AS "CP.CODE", 
		CPR.CASE_NUMBER AS "CPR.CASE_NUMBER", 
		GA.ADDRESS_LINE1 AS "GA.ADDRESS_LINE1", 
		GA.ADDRESS_LINE2 AS "GA.ADDRESS_LINE2", 
		P.PERSON_REQUESTED_NAME AS "P.PERSON_REQUESTED_NAME", 
		PR.PARTY_ROLE_DESCRIPTION AS "PR.PARTY_ROLE_DESCRIPTION"
