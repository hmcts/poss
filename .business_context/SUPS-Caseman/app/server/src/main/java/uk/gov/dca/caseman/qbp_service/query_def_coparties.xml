<?xml version="1.0" encoding="UTF-8"?>
<QueryDef>
	<DBMapDef location="uk/gov/dca/caseman/qbp_service/map_coparties.xml"/>
	<Query pivotNode="/PartyQueryResults/PartyQueryResult" tables="CO GA">
		<Join>
			GA.CO_NUMBER = CO.CO_NUMBER AND
			GA.VALID_TO IS NULL AND
			GA.ADDRESS_TYPE_CODE IN ('CO DEBTOR')
        </Join>
		<Modify notModifiable="true"/>	
	</Query>
</QueryDef>