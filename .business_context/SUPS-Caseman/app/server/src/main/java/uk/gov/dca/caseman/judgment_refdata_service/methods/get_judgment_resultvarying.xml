<?xml version="1.0" encoding="UTF-8"?>
<!--
Service: JudgmentRefdata
	Method:  getJudgmentResultvarying()
	File:    get_judgment_resultvarying.xml
	Author:  Troy Baines
	Created: 20 November 2004
	Description: 
        Retrieves the list of variation results for the judgment window
-->
<service-method>
	<pipeline>
		<Query>
			<QueryDef location="uk/gov/dca/caseman/judgment_refdata_service/query_def_resultvarying.xml"/>
			<QueryExtension pivotNode="/JudgmentResultsVary/Result">
				<Constraint>CRC.RV_DOMAIN = 'RESULT_VARYING'</Constraint>
			</QueryExtension>
		</Query>
	</pipeline>
	<Security roles="viewOnly medium high wcSuper scSuper bmsSuper aeSuper dmSuper cpSuper ccbcMan ccbcUser ccbcSGB2"/>
</service-method>
