<?xml version="1.0" encoding="UTF-8"?>
<service-method>
	<pipeline>
		<Update>
			<QueryDef location="uk/gov/dca/caseman/ae_service/query_def_modify.xml"/>
			<DataSource xpath="/params/param[@name='AEDetails']"/>
			<QueryExtension pivotNode="/AEApplications/AEApplication">
				<CheckExists table="A" fields="AE_NUMBER" onNotExist="add" onExist="update"/>
				<!--CheckExists table="A" fields="DEBTORS_EMPLOYERS_PARTY_ID" onNotExist="add" onExist="update"/-->
			</QueryExtension>				
			<QueryExtension pivotNode="/AEApplications/AEApplication/Employer">
				<CheckExists table="P" fields="PARTY_ID" onNotExist="add" onExist="update"/>
			</QueryExtension>
			<QueryExtension pivotNode="/AEApplications/AEApplication/Employer/ContactDetails/Addresses/Address">
				<CheckExists table="GA" fields="ADDRESS_ID" onNotExist="add" onExist="update"/>
				<!--CheckExists table="GA" fields="PARTY_ID" onNotExist="fail" onExist="update"/-->
			</QueryExtension>	
		</Update>
	</pipeline>
	<Security roles="user"/>
</service-method>
