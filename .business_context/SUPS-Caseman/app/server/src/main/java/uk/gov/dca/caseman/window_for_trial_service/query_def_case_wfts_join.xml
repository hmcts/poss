	To enable excluded dates to be amended an approach has been adopted of initially removing all
	excluded dates and then adding the actual excluded dates associated with this update
-->
<QueryDef>
	<DBMapDef location="uk/gov/dca/caseman/window_for_trial_service/map_case_wfts_join.xml"/>
	<Query pivotNode="/WindowsForTrial/WindowForTrial" tables="WFT">
	   	<LinkedJoin type="root" key="WFT.WFT_CASE_NUMBER WFT.WFT_ID">
	   		<Join/>
	   	</LinkedJoin>
	   	<Modify/>
	</Query>
	
	<!--
	<Query pivotNode="/WindowsForTrial/WindowForTrial/DatesSet" tables="WFT">
	  <SQL type="select">
		SELECT 'false' AS "WFT.DATES_SET" 
		FROM DUAL
      	  </SQL>
          <Modify notModifiable="true"/>
	</Query>
	-->

	<!--
     <Query pivotNode="/WindowsForTrial/WindowForTrial/Dates" tables="WFE">
	  	<Join>
	  	  WFE.WFE_WFT_ID = ${WFT.WFT_ID} AND
	  	  WFE.WFE_WFT_CASE_NUMBER = ${WFT.WFT_CASE_NUMBER}
	  	</Join>	
	  	<Modify>
		</Modify>
	 </Query>
	  -->

     <Query pivotNode="/WindowsForTrial/WindowForTrial/Dates/Date" tables="WFE">
	   	<LinkedJoin type="query" key="WFE.WFE_EXCLUSION_DATE">
    		<Parent key="WFT.WFT_CASE_NUMBER WFT.WFT_ID" tables="WFT"/>
	  		<Join>
	  	    	WFE.WFE_WFT_CASE_NUMBER = WFT.WFT_CASE_NUMBER
	  	     	AND WFE.WFE_WFT_ID = WFT.WFT_ID
	  		</Join>	
		</LinkedJoin>
	  	<Modify/>
	  </Query>
	
