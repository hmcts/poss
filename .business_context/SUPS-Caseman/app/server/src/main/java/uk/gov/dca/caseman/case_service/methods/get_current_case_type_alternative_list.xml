<?xml version="1.0" encoding="UTF-8"?>
<!--
	Service: Case
	Method:  getCurrentCaseTypeAlternativeList()
	Author:  Phil Haferer (EDS) 
	Created: 14 March 2005
	Description:
	    Get a list of Case Types that could be used to replace the current Case Type.
	    Each Case Type falls into the category of either Solvency or Insolvency.
	    A given Case Type may only be replaced by another Case Type of the same category.
-->
<service-method>
	<pipeline>
		<Query>
			<QueryDef 
				location="uk/gov/dca/caseman/case_service/query_def_get_current_case_type_alternative_list.xml"/>			
			<QueryExtension pivotNode="/Case">
				<Param name="param.caseNumber" xpath="/params/param[@name = 'caseNumber']"/>
				<Constraint>C.CASE_NUMBER = ${param.caseNumber}</Constraint>
			</QueryExtension>
		</Query>
	</pipeline>
	<Security roles="wcSuper scSuper bmsSuper aeSuper dmSuper cpSuper ccbcMan ccbcUser ccbcSGB2"/> 
</service-method>