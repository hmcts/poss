<?xml version="1.0" encoding="UTF-8"?>
<WebServiceConfig>
	<Init>
		<UserName>nobody</UserName>
		<Password>test</Password>
		<EndPoint>http://localhost:8090/transformation/</EndPoint>
		<java.naming.factory.initial>org.jnp.interfaces.NamingContextFactory</java.naming.factory.initial>
		<java.naming.provider.url>jnp://localhost:6003</java.naming.provider.url>
		<java.naming.factory.url.pkgs>java.naming.factory.url.pkgs</java.naming.factory.url.pkgs>
		<java.naming.security.principal/>
		<java.naming.security.credentials/>
		<java.naming.security.protocol/>
	</Init>
	<ApplicationService>
		<Name>TRANSFER</Name>
		<WebService>Transfer</WebService>
		<Method>
			<Name>TransferCase</Name>
			<WebServiceName>transferCase</WebServiceName>
		</Method>
		<Method>
			<Name>Case</Name>
			<WebServiceName>getCase</WebServiceName>
		</Method>
	</ApplicationService>
	<ApplicationService>
		<Name>CaseLegacy</Name>
		<WebService>CaseLegacy</WebService>
		<Method>
			<Name>CaseTransferCentral</Name>
			<WebServiceName>caseTransferCentral</WebServiceName>
		</Method>
	</ApplicationService>
	<ApplicationService>
		<Name>WarrantLegacy</Name>
		<WebService>WarrantLegacy</WebService>
		<Method>
			<Name>WarrantTransferCentral</Name>
			<WebServiceName>warrantTransferCentral</WebServiceName>
		</Method>
	</ApplicationService>
	<ApplicationService>
		<Name>CaseCoEventLegacy</Name>
		<WebService>CoCaseEventLegacy</WebService>
		<Method>
			<Name>CaseCoEventTransferCentral</Name>
			<WebServiceName>coCaseEventTransferCentral</WebServiceName>
		</Method>				
