<?xml version="1.0" encoding="UTF-8"?>
<WebServiceConfig>
	<Init>
		<UserName>nobody</UserName>
		<Password>test</Password>
		<EndPoint>http://localhost:8080/caseman/</EndPoint>
		<java.naming.factory.initial>org.jnp.interfaces.NamingContextFactory</java.naming.factory.initial>
		<java.naming.provider.url>jnp://localhost:7003</java.naming.provider.url>
		<java.naming.factory.url.pkgs>java.naming.factory.url.pkgs</java.naming.factory.url.pkgs>
		<java.naming.security.principal/>
		<java.naming.security.credentials/>
		<java.naming.security.protocol/>
	</Init>
	<ApplicationService>
		<Name>TRANSFER</Name>
		<WebService>Transfer</WebService>
		<Method>
			<Name>TransferCase</Name>
			<WebServiceName>transferCase</WebServiceName>
		</Method>
		<Method>
			<Name>Case</Name>
			<WebServiceName>getCase</WebServiceName>
		</Method>
	</ApplicationService>
	<ApplicationService>
		<Name>Obligation</Name>
		<WebService>ObligationType</WebService>
		<Method>
			<Name>ObligationType</Name>
			<WebServiceName>getObligationTypes</WebServiceName>
		</Method>
	</ApplicationService>
	<ApplicationService>
		<Name>CaseLegacy</Name>
		<WebService>CaseLegacy</WebService>
		<Method>
			<Name>CaseTransferCentral</Name>
			<WebServiceName>caseTransferCentral</WebServiceName>
		</Method>
	</ApplicationService>
	<ApplicationService>
		<Name>Warrant</Name>
		<WebService>Warrant</WebService>
		<Method>
			<Name>addWarrant</Name>
			<WebServiceName>addWarrant</WebServiceName>
		</Method>
	</ApplicationService>
	<ApplicationService>
		<Name>CaseEvent</Name>
		<WebService>CaseEvent</WebService>
		<Method>
			<Name>addCaseEvent</Name>
			<WebServiceName>insertTransferredCaseEvents</WebServiceName>
		</Method>
	</ApplicationService>
	<ApplicationService>
		<Name>LegacyInbound</Name>
		<WebService>LegacyInbound</WebService>
		<Method>
			<Name>caseTransfer</Name>
			<WebServiceName>caseTransfer</WebServiceName>
		</Method>
	</ApplicationService>
</WebServiceConfig>
