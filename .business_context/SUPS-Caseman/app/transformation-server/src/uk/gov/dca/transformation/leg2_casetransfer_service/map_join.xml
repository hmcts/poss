<?xml version="1.0" encoding="UTF-8"?>
<DBMapDef>
	<DataSource id="java:OracleDS"/>
	<Tables>
		<Table alias="C" name="CASES"/>
		<Table alias="CT" name="COURTS"/>
		<Table alias="D" name="DEFENDANTS"/>
		<Table alias="AM" name="AMENDMENTS"/>
		<Table alias="J" name="JUDGMENTS"/>
		<Table alias="V" name="VARIATIONS"/>
		<Table alias="A" name="ADDRESSES"/>
		<Table alias="CE" name="CASE_EVENTS"/>
		<Table alias="ED" name="ECHR_DETAILS"/>
		<Table alias="EAP" name="ECHR_ARTICLE_PROTOCOL"/>
		<Table alias="AEA" name="AE_APPLICATIONS"/>
		<Table alias="AEE" name="AE_EVENTS"/>
		<Table alias="OB" name="OBLIGATIONS"/>
		<Table alias="WFT" name="WINDOW_FOR_TRIAL"/>
		<Table alias="WFTE" name="WFT_EXCLUSIONS"/>
	</Tables>
	<Mapping>
		<params>
			<ds>
				<ManageCase>
					<Case>
						<CaseNumber>${C.CASE_NUMBER}</CaseNumber>
						<CaseType>${C.CASE_TYPE}</CaseType>
						<Status>${C.STATUS}</Status>
						<AdminCourtCode>${C.ADMIN_CRT_CODE}</AdminCourtCode>
						<BriefDetails>${C.BRIEF_DETAILS_OF_CLAIM}</BriefDetails>
						<Particulars>${C.PARTICULARS_OF_CLAIM}</Particulars>
						<ReceiptDate>${C.RECEIPT_DATE}</ReceiptDate>
						<AmountClaimed>${C.AMOUNT_CLAIMED}</AmountClaimed>
						<CourtFee>${C.COURT_FEE}</CourtFee>
						<SolicitorCosts>${C.SOLICITORS_COSTS}</SolicitorCosts>
						<Total>${C.TOTAL}</Total>
						<DateOfIssue>${C.DATE_OF_ISSUE}</DateOfIssue>
						<TransCourtcode>${C.TRANS_CRT_CODE}</TransCourtcode>
						<TransferDate>${C.DATE_OF_TRANSFER}</TransferDate>
						<TransferReason>${C.TRANSFER_REASON}</TransferReason>
						<DateTransferredIn>${C.DATE_TRANSFERRED_IN}</DateTransferredIn>
						<PreviousCourt>${C.PREVIOUS_COURT}</PreviousCourt>
						<TransferStatus>${C.TRANSFER_STATUS}</TransferStatus>
						<XferReceiptDate>${C.XFER_RECEIPT_DATE}</XferReceiptDate>
						<RepAddress>
							<Address>
								<CodedParties>
									<RepCode>${C.REP_CODE}</RepCode>
									<AdminCourtCode/>
									<PartyId/>
								</CodedParties>
								<GivenAddress>
									<AddressId/>
									<Line1>${C.REP_ADDR_1}</Line1>
									<Line2>${C.REP_ADDR_2}</Line2>
									<Line3>${C.REP_ADDR_3}</Line3>
									<Line4>${C.REP_ADDR_4}</Line4>
									<PostCode>${C.REP_POSTCODE}</PostCode>
									<PartyId/>
									<ValidFrom/>
									<PartyRoleCode/>
									<AddrTypeCode/>
									<CaseNumber/>
									<UpdatedBy/>
									<CasePartyNo/>
									<CourtCode/>
								</GivenAddress>
								<Parties>
									<PartyId/>
									<RepName>${C.REP_NAME}</RepName>
									<DX>${C.REP_DX}</DX>
									<TelephoneNumber>${C.REP_TEL_NO}</TelephoneNumber>
								</Parties>
								<CasePartyRoles>
									<Reference>$C.REFERENCE}</Reference>
									<PartyId/>
									<PartyRoleCode/>
									<CasePartyNo/>
									<CaseNumber/>
								</CasePartyRoles>
							</Address>
						</RepAddress>
						<PlantiffAddress>
							<Address>
								<CodedParties>
									<RepCode>${C.PLTF_CODE}</RepCode>
									<AdminCourtCode/>
									<PartyId/>
								</CodedParties>
								<GivenAddress>
									<AddressId/>
									<Line1>${C.PLAINTIFF_DETAILS_2}</Line1>
									<Line2>${C.PLAINTIFF_DETAILS_3}</Line2>
									<Line3>${C.PLAINTIFF_DETAILS_4}</Line3>
									<Line4>${C.PLAINTIFF_DETAILS_5}</Line4>
									<PostCode>${C.PLAINTIFF_DETAILS_6}</PostCode>
									<PartyId/>
									<ValidFrom/>
									<PartyRoleCode/>
									<AddrTypeCode/>
									<CaseNumber/>
									<UpdatedBy/>
									<CasePartyNo/>
									<CourtCode/>
								</GivenAddress>
								<Parties>
									<PartyId/>
									<RepName>${C.PLAINTIFF_DETAILS_1}</RepName>
									<DX>${C.PLTF_DX}</DX>
									<TelephoneNumber>${C.PLAINTIFF_DETAILS_7}</TelephoneNumber>
								</Parties>
								<CasePartyRoles>
									<Reference>$C.PLAINTIFF_REFERENCE}</Reference>
									<PayeeFlag>$C.PAYEE_FLAG}</PayeeFlag>
									<PartyId/>
									<PartyRoleCode/>
									<CasePartyNo/>
									<CaseNumber/>
								</CasePartyRoles>
							</Address>
						</PlantiffAddress>
					</Case>
					<Defendants>
						<Defendant>
							<CaseNumber>${D.CASE_NUMBER}</CaseNumber>
							<ID>${D.ID}</ID>
							<Name>${D.NAME}</Name>
							<DateOfServiceRO>${D.DATE_OF_SERVICE_RO}</DateOfServiceRO>
							<DateOfServiceOther>${D.DATE_OF_SERVICE_OTHER}</DateOfServiceOther>
							<SolCode>${D.SOL_CODE}</SolCode>
							<SolName>${D.SOLICITOR_NAME}</SolName>
							<SolAddr1>${D.SOLICITOR_ADDR_1}</SolAddr1>
							<SolAddr2>${D.SOLICITOR_ADDR_2}</SolAddr2>
							<SolAddr3>${D.SOLICITOR_ADDR_3}</SolAddr3>
							<SolAddr4>${D.SOLICITOR_ADDR_4}</SolAddr4>
							<SolAddr5>${D.SOLICITOR_ADDR_5}</SolAddr5>
							<SolPostcode>${D.SOLICITOR_POSTCODE}</SolPostcode>
							<SolTelephone>${D.SOLICITOR_TEL_NO}</SolTelephone>
							<SolDX>${D.SOL_DX}</SolDX>
							<SolBarJudgment>${D.BAR_JUDGMENT}</SolBarJudgment>
							<MethodOfService>${D.METHOD_OF_SERVICE}</MethodOfService>
						</Defendant>
					</Defendants>
					<Amendments>
						<Amendment>
							<AmendSequence>${AM.AMEND_SEQ}</AmendSequence>
							<TabName>${AM.TAB_NAME}</TabName>
							<ColName>${AM.COL_NAME}</ColName>
							<ColFormat>${AM.COL_FORMAT}</ColFormat>
							<CaseNumber>${AM.CASE_NUMBER}</CaseNumber>
							<DefendantID>${AM.DEFT_ID}</DefendantID>
							<WarrantNumber>${AM.WRT_NUMBER}</WarrantNumber>
							<TabSequence>${AM.TAB_SEQ}</TabSequence>
							<ColFormat>${AM.COL_VALUE}</ColFormat>
							<AmendDate>${AM.AMEND_DATE}</AmendDate>
							<UserID>${AM.USER_ID}</UserID>
							<Comments>${AM.COMMENTS}</Comments>
							<AmendCONumber>${AM.AMEND_CO_NUMBER}</AmendCONumber>
						</Amendment>
					</Amendments>
					<Judgments>
						<Judgment>
							<JudgSequence>${J.JUDG_SEQ}</JudgSequence>
							<DeftCaseNumber>${J.DEFT_CASE_NUMBER}</DeftCaseNumber>
							<DefendantID>${J.DEFT_ID}</DefendantID>
							<JudgmentFor>${J.JUDGMENT_FOR}</JudgmentFor>
							<JudgmentType>${J.JUDGMENT_TYPE}</JudgmentType>
							<Joint>${J.JOINT_JUDGMENT}</Joint>
							<JudgmentDate>${J.JUDGMENT_DATE}</JudgmentDate>
							<SentToRTL>${J.SENT_TO_RTL}</SentToRTL>
							<StatusToRTL>${J.STATUS_TO_RTL}</StatusToRTL>
							<FinalPaymentDate>${J.DATE_OF_FINAL_PAYMENT}</FinalPaymentDate>
							<Status>${J.STATUS}</Status>
							<JudgmentAmount>${J.JUDGMENT_AMOUNT}</JudgmentAmount>
							<TotalCosts>${J.TOTAL_COSTS}</TotalCosts>
							<PaidBefore>${J.PAID_BEFORE_JUDGMENT}</PaidBefore>
							<Total>${J.TOTAL}</Total>
							<InstallmentAmount>${J.INSTALMENT_AMOUNT}</InstallmentAmount>
							<InstallmentPeriod>${J.INSTALMENT_PERIOD}</InstallmentPeriod>
							<FirstPaymentDate>${J.FIRST_PAYMENT_DATE}</FirstPaymentDate>
							<PayeeName>${J.PAYEE_NAME}</PayeeName>
							<PayeeAddr1>${J.PAYEE_ADDR_1}</PayeeAddr1>
							<PayeeAddr2>${J.PAYEE_ADDR_2}</PayeeAddr2>
							<PayeeAddr3>${J.PAYEE_ADDR_3}</PayeeAddr3>
							<PayeeAddr4>${J.PAYEE_ADDR_4}</PayeeAddr4>
							<PayeeAddr5>${J.PAYEE_ADDR_5}</PayeeAddr5>
							<PayeePostcode>${J.PAYEE_POSTCODE}</PayeePostcode>
							<PayeeTelephone>${J.PAYEE_TEL_NO}</PayeeTelephone>
							<PayeeReference>${J.PAYEE_REFERENCE}</PayeeReference>
							<PayReceiptDate>${J.PAY_RECEIPT_DATE}</PayReceiptDate>
							<JudgmentCourtCode>${J.JUDGMENT_COURT_CODE}</JudgmentCourtCode>
							<Variations>
								<Variation>
									<VarSeq>${V.VARY_SEQ}</VarSeq>
									<JudgSeq>${V.JUDG_SEQ}</JudgSeq>
									<ApplicationDate>${V.APPLICATION_DATE}</ApplicationDate>
									<Requester>${V.REQUESTER}</Requester>
									<OfferAmount>${V.OFFER_AMOUNT}</OfferAmount>
									<OfferPeriod>${V.OFFER_PERIOD}</OfferPeriod>
									<FirstPaymentDate>${V.FIRST_PAYMENT_DATE}</FirstPaymentDate>
									<Response>${V.PLAINTIFF_RESPONSE}</Response>
									<Result>${V.RESULT}</Result>
									<ResultDate>${V.RESULT_DATE}</ResultDate>
									<DeteminationAmount>${V.DETERMINATION_AMOUNT}</DeteminationAmount>
									<DeterminationPeriod>${V.DETERMINATION_PERIOD}</DeterminationPeriod>
									<Objection>${V.OBJECTION}</Objection>
									<Objector>${V.OBJECTOR}</Objector>
									<ResponseDate>${V.RESPONSE_DATE}</ResponseDate>
									<HearingReq>${V.HEARING_REQD}</HearingReq>
									<ObjectionDate>${V.OBJECTION_DATE}</ObjectionDate>
								</Variation>
							</Variations>
						</Judgment>
					</Judgments>
					<Addresses>
						<Address>
							<AddressSequence>${A.ADDR_SEQ}</AddressSequence>
							<DeftCaseNumber>${A.DEFT_CASE_NUMBER}</DeftCaseNumber>
							<DefendantID>${A.DEFT_ID}</DefendantID>
							<CourtCode>${A.CRT_CODE}</CourtCode>
							<AddressType>${A.ADDR_TYPE}</AddressType>
							<Addr1>${A.ADDR_1}</Addr1>
							<Addr2>${A.ADDR_2}</Addr2>
							<Addr3>${A.ADDR_3}</Addr3>
							<Addr4>${A.ADDR_4}</Addr4>
							<Addr5>${A.ADDR_5}</Addr5>
							<AddrPostcode>${A.POSTCODE}</AddrPostcode>
							<Username>${A.USERNAME}</Username>
							<ValidFrom>${A.VALID_FROM}</ValidFrom>
							<ValidTo>${A.VALID_TO}</ValidTo>
							<Reference>${A.REFERENCE}</Reference>
							<AddrAldSequence>${A.ADDR_ALD_SEQ}</AddrAldSequence>
							<DXNumber>${A.DX}</DXNumber>
							<AddressCONumber>${A.ADDR_CO_NUMBER}</AddressCONumber>
							<Telephone>${A.TEL_NO}</Telephone>
							<AddressTypeSequence>${A.ADDR_TYPE_SEQ}</AddressTypeSequence>
						</Address>
					</Addresses>
					<CaseEvents>
						<CaseEvent>
							<EventSeq>${CE.EVENT_SEQ}</EventSeq>
							<CaseNumber>${CE.CASE_NUMBER}</CaseNumber>
							<DeftCaseNumber>${CE.DEFT_CASE_NUMBER}</DeftCaseNumber>
							<DeftID>${CE.DEFT_ID}</DeftID>
							<EventID>${CE.STD_EVENT_ID}</EventID>
							<Requestor>${CE.REQUESTER}</Requestor>
							<Details>${CE.DETAILS}</Details>
							<EventDate>${CE.EVENT_DATE}</EventDate>
							<Result>${CE.RESULT}</Result>
							<WarrantNumber>${CE.WRT_NUMBER}</WarrantNumber>
							<JudgSequence>${CE.JUDG_SEQ}</JudgSequence>
							<VarySequence>${CE.VARY_SEQ}</VarySequence>
							<Deleted>${CE.DELETED_FLAG}</Deleted>
							<UserName>${CE.USERNAME}</UserName>
							<ReceiptDate>${CE.RECEIPT_DATE}</ReceiptDate>
							<BMSTaskNumber>${CE.BMS_TASK_NUMBER}</BMSTaskNumber>
							<StatsModule>${CE.STATS_MODULE}</StatsModule>
							<AgeCategory>${CE.AGE_CATEGORY}</AgeCategory>
							<Court>${CE.CRT_CODE}</Court>
							<ResultDate>${CE.RESULT_DATE}</ResultDate>
						</CaseEvent>
					</CaseEvents>
					<ECHRDetails>
						<ECHRDetail>
							<DeftCaseNo>${ED.DEFT_CASE_NUMBER}</DeftCaseNo>
							<EventSeq>${ED.EVENT_SEQ}</EventSeq>
							<PltfCode>${ED.PLTF_CODE}</PltfCode>
							<PltfDetails>${ED.PLAINTIFF_DETAILS_1}</PltfDetails>
							<EventDate>${ED.EVENT_DATE}</EventDate>
							<ApplicationDate>${ED.DATE_OF_APPLN}</ApplicationDate>
							<UserName>${ED.USERNAME}</UserName>
							<JudgeName>${ED.JUDGE_NAME}</JudgeName>
							<ApplicationOutcome>${ED.OUTCOME_OF_APPLN}</ApplicationOutcome>
							<Deleted>${ED.DELETED_FLAG}</Deleted>
							<ApplicationPartyMade>${ED.PARTY_MADE_APPLN}</ApplicationPartyMade>
							<PartyName>${ED.NAME_OF_PARTY}</PartyName>
						</ECHRDetail>
					</ECHRDetails>
					<ECHRArticleProtocol>
						<EventSeq>${EAP.EVENT_SEQ}</EventSeq>
						<ArtOrProt>${EAP.ART_OR_PROT}</ArtOrProt>
						<LowValue>${EAP.VALS_LOW_VALUE}</LowValue>
						<Description>${EAP.DESCRIPTION}</Description>
						<DeftCaseNumber>${EAP.DEFT_CASE_NUMBER}</DeftCaseNumber>
					</ECHRArticleProtocol>
					<AEApplications>
						<AEApplication>
							<AEAppNo>${AEA.AE_NUMBER}</AEAppNo>
							<AEAppCaseNumber>${AEA.CASE_NUMBER}</AEAppCaseNumber>
							<AEAppType>${AEA.AE_TYPE}</AEAppType>
							<AEAppReceiptDate>${AEA.DATE_OF_RECEIPT}</AEAppReceiptDate>
							<AEAppCreationDate>${AEA.DATE_OF_CREATION}</AEAppCreationDate>
							<AEAppIssueDate>${AEA.DATE_OF_ISSUE}</AEAppIssueDate>
							<AEAppAmount>${AEA.AMOUNT_OF_AE}</AEAppAmount>
							<AEAppDefendantID>${AEA.DEFENDANT_ID}</AEAppDefendantID>
							<AEAppJudgSeq>${AEA.JUDG_SEQ}</AEAppJudgSeq>
							<AEAppOccupation>${AEA.DEBTOR_OCCUPATION}</AEAppOccupation>
							<AEAppPayrollNo>${AEA.PAYROLL_NUMBER}</AEAppPayrollNo>
							<AEAppEmployer>${AEA.NAMED_EMPLOYER}</AEAppEmployer>
							<AEAppAEFee>${AEA.AE_FEE}</AEAppAEFee>
							<AEAppPERate>${AEA.PROTECTED_EARNINGS_RATE}</AEAppPERate>
							<AEAppPEPeriod>${AEA.PROTECTED_EARNINGS_PERIOD}</AEAppPEPeriod>
							<AEAppDeductionRate>${AEA.NORMAL_DEDUCTION_RATE}</AEAppDeductionRate>
							<AEAppDeductionReiod>${AEA.NORMAL_DEDUCTION_PERIOD}</AEAppDeductionReiod>
							<AEAppCAPSSeq>${AEA.CAPS_SEQUENCE}</AEAppCAPSSeq>
							<AEAppCrtCode>${AEA.ISSUING_CRT_CODE}</AEAppCrtCode>
						</AEApplication>
					</AEApplications>
					<AEEvents>
						<AEEvent>
							<EventSeq>${AEE.AE_EVENT_SEQ}</EventSeq>
							<AENo>${AEE.AE_NUMBER}</AENo>
							<EventDate>${AEE.EVENT_DATE}</EventDate>
							<DateEntered>${AEE.DATE_ENTERED}</DateEntered>
							<EventID>${AEE.STD_EVENT_ID}</EventID>
							<IssueStage>${AEE.ISSUE_STAGE}</IssueStage>
							<Details>${AEE.DETAILS}</Details>
							<HrgSequence>${AEE.HRG_SEQ}</HrgSequence>
							<Error>${AEE.ERROR_INDICATOR}</Error>
							<Username>${AEE.USERNAME}</Username>
							<Bailiff>${AEE.BAILIFF_IDENTIFIER}</Bailiff>
							<ServiceStatus>${AEE.SERVICE_STATUS}</ServiceStatus>
							<ServiceDate>${AEE.SERVICE_DATE}</ServiceDate>
							<ProcessStage>${AEE.PROCESS_STAGE}</ProcessStage>
							<ProcessDate>${AEE.PROCESS_DATE}</ProcessDate>
							<ReportValue1>${AEE.REPORT_VALUE_1}</ReportValue1>
							<ReportValue2>${AEE.REPORT_VALUE_2}</ReportValue2>
							<ReportValue3>${AEE.REPORT_VALUE_3}</ReportValue3>
							<ReportValue4>${AEE.REPORT_VALUE_4}</ReportValue4>
							<ReportValue5>${AEE.REPORT_VALUE_5}</ReportValue5>
							<ReportValue6>${AEE.REPORT_VALUE_6}</ReportValue6>
							<ReportValue7>${AEE.REPORT_VALUE_7}</ReportValue7>
							<ReportValue8>${AEE.REPORT_VALUE_8}</ReportValue8>
							<ReportValue9>${AEE.REPORT_VALUE_9}</ReportValue9>
							<ReportValue10>${AEE.REPORT_VALUE_10}</ReportValue10>
							<ReportValue11>${AEE.REPORT_VALUE_11}</ReportValue11>
							<ReportValue12>${AEE.REPORT_VALUE_12}</ReportValue12>
							<ReportValue13>${AEE.REPORT_VALUE_13}</ReportValue13>
							<WarrantID>${AEE.WARRANT_NUMBER}</WarrantID>
						</AEEvent>
					</AEEvents>
					<Obligations>
						<Obligation>
							<CaseNumber>${O.CASE_NUMBER}</CaseNumber>
							<EventSeq>${O.EVENT_SEQ}</EventSeq>
							<AEEventSeq>${O.AE_EVENT_SEQ}</AEEventSeq>
							<Type>${O.OBLIGATION_TYPE}</Type>
							<ExpiryDate>${O.EXPIRY_DATE}</ExpiryDate>
							<Notes>${O.NOTES}</Notes>
							<LastUsedBy>${O.LAST_USED_BY}</LastUsedBy>
							<Sequence>${O.OBLIGATION_SEQ}</Sequence>
							<DeleteFlag>${O.DELETE_FLAG}</DeleteFlag>
						</Obligation>
					</Obligations>
					<WindowsForTrial>
						<WindowForTrial>
							<ID>${WFT.WFT_ID}</ID>
							<CaseNumber>${WFT.WFT_CASE_NUMBER}</CaseNumber>
							<CurrentCourt>${WFT.WFT_CURRENT_COURT}</CurrentCourt>
							<Status>${WFT.WFT_STATUS}</Status>
							<OutcomeDate>${WFT.WFT_OUTCOME_DATE}</OutcomeDate>
							<StartDate>${WFT.WFT_START_DATE}</StartDate>
							<EndDate>${WFT.WFT_END_DATE}</EndDate>
							<Track>${WFT.WFT_TRACK}</Track>
							<JudgesName>${WFT.WFT_JUDGES_NAME}</JudgesName>
							<ReasonForAdj>${WFT.WFT_REASON_FOR_ADJ}</ReasonForAdj>
							<Notes>${WFT.WFT_NOTES}</Notes>
							<ConfFlag>${WFT.WFT_CASE_MANAGE_CONF_FLAG}</ConfFlag>
							<ConfDate>${WFT.WFT_CASE_MANAGE_CONF_DATE}</ConfDate>
							<EstimatedDays>${WFT.WFT_ESTIMATED_DAYS}</EstimatedDays>
							<EstimatedHours>${WFT.WFT_ESTIMATED_HOURS}</EstimatedHours>
							<EstimatedMins>${WFT.WFT_ESTIMATED_MINS}</EstimatedMins>
							<ExtractedForDM>${WFT.WFT_EXTRACTED_FOR_DM}</ExtractedForDM>
							<Old_Status>${WFT.WFT_OLD_STATUS}</Old_Status>
							<OldOutcomeDate>${WFT.WFT_OLD_OUTCOME_DATE}</OldOutcomeDate>
						</WindowForTrial>
					</WindowsForTrial>
					<WFTExclusions>
						<WFTExclusion>
							<ExclusionDate>${WFTE.WFE_EXCLUSION_DATE}</ExclusionDate>
							<CaseNumber>${WFTE.WFE_WFT_CASE_NUMBER}</CaseNumber>
							<ID>${WFTE.WFE_WFT_ID}</ID>
						</WFTExclusion>
					</WFTExclusions>
				</ManageCase>
			</ds>
		</params>
	</Mapping>
</DBMapDef>
