<?xml version="1.0" encoding="utf-8"?>
<pl:system-content xmlns:pl="http://www.polarlake.com/platform/1.0">
    <pl:circuit name="ccbc_rtl_file_first_day">
        <pl:definitions>
            <pl:definition name="DelimitedRPModule Circuit" value="file:///{pl$polarlake_home}/DelimitedRPModule/circuits/DelimitedRPModule.cir"/>
            <pl:definition name="ccbc_rtl_file_first_day" value="file:///{pl$caseman_home}/Sups/circuits/FirstDayRTL.html"/>
        </pl:definitions>
        <pl:importcircuit name="com.polarlake.circuits.BaseCircuit"/>
        <pl:importcircuit name="DelimitedRPModule Circuit"/>
        <pl:importmodule name="com.polarlake.platform.databasemodule.DatabaseModuleApplication"/>
        <pl:importmodule name="com.polarlake.platform.nonxml.NonXmlBuilder"/>
        <pl:importmodule name="com.polarlake.SnmpTrapModule"/>
        <pl:importmodule name="com.polarlake.platform.MapperApplication"/>
        <pl:documentation name="ccbc_rtl_file_first_day"/>
        <pl:application-data name="Resources" type="Resources">
            <pl:application-data name="Functions" type="functions" application="com.polarlake.platform.librarymodule.LibraryModuleApplication">
                <pl:application-data name="determineBalanceDueFromDebtor" type="function" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value="">
                    <pl:application-data name="type" type="property" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value="beanshell"/>
                    <pl:application-data name="methodName" type="property" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value="determineBalanceDueFromDebtor"/>
                    <pl:application-data name="category" type="property" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value="Miscellaneous"/>
                    <pl:application-data name="script" type="property" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value="import java.text.DecimalFormat;&#10;import org.apache.log4j.Logger;&#10; &#10;String determineBalanceDueFromDebtor(String pFeeAmount, String pTotalPaidOut, String pTotalFeesPaid, String pTotalPassThrough, &#10;           String pTotalDebts, String pMoniesInCourt)&#10; {&#10;  String returnvalue = &quot;&quot;;&#10;  double dFeeAmount;&#10;  double dTotalPaidOut;&#10;  double dTotalFeesPaid;&#10;  double dTotalPassThrough;&#10;  double dTotalDebts;&#10;  double dMoniesInCourt;&#10;  double dBalanceDueFromDebtor;&#10; &#10;  Logger logger = Logger.getLogger(&quot;com.info&quot;);&#10;  String function_name = &quot;determineBalanceDueFromDebtor&quot;;&#10;  &#10;  logger.info(&quot;pTotalPassThrough Total in &quot; + function_name + &quot; = &quot; + pTotalPassThrough);&#10;  logger.info(&quot;pFeeAmount in &quot; + function_name + &quot; = &quot; + pFeeAmount);  &#10;  logger.info(&quot;pTotalPaidOut in &quot; + function_name + &quot; = &quot; + pTotalPaidOut);  &#10;  logger.info(&quot;pTotalFeesPaid in &quot; + function_name + &quot; = &quot; + pTotalFeesPaid);  &#10;  logger.info(&quot;pTotalPassThrough in &quot; + function_name + &quot; = &quot; + pTotalPassThrough);&#10;  logger.info(&quot;pMoniesInCourt in &quot; + function_name + &quot; = &quot; + pMoniesInCourt); &#10;  logger.info(&quot;pTotalDebts in &quot; + function_name + &quot; = &quot; + pTotalDebts);  &#10;&#10;  if (pFeeAmount != null &amp;&amp; !pFeeAmount.equals(&quot;&quot;)){&#10;   dFeeAmount = Double.parseDouble(pFeeAmount);&#10;  } &#10;  else{&#10;   dFeeAmount = 0.00;&#10;  }&#10;  &#10;  if (pTotalPaidOut != null &amp;&amp; !pTotalPaidOut.equals(&quot;&quot;)){&#10;   dTotalPaidOut = Double.parseDouble(pTotalPaidOut);&#10;  }&#10;  else{&#10;   dTotalPaidOut = 0.00;&#10;  }&#10;  &#10;  if (pTotalFeesPaid !=null &amp;&amp; !pTotalFeesPaid.equals(&quot;&quot;)){&#10;   dTotalFeesPaid = Double.parseDouble(pTotalFeesPaid);&#10;  } &#10;  else{&#10;   dTotalFeesPaid = 0.00;&#10;  }&#10;  &#10;  if (pTotalPassThrough !=null &amp;&amp; !pTotalPassThrough.equals(&quot;&quot;)){&#10;   dTotalPassThrough = Double.parseDouble(pTotalPassThrough);&#10;  } &#10;  else{&#10;   dTotalPassThrough = 0.00;&#10;  }&#10;  &#10;  if (pTotalDebts !=null &amp;&amp; !pTotalDebts.equals(&quot;&quot;)){&#10;   dTotalDebts = Double.parseDouble(pTotalDebts);&#10;  }&#10;   else{&#10;   dTotalDebts = 0.00;&#10;  }&#10;  &#10;  if (pMoniesInCourt !=null &amp;&amp; !pMoniesInCourt.equals(&quot;&quot;)){&#10;   dMoniesInCourt = Double.parseDouble(pMoniesInCourt);&#10;  } &#10;  else{&#10;   dMoniesInCourt = 0.00;&#10;  }&#10;  &#10;  &#10;  dBalanceDueFromDebtor = (dTotalDebts + dFeeAmount) - (dTotalPaidOut + dTotalFeesPaid + dTotalPassThrough + dMoniesInCourt);&#10;  logger.info(&quot;dTotalPassThrough Total in &quot; + function_name + &quot; = &quot; + dTotalPassThrough);&#10;  logger.info(&quot;dFeeAmount in &quot; + function_name + &quot; = &quot; + dFeeAmount);  &#10;  logger.info(&quot;dTotalPaidOut in &quot; + function_name + &quot; = &quot; + dTotalPaidOut);  &#10;  logger.info(&quot;dTotalFeesPaid in &quot; + function_name + &quot; = &quot; + dTotalFeesPaid);  &#10;  logger.info(&quot;dTotalPassThrough in &quot; + function_name + &quot; = &quot; + dTotalPassThrough);&#10;  logger.info(&quot;dMoniesInCourt in &quot; + function_name + &quot; = &quot; + dMoniesInCourt);&#10;  logger.info(&quot;dTotalDebts in &quot; + function_name + &quot; = &quot; + dTotalDebts);&#10;  logger.info(&quot;BalanceDueFromDebtor Total in &quot; + function_name + &quot; = &quot; + dBalanceDueFromDebtor);    &#10;  &#10;  if(dBalanceDueFromDebtor &lt; 0.00) {&#10;  &#9;logger.info(&quot;BalanceDueFromDebtors is negative, setting it to 0.00 &quot; + function_name);&#10;  &#9;dBalanceDueFromDebtor = 0.00;&#9;&#10;  }&#10;  &#10;  returnvalue  = new DecimalFormat(&quot;#######0.00&quot;).format(dBalanceDueFromDebtor);&#10;   logger.info(&quot;Total in &quot; + function_name + &quot; = &quot; + returnvalue);&#10;             &#10;     return returnvalue;&#10; } &#10; "/>
                    <pl:application-data name="description" type="property" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value=""/>
                </pl:application-data>
                <pl:application-data name="countOfRecords" type="function" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value="">
                    <pl:application-data name="type" type="property" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value="beanshell"/>
                    <pl:application-data name="methodName" type="property" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value="countOfRecords"/>
                    <pl:application-data name="category" type="property" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value="Miscellaneous"/>
                    <pl:application-data name="script" type="property" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value="import org.apache.log4j.Logger;&#10;&#10;String countOfRecords(String[] count)&#10;    {&#10;        Logger logger = Logger.getLogger(&quot;com.info&quot;);&#9;&#9;&#10;        //IF your reading this I was forced to use this function because polar lake cannot execute xpath functions in the form count(//record) in the userpath functionality of Polar Lake&#10;        &#10;        String function_name = &quot;countOfRecords&quot;;&#10;&#9;logger.info(&quot;Count = &quot; + count.length + &quot; - In Function &quot; +function_name);&#9;&#10;&#9;return Integer.toString(count.length);&#10;    }"/>
                    <pl:application-data name="description" type="property" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value=""/>
                </pl:application-data>
                <pl:application-data name="recordCount" type="function" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value="">
                    <pl:application-data name="type" type="property" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value="beanshell"/>
                    <pl:application-data name="methodName" type="property" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value="recordCount"/>
                    <pl:application-data name="category" type="property" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value="Miscellaneous"/>
                    <pl:application-data name="script" type="property" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value="import org.apache.log4j.Logger;&#10;&#10;String recordCount(String count)&#10;    {&#10;        Logger logger = Logger.getLogger(&quot;com.info&quot;);              &#10;        String function_name = &quot;recordCount&quot;;&#10;        StringBuffer strCount = new StringBuffer(count);&#10;&#9;&#9;&#10;&#9;while (strCount.length() &lt; 10) {&#10;&#9;&#9;strCount.append(&quot; &quot;);&#9;&#10;&#10;&#9;}&#10;&#9;&#9;&#10;&#9;return strCount.toString();&#10;    }"/>
                    <pl:application-data name="description" type="property" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value=""/>
                </pl:application-data>
                <pl:application-data name="formatDates" type="function" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value="">
                    <pl:application-data name="type" type="property" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value="beanshell"/>
                    <pl:application-data name="methodName" type="property" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value="formatDates"/>
                    <pl:application-data name="category" type="property" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value="Miscellaneous"/>
                    <pl:application-data name="script" type="property" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value="import org.apache.log4j.Logger;&#10;import java.text.ParseException;&#10;import java.text.SimpleDateFormat;&#10;import java.util.Date;&#10;&#10;String formatDates(String pDate)&#10;    {&#10;        Logger logger = Logger.getLogger(&quot;com.info&quot;);   &#10;        String function_name = &quot;formatDates&quot;;&#10;&#10;        if(pDate != null &amp;&amp; (!pDate.trim().equals(&quot;&quot;))) {&#9;&#10;        &#9;SimpleDateFormat dateFormat = null;&#10;        &#9;dateFormat = new SimpleDateFormat(&quot;DD-MM-YYYY&quot;);&#10;         &#9;dateFormat.applyPattern(&quot;ddMMyyyy&quot;);&#10;       &#9;Date parseDate = null;&#10;&#10;&#9;try {&#10;          &#9;&#9; parseDate = dateFormat.parse(pDate);&#10;      &#9; } catch (ParseException pe) {&#10;           &#9;&#9; logger.error(&quot;ParseException caught&quot;);  &#10;       &#9;}&#10;&#9; logger.info(&quot;Date is not null in &quot; + function_name + &quot; , returning &quot; +dateFormat.format(parseDate));&#10;       &#9;return dateFormat.format(parseDate);&#10;       } else {&#10;&#9; logger.info(&quot;Date is null in &quot; + function_name + &quot; , returning null&quot;);&#10;&#9;return &quot;&quot;;&#10;        }&#10;    }"/>
                    <pl:application-data name="description" type="property" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value=""/>
                </pl:application-data>
                <pl:application-data name="formatStringDate" type="function" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value="">
                    <pl:application-data name="type" type="property" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value="beanshell"/>
                    <pl:application-data name="methodName" type="property" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value="formatDates"/>
                    <pl:application-data name="category" type="property" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value="Miscellaneous"/>
                    <pl:application-data name="script" type="property" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value="import org.apache.log4j.Logger;&#10;import java.text.ParseException;&#10;import java.text.SimpleDateFormat;&#10;import java.util.Date;&#10;&#10;String formatDates(String pDate)&#10;    {&#10;        Logger logger = Logger.getRootLogger();&#10;        String function_name = &quot;formatDates&quot;;&#10;&#10;        if(pDate != null &amp;&amp; (!pDate.trim().equals(&quot;&quot;))) {&#9;&#10;        &#9;SimpleDateFormat dateFormat = null;&#10;&#10;        &#9;dateFormat = new SimpleDateFormat(&quot;dd-MMM-yyyy&quot;);&#10;       &#9;Date parseDate = null;&#10;&#9;try {&#10;          &#9;&#9; parseDate = dateFormat.parse(pDate);&#10;      &#9; } catch (ParseException pe) {&#10;           &#9;&#9; logger.error(&quot;ParseException caught&quot;);  &#10;       &#9;}&#10;&#9; logger.info(&quot;Date is not null in &quot; + function_name + &quot; , returning null&quot;);&#10;         &#9;dateFormat.applyPattern(&quot;ddMMyyyy&quot;);&#10;       &#9;return dateFormat.format(parseDate);&#10;       } else {&#10;&#9; logger.info(&quot;Date is null in &quot; + function_name + &quot; , returning null&quot;);&#10;&#9;return &quot;&quot;;&#10;        }&#10;    }"/>
                    <pl:application-data name="description" type="property" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value=""/>
                </pl:application-data>
                <pl:application-data name="formatTotal" type="function" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value="">
                    <pl:application-data name="type" type="property" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value="beanshell"/>
                    <pl:application-data name="methodName" type="property" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value="formatTotal"/>
                    <pl:application-data name="category" type="property" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value="Miscellaneous"/>
                    <pl:application-data name="script" type="property" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value="import java.text.DecimalFormat;&#10;import org.apache.log4j.Logger;&#10;&#10;String formatTotal(String pTotal)&#10;&#9;{&#10;&#9;&#9;String returnvalue = &quot;&quot;;&#10;&#9;&#9;double dTotal = 0.00;&#10;&#9;&#9;&#9;&#9;&#10;&#9;&#9;Logger logger = Logger.getLogger(&quot;com.info&quot;);&#10;&#9;&#9;String function_name = &quot;formatTotal&quot;;&#10;&#9;&#9;&#10;&#9;&#9;if (pTotal != null &amp;&amp; !pTotal.equals(&quot;&quot;)){&#10;&#9;&#9;&#9;dTotal = Double.parseDouble(pTotal);&#10;&#9;&#9;}&#10;&#9;        returnvalue =  new DecimalFormat(&quot;#######0.00&quot;).format(dTotal);&#10;&#9;        logger.info(&quot;Total in &quot; + function_name + &quot; = &quot; + returnvalue);&#9;&#10;&#9;&#10;&#9;        return returnvalue;&#10;&#9;}&#9;"/>
                    <pl:application-data name="description" type="property" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value=""/>
                </pl:application-data>
            </pl:application-data>
            <pl:application-data name="Initial Contexts" type="initialcontexts" application="com.polarlake.platform.librarymodule.LibraryModuleApplication"/>
            <pl:application-data name="Scripts" type="scripts" application="com.polarlake.platform.librarymodule.LibraryModuleApplication">
                <pl:application-data name="wait" type="script" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value="">
                    <pl:application-data name="url" type="property" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value=""/>
                    <pl:application-data name="remote" type="property" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value="false"/>
                    <pl:application-data name="type" type="property" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value="beanshell"/>
                    <pl:application-data name="cache" type="property" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value="never_resolve"/>
                    <pl:application-data name="script" type="property" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value="import org.jdom.*;&#10;import org.jdom.input.*;&#10;import org.jdom.output.*;&#10;import com.polarlake.platform.api.*;&#10;import com.polarlake.platform.api.helper.*;&#10;import com.polarlake.platform.api.exception.*;&#10;&#10;/**&#10; * A JDOM beanshell must return a JDOM document.&#10; */&#10;Document processDocument(Document doc) {&#10;    return doc;&#10;}"/>
                    <pl:application-data name="description" type="property" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value="A PolarLake Platform Beanshell script must be coded to return a JDOM document.They can be composed from calls to imported modules as well as local methods.Only the first method in the script will be executed, so it should make any appropriate method calls if the entire script is not contained in it."/>
                </pl:application-data>
                <pl:application-data name="addALLExtracts" type="script" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value="">
                    <pl:application-data name="url" type="property" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value=""/>
                    <pl:application-data name="remote" type="property" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value="false"/>
                    <pl:application-data name="type" type="property" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value="beanshell"/>
                    <pl:application-data name="cache" type="property" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value="never_resolve"/>
                    <pl:application-data name="script" type="property" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value="import java.util.Iterator;&#10;import java.util.List;&#10;&#10;import org.apache.log4j.Logger;&#10;&#10;import org.jdom.*;  &#10;import org.jdom.input.*;  &#10;import org.jdom.output.*;  &#10;import org.jdom.xpath.XPath;&#10;&#10;import com.polarlake.platform.api.*;  &#10;import com.polarlake.platform.api.helper.*;  &#10;import com.polarlake.platform.api.exception.*;  &#10;import com.polarlake.platform.common.ParameterName;&#10;  &#10;/**  &#10; * A JDOM beanshell must return a JDOM document.  &#10; */  &#10; Document processDocument(Document doc, ExecutiveProcessInterface process) &#10; { &#10; &#10;       XMLOutputter xo = new XMLOutputter(Format.getPrettyFormat());&#10;&#10;       Logger loggerI = Logger.getLogger(&quot;com.info&quot;);&#10;       Logger loggerW = Logger.getLogger(&quot;com.patrol&quot;);&#10;       Logger loggerE = Logger.getLogger(&quot;com.error&quot;);&#10;       &#10;       Document docCOExtract = new Document();&#10;       Document docJudgmentExtract  = new Document();&#10;       Document docCE233Extract = new Document();&#10;       Document docCE236Extract  = new Document();&#10;       Document docCO935Extract  = new Document();&#10;       Document docDeRegExtract  = new Document();&#10;       Document docCODeRegExtract  = new Document();&#10;       &#10;       String endStr = &quot;  ID_AT_THE_END&quot;;&#10;      try &#10;      { &#10;          VariableContainerInterface vci = process.getProcessDocGroup(); &#10;&#10;          if (vci != null) &#10;          { &#10;&#10;              VariableInterface vi = vci.getVariable(&quot;COExtract&quot;);              &#10;              if(vi != null) {             &#10;              &#9;docCOExtract = (Document)vi.getValue();&#10;              } &#10;              &#10;              VariableInterface vi = vci.getVariable(&quot;JudgmentExtract&quot;);               &#10;              if(vi != null) {&#10;              &#9;docJudgmentExtract = (Document)vi.getValue(); &#10;              } &#10;&#10;              &#10;              VariableInterface vi = vci.getVariable(&quot;CE233Extract&quot;);              &#10;              if(vi != null) {&#10;              &#9;docCE233Extract = (Document)vi.getValue(); &#10;              }&#10;              &#10;              VariableInterface vi = vci.getVariable(&quot;CE236Extract&quot;);               &#10;              if(vi != null) {&#10;              &#9;docCE236Extract = (Document)vi.getValue();&#10;              }&#10;              &#10;              VariableInterface vi = vci.getVariable(&quot;CO935Extract&quot;);               &#10;              if(vi != null) {&#10;              &#9;docCO935Extract = (Document)vi.getValue(); &#10;              }&#10;              &#10;              VariableInterface vi = vci.getVariable(&quot;DeRegExtract&quot;);               &#10;              if(vi != null) {&#10;              &#9;docDeRegExtract = (Document)vi.getValue(); &#10;              }&#10;              &#10;              VariableInterface vi = vci.getVariable(&quot;CODeRegExtract&quot;);               &#10;              if(vi != null) {&#10;              &#9;docCODeRegExtract = (Document)vi.getValue(); &#10;              }&#10;          } &#10;      } &#10;      catch (DocVariableException dve) &#10;      { &#10;          loggerE.error(&quot;\n Error in Run Script addALLExtracts&quot;);&#10;      } &#10;&#10;        List paramsCOExtract;&#10;        List paramsJudgmentExtract;&#10;        List paramsCE233Extract;&#10;        List paramsCE236Extract;&#10;        List paramsCO935Extract;&#10;        List paramsDeRegExtract;&#10;        List paramsCODeRegExtract;&#10;       &#10;        try {&#10; &#10; &#9;    if(docCOExtract.getContentSize() != 0) {                  &#10;            &#9;paramsCOExtract = XPath.selectNodes(docCOExtract, &quot;//record&quot;);&#10;&#10;            } else {&#10;            &#9;paramsCOExtract = new ArrayList();&#10;            }&#10;&#10;  &#9;    if(docJudgmentExtract.getContentSize() != 0) {      &#10;            &#9;paramsJudgmentExtract = XPath.selectNodes(docJudgmentExtract, &quot;//record&quot;);&#10;            } else {&#10;            &#9;paramsJudgmentExtract = new ArrayList();&#10;            }&#10; &#10;   &#9;    if(docCE233Extract.getContentSize() != 0)  {  &#10;            &#9;paramsCE233Extract = XPath.selectNodes(docCE233Extract, &quot;//record&quot;);&#10;            } else {&#10;            &#9;paramsCE233Extract = new ArrayList();&#10;&#10;            }&#10;&#10;   &#9;    if(docCE236Extract.getContentSize() != 0) {   &#10;            &#9;paramsCE236Extract = XPath.selectNodes(docCE236Extract, &quot;//record&quot;);&#10;            } else {&#10;            &#9;paramsCE236Extract = new ArrayList();&#10;            }&#10;&#10;   &#9;    if(docCO935Extract.getContentSize() != 0) {     &#10;            &#9;paramsCO935Extract = XPath.selectNodes(docCO935Extract, &quot;//record&quot;);&#10;            } else {&#10;            &#9;paramsCO935Extract = new ArrayList();&#10;            }&#10;&#10;&#9;    if(docDeRegExtract.getContentSize() != 0) {     &#10;            &#9;paramsDeRegExtract = XPath.selectNodes(docDeRegExtract, &quot;//record&quot;);&#10;            } else {&#10;            &#9;paramsDeRegExtract = new ArrayList();&#10;            }&#10;            &#10;            if(docCODeRegExtract.getContentSize() != 0) {     &#10;            &#9;paramsCODeRegExtract = XPath.selectNodes(docCODeRegExtract, &quot;//record&quot;);&#10;            } else {&#10;            &#9;paramsCODeRegExtract = new ArrayList();&#10;            }&#10;          &#10;            if(paramsCOExtract.size() != 0 || paramsJudgmentExtract.size() != 0 || paramsCE233Extract.size() != 0 || paramsCE236Extract.size() != 0 || paramsCO935Extract.size() != 0 || paramsDeRegExtract.size() != 0 || paramsCODeRegExtract.size() != 0) {&#10;           &#10;            &#9;Document rtlDoc = new Document();&#10;            &#9;Element dataExtract = new Element(&quot;data_extracted&quot;);&#10;        &#10;            &#9;if(paramsCOExtract.size() != 0) {&#10;          &#9;&#9;loggerW.warn(&quot;\n In Run Script addALLExtracts and CO Extract Count = &quot; + paramsCOExtract.size());&#10;&#9;&#9;&#9;Iterator it = paramsCOExtract.iterator();&#10;&#9;&#9;&#9;while(it.hasNext()) {&#10;&#9;&#9;&#9;&#9;Element currentElement = (Element) it.next();&#10;&#9;&#9;&#9;&#9;if(currentElement instanceof Element &amp;&amp; currentElement.getName().equals(&quot;record&quot;)) {&#10;&#9;&#9;&#9;&#9;&#9;dataExtract.addContent(currentElement.clone().detach());&#9;&#9;&#9;&#10;&#9;&#9;&#9;&#9;}&#10;&#9;&#9;&#9;&#10;&#9;&#9;&#9;}&#9;&#9;&#9;&#9;&#9;&#9;&#10;            &#9;}&#10;            &#9;&#10;            &#9;if(paramsJudgmentExtract.size() != 0) {&#10;          &#9;&#9;loggerW.warn(&quot;\n In Run Script addALLExtracts and Judgment Extract Count = &quot; + paramsJudgmentExtract.size());&#10;&#9;&#9;&#9;Iterator it = paramsJudgmentExtract.iterator();&#10;&#9;&#9;&#9;while(it.hasNext()) {&#10;&#9;&#9;&#9;&#9;Element currentElement = (Element) it.next();&#10;&#9;&#9;&#9;&#9;if(currentElement instanceof Element &amp;&amp; currentElement.getName().equals(&quot;record&quot;)) {&#10;&#9;&#9;&#9;&#9;&#9;dataExtract.addContent(currentElement.clone().detach());&#9;&#9;&#9;&#10;&#9;&#9;&#9;&#9;}&#10;&#9;&#9;&#9;}&#9;&#10;            &#9;}&#10;            &#9;&#10;            &#9;if(paramsCE233Extract.size() != 0) {&#10;          &#9;&#9;loggerW.warn(&quot;\n In Run Script addALLExtracts and Event 233 Extract Count = &quot; + paramsCE233Extract.size());&#10;&#9;&#9;&#9;Iterator it = paramsCE233Extract.iterator();&#10;&#9;&#9;&#9;while(it.hasNext()) {&#10;&#9;&#9;&#9;&#9;Element currentElement = (Element) it.next();&#10;&#9;&#9;&#9;&#9;if(currentElement instanceof Element &amp;&amp; currentElement.getName().equ