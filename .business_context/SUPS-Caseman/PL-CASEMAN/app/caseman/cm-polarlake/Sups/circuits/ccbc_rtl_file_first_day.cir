        </pl:seqlist>
        <pl:seqlist name="Extract DeRegistration Case Events Sequence">
            <pl:eventprocessor name="pl:printmessage" disable="false">
                <pl:parameter name="design">
                    <pl:parameter name="uid" value="390"/>
                    <pl:parameter name="alias" value="Print Message"/>
                </pl:parameter>
                <pl:parameter name="trigger" value="start"/>
                <pl:parameter name="message" value="-&#10;--&gt; Retrieve DeRegistration Case Events for RTL&#10;--&gt;SEQUENCE - Extract DeRegistration Case Events Sequence&#10;--&gt;VIEW - Extract Extract DeRegistration Case Events View&#10;--&gt;CIRCUIT - ccbc_rtl_file_first_day&#10;----------------------------------------------------------------------------------"/>
                <pl:parameter name="use_log4j" value="true"/>
                <pl:parameter name="log_level" value="INFO"/>
            </pl:eventprocessor>
            <pl:eventprocessor name="pl:sqltoxml" disable="false">
                <pl:parameter name="design">
                    <pl:parameter name="uid" value="392"/>
                    <pl:parameter name="alias" value="Extract DeRegistration Case Events"/>
                </pl:parameter>
                <pl:parameter name="transaction_key" value="extract data"/>
                <pl:parameter name="sql" value="(SELECT CAS.admin_crt_code, &#10;eve.event_seq,&#10;judg.judg_seq,&#10;       CAS.CASE_NUMBER,&#10;       lpad(to_char(NVL(JUDG.JUDGMENT_AMOUNT, 0) + NVL(JUDG.TOTAL_COSTS, 0) - NVL(JUDG.PAID_BEFORE_JUDGMENT, 0)), 10) &quot;JUDG_TOTAL&quot;,&#10;       JUDG.TOTAL_CURRENCY,&#10;       to_char (JUDG.JUDGMENT_DATE,&apos;DDMMYYYY&apos;) &quot;JUDG_DATE&quot;, &#10;       decode(eve.std_event_id, 79,&#10;       &#9;&#9;&#9;&#9;decode(JUDG.STATUS,&apos;SET ASIDE&apos;,&apos;C&apos;,&#10;                          &#9;&#9;&#9;   &apos;CANCELLED&apos;,&apos;C&apos;,&#10;                          &#9;&#9;&#9;   &apos;SATISFIED&apos;,&apos;S&apos;,&#10;                                      &#9;&#9;   &apos;C&apos;), &#10;                                170,&apos;C&apos;,   &#10;                                600,&#10;                                decode(JUDG.STATUS,&apos;SET ASIDE&apos;,&apos;C&apos;,&#10;                          &#9;&#9;&#9;   &apos;CANCELLED&apos;,&apos;C&apos;,&#10;                          &#9;&#9;&#9;   &apos;SATISFIED&apos;,&apos;S&apos;,&#10;                                      &#9;&#9;   &apos;C&apos;),   &#9;&#9;   &#10;                                &apos;R&apos;) &quot;STATUS&quot;,&#10;       decode(JUDG.STATUS,&apos;SET ASIDE&apos;,  to_char(EVE.RESULT_DATE,&apos;DDMMYYYY&apos;),&#10;       &#9;&#9;&#9;  &apos;CANCELLED&apos;, to_char(JUDG.DATE_OF_FINAL_PAYMENT,&apos;DDMMYYYY&apos;),&#10;       &#9;&#9;&#9;  &apos;SATISFIED&apos;, to_char(JUDG.DATE_OF_FINAL_PAYMENT,&apos;DDMMYYYY&apos;),&#10;       &#9;&#9;&#9;  to_char(SYSDATE,&apos;DDMMYYYY&apos;)) &quot;CANC_DATE&quot;,&#10;       PAR.PERSON_REQUESTED_NAME,&#10;       ADDR.ADDRESS_LINE1, &#10;       ADDR.ADDRESS_LINE2, &#10;       ADDR.ADDRESS_LINE3,&#10;       ADDR.ADDRESS_LINE4, &#10;       ADDR.ADDRESS_LINE5, &#10;       ADDR.POSTCODE,&#10;       to_char(PAR.PERSON_DOB,&apos;DDMMYYYY&apos;) &quot;PAR.PERSON_DOB&quot;&#10;FROM   CASES             CAS,&#10;       CASE_PARTY_ROLES  CPR,&#10;       PARTIES           PAR,&#10;       GIVEN_ADDRESSES   ADDR,&#10;       JUDGMENTS         JUDG,&#10;       CASE_EVENTS       EVE&#10;WHERE  CAS.CASE_NUMBER              = CPR.CASE_NUMBER&#10;AND    CPR.PARTY_ROLE_CODE          = &apos;DEFENDANT&apos;&#10;AND    PAR.PARTY_ID                 = CPR.PARTY_ID&#10;AND    ADDR.CASE_NUMBER             = CPR.CASE_NUMBER&#10;AND    ADDR.PARTY_ROLE_CODE         = CPR.PARTY_ROLE_CODE&#10;AND    ADDR.CASE_PARTY_NO           = CPR.CASE_PARTY_NO&#10;AND    ADDR.ADDRESS_TYPE_CODE       = &apos;SERVICE&apos;&#10;AND    JUDG.CASE_NUMBER             = CPR.CASE_NUMBER&#10;AND    JUDG.AGAINST_PARTY_ROLE_CODE = CPR.PARTY_ROLE_CODE&#10;AND    JUDG.AGAINST_CASE_PARTY_NO   = CPR.CASE_PARTY_NO&#10;AND    JUDG.JUDGMENT_DATE           &gt; ADD_MONTHS(SYSDATE,-72)&#10;AND    ADDR.ADDRESS_ID &#9;&#9;    = JUDG.AGAINST_PARTY_ADDR_ID_JUDG_REG&#10;AND   (EVE.DELETED_FLAG             = &apos;N&apos; &#10;OR     EVE.DELETED_FLAG             IS NULL)       &#10;AND    EVE.DATE_TO_RTL              &gt; &apos;24-FEB-2007&apos;&#10;AND    EVE.DATE_TO_RTL              &lt; &apos;27-FEB-2007&apos;&#10;AND    (EVE.EVENT_DATE&#9;&#9;    = &apos;25-FEB-2007&apos;&#10;OR     EVE.EVENT_DATE&#9;&#9;    = &apos;26-FEB-2007&apos;)   &#10;AND    EVE.STD_EVENT_ID             IN (170,79,600)                                                                                                                                          &#10;AND  (                                                             &#10;       (                                                            &#10;        JUDG.JUDG_SEQ               = EVE.JUDG_SEQ                  &#10; AND    EVE.STD_EVENT_ID&#9;    !=79                            &#10;       )                                                            &#10; OR    (                                                            &#10;       JUDG.CASE_NUMBER            = EVE.CASE_NUMBER               &#10; AND    EVE.STD_EVENT_ID            = 79                            &#10;       )                                                                                                                      &#10;     ) &#10; ) UNION&#10; (SELECT CAS.admin_crt_code, &#10; eve.event_seq,&#10; judg.judg_seq,&#10;       CAS.CASE_NUMBER,&#10;       lpad(to_char(NVL(JUDG.JUDGMENT_AMOUNT, 0) + NVL(JUDG.TOTAL_COSTS, 0) - NVL(JUDG.PAID_BEFORE_JUDGMENT, 0)), 10) &quot;JUDG_TOTAL&quot;,&#10;       JUDG.TOTAL_CURRENCY,&#10;       to_char (JUDG.JUDGMENT_DATE,&apos;DDMMYYYY&apos;) &quot;JUDG_DATE&quot;, &#10;       decode(eve.std_event_id, 79,&#10;       &#9;&#9;&#9;&#9;decode(JUDG.STATUS,&apos;SET ASIDE&apos;,&apos;C&apos;,&#10;                          &#9;&#9;&#9;   &apos;CANCELLED&apos;,&apos;C&apos;,&#10;                          &#9;&#9;&#9;   &apos;SATISFIED&apos;,&apos;S&apos;,&#10;                                      &#9;&#9;   &apos;C&apos;), &#10;                                170,&apos;C&apos;,    &#10;                                600,&#10;                                decode(JUDG.STATUS,&apos;SET ASIDE&apos;,&apos;C&apos;,&#10;                          &#9;&#9;&#9;   &apos;CANCELLED&apos;,&apos;C&apos;,&#10;                          &#9;&#9;&#9;   &apos;SATISFIED&apos;,&apos;S&apos;,&#10;                                      &#9;&#9;   &apos;C&apos;),  &#9;&#9;   &#10;                                &apos;R&apos;) &quot;STATUS&quot;,      &#10;       decode(JUDG.STATUS,&apos;SET ASIDE&apos;,  to_char(EVE.RESULT_DATE,&apos;DDMMYYYY&apos;),&#10;       &#9;&#9;&#9;  &apos;CANCELLED&apos;,to_char(JUDG.DATE_OF_FINAL_PAYMENT,&apos;DDMMYYYY&apos;),&#10;       &#9;&#9;&#9;  &apos;SATISFIED&apos;,to_char(JUDG.DATE_OF_FINAL_PAYMENT,&apos;DDMMYYYY&apos;),&#10;       &#9;&#9;&#9;  to_char(SYSDATE,&apos;DDMMYYYY&apos;)) &quot;CANC_DATE&quot;,&#10;       PAR.PERSON_REQUESTED_NAME,&#10;       ADDR.ADDRESS_LINE1, &#10;       ADDR.ADDRESS_LINE2, &#10;       ADDR.ADDRESS_LINE3,&#10;       ADDR.ADDRESS_LINE4, &#10;       ADDR.ADDRESS_LINE5, &#10;       ADDR.POSTCODE,&#10;       to_char(PAR.PERSON_DOB,&apos;DDMMYYYY&apos;) &quot;PAR.PERSON_DOB&quot;&#10;FROM   CASES             CAS,&#10;       CASE_PARTY_ROLES  CPR,&#10;       PARTIES           PAR,&#10;       GIVEN_ADDRESSES   ADDR,&#10;       JUDGMENTS         JUDG,&#10;       CASE_EVENTS       EVE&#10;WHERE  CAS.CASE_NUMBER              = CPR.CASE_NUMBER&#10;AND    CPR.PARTY_ROLE_CODE          = &apos;CLAIMANT&apos;&#10;AND    PAR.PARTY_ID                 = CPR.PARTY_ID&#10;AND    ADDR.CASE_NUMBER             = CPR.CASE_NUMBER&#10;AND    ADDR.PARTY_ROLE_CODE         = CPR.PARTY_ROLE_CODE&#10;AND    ADDR.CASE_PARTY_NO           = CPR.CASE_PARTY_NO&#10;AND    ADDR.ADDRESS_TYPE_CODE       = &apos;SERVICE&apos;&#10;AND    JUDG.CASE_NUMBER             = CPR.CASE_NUMBER&#10;AND    JUDG.AGAINST_PARTY_ROLE_CODE = CPR.PARTY_ROLE_CODE&#10;AND    JUDG.AGAINST_CASE_PARTY_NO   = CPR.CASE_PARTY_NO&#10;AND    JUDG.JUDGMENT_DATE           &gt; ADD_MONTHS(SYSDATE,-72)&#10;AND    ADDR.ADDRESS_ID &#9;&#9;    = JUDG.AGAINST_PARTY_ADDR_ID_JUDG_REG&#10;AND   (EVE.DELETED_FLAG             = &apos;N&apos; &#10;OR     EVE.DELETED_FLAG             IS NULL)       &#10;AND    EVE.DATE_TO_RTL              &gt; &apos;24-FEB-2007&apos;&#10;AND    EVE.DATE_TO_RTL              &lt; &apos;27-FEB-2007&apos;&#10;AND    (EVE.EVENT_DATE&#9;&#9;    = &apos;25-FEB-2007&apos;&#10;OR     EVE.EVENT_DATE&#9;&#9;    = &apos;26-FEB-2007&apos;)   &#10;AND    EVE.STD_EVENT_ID             IN (170,79,600)                                                                                                                                          &#10;AND  (                                                             &#10;       (                                                            &#10;        JUDG.JUDG_SEQ               = EVE.JUDG_SEQ                  &#10; AND    EVE.STD_EVENT_ID&#9;    !=79                            &#10;       )                                                            &#10; OR    (                                                            &#10;       JUDG.CASE_NUMBER            = EVE.CASE_NUMBER               &#10; AND    EVE.STD_EVENT_ID            = 79                            &#10;       )                                                            &#10;     ) &#10;)    &#10;UNION&#10; (SELECT CAS.admin_crt_code, &#10; eve.event_seq,&#10; judg.judg_seq,&#10;       CAS.CASE_NUMBER,&#10;       lpad(to_char(NVL(JUDG.JUDGMENT_AMOUNT, 0) + NVL(JUDG.TOTAL_COSTS, 0) - NVL(JUDG.PAID_BEFORE_JUDGMENT, 0)), 10) &quot;JUDG_TOTAL&quot;,&#10;       JUDG.TOTAL_CURRENCY,&#10;       to_char (JUDG.JUDGMENT_DATE,&apos;DDMMYYYY&apos;) &quot;JUDG_DATE&quot;, &#10;       decode(eve.std_event_id, 79,&#10;       &#9;&#9;&#9;&#9;decode(JUDG.STATUS,&apos;SET ASIDE&apos;,&apos;C&apos;,&#10;                          &#9;&#9;&#9;   &apos;CANCELLED&apos;,&apos;C&apos;,&#10;                          &#9;&#9;&#9;   &apos;SATISFIED&apos;,&apos;S&apos;,&#10;                                      &#9;&#9;   &apos;C&apos;), &#10;                                170,&apos;C&apos;,   &#10;                                600,&#10;                                decode(JUDG.STATUS,&apos;SET ASIDE&apos;,&apos;C&apos;,&#10;                          &#9;&#9;&#9;   &apos;CANCELLED&apos;,&apos;C&apos;,&#10;                          &#9;&#9;&#9;   &apos;SATISFIED&apos;,&apos;S&apos;,&#10;                                      &#9;&#9;   &apos;C&apos;),  &#9;&#9;   &#10;                                &apos;R&apos;) &quot;STATUS&quot;,&#10;       decode(JUDG.STATUS,&apos;SET ASIDE&apos;,  to_char(EVE.RESULT_DATE,&apos;DDMMYYYY&apos;),&#10;       &#9;&#9;&#9;  &apos;CANCELLED&apos;,to_char(JUDG.DATE_OF_FINAL_PAYMENT,&apos;DDMMYYYY&apos;),&#10;       &#9;&#9;&#9;  &apos;SATISFIED&apos;,to_char(JUDG.DATE_OF_FINAL_PAYMENT,&apos;DDMMYYYY&apos;),&#10;       &#9;&#9;&#9;  to_char(SYSDATE,&apos;DDMMYYYY&apos;)) &quot;CANC_DATE&quot;,&#10;       PAR.PERSON_REQUESTED_NAME,&#10;       ADDR.ADDRESS_LINE1, &#10;       ADDR.ADDRESS_LINE2, &#10;       ADDR.ADDRESS_LINE3,&#10;       ADDR.ADDRESS_LINE4, &#10;       ADDR.ADDRESS_LINE5, &#10;       ADDR.POSTCODE,&#10;       to_char(PAR.PERSON_DOB,&apos;DDMMYYYY&apos;) &quot;PAR.PERSON_DOB&quot;&#10;FROM   CASES             CAS,&#10;       CASE_PARTY_ROLES  CPR,&#10;       PARTIES           PAR,&#10;       GIVEN_ADDRESSES   ADDR,&#10;       JUDGMENTS         JUDG,&#10;       CASE_EVENTS       EVE,&#10;       CODED_PARTIES&#9; CPAR&#10;WHERE  CAS.CASE_NUMBER              = CPR.CASE_NUMBER&#10;AND    CPR.PARTY_ROLE_CODE          = &apos;CLAIMANT&apos;&#10;AND    PAR.PARTY_ID                 = CPR.PARTY_ID&#10;AND    ADDR.CASE_NUMBER &#9;    IS NULL&#10;AND    ADDR.ADDRESS_TYPE_CODE       = &apos;CODED PARTY&apos;&#10;AND    ADDR.PARTY_ID&#9;&#9;    = CPAR.PARTY_ID&#10;AND    CPR.PARTY_ID&#9;&#9;    = CPAR.PARTY_ID&#10;AND    JUDG.CASE_NUMBER             = CPR.CASE_NUMBER&#10;AND    JUDG.AGAINST_PARTY_ROLE_CODE = CPR.PARTY_ROLE_CODE&#10;AND    JUDG.AGAINST_CASE_PARTY_NO   = CPR.CASE_PARTY_NO&#10;AND    JUDG.JUDGMENT_DATE           &gt; ADD_MONTHS(SYSDATE,-72)&#10;AND    ADDR.ADDRESS_ID &#9;&#9;    = JUDG.AGAINST_PARTY_ADDR_ID_JUDG_REG&#10;AND   (EVE.DELETED_FLAG             = &apos;N&apos; &#10;OR     EVE.DELETED_FLAG             IS NULL)       &#10;AND    EVE.DATE_TO_RTL              &gt; &apos;24-FEB-2007&apos;&#10;AND    EVE.DATE_TO_RTL              &lt; &apos;27-FEB-2007&apos;&#10;AND    (EVE.EVENT_DATE&#9;&#9;    = &apos;25-FEB-2007&apos;&#10;OR     EVE.EVENT_DATE&#9;&#9;    = &apos;26-FEB-2007&apos;)                                                                                 &#10;AND    EVE.STD_EVENT_ID             IN (170,79,600)                                                                                                                                          &#10;AND  (                                                             &#10;       (                                                            &#10;        JUDG.JUDG_SEQ               = EVE.JUDG_SEQ                  &#10; AND    EVE.STD_EVENT_ID&#9;    !=79                            &#10;       )                                                            &#10; OR    (                                                            &#10;       JUDG.CASE_NUMBER            = EVE.CASE_NUMBER               &#10; AND    EVE.STD_EVENT_ID            = 79                            &#10;       )                                                            &#10;     ) &#10;)"/>
                <pl:parameter name="forward_option" value="0"/>
                <pl:parameter name="sqlwarntoerror" value="false"/>
                <pl:parameter name="query" value="true"/>
