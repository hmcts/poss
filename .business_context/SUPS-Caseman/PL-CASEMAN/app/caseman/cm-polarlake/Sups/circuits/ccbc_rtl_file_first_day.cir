        <pl:seqlist name="Update Judgment AddressID Sequence">
            <pl:eventprocessor name="pl:starttransaction" disable="false">
                <pl:parameter name="design">
                    <pl:parameter name="uid" value="413"/>
                    <pl:parameter name="alias" value="DB Start"/>
                </pl:parameter>
                <pl:parameter name="trigger" value="start"/>
                <pl:parameter name="connection" value="casm"/>
                <pl:parameter name="transaction_key" value="Address ID"/>
                <pl:parameter name="transaction_level" value="0"/>
            </pl:eventprocessor>
            <pl:eventprocessor name="pl:interpreter" disable="false">
                <pl:parameter name="useview" value="Setup Audit - Update Address ID - View"/>
                <pl:parameter name="design">
                    <pl:parameter name="uid" value="439"/>
                    <pl:parameter name="alias" value="PolarLake Interpreter"/>
                </pl:parameter>
            </pl:eventprocessor>
            <pl:eventprocessor name="pl:addprocessvariable" disable="false">
                <pl:parameter name="design">
                    <pl:parameter name="uid" value="402"/>
                    <pl:parameter name="alias" value="Add Process Variables"/>
                </pl:parameter>
                <pl:parameter name="trigger" value="start"/>
                <pl:parameter name="map">
                    <pl:parameter name="CurrentAddressID" value=""/>
                </pl:parameter>
            </pl:eventprocessor>
            <pl:eventprocessor name="pl:xmltoprocessvariable" disable="false">
                <pl:parameter name="design">
                    <pl:parameter name="uid" value="410"/>
                    <pl:parameter name="alias" value="XML to Process Variable (simple)"/>
                </pl:parameter>
                <pl:parameter name="depth" value="any"/>
                <pl:parameter name="element_name" value="judg_seq"/>
                <pl:parameter name="select" value="element_value"/>
                <pl:parameter name="attribute_name" value=""/>
                <pl:parameter name="param_name" value="judgment_sequence"/>
                <pl:parameter name="use_default" value="off"/>
            </pl:eventprocessor>
            <pl:eventprocessor name="pl:script" disable="false">
                <pl:parameter name="design">
                    <pl:parameter name="uid" value="411"/>
                    <pl:parameter name="alias" value="wait"/>
                </pl:parameter>
                <pl:parameter name="name" value="wait"/>
                <pl:parameter name="useScriptasAlias" value="true"/>
                <pl:parameter name="forwardToProcVar" value="false"/>
                <pl:parameter name="process_variable_name" value=""/>
            </pl:eventprocessor>
            <pl:eventprocessor name="pl:printmessage" disable="false">
                <pl:parameter name="design">
                    <pl:parameter name="uid" value="408"/>
                    <pl:parameter name="alias" value="Print Message"/>
                </pl:parameter>
                <pl:parameter name="trigger" value="start"/>
                <pl:parameter name="message" value="-&#10;--&gt; Starting to update Address ID for RTL for judgment&#10;--&gt;SEQUENCE -Update Judgment AddressID Sequence&#10;--&gt;VIEW - Update Judgment AddressID View&#10;--&gt;CIRCUIT - ccbc_rtl_file_first_day&#10;----------------------------------------------------------------------------------"/>
                <pl:parameter name="use_log4j" value="true"/>
                <pl:parameter name="log_level" value="INFO"/>
            </pl:eventprocessor>
            <pl:eventprocessor name="pl:sqltoxml" disable="false">
                <pl:parameter name="design">
                    <pl:parameter name="uid" value="401"/>
                    <pl:parameter name="alias" value="DB SQL - Select AddressID"/>
                </pl:parameter>
                <pl:parameter name="transaction_key" value="Address ID"/>
                <pl:parameter name="sql" value="select ga.address_id from given_addresses ga, case_party_roles cpr, judgments j&#10;where cpr.party_role_code = j.against_party_role_code&#10;and cpr.case_party_no = j.against_case_party_no&#10;and cpr.case_number = j.case_number&#10;and j.judg_seq = ?&#10;and ga.party_id = cpr.party_id&#10;and ga.address_type_code in (&apos;CODED PARTY&apos;, &apos;SERVICE&apos;)&#10;and ga.valid_to IS NULL"/>
                <pl:parameter name="forward_option" value="8"/>
                <pl:parameter name="sqlwarntoerror" value="false"/>
                <pl:parameter name="query" value="true"/>
                <pl:parameter name="input_mappings">
                    <pl:parameter name="input schemas">
                        <pl:parameter name="0">
