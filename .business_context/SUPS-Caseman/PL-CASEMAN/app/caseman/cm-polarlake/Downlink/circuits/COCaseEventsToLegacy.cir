            <pl:parameter name="useview" value="Main Sups Caseman to Legacy View"/>
            <pl:parameter name="address" value="file:///{pl$Court_Config}"/>
            <pl:parameter name="wait" value="false"/>
            <pl:parameter name="process_priority" value="5"/>
            <pl:parameter name="design">
                <pl:parameter name="uid" value="813"/>
            </pl:parameter>
        </pl:action>
        <pl:action name="transportprovider.command">
            <pl:parameter name="command" value="start"/>
            <pl:parameter name="application" value="SYSTEM"/>
            <pl:parameter name="provider" value="xmltclientprovider"/>
            <pl:parameter name="alias" value="Shutdown"/>
            <pl:parameter name="ackonreceipt" value="false"/>
            <pl:parameter name="ackonprocessed" value="false"/>
            <pl:parameter name="design">
                <pl:parameter name="uid" value="814"/>
            </pl:parameter>
        </pl:action>
    </pl:circuit>
</pl:system-content>