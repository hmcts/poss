                <pl:parameter name="trigger" value="start"/>
                <pl:parameter name="message" value="-&#10;--&gt; After Address Employer Insert&#10;--&gt; SEQUENCE - Address Employer Sequence&#10;--&gt; VIEW - Address Employer View&#10;--&gt; CIRCUIT - {$CircuitName}&#10;----------------------------------------------------------------------------------"/>
