        <pl:seqlist name="Retrieve Courts within Grouping Court Sequence">
            <pl:eventprocessor name="pl:printmessage" disable="false">
                <pl:parameter name="design">
                    <pl:parameter name="uid" value="182"/>
                    <pl:parameter name="alias" value="Print Message"/>
                </pl:parameter>
                <pl:parameter name="trigger" value="start"/>
                <pl:parameter name="message" value="- &#10;--&gt; Start of Retrieve Courts within Grouping Court Sequence -  Grouping Court = {$grouping_court_code} &#10;--&gt; SEQUENCE - Retrieve Courts within Grouping Court Sequence&#10;--&gt; VIEW - Retrieve Courts within Grouping Court View&#10;--&gt; CIRCUIT - {$CircuitName}&#10;----------------------------------------------------------------------------------"/>
                <pl:parameter name="use_log4j" value="true"/>
                <pl:parameter name="log_level" value="INFO"/>
            </pl:eventprocessor>
            <pl:eventprocessor name="pl:storecontextdoc" disable="false">
                <pl:parameter name="design">
                    <pl:parameter name="uid" value="130"/>
                    <pl:parameter name="alias" value="Store Context Document"/>
                </pl:parameter>
                <pl:parameter name="variable" value="Court-Main"/>
                <pl:parameter name="consume" value="false"/>
                <pl:parameter name="validate" value="false"/>
            </pl:eventprocessor>
            <pl:eventprocessor name="pl:starttransaction" disable="false">
                <pl:parameter name="design">
                    <pl:parameter name="uid" value="16"/>
                    <pl:parameter name="alias" value="DB Start - Second"/>
                </pl:parameter>
                <pl:parameter name="trigger" value="start"/>
                <pl:parameter name="connection" value="supsdb01"/>
                <pl:parameter name="transaction_key" value="Second"/>
                <pl:parameter name="transaction_level" value="0"/>
            </pl:eventprocessor>
            <pl:eventprocessor name="pl:sqltoxml" disable="false">
                <pl:parameter name="design">
                    <pl:parameter name="uid" value="1573"/>
                    <pl:parameter name="alias" value="DB SQL - Get Court List"/>
                </pl:parameter>
                <pl:parameter name="transaction_key" value="Second"/>
                <pl:parameter name="sql" value="select CODE from courts where CASEMAN_INSERVICE = &apos;Y&apos; and SUPS_CENTRALISED_FLAG = &apos;Y&apos; and  WFT_GROUPING_COURT = ?&#10;order by CODE"/>
                <pl:parameter name="forward_option" value="0"/>
                <pl:parameter name="sqlwarntoerror" value="false"/>
                <pl:parameter name="query" value="true"/>
                <pl:parameter name="input_mappings">
