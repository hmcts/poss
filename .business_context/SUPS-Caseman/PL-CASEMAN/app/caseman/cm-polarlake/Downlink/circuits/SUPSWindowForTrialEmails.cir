        <pl:seqlist name="File Header Sequence">
            <pl:eventprocessor name="pl:printmessage" disable="false">
                <pl:parameter name="design">
                    <pl:parameter name="uid" value="1630"/>
                    <pl:parameter name="alias" value="Print Message"/>
                </pl:parameter>
                <pl:parameter name="trigger" value="start"/>
                <pl:parameter name="message" value="- &#10;--&gt; Add file header for Grouping Court - {$grouping_court_code}&#10;--&gt; SEQUENCE - File Header Sequence&#10;--&gt; VIEW - File Header View&#10;--&gt; CIRCUIT - {$CircuitName}&#10;----------------------------------------------------------------------------------"/>
                <pl:parameter name="use_log4j" value="true"/>
                <pl:parameter name="log_level" value="INFO"/>
            </pl:eventprocessor>
            <pl:eventprocessor name="pl:sqltoxml" disable="false">
                <pl:parameter name="design">
                    <pl:parameter name="uid" value="1617"/>
                    <pl:parameter name="alias" value="Add Header to Output File"/>
                </pl:parameter>
                <pl:parameter name="transaction_key" value="Second"/>
                <pl:parameter name="sql" value="select &#10;&apos;TABLE&apos;||chr(13) a,&#10;&apos;0,1&apos;||chr(13) a,&#10;&apos;&quot;&quot;&apos;||chr(13) a,&#10;&apos;VECTORS&apos;||chr(13) a,&#10;&apos;0,63&apos;||chr(13) a,&#10;&apos;&quot;&quot;&apos;||chr(13) a,&#10;&apos;TUPLES&apos;||chr(13) a,&#10;&apos;0,18&apos;||chr(13) a,&#10;&apos;&quot;&quot;&apos;||chr(13) a,&#10;&apos;DATA&apos;||chr(13) a,&#10;&apos;0,0&apos;||chr(13) a,&#10;&apos;&quot;&quot;&apos;||chr(13) a,&#10;&apos;-1,0&apos;||chr(13) a,&#10;&apos;BOT&apos;||chr(13) a,&#10;&apos;1,0&apos;||chr(13) a,&#10;&apos;&quot;CLAIM NUMBER&quot;&apos;||chr(13) a,&#10;&apos;1,0&apos;||chr(13) a,&#10;&apos;&quot;any ZDIARYMAIN CLAIMANT&quot;&apos;||chr(13) a,&#10;&apos;1,0&apos;||chr(13) a,&#10;&apos;&quot;any ZDIARYMAIN DEFENDANT&quot;&apos;||chr(13) a,&#10;&apos;1,0&apos;||chr(13) a,&#10;&apos;&quot;Track&quot;&apos;||chr(13) a,&#10;&apos;1,0&apos;||chr(13) a,&#10;&apos;&quot;DAYS&quot;&apos;||chr(13) a,&#10;&apos;1,0&apos;||chr(13) a,&#10;&apos;&quot;HOURS&quot;&apos;||chr(13) a,&#10;&apos;1,0&apos;||chr(13) a,&#10;&apos;&quot;MINUTES&quot;&apos;||chr(13) a,&#10;&apos;1,0&apos;||chr(13) a,&#10;&apos;&quot;From&quot;&apos;||chr(13) a,&#10;&apos;1,0&apos;||chr(13) a,&#10;&apos;&quot;To&quot;&apos;||chr(13) a,&#10;&apos;1,0&apos;||chr(13) a,&#10;&apos;&quot;COURT&quot;&apos;||chr(13) a,&#10;&apos;1,0&apos;||chr(13) a,&#10;&apos;&quot;STATUS&quot;&apos;||chr(13) a,&#10;&apos;1,0&apos;||chr(13) a,&#10;&apos;&quot;OUTCOME DATE&quot;&apos;||chr(13) a,&#10;&apos;1,0&apos;||chr(13) a,&#10;&apos;&quot;JUDGES NAME&quot;&apos;||chr(13) a,&#10;&apos;1,0&apos;||chr(13) a,&#10;&apos;&quot;REASON FOR ADJOURNMENT&quot;&apos;||chr(13) a,&#10;&apos;1,0&apos;||chr(13) a,&#10;&apos;&quot;CMC FLAG&quot;&apos;||chr(13) a,&#10;&apos;1,0&apos;||chr(13) a,&#10;&apos;&quot;CMC DATE&quot;&apos;||chr(13) a,&#10;&apos;1,0&apos;||chr(13) a,&#10;&apos;&quot;NOTES&quot;&apos;||chr(13) a,&#10;&apos;1,0&apos;||chr(13) a,&#10;&apos;&quot;EXCLUDED DATES&quot;&apos;||chr(13) a,&#10;&apos;-1,0&apos;||chr(13) a,&#10;&apos;BOT&apos;||chr(13) a&#10;from dual"/>
                <pl:parameter name="forward_option" value="0"/>
                <pl:parameter name="sqlwarntoerror" value="false"/>
                <pl:parameter name="query" value="true"/>
                <pl:parameter name="input_mappings"/>
                <pl:parameter name="output_mappings"/>
                <pl:parameter name="uses_transaction" value="true"/>
