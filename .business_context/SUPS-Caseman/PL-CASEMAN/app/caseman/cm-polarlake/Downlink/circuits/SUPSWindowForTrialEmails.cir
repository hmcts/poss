        <pl:application-data name="Resources" type="Resources">
            <pl:application-data name="Functions" type="functions" application="com.polarlake.platform.librarymodule.LibraryModuleApplication">
                <pl:application-data name="formatDates" type="function" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value="">
                    <pl:application-data name="type" type="property" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value="beanshell"/>
                    <pl:application-data name="methodName" type="property" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value="formatDates"/>
                    <pl:application-data name="category" type="property" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value="Miscellaneous"/>
                    <pl:application-data name="script" type="property" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value="import org.apache.log4j.Logger;&#10;import java.text.ParseException;&#10;import java.text.SimpleDateFormat;&#10;import java.util.Date;&#10;&#10;String formatDates(String pDate)&#10;    {&#10;        Logger loggerInfo = Logger.getLogger(&quot;com.info&quot;);&#10;        Logger loggerE = Logger.getLogger(&quot;com.error&quot;);&#10;        String function_name = &quot;formatDates&quot;;&#10;&#10;        if(pDate != null &amp;&amp; (!pDate.trim().equals(&quot;&quot;))) {&#9;&#10;        &#9;SimpleDateFormat dateFormat = null;&#10;        &#9;dateFormat = new SimpleDateFormat(&quot;yyyy-MM-dd&quot;);&#10;         &#9;dateFormat.applyPattern(&quot;yyyy-MM-dd&quot;);&#10;       &#9;Date parseDate = null;&#10;&#10;&#9;try {&#10;          &#9;&#9; parseDate = dateFormat.parse(pDate);&#10;      &#9; } catch (ParseException pe) {&#10;           &#9;&#9; loggerE.error(&quot;ParseException caught&quot;);  &#10;       &#9;}&#10;&#9; loggerInfo.info(&quot;Date is not null in &quot; + function_name + &quot; , returning null&quot;);&#10;       &#9;return dateFormat.format(parseDate);&#10;       } else {&#10;&#9; loggerInfo.info(&quot;Date is null in &quot; + function_name + &quot; , returning null&quot;);&#10;&#9;return null;&#10;        }&#10;    }"/>
                    <pl:application-data name="description" type="property" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value=""/>
                </pl:application-data>
                <pl:application-data name="formatDatesForUpdates" type="function" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value="">
                    <pl:application-data name="type" type="property" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value="beanshell"/>
                    <pl:application-data name="methodName" type="property" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value="formatDates"/>
                    <pl:application-data name="category" type="property" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value="Miscellaneous"/>
                    <pl:application-data name="script" type="property" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value="import org.apache.log4j.Logger;&#10;import java.text.ParseException;&#10;import java.text.SimpleDateFormat;&#10;import java.util.Date;&#10;&#10;String formatDates(String pDate)&#10;    {&#10;        Logger logger = Logger.getRootLogger();&#10;        String function_name = &quot;formatDates&quot;;&#10;&#10;        if(pDate != null &amp;&amp; (!pDate.trim().equals(&quot;&quot;))) {&#9;&#10;        &#9;SimpleDateFormat dateFormat = null;&#10;&#10;        &#9;dateFormat = new SimpleDateFormat(&quot;yyyy-MM-dd&quot;);&#10;       &#9;Date parseDate = null;&#10;&#9;try {&#10;          &#9;&#9; parseDate = dateFormat.parse(pDate);&#10;      &#9; } catch (ParseException pe) {&#10;           &#9;&#9; logger.error(&quot;ParseException caught&quot;);  &#10;       &#9;}&#10;&#9; logger.info(&quot;Date is not null in &quot; + function_name + &quot; , returning null&quot;);&#10;         &#9;dateFormat.applyPattern(&quot;dd-MMM-yyyy&quot;);&#10;       &#9;return dateFormat.format(parseDate);&#10;       } else {&#10;&#9; logger.info(&quot;Date is null in &quot; + function_name + &quot; , returning null&quot;);&#10;&#9;return &quot;&quot;;&#10;        }&#10;    }"/>
                    <pl:application-data name="description" type="property" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value=""/>
                </pl:application-data>
                <pl:application-data name="determineCaseEventsPartyRole" type="function" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value="">
                    <pl:application-data name="type" type="property" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value="beanshell"/>
                    <pl:application-data name="methodName" type="property" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value="determineCaseEventsPartyRole"/>
                    <pl:application-data name="category" type="property" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value="Miscellaneous"/>
                    <pl:application-data name="script" type="property" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value="import org.apache.log4j.Logger;&#10;&#10;String determineCaseEventsPartyRole(String pEvent)&#10;    {&#10;        Logger logger = Logger.getLogger(&quot;com.info&quot;);&#10;        String function_name = &quot;determineCaseEventsPartyRole&quot;;&#10;&#10;        if(pEvent != null &amp;&amp; (!pEvent.trim().equals(&quot;&quot;)) &amp;&amp; (!pEvent.trim().equals(&quot;0&quot;))) {&#9;&#10;        &#9;&#10;&#9; logger.info(&quot;Event Party Role Code for &quot; + function_name + &quot; , is Defendant&quot;);&#10;       &#9;return &quot;DEFENDANT&quot;;&#10;       } else if (pEvent != null &amp;&amp; (!pEvent.trim().equals(&quot;&quot;)) &amp;&amp; pEvent.trim().equals(&quot;0&quot;)) {&#10;&#9; logger.info(&quot;Event Party Role Code for &quot; + function_name + &quot; , is Defendant for a Judgment&quot;);&#10;&#9;return &quot;DEFENDANT&quot;;&#10;        } else {&#10;&#9;return &quot;CLAIMANT&quot;;&#10;        }&#10;    }"/>
                    <pl:application-data name="description" type="property" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value=""/>
                </pl:application-data>
                <pl:application-data name="determineCasePartyRoleForCaseEvents" type="function" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value="">
                    <pl:application-data name="type" type="property" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value="beanshell"/>
                    <pl:application-data name="methodName" type="property" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value="determineCasePartyRoleForCaseEvents"/>
                    <pl:application-data name="category" type="property" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value="Miscellaneous"/>
                    <pl:application-data name="script" type="property" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value="import org.apache.log4j.Logger;&#10;&#10;String determineCasePartyRoleForCaseEvents(String pEvent)&#10;    {&#10;        Logger logger = Logger.getLogger(&quot;com.info&quot;);&#10;        String function_name = &quot;determineCasePartyRoleForCaseEvents&quot;;&#10;&#10;        if(pEvent != null &amp;&amp; (!pEvent.trim().equals(&quot;&quot;)) &amp;&amp; (!pEvent.trim().equals(&quot;0&quot;))) {&#9;&#10;        &#9;&#10;&#9; logger.info(&quot;Event Party Role Code for &quot; + function_name + &quot; , is Defendant&quot;);&#10;       &#9;return pEvent;&#10;       } else if(pEvent != null &amp;&amp; (!pEvent.trim().equals(&quot;&quot;)) &amp;&amp; pEvent.trim().equals(&quot;0&quot;)) {&#10;&#9; logger.info(&quot;Event Party Role Code for &quot; + function_name + &quot; , is Defandant for Judgment&quot;);&#10;&#9;return pEvent;&#10;        } else {&#10; &#9;logger.info(&quot;Event Party Role Code for &quot; + function_name + &quot; , is Claimant&quot;);&#10;       &#9;return &quot;1&quot;;&#10;       }&#10;    }"/>
                    <pl:application-data name="description" type="property" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value=""/>
                </pl:application-data>
                <pl:application-data name="determinePartyRoleCodeForDefendant" type="function" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value="">
                    <pl:application-data name="type" type="property" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value="beanshell"/>
                    <pl:application-data name="methodName" type="property" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value="determinePartyRoleCodeForDefendant"/>
                    <pl:application-data name="category" type="property" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value="Miscellaneous"/>
                    <pl:application-data name="script" type="property" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value="import org.apache.log4j.Logger;&#10;&#10;String determinePartyRoleCodeForDefendant(String pAddressLine)&#10;    {&#10;        Logger logger = Logger.getLogger(&quot;com.info&quot;);&#10;        String function_name = &quot;determinePartyRoleCodeForDefendant&quot;;&#10;&#10;        if(pAddressLine != null &amp;&amp; (!pAddressLine.trim().equals(&quot;&quot;))) {&#9;&#10;        &#9;&#10;&#9; logger.info(&quot;Party Role Code for &quot; + function_name + &quot; , is Defendant&quot;);&#10;       &#9;  return &quot;DEFENDANT&quot;;&#10;       } else {&#10;&#9; logger.info(&quot;Party Role Code for &quot; + function_name + &quot; , is Null&quot;);&#10;&#9; return &quot;&quot;;&#10;        }&#10;    }"/>
                    <pl:application-data name="description" type="property" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value=""/>
                </pl:application-data>
                <pl:application-data name="determinePartyRole" type="function" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value="">
                    <pl:application-data name="type" type="property" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value="beanshell"/>
                    <pl:application-data name="methodName" type="property" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value="determinePartyRole"/>
                    <pl:application-data name="category" type="property" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value="Miscellaneous"/>
                    <pl:application-data name="script" type="property" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value="import org.apache.log4j.Logger;&#10;&#10;String determinePartyRole(String pAddrType, String pDeftId)&#10;    {&#10;        Logger logger = Logger.getLogger(&quot;com.info&quot;);&#10;        String function_name = &quot;determinePartyRole&quot;;&#10;&#10;        if(pDeftId != null &amp;&amp; (!pDeftId.trim().equals(&quot;&quot;)) &amp;&amp; pAddrType != null &amp;&amp; (!pAddrType.trim().equals(&quot;&quot;)) &amp;&amp;  (!pAddrType.trim().equals(&quot;EMPLOYER&quot;) || !pAddrType.trim().equals(&quot;POSS&quot;) )) {&#10;        &#9;&#10;&#9; logger.info(&quot;Party Role Code for &quot; + function_name + &quot; , DEFENDANT&quot;);&#10;       &#9;return &quot;DEFENDANT&quot;;&#10;       } else if (pAddrType != null &amp;&amp; (!pAddrType.trim().equals(&quot;&quot;)) &amp;&amp; (!pAddrType.trim().equals(&quot;EMPLOYER&quot;) || !pAddrType.trim().equals(&quot;POSS&quot;) )) {&#10;&#9; logger.info(&quot;Party Role Code for &quot; + function_name + &quot; , CLAIMANT&quot;);&#10;       &#9;return &quot;CLAIMANT&quot;;&#10;       } else if (pAddrType != null &amp;&amp; (!pAddrType.trim().equals(&quot;&quot;)) &amp;&amp; pAddrType.trim().equals(&quot;EMPLOYER&quot;) || pAddrType.trim().equals(&quot;POSS&quot;)) {&#10;&#9; logger.info(&quot;Party Role Code for &quot; + function_name + &quot; , Party Role Code of&quot; +pAddrType);&#10;       &#9;return null;&#10;       } else  {&#10;&#9; logger.info(&quot;Event Party Role Code for &quot; + function_name + &quot; , umatched party Role Code&quot;);&#10;       &#9;return null;&#10;        }&#10;    }"/>
                    <pl:application-data name="description" type="property" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value=""/>
                </pl:application-data>
                <pl:application-data name="determinePossAddress" type="function" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value="">
                    <pl:application-data name="type" type="property" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value="beanshell"/>
                    <pl:application-data name="methodName" type="property" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value="determinePossAddress"/>
                    <pl:application-data name="category" type="property" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value="Miscellaneous"/>
                    <pl:application-data name="script" type="property" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value="import org.apache.log4j.Logger;&#10;&#10;String determinePossAddress(String pAddrType)&#10;    {&#10;        Logger logger = Logger.getLogger(&quot;com.info&quot;);&#10;        String function_name = &quot;determinePossAddress&quot;;&#10;&#10;        if(pAddrType != null &amp;&amp; (!pAddrType.trim().equals(&quot;&quot;)) &amp;&amp; pAddrType.trim().equals(&quot;POSS&quot;) ) {&#10;        &#9;&#10;&#9; logger.info(&quot;Addr Type Code for &quot; + function_name + &quot; , POSSESSION&quot;);&#10;       &#9;return &quot;POSSESSION&quot;;&#10;       } else  {&#10;&#9; logger.info(&quot;Addr Type Code for &quot; + function_name + &quot; , &quot; + pAddrType);&#10;       &#9;return pAddrType;&#10;        }&#10;    }"/>
                    <pl:application-data name="description" type="property" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value=""/>
                </pl:application-data>
                <pl:application-data name="truncatePostcodeForPlantiffAddress" type="function" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value="">
                    <pl:application-data name="type" type="property" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value="beanshell"/>
                    <pl:application-data name="methodName" type="property" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value="truncatePostcodeForPlantiffAddress"/>
                    <pl:application-data name="category" type="property" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value="Miscellaneous"/>
                    <pl:application-data name="script" type="property" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value="import org.apache.log4j.Logger;&#10;&#10;String truncatePostcodeForPlantiffAddress(String pPostcode)&#10;    {&#10;        Logger logger = Logger.getLogger(&quot;com.info&quot;);&#10;        String function_name = &quot;truncatePostcodeForPlantiffAddress&quot;;&#10;&#10;        if(pPostcode != null &amp;&amp; (!pPostcode.trim().equals(&quot;&quot;)) &amp;&amp; pPostcode.length() &lt;=8 ) {&#10;        &#9;&#10;&#9; logger.info(&quot;PostCode for &quot; + function_name + &quot; , &quot; +pPostcode);&#10;       &#9;return pPostcode;&#10;       } else if (pPostcode != null &amp;&amp; (!pPostcode.trim().equals(&quot;&quot;))) {&#10;&#9; logger.info(&quot;PostCode for &quot; + function_name + &quot; , &quot; + pPostcode.substring(0, 8));&#10;       &#9;return pPostcode.substring(0, 8);&#10;        } else {&#10;&#9; logger.info(&quot;PostCode for &quot; + function_name + &quot; , &quot; +pPostcode);&#10;       &#9;return pPostcode;&#10;       }&#10;    }"/>
                    <pl:application-data name="description" type="property" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value=""/>
                </pl:application-data>
                <pl:application-data name="truncateErrorMsg" type="function" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value="">
                    <pl:application-data name="type" type="property" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value="beanshell"/>
                    <pl:application-data name="methodName" type="property" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value="truncateErrorMsg"/>
                    <pl:application-data name="category" type="property" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value="Miscellaneous"/>
                    <pl:application-data name="script" type="property" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value="import org.apache.log4j.Logger;&#10;&#10;String truncateErrorMsg(String pMsg)&#10;    {&#10;        Logger logger = Logger.getLogger(&quot;com.info&quot;);&#10;        String function_name = &quot;truncateErrorMsg&quot;;&#10;&#10;        if(pMsg != null &amp;&amp; (!pMsg.trim().equals(&quot;&quot;)) &amp;&amp; pMsg.length() &lt;=200 ) {&#10;        &#9;&#10;&#9; logger.info(&quot;Msg for &quot; + function_name + &quot; , &quot; +pMsg);&#10;       &#9;return pMsg;&#10;       } else if (pMsg != null &amp;&amp; (!pMsg.trim().equals(&quot;&quot;))) {&#10;&#9; logger.info(&quot;Msg for &quot; + function_name + &quot; , &quot; + pMsg.substring(0, 200));&#10;       &#9;return pMsg.substring(0, 200);&#10;        } else {&#10;&#9; logger.info(&quot;Msg for &quot; + function_name + &quot; , &quot; + pMsg);&#10;&#9;return pMsg;&#10;        }&#10;    }"/>
                    <pl:application-data name="description" type="property" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value=""/>
                </pl:application-data>
                <pl:application-data name="truncateTelForPlantiffAddress" type="function" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value="">
                    <pl:application-data name="type" type="property" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value="beanshell"/>
                    <pl:application-data name="methodName" type="property" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value="truncateTelForPlantiffAddress"/>
                    <pl:application-data name="category" type="property" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value="Miscellaneous"/>
                    <pl:application-data name="script" type="property" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value="import org.apache.log4j.Logger;&#10;&#10;String truncateTelForPlantiffAddress(String pTel)&#10;    {&#10;        Logger logger = Logger.getLogger(&quot;com.info&quot;);&#10;        String function_name = &quot;truncateTelForPlantiffAddress&quot;;&#10;&#10;        if(pTel != null &amp;&amp; (!pTel.trim().equals(&quot;&quot;)) &amp;&amp; pTel.length() &lt;=24 ) {&#10;        &#9;&#10;&#9; logger.info(&quot;Telephone for &quot; + function_name + &quot; , &quot; +pTel);&#10;       &#9;return pTel;&#10;       } else if (pTel != null &amp;&amp; (!pTel.trim().equals(&quot;&quot;))) {&#10;&#9; logger.info(&quot;pTel for &quot; + function_name + &quot; , &quot; + pTel.substring(0, 24));&#10;       &#9;return pTel.substring(0, 24);&#10;        } else {&#10;&#9; logger.info(&quot;pTel for &quot; + function_name + &quot; , &quot; +pTel);&#10;       &#9;return pTel;&#10;       }&#10;    }"/>
                    <pl:application-data name="description" type="property" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value=""/>
                </pl:application-data>
                <pl:application-data name="truncateStatus" type="function" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value="">
                    <pl:application-data name="type" type="property" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value="beanshell"/>
                    <pl:application-data name="methodName" type="property" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value="truncateStatus"/>
                    <pl:application-data name="category" type="property" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value="Miscellaneous"/>
                    <pl:application-data name="script" type="property" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value="import org.apache.log4j.Logger;&#10;&#10;String truncateStatus(String pStatus)&#10;    {&#10;        Logger logger = Logger.getLogger(&quot;com.info&quot;);&#10;        String function_name = &quot;truncateStatus&quot;;&#10;&#10;        if(pStatus != null &amp;&amp; (!pStatus.trim().equals(&quot;&quot;)) &amp;&amp; pStatus.length() &lt;=12 ) {&#10;        &#9;&#10;&#9; logger.info(&quot;Status for &quot; + function_name + &quot; , &quot; +pStatus);&#10;       &#9;return pStatus;&#10;       } else if (pStatus != null &amp;&amp; (!pStatus.trim().equals(&quot;&quot;))) {&#10;&#9; logger.info(&quot;pStatus for &quot; + function_name + &quot; , &quot; + pStatus.substring(0, 12));&#10;       &#9;return pStatus.substring(0, 12);&#10;        } else {&#10;&#9; logger.info(&quot;pStatus for &quot; + function_name + &quot; , &quot; +pStatus);&#10;       &#9;return pStatus;&#10;       }&#10;    }"/>
                    <pl:application-data name="description" type="property" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value=""/>
                </pl:application-data>
                <pl:application-data name="determineBarJudgment" type="function" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value="">
                    <pl:application-data name="type" type="property" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value="beanshell"/>
                    <pl:application-data name="methodName" type="property" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value="determineBarJudgment"/>
                    <pl:application-data name="category" type="property" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value="Miscellaneous"/>
                    <pl:application-data name="script" type="property" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value="import org.apache.log4j.Logger;&#10;&#10;String determineBarJudgment(String pBarJudg)&#10;    {&#10;        Logger logger = Logger.getLogger(&quot;com.info&quot;);&#10;        String function_name = &quot;determineBarJudgment&quot;;&#10;&#10;        if(pBarJudg != null &amp;&amp; (!pBarJudg.trim().equals(&quot;&quot;)) &amp;&amp; (!pBarJudg.trim().equals(&quot;N&quot;))) {&#9;&#10;        &#9;&#10;&#9; logger.info(&quot;Bar Judgment for &quot; + function_name + &quot; = N&quot;);&#10;       &#9;return &quot;N&quot;;&#10;       } else {&#10;&#9; logger.info(&quot;Bar Judgment for &quot; + function_name + &quot; = Y&quot;);&#10;       &#9;return &quot;Y&quot;;&#10;       }&#10;    }"/>
                    <pl:application-data name="description" type="property" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value=""/>
                </pl:application-data>
                <pl:application-data name="determineCasePartyNumberForJudgment" type="function" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value="">
                    <pl:application-data name="type" type="property" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value="beanshell"/>
                    <pl:application-data name="methodName" type="property" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value="determineCasePartyNumberForJudgment"/>
                    <pl:application-data name="category" type="property" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value="Miscellaneous"/>
                    <pl:application-data name="script" type="property" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value="import org.apache.log4j.Logger;&#10;&#10;String determineCasePartyNumberForJudgment(String pEvent, String pParty)&#10;    {&#10;        Logger logger = Logger.getLogger(&quot;com.info&quot;);&#10;        String function_name = &quot;determineCasePartyNumberForJudgment&quot;;&#10;&#10;        if(pEvent != null &amp;&amp; (!pEvent.trim().equals(&quot;&quot;)) &amp;&amp; (!pEvent.trim().equals(&quot;0&quot;)) &amp;&amp; pParty != null &amp;&amp; (!pParty.trim().equals(&quot;&quot;)) &amp;&amp; (pParty.trim().equals(&quot;DEFENDANT&quot;))) {&#9;&#10;        &#9;&#10;&#9; logger.info(&quot;Event Party Role Code for &quot; + function_name + &quot; , is Claimant&quot;);&#10;       &#9; return &quot;1&quot;;&#10;        } else {&#10; &#9; logger.info(&quot;Event Party Role Code for &quot; + function_name + &quot; , is Defendant&quot;);&#10;       &#9; return pEvent;&#10;       }&#10;    }"/>
                    <pl:application-data name="description" type="property" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value=""/>
                </pl:application-data>
                <pl:application-data name="determineCasePartyRoleForJudgment" type="function" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value="">
                    <pl:application-data name="type" type="property" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value="beanshell"/>
                    <pl:application-data name="methodName" type="property" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value="determineCasePartyRoleForJudgment"/>
                    <pl:application-data name="category" type="property" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value="Miscellaneous"/>
                    <pl:application-data name="script" type="property" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value="import org.apache.log4j.Logger;&#10;&#10;String determineCasePartyRoleForJudgment(String pEvent, String pParty)&#10;    {&#10;        Logger logger = Logger.getLogger(&quot;com.info&quot;);&#10;        String function_name = &quot;determineCasePartyRoleForJudgment&quot;;&#10;&#10;        if(pEvent != null &amp;&amp; (!pEvent.trim().equals(&quot;&quot;)) &amp;&amp; (!pEvent.trim().equals(&quot;0&quot;)) &amp;&amp; pParty != null &amp;&amp; (!pParty.trim().equals(&quot;&quot;)) &amp;&amp; (pParty.trim().equals(&quot;DEFENDANT&quot;))) {&#9;&#10;        &#9;&#10;&#9; logger.info(&quot;Event Party Role Code for &quot; + function_name + &quot; , is Claimant&quot;);&#10;&#9; return &quot;CLAIMANT&quot;;&#10;        } else {&#10; &#9; logger.info(&quot;Event Party Role Code for &quot; + function_name + &quot; , is Defendant&quot;);&#10;       &#9; return &quot;DEFENDANT&quot;;&#10;       }&#10;    }"/>
                    <pl:application-data name="description" type="property" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value=""/>
                </pl:application-data>
                <pl:application-data name="determineCasePartyNumberInFavourParty" type="function" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value="">
                    <pl:application-data name="type" type="property" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value="beanshell"/>
                    <pl:application-data name="methodName" type="property" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value="determineCasePartyNumberInFavourParty"/>
                    <pl:application-data name="category" type="property" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value="Miscellaneous"/>
                    <pl:application-data name="script" type="property" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value="import org.apache.log4j.Logger;&#10;&#10;String determineCasePartyNumberInFavourParty(String pEvent, String pParty)&#10;    {&#10;        Logger logger = Logger.getLogger(&quot;com.info&quot;);&#10;        String function_name = &quot;determineCasePartyNumberInFavourParty&quot;;&#10;&#10;        if(pEvent != null &amp;&amp; (!pEvent.trim().equals(&quot;&quot;)) &amp;&amp; (!pEvent.trim().equals(&quot;0&quot;)) &amp;&amp; pParty != null &amp;&amp; (!pParty.trim().equals(&quot;&quot;)) &amp;&amp; (pParty.trim().equals(&quot;DEFENDANT&quot;))) {&#9;&#10;        &#9;&#10;&#9; logger.info(&quot;Event Party Role Code for &quot; + function_name + &quot; , is Defendant&quot;);&#10;       &#9; return pEvent;&#10;        } else {&#10; &#9; logger.info(&quot;Event Party Role Code for &quot; + function_name + &quot; , is Claimant&quot;);&#10;       &#9; return &quot;1&quot;;&#10;       }&#10;    }"/>
                    <pl:application-data name="description" type="property" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value=""/>
                </pl:application-data>
                <pl:application-data name="determineCasePartyRoleInFavourParty" type="function" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value="">
                    <pl:application-data name="type" type="property" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value="beanshell"/>
                    <pl:application-data name="methodName" type="property" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value="determineCasePartyRoleInFavourParty"/>
                    <pl:application-data name="category" type="property" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value="Miscellaneous"/>
                    <pl:application-data name="script" type="property" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value="import org.apache.log4j.Logger; &#10;    &#10;String determineCasePartyRoleInFavourParty(String pParty)&#10;    {&#10;        Logger logger = Logger.getLogger(&quot;com.info&quot;);&#10;        String function_name = &quot;determineCasePartyRoleInFavourParty&quot;;&#10;&#10;        if(pParty != null &amp;&amp; (!pParty.trim().equals(&quot;&quot;)) &amp;&amp; (pParty.trim().equals(&quot;DEFENDANT&quot;))) {&#9;&#10;        &#9;&#10;&#9; logger.info(&quot;Event Party Role Code for &quot; + function_name + &quot; , is Defendant&quot;);&#10;       &#9; return &quot;DEFENDANT&quot;;&#10;        } else {&#10; &#9;logger.info(&quot;Event Party Role Code for &quot; + function_name + &quot; , is Claimant&quot;);&#10;       &#9;return &quot;CLAIMANT&quot;;&#10;       }&#10;    }"/>
                    <pl:application-data name="description" type="property" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value=""/>
                </pl:application-data>
                <pl:application-data name="determinePreviousCourtID" type="function" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value="">
                    <pl:application-data name="type" type="property" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value="beanshell"/>
                    <pl:application-data name="methodName" type="property" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value="determinePreviousCourtID"/>
                    <pl:application-data name="category" type="property" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value="Miscellaneous"/>
                    <pl:application-data name="script" type="property" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value="import org.apache.log4j.Logger;&#10;&#10;String determinePreviousCourtID(String pCourtID, String pTransCourtID)&#10;    {&#10;        Logger logger = Logger.getLogger(&quot;com.info&quot;);&#10;        String function_name = &quot;determinePreviousCourtID&quot;;&#10;&#10;        if(pCourtID != null &amp;&amp; (!pCourtID.trim().equals(&quot;&quot;))) {&#9;&#10;        &#9;&#10;&#9; logger.info(&quot;Previous CourtID for &quot; + function_name + &quot; = &quot;);&#10;       &#9;return pCourtID;&#10;       } else {&#10;&#9; logger.info(&quot;Bar Judgment for &quot; + function_name + &quot; = Y&quot;);&#10;       &#9;return pTransCourtID;&#10;       }&#10;    }"/>
                    <pl:application-data name="description" type="property" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value=""/>
                </pl:application-data>
                <pl:application-data name="determinePartyRoleCodeForRep" type="function" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value="">
                    <pl:application-data name="type" type="property" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value="beanshell"/>
                    <pl:application-data name="methodName" type="property" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value="determinePartyRoleCodeForRep"/>
                    <pl:application-data name="category" type="property" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value="Miscellaneous"/>
                    <pl:application-data name="script" type="property" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value="import org.apache.log4j.Logger;&#10;&#10;String determinePartyRoleCodeForRep(String pAddressLine)&#10;    {&#10;        Logger logger = Logger.getLogger(&quot;com.info&quot;);&#10;        String function_name = &quot;determinePartyRoleCodeForRep&quot;;&#10;&#10;        if(pAddressLine != null &amp;&amp; (!pAddressLine.trim().equals(&quot;&quot;))) {&#9;&#10;        &#9;&#10;&#9; logger.info(&quot;Party Role Code for &quot; + function_name + &quot; , is Solictor&quot;);&#10;       &#9;  return &quot;SOLICITOR&quot;;&#10;       } else {&#10;&#9; logger.info(&quot;Party Role Code for &quot; + function_name + &quot; , is Null&quot;);&#10;&#9; return &quot;&quot;;&#10;        }&#10;    }"/>
                    <pl:application-data name="description" type="property" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value=""/>
                </pl:application-data>
                <pl:application-data name="determineNationalCodedPartyCodeForRep" type="function" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value="">
                    <pl:application-data name="type" type="property" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value="beanshell"/>
                    <pl:application-data name="methodName" type="property" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value="determineNationalCodedPartyCodeForRep"/>
                    <pl:application-data name="category" type="property" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value="Miscellaneous"/>
                    <pl:application-data name="script" type="property" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value="import org.apache.log4j.Logger;&#10;&#10;&#10;String determineNationalCodedPartyCodeForRep(String pCode)&#10;    {&#10;        Logger logger = Logger.getLogger(&quot;com.info&quot;);&#10;        String function_name = &quot;determineNationalCodedPartyCodeForRep&quot;;&#10;&#10;        if(pCode != null &amp;&amp; (!pCode.trim().equals(&quot;&quot;)) &amp;&amp; (Integer.parseInt(pCode) &gt;= 1500 &amp;&amp; Integer.parseInt(pCode) &lt;= 2000)) {&#9;&#10;        &#9;&#10;&#9; logger.info(&quot;Coded Party Rep Code for &quot; + function_name + &quot; , &quot; +pCode);&#10;       &#9;  return pCode;&#10;       } else {&#10;&#9; logger.info(&quot;Coded Party Rep Code for &quot; + function_name + &quot; , is Null&quot;);&#10;&#9; return &quot;&quot;;&#10;        }&#10;    }"/>
                    <pl:application-data name="description" type="property" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value=""/>
                </pl:application-data>
                <pl:application-data name="retrieveExclusionDates" type="function" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value="">
                    <pl:application-data name="type" type="property" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value="beanshell"/>
                    <pl:application-data name="methodName" type="property" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value="retrieveExclusionDates"/>
                    <pl:application-data name="category" type="property" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value="Miscellaneous"/>
                    <pl:application-data name="script" type="property" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value="import java.lang.StringBuffer;&#10;import org.apache.log4j.Logger;&#10;&#10;String retrieveExclusionDates(String[] pDates)&#10;    {&#10;        Logger logger = Logger.getLogger(&quot;com.info&quot;);&#10;        String function_name = &quot;retrieveExclusionDates&quot;;&#10;        logger.info(&quot;Starting Processing ExclusionsDates for &quot; + function_name);&#10;        String dateStr;&#10;        StringBuffer strBuf = new StringBuffer(&quot; &quot;);&#10;&#9;    &#10;        if(pDates != null &amp;&amp; (pDates.length &gt; 0)) {&#9;&#10;        &#9;for (int i=0; i &lt; pDates.length; i++) {&#10;        &#9;    dateStr = pDates[i];&#10;        &#9;    if(dateStr != null &amp;&amp; (!dateStr.equals(&quot;&quot;))) {&#10;        &#9;        strBuf.append(dateStr);&#10;           &#9;        strBuf.append(&quot;&quot;);&#10;        &#9;    }&#10;        &#9;    &#10;        &#9;}&#10;&#9; logger.info(&quot;ExclusionsDates for &quot; + function_name + &quot; ,have been returned as &quot; + strBuf.toString());&#10;       &#9;  return strBuf.toString();&#10;       } else {&#10;&#9; logger.info(&quot;ExclusionsDates for for &quot; + function_name + &quot; , is Empty&quot;);&#10;&#9; return &quot;&quot;;&#10;        }&#10;    }"/>
                    <pl:application-data name="description" type="property" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value=""/>
                </pl:application-data>
                <pl:application-data name="concatWFTData" type="function" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value="">
                    <pl:application-data name="type" type="property" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value="beanshell"/>
                    <pl:application-data name="methodName" type="property" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value="concatWFTData"/>
                    <pl:application-data name="category" type="property" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value="Miscellaneous"/>
                    <pl:application-data name="script" type="property" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value="import org.apache.log4j.Logger;&#10;&#10;String concatWFTData(String pWFTData, String pWFTDataComplete)&#10;    {&#10;        Logger logger = Logger.getLogger(&quot;com.info&quot;);&#10;        String function_name = &quot;concatWFTData&quot;;&#10;&#10;        if(pWFTData != null &amp;&amp; (!pWFTData.trim().equals(&quot;&quot;)) &amp;&amp; pWFTDataComplete != null) {&#10;        &#9;&#10;&#9; logger.info(&quot;WFTDataComplete and WFTData for &quot; + function_name + &quot; , &quot; +pWFTDataComplete+pWFTData);&#10;       &#9;return pWFTDataComplete+pWFTData;&#10;       } else if (pWFTData != null &amp;&amp; (!pWFTData.trim().equals(&quot;&quot;)) &amp;&amp; pWFTDataComplete == null) {&#10;&#9; logger.info(&quot;pWFTDataComplete is null and WFTData for &quot; + function_name + &quot; , &quot; + pWFTData);&#10;       &#9;return pWFTData;&#10;       } else if (pWFTData != null &amp;&amp; pWFTDataComplete != null) {&#10;&#9; logger.info(&quot;WFTData is not null but empty and WFTDataComplete for &quot; + function_name + &quot; , &quot; + pWFTData);&#10;       &#9;return pWFTDataComplete;&#10;       } else if (pWFTData == null &amp;&amp; pWFTDataComplete != null) {&#10;&#9; logger.info(&quot;WFTData is null and WFTDataComplete for &quot; + function_name + &quot; , &quot; + pWFTData);&#10;       &#9;return pWFTDataComplete;     &#9;      &#9;&#10;       } else {&#10;&#9; logger.info(&quot;WFTDataComplete is empty  for &quot; + function_name);&#10;       &#9;return &quot;&quot;;&#10;       }&#10;    }"/>
                    <pl:application-data name="description" type="property" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value=""/>
                </pl:application-data>
            </pl:application-data>
            <pl:application-data name="Initial Contexts" type="initialcontexts" application="com.polarlake.platform.librarymodule.LibraryModuleApplication"/>
            <pl:application-data name="Scripts" type="scripts" application="com.polarlake.platform.librarymodule.LibraryModuleApplication">
                <pl:application-data name="Document Logger Error Case-Sups - Caseman" type="script" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value="">
                    <pl:application-data name="url" type="property" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value=""/>
                    <pl:application-data name="remote" type="property" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value="false"/>
                    <pl:application-data name="type" type="property" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value="beanshell"/>
                    <pl:application-data name="cache" type="property" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value="never_resolve"/>
                    <pl:application-data name="script" type="property" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value="import org.apache.log4j.Logger;&#10;import org.jdom.*;  &#10;import org.jdom.input.*;  &#10;import org.jdom.output.*;  &#10;import com.polarlake.platform.api.*;  &#10;import com.polarlake.platform.api.helper.*;  &#10;import com.polarlake.platform.api.exception.*;  &#10;  &#10;/**  &#10; * A JDOM beanshell must return a JDOM document.  &#10; */  &#10; Document processDocument(Document doc, ExecutiveProcessInterface process) &#10; { &#10;&#10;   try &#10;   { &#10;      VariableContainerInterface vci = process.getProcessDocGroup(); &#10;      if (vci != null) &#10;      { &#10;        VariableInterface vi = vci.getVariable(&quot;Case-Sups&quot;); &#10;        Document doc = (Document)vi.getValue(); &#10;        XMLOutputter xo = new XMLOutputter(Format.getPrettyFormat());&#10;        Logger logger = Logger.getRootLogger();&#10;        logger.error(xo.outputString(doc));&#10;     } &#10;  } &#10;  catch (DocVariableException dve) &#10;  { &#10;    /* do nothing */ &#10;   } &#10;      return doc;&#9;&#10;} &#10;"/>
                    <pl:application-data name="description" type="property" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value="A PolarLake Platform Beanshell script must be coded to return a JDOM document.They can be composed from calls to imported modules as well as local methods.Only the first method in the script will be executed, so it should make any appropriate method calls if the entire script is not contained in it."/>
                </pl:application-data>
                <pl:application-data name="Process Doc Logger Error - Caseman" type="script" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value="">
                    <pl:application-data name="url" type="property" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value=""/>
                    <pl:application-data name="remote" type="property" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value="false"/>
                    <pl:application-data name="type" type="property" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value="beanshell"/>
                    <pl:application-data name="cache" type="property" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value="never_resolve"/>
                    <pl:application-data name="script" type="property" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value="import org.apache.log4j.Logger;&#10;import org.jdom.*;  &#10;import org.jdom.input.*;  &#10;import org.jdom.output.*;  &#10;import com.polarlake.platform.api.*;  &#10;import com.polarlake.platform.api.helper.*;  &#10;import com.polarlake.platform.api.exception.*;  &#10;import com.polarlake.platform.common.ParameterName;&#10;  &#10;/**  &#10; * A JDOM beanshell must return a JDOM document.  &#10; */  &#10; Document processDocument(Document doc, ExecutiveProcessInterface process) &#10; { &#10;       XMLOutputter xo = new XMLOutputter(Format.getPrettyFormat());&#10;       Logger logger = Logger.getLogger(&quot;com.error&quot;);&#10;&#10;       String processCaseName = Util.getProcessVariable (process, new ParameterName(&quot;court_code&quot;));&#10;       String processCircuitName = Util.getProcessVariable (process, new ParameterName(&quot;CircuitName&quot;));&#10;       logger.error(&quot;\n&quot; +&#10;     &quot;Error in Caseman Transfer Script Printing Xml Doc in Circuit = &quot; +  &#10;      processCircuitName +&#10;      &quot;\n For CaseNumber = &quot; +&#9;&#10;       processCaseName+ &#10;       &quot;\n&quot;+ &#10;       xo.outputString(doc));&#10;      return doc;&#9;&#10;} &#10;"/>
                    <pl:application-data name="description" type="property" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value="A PolarLake Platform Beanshell script must be coded to return a JDOM document.They can be composed from calls to imported modules as well as local methods.Only the first method in the script will be executed, so it should make any appropriate method calls if the entire script is not contained in it."/>
                </pl:application-data>
                <pl:application-data name="Process Doc Logger Debug - Caseman" type="script" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value="">
                    <pl:application-data name="url" type="property" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value=""/>
                    <pl:application-data name="remote" type="property" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value="false"/>
                    <pl:application-data name="type" type="property" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value="beanshell"/>
                    <pl:application-data name="cache" type="property" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value="never_resolve"/>
                    <pl:application-data name="script" type="property" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value="import org.apache.log4j.Logger;&#10;import org.jdom.*;  &#10;import org.jdom.input.*;  &#10;import org.jdom.output.*;  &#10;import com.polarlake.platform.api.*;  &#10;import com.polarlake.platform.api.helper.*;  &#10;import com.polarlake.platform.api.exception.*;  &#10;import com.polarlake.platform.common.ParameterName;&#10;  &#10;/**  &#10; * A JDOM beanshell must return a JDOM document.  &#10; */  &#10; Document processDocument(Document doc, ExecutiveProcessInterface process) &#10; { &#10;       XMLOutputter xo = new XMLOutputter(Format.getPrettyFormat());&#10;       Logger logger = Logger.getLogger(&quot;com.debug&quot;);&#10;&#10;       String processCaseName = Util.getProcessVariable (process, new ParameterName(&quot;court_code&quot;));&#10;       String processCircuitName = Util.getProcessVariable (process, new ParameterName(&quot;CircuitName&quot;));&#10;&#10;      logger.debug(&quot;\n&quot; +&#10;     &quot;Debug in Caseman Transfer Script Printing Xml Doc in Circuit = &quot; +  &#10;      processCircuitName +&#10;      &quot;\n For CaseNumber = &quot; +&#9;&#10;       processCaseName+ &#10;       &quot;\n&quot;+ &#10;       xo.outputString(doc));&#10;      return doc;&#9;&#10;} &#10;"/>
                    <pl:application-data name="description" type="property" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value="A PolarLake Platform Beanshell script must be coded to return a JDOM document.They can be composed from calls to imported modules as well as local methods.Only the first method in the script will be executed, so it should make any appropriate method calls if the entire script is not contained in it."/>
                </pl:application-data>
                <pl:application-data name="Process Doc Logger Info - Caseman" type="script" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value="">
                    <pl:application-data name="url" type="property" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value=""/>
                    <pl:application-data name="remote" type="property" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value="false"/>
                    <pl:application-data name="type" type="property" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value="beanshell"/>
                    <pl:application-data name="cache" type="property" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value="never_resolve"/>
                    <pl:application-data name="script" type="property" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value="import org.apache.log4j.Logger;&#10;import org.jdom.*;  &#10;import org.jdom.input.*;  &#10;import org.jdom.output.*;  &#10;import com.polarlake.platform.api.*;  &#10;import com.polarlake.platform.api.helper.*;  &#10;import com.polarlake.platform.api.exception.*;  &#10;import com.polarlake.platform.common.ParameterName;&#10;  &#10;/**  &#10; * A JDOM beanshell must return a JDOM document.  &#10; */  &#10; Document processDocument(Document doc, ExecutiveProcessInterface process) &#10; { &#10;       XMLOutputter xo = new XMLOutputter(Format.getPrettyFormat());&#10;       Logger logger = Logger.getLogger(&quot;com.info&quot;);&#10;&#10;       String processCaseName = Util.getProcessVariable (process, new ParameterName(&quot;court_code&quot;));&#10;&#10;       String processCircuitName = Util.getProcessVariable (process, new ParameterName(&quot;CircuitName&quot;));&#10;&#10;       logger.info(&quot;\n&quot; +&#10;     &quot;In Caseman Transfer Script Printing Xml Doc in Circuit = &quot; +  &#10;      processCircuitName +&#10;      &quot;\n For CaseNumber = &quot; +&#9;&#10;       processCaseName+ &#10;       &quot;\n&quot;+ &#10;       xo.outputString(doc));&#10;      return doc;&#9;&#10;} &#10;"/>
                    <pl:application-data name="description" type="property" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value="A PolarLake Platform Beanshell script must be coded to return a JDOM document.They can be composed from calls to imported modules as well as local methods.Only the first method in the script will be executed, so it should make any appropriate method calls if the entire script is not contained in it."/>
                </pl:application-data>
                <pl:application-data name="JDom Processing" type="script" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value="">
                    <pl:application-data name="url" type="property" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value=""/>
                    <pl:application-data name="remote" type="property" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value="false"/>
                    <pl:application-data name="type" type="property" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value="beanshell"/>
                    <pl:application-data name="cache" type="property" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value="never_resolve"/>
                    <pl:application-data name="script" type="property" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value="import org.jdom.*;&#10;import org.jdom.input.*;&#10;import org.jdom.output.*;&#10;import com.polarlake.platform.api.*;&#10;import com.polarlake.platform.api.helper.*;&#10;import com.polarlake.platform.api.exception.*;&#10;&#10;/**&#10; * A JDOM beanshell must return a JDOM document.&#10; */&#10;Document processDocument(Document doc) {&#10;&#10;   return doc;&#10;}"/>
                    <pl:application-data name="description" type="property" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value="This returns the empty doc without doing anything."/>
                </pl:application-data>
                <pl:application-data name="Process Doc Logger Fatal - Caseman" type="script" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value="">
                    <pl:application-data name="url" type="property" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value=""/>
                    <pl:application-data name="remote" type="property" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value="false"/>
                    <pl:application-data name="type" type="property" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value="beanshell"/>
                    <pl:application-data name="cache" type="property" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value="never_resolve"/>
                    <pl:application-data name="script" type="property" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value="import org.apache.log4j.Logger;&#10;import org.jdom.*;  &#10;import org.jdom.input.*;  &#10;import org.jdom.output.*;  &#10;import com.polarlake.platform.api.*;  &#10;import com.polarlake.platform.api.helper.*;  &#10;import com.polarlake.platform.api.exception.*;  &#10;import com.polarlake.platform.common.ParameterName;&#10;  &#10;/**  &#10; * A JDOM beanshell must return a JDOM document.  &#10; */  &#10; Document processDocument(Document doc, ExecutiveProcessInterface process) &#10; { &#10;       XMLOutputter xo = new XMLOutputter(Format.getPrettyFormat());&#10;       Logger logger = Logger.getLogger(&quot;com.fatal&quot;);&#10;&#10;       String processCaseName = Util.getProcessVariable (process, new ParameterName(&quot;court_code&quot;));&#10;       String processCircuitName = Util.getProcessVariable (process, new ParameterName(&quot;CircuitName&quot;));&#10;       logger.error(&quot;\n&quot; +&#10;     &quot;Fatal Error in Caseman Transfer Script Printing Xml Doc in Circuit = &quot; +  &#10;      processCircuitName +&#10;      &quot;\n For CaseNumber = &quot; +&#9;&#10;       processCaseName+ &#10;       &quot;\n&quot;+ &#10;       xo.outputString(doc));&#10;      return doc;&#9;&#10;} &#10;"/>
                    <pl:application-data name="description" type="property" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value="A PolarLake Platform Beanshell script must be coded to return a JDOM document.They can be composed from calls to imported modules as well as local methods.Only the first method in the script will be executed, so it should make any appropriate method calls if the entire script is not contained in it."/>
                </pl:application-data>
            </pl:application-data>
