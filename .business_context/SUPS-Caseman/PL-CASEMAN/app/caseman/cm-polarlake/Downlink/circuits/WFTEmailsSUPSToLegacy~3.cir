                        </pl:parameter>
                        <pl:parameter name="[0]/aa:parameters/aa:param1/text()">
                            <pl:parameter name="main">
                                <pl:parameter name="nocontext">
                                    <pl:parameter name="function-id" value="2"/>
                                    <pl:parameter name="name" value="identity"/>
