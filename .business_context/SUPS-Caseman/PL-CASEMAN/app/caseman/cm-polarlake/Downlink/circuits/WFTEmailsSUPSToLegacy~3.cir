        <pl:seqlist name="Retrieve WFT Data Previous Court Sequence">
            <pl:eventprocessor name="pl:printmessage" disable="false">
                <pl:parameter name="design">
                    <pl:parameter name="uid" value="1405"/>
                    <pl:parameter name="alias" value="Print Message"/>
                </pl:parameter>
                <pl:parameter name="trigger" value="start"/>
                <pl:parameter name="message" value="- &#10;--&gt; Retrieve WFT Data for {$TableName} Number = {$case_number-complex} &#10;--&gt; SEQUENCE - Retrieve WFT Data Previous Court Sequence&#10;--&gt; VIEW - Retrieve WFT Data Previous Court View&#10;--&gt; CIRCUIT - {$CircuitName}&#10;----------------------------------------------------------------------------------"/>
                <pl:parameter name="use_log4j" value="true"/>
                <pl:parameter name="log_level" value="INFO"/>
            </pl:eventprocessor>
            <pl:eventprocessor name="pl:sqltoxml" disable="false">
                <pl:parameter name="design">
                    <pl:parameter name="uid" value="1406"/>
                    <pl:parameter name="alias" value="DB SQL - Retrieve WFT Data"/>
                </pl:parameter>
                <pl:parameter name="transaction_key" value="Second"/>
                <pl:parameter name="sql" value="select &#10;&apos;1,0&apos;||chr(13) a,&#10;&apos;&quot;&apos;||w.WFT_CASE_NUMBER||&apos;&quot;&apos;||chr(13) a,&#10;&apos;1,0&apos;||chr(13) a,&#10;&apos;&quot;&apos;||(Select dc.PERSON_REQUESTED_NAME from PARTIES dc, WINDOW_FOR_TRIAL wc, CASE_PARTY_ROLES cpc, COURTS coc&#10;where wc.WFT_EXTRACTED_FOR_DM is null&#10;and   wc.WFT_CASE_NUMBER&#9;= cpc.CASE_NUMBER&#10;and   wc.WFT_CASE_NUMBER&#9;= w.WFT_CASE_NUMBER&#10;and   wc.WFT_ID&#9;&#9;&#9;= w.WFT_ID&#10;and   dc.PARTY_ID&#9;&#9;= cpc.PARTY_ID&#10;and   cpc.PARTY_ROLE_CODE&#9;= &apos;CLAIMANT&apos;&#10;and   cpc.CASE_PARTY_NO&#9;&#9;= 1&#10;and   wc.WFT_PREVIOUS_COURT       = coc.CODE&#10;and   wc.WFT_PREVIOUS_COURT&#9;= ?)||&apos;&quot;&apos;||chr(13) a,&#10;&apos;1,0&apos;||chr(13) a,&#10;&apos;&quot;&apos;||(Select dc.PERSON_REQUESTED_NAME from PARTIES dc, WINDOW_FOR_TRIAL wc, CASE_PARTY_ROLES cpc, COURTS coc&#10;where wc.WFT_EXTRACTED_FOR_DM is null&#10;and   wc.WFT_CASE_NUMBER&#9;= cpc.CASE_NUMBER&#10;and   wc.WFT_CASE_NUMBER&#9;= w.WFT_CASE_NUMBER&#10;and   wc.WFT_ID&#9;&#9;&#9;= w.WFT_ID&#10;and   dc.PARTY_ID&#9;&#9;= cpc.PARTY_ID&#10;and   cpc.PARTY_ROLE_CODE&#9;= &apos;DEFENDANT&apos;&#10;and   cpc.CASE_PARTY_NO&#9;&#9;= 1&#10;and   wc.WFT_PREVIOUS_COURT       = coc.CODE&#10;and   wc.WFT_PREVIOUS_COURT&#9;= ?)||&apos;&quot;&apos;||chr(13) a,&#10;&apos;1,0&apos;||chr(13) a,&#10;&apos;&quot;&apos;||decode(w.WFT_TRACK,&apos;MULTI&apos;,&apos;Multi&apos;,&apos;FAST&apos;,&apos;Fast&apos;,w.WFT_TRACK)||&apos;&quot;&apos;||chr(13) a,&#10;&apos;0,&apos;||to_char(w.WFT_ESTIMATED_DAYS)||chr(13) a,&#10;&apos;V&apos;||chr(13) a,&#10;&apos;0,&apos;||to_char(w.WFT_ESTIMATED_HOURS)||chr(13) a,&#10;&apos;V&apos;||chr(13) a,&#10;&apos;0,&apos;||to_char(w.WFT_ESTIMATED_MINS)||chr(13) a,&#10;&apos;V&apos;||chr(13) a,&#10;&apos;0,&apos;||to_char(w.WFT_START_DATE,&apos;DD/MM/YYYY&apos;)||chr(13) a,&#10;&apos;V&apos;||chr(13) a,&#10;&apos;0,&apos;||to_char(w.WFT_END_DATE,&apos;DD/MM/YYYY&apos;)||chr(13) a,&#10;&apos;V&apos;||chr(13) a,&#10;&apos;1,0&apos;||chr(13) a,&#10;&apos;&quot;&apos;||co.NAME||&apos;&quot;&apos;||chr(13) a,&#10;&apos;1,0&apos;||chr(13) a,&#10;&apos;&quot;&apos;||?||&apos;&quot;&apos;||chr(13) a,&#10;&apos;0,&apos;||to_char(w.WFT_OUTCOME_DATE,&apos;DD/MM/YYYY&apos;)||chr(13) a,&#10;&apos;V&apos;||chr(13) a,&#10;&apos;1,0&apos;||chr(13) a, &#10;&apos;&quot;&apos;||w.WFT_JUDGES_NAME||&apos;&quot;&apos;||chr(13) a,&#10;&apos;1,0&apos;||chr(13) a, &#10;&apos;&quot;&apos;||w.WFT_REASON_FOR_ADJ||&apos;&quot;&apos;||chr(13) a,&#10;&apos;1,0&apos;||chr(13) a,&#10;&apos;&quot;&apos;||w.WFT_CASE_MANAGE_CONF_FLAG||&apos;&quot;&apos;||chr(13) a,&#10;&apos;0,&apos;||to_char(w.WFT_CASE_MANAGE_CONF_DATE,&apos;DD/MM/YYYY&apos;)||chr(13) a,&#10;&apos;V&apos;||chr(13) a,&#10;&apos;1,0&apos;||chr(13) a,&#10;&apos;&quot;&apos;||w.WFT_NOTES||&apos;&quot;&apos;||chr(13) a,&#10;&apos;1,0&apos;||chr(13) a,&#10;&apos;&quot;&apos;||?||&apos;&quot;&apos;||chr(13) a,&#10;&apos;-1,0&apos;||chr(13) a,&#10;&apos;BOT&apos;||chr(13) a&#10;from  WINDOW_FOR_TRIAL w, COURTS co&#10;where w.WFT_EXTRACTED_FOR_DM is null&#10;and   w.WFT_PREVIOUS_COURT       = co.CODE&#10;and   w.WFT_PREVIOUS_COURT&#9;= ?&#10;and   w.WFT_CASE_NUMBER = ?&#10;and   w.WFT_ID = ?&#10;order by w.WFT_CASE_NUMBER, w.WFT_ID"/>
                <pl:parameter name="forward_option" value="0"/>
                <pl:parameter name="sqlwarntoerror" value="false"/>
                <pl:parameter name="query" value="true"/>
                <pl:parameter name="input_mappings">
                    <pl:parameter name="input schemas">
                        <pl:parameter name="0">
                            <pl:parameter name="expand">
