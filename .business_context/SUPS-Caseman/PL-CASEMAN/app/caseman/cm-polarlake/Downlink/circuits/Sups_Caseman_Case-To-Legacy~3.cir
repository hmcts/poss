                    <pl:parameter name="output schemas">
                        <pl:parameter name="0">
                            <pl:parameter name="root" value="/Judgments"/>
                            <pl:parameter name="schema" value="legacy_judgment"/>
                            <pl:parameter name="using" value="."/>
