&#9;&#9;&#9;AND &#9;AEA.PARTY_AGAINST_CASE_PARTY_NO = 1 AND AEA.PARTY_AGAINST_PARTY_ROLE_CODE = &apos;CLAIMANT&apos;) &#10;&#9;&#9;&#9;UNION&#10;&#9;&#9;&#9;(SELECT GA.CASE_NUMBER AS &quot;GA.DEFT_CASE_NUMBER&quot;&#10;&#9;&#9;, &#9;GA.ADDRESS_ID AS &quot;GA.ADDRESS_ID&quot;&#10;&#9;       &#9;, &#9;AEA.PARTY_AGAINST_CASE_PARTY_NO AS &quot;GA.DEFT_ID&quot;&#10;&#9;        &#9;,   &#9;GA.COURT_CODE AS &quot;GA.COURT_CODE&quot;&#10;&#9;        &#9;,&#9;GA.ADDRESS_TYPE_CODE AS &quot;GA.ADDRESS_TYPE_CODE&quot;&#10;&#9;       &#9;,&#9;SUBSTR(GA.ADDRESS_LINE1, 1, 30)   AS &quot;GA.ADDRESS_LINE1&quot;&#10;&#9;&#9;&#9;,      SUBSTR(GA.ADDRESS_LINE2, 1, 30)   AS &quot;GA.ADDRESS_LINE2&quot;&#10;&#9;&#9;&#9;,      SUBSTR(GA.ADDRESS_LINE3, 1, 30)   AS &quot;GA.ADDRESS_LINE3&quot;&#10;&#9;&#9;&#9;,      SUBSTR(GA.ADDRESS_LINE4, 1, 30)   AS &quot;GA.ADDRESS_LINE4&quot;&#10;&#9;&#9;&#9;,      SUBSTR(GA.ADDRESS_LINE5, 1, 30)   AS &quot;GA.ADDRESS_LINE5&quot;&#10;&#9;&#9;&#9;,      GA.POSTCODE&#9;&#9;AS&#9;&quot;GA.POSTCODE&quot;&#10;&#9;&#9;&#9;,      GA.UPDATED_BY&#9;AS&#9;&quot;GA.UPDATED_BY&quot;&#10;&#9;&#9;&#9;,&#9;GA.VALID_FROM &#9;AS &#9;&quot;GA.VALID_FROM&quot;&#10;&#9;&#9;&#9;,&#9;GA.VALID_TO &#9;AS &#9;&quot;GA.VALID_TO&quot;&#10;&#9;&#9;&#9;,      SUBSTR(P.DX_NUMBER, 1, 30)  AS &quot;P.DX_NUMBER&quot;&#10;&#9;&#9;&#9;,      P.TEL_NO                        AS &quot;P.TEL_NO&quot;&#10;&#9;&#9;&#9;,      P.PERSON_REQUESTED_NAME         AS &quot;P.PERSON_REQUESTED_NAME&quot;&#10;&#9;&#9;&#9;,      P.ORA_ROWSCN                    AS &quot;P_ORA_ROWSCN&quot;&#10;&#9;&#9;&#9;,      GA.ORA_ROWSCN                      AS &quot;GA_ORA_ROWSCN&quot;&#9;&#10;&#9;&#9;&#9;,      AEA.ORA_ROWSCN                      AS &quot;AEA_ORA_ROWSCN&quot;&#9;&#10;&#9;&#9;&#9;FROM   PARTIES          P&#10;&#9;&#9;&#9;,      GIVEN_ADDRESSES  GA&#10;&#9;&#9;&#9;, &#9;   AE_APPLICATIONS AEA&#10;&#9;&#9;&#9;WHERE   AEA.CASE_NUMBER  = ?&#10;&#9;&#9;&#9;AND &#9;GA.ADDRESS_TYPE_CODE = &apos;EMPLOYER&apos;&#10;&#9;&#9;&#9;AND &#9;AEA.DEBTORS_EMPLOYERS_PARTY_ID = P.PARTY_ID&#10;&#9;&#9;&#9;AND &#9;GA.PARTY_ID = P.PARTY_ID&#10;&#9;&#9;&#9;AND &#9;AEA.PARTY_AGAINST_CASE_PARTY_NO &lt;= 9 AND AEA.PARTY_AGAINST_PARTY_ROLE_CODE = &apos;DEFENDANT&apos;) "/>
