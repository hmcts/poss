                    <pl:parameter name="alias" value="DB SQL Claimant and Defendant Number Check"/>
                </pl:parameter>
                <pl:parameter name="transaction_key" value="First"/>
                <pl:parameter name="sql" value=" select count(case_number)&#10; from case_party_roles&#10; where case_number = ? and&#10; ((party_role_code = &apos;CLAIMANT&apos; and case_party_no &gt; 1) or&#10; (party_role_code = &apos;DEFENDANT&apos; and case_party_no &gt; 9))"/>
