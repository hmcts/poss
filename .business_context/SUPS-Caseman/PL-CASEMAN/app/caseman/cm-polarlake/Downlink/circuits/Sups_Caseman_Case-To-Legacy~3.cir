            <pl:eventprocessor name="pl:sqltoxml" disable="false">
                <pl:parameter name="design">
                    <pl:parameter name="uid" value="847"/>
                    <pl:parameter name="alias" value="DB SQL"/>
                </pl:parameter>
                <pl:parameter name="transaction_key" value="First"/>
                <pl:parameter name="sql" value="(select * from judgments j &#10;where j.case_number = ? &#10;and j.against_party_role_code = &apos;DEFENDANT&apos; &#10;and j.against_case_party_no &lt; 10 &#10;and NOT EXISTS (select null from infavour_parties ip &#10;where ip.judg_seq = j.judg_seq&#10;and ip.party_role_code = &apos;CLAIMANT&apos;&#10;and ip.case_party_no &gt; 1)) &#10;union&#10;(select * from judgments j&#10;where case_number = ? &#10;and against_party_role_code = &apos;CLAIMANT&apos; &#10;and against_case_party_no &lt; 2&#10;and NOT EXISTS (select null from infavour_parties ip &#10;where ip.judg_seq = j.judg_seq&#10;and ip.party_role_code = &apos;DEFENDANT&apos;&#10;and ip.case_party_no &gt; 9)) "/>
                <pl:parameter name="forward_option" value="0"/>
                <pl:parameter name="sqlwarntoerror" value="false"/>
                <pl:parameter name="query" value="true"/>
                <pl:parameter name="input_mappings">
