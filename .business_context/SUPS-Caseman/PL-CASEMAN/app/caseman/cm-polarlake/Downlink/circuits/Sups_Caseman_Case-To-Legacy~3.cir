        <pl:seqlist name="Defendant Solicitor Address Sequence">
            <pl:eventprocessor name="pl:printmessage" disable="false">
                <pl:parameter name="design">
                    <pl:parameter name="uid" value="719"/>
                    <pl:parameter name="alias" value="Print Message"/>
                </pl:parameter>
                <pl:parameter name="trigger" value="start"/>
                <pl:parameter name="message" value="-&#10;--&gt; Starting DB SQL select for Defendants Solicitor Address- Case Number = {$case_number-complex}&#10;--&gt; SEQUENCE - Defendant Address Sequence&#10;--&gt; VIEW - Defendant Address View&#10;--&gt; CIRCUIT - {$CircuitName}&#10;----------------------------------------------------------------------------------"/>
                <pl:parameter name="use_log4j" value="true"/>
                <pl:parameter name="log_level" value="INFO"/>
            </pl:eventprocessor>
            <pl:eventprocessor name="pl:sqltoxml" disable="false">
                <pl:parameter name="design">
                    <pl:parameter name="uid" value="717"/>
                    <pl:parameter name="alias" value="DB SQL"/>
                </pl:parameter>
                <pl:parameter name="transaction_key" value="First"/>
                <pl:parameter name="sql" value="(SELECT NULL                               AS &quot;CP.CODE&quot;&#10;&#9;&#9;,      CPR2CPR.CPR_A_CASE_PARTY_NO AS  &quot;CPR2CPR.CPR_A_CASE_PARTY_NO&quot;&#10;&#9;&#9;,      SOLP.PERSON_REQUESTED_NAME   AS &quot;SOLP.PERSON_REQUESTED_NAME&quot;&#10;&#9;&#9;,      SUBSTR(GA.ADDRESS_LINE1, 1, 30)   AS &quot;GA.ADDRESS_LINE1&quot;&#10;&#9;&#9;,      SUBSTR(GA.ADDRESS_LINE2, 1, 30)   AS &quot;GA.ADDRESS_LINE2&quot;&#10;&#9;&#9;,      SUBSTR(GA.ADDRESS_LINE3, 1, 30)   AS &quot;GA.ADDRESS_LINE3&quot;&#10;&#9;&#9;,      SUBSTR(GA.ADDRESS_LINE4, 1, 30)   AS &quot;GA.ADDRESS_LINE4&quot;&#10;&#9;&#9;,      SUBSTR(GA.ADDRESS_LINE5, 1, 30)   AS &quot;GA.ADDRESS_LINE5&quot;&#10;&#9;&#9;,      GA.POSTCODE                        AS &quot;GA.POSTCODE&quot;&#10;&#9;&#9;,      SOLP.TEL_NO                        AS &quot;SOLP.TEL_NO&quot;&#10;&#9;&#9;,      SUBSTR(SOLP.DX_NUMBER, 1, 30)  AS &quot;SOLP.DX_NUMBER&quot;&#10;&#9;&#9;,      CPR.ORA_ROWSCN                     AS &quot;CPR_ORA_ROWSCN&quot;&#10;&#9;&#9;,      SOLP.ORA_ROWSCN                    AS &quot;SOLP_ORA_ROWSCN&quot;&#10;&#9;&#9;,      NULL                               AS &quot;CP_ORA_ROWSCN&quot;&#10;&#9;&#9;,      GA.ORA_ROWSCN                      AS &quot;GA_ORA_ROWSCN&quot;&#10;&#9;&#9;,      CPR2CPR.ORA_ROWSCN                 AS &quot;CPR2CPR_ORA_ROWSCN&quot;&#10;&#9;&#9;,      CPR2CPR.PERSONAL_REFERENCE&#9;&#9;  AS &quot;CPR2CPR.PERSONAL_REFRENCE&quot;&#10;&#9;&#9;FROM   CASE_PARTY_ROLES CPR&#10;&#9;&#9;,      PARTIES          SOLP&#10;&#9;&#9;,      GIVEN_ADDRESSES  GA&#10;&#9;&#9;,      CPR_TO_CPR_RELATIONSHIP CPR2CPR&#10;&#9;&#9;WHERE  CPR.CASE_NUMBER = ?&#9;&#9;&#10;&#9;&#9;AND    CPR.PARTY_ROLE_CODE =&apos;SOLICITOR&apos;&#10;&#9;&#9;AND    SOLP.PARTY_ID = CPR.PARTY_ID&#10;&#9;&#9;AND    GA.CASE_NUMBER =  ?&#10;&#9;&#9;AND    GA.PARTY_ROLE_CODE =&apos;SOLICITOR&apos;&#10;&#9;&#9;AND    GA.CASE_PARTY_NO = CPR.CASE_PARTY_NO&#10;&#9;&#9;AND    GA.ADDRESS_TYPE_CODE = &apos;SOLICITOR&apos;&#10;&#9;&#9;AND    GA.VALID_TO IS NULL&#10;           AND    CPR2CPR.CPR_A_CASE_NUMBER =  ? &#10;           &#9;AND&#9;CPR.CASE_PARTY_NO = CPR2CPR.CPR_B_CASE_PARTY_NO&#10;&#9;&#9;AND    CPR2CPR.CPR_A_CASE_PARTY_NO = ?&#10;&#9;&#9;AND    CPR2CPR.CPR_A_PARTY_ROLE_CODE = &apos;DEFENDANT&apos;   &#10;&#9;&#9;AND    CPR2CPR.CPR_B_PARTY_ROLE_CODE = &apos;SOLICITOR&apos; &#10;&#9;&#9;AND    CPR2CPR.DELETED_FLAG = &apos;N&apos;) &#10;&#9;&#9;UNION (SELECT  CP.CODE                            AS &quot;CP.CODE&quot;&#10;&#9;    ,      CPR2CPR.CPR_A_CASE_PARTY_NO        AS  &quot;CPR2CPR.CPR_A_CASE_PARTY_NO&quot;&#10;&#9;&#9;,      SOLP.PERSON_REQUESTED_NAME         AS &quot;SOLP.PERSON_REQUESTED_NAME&quot;&#10;&#9;&#9;,      SUBSTR(GA.ADDRESS_LINE1, 1, 30)   AS &quot;GA.ADDRESS_LINE1&quot;&#10;&#9;&#9;,      SUBSTR(GA.ADDRESS_LINE2, 1, 30)   AS &quot;GA.ADDRESS_LINE2&quot;&#10;&#9;&#9;,      SUBSTR(GA.ADDRESS_LINE3, 1, 30)   AS &quot;GA.ADDRESS_LINE3&quot;&#10;&#9;&#9;,      SUBSTR(GA.ADDRESS_LINE4, 1, 30)   AS &quot;GA.ADDRESS_LINE4&quot;&#10;&#9;&#9;,      SUBSTR(GA.ADDRESS_LINE5, 1, 30)   AS &quot;GA.ADDRESS_LINE5&quot;&#10;&#9;&#9;,      GA.POSTCODE                        AS &quot;GA.POSTCODE&quot;&#10;&#9;&#9;,      SOLP.TEL_NO                        AS &quot;SOLP.TEL_NO&quot;&#10;&#9;&#9;,      SUBSTR(SOLP.DX_NUMBER, 1, 30)  AS &quot;SOLP.DX_NUMBER&quot;&#10;&#9;&#9;,      CPR.ORA_ROWSCN                     AS &quot;CPR_ORA_ROWSCN&quot;&#10;&#9;&#9;,      SOLP.ORA_ROWSCN                    AS &quot;SOLP_ORA_ROWSCN&quot;&#10;&#9;&#9;,      CP.ORA_ROWSCN                      AS &quot;CP_ORA_ROWSCN&quot;&#10;&#9;&#9;,      GA.ORA_ROWSCN                      AS &quot;GA_ORA_ROWSCN&quot;&#10;&#9;&#9;,      CPR2CPR.ORA_ROWSCN                 AS &quot;CPR2CPR_ORA_ROWSCN&quot;&#10;&#9;&#9;,      CPR2CPR.PERSONAL_REFERENCE&#9;&#9;  AS &quot;CPR2CPR.PERSONAL_REFRENCE&quot;&#10;&#9;&#9;FROM   CASE_PARTY_ROLES CPR&#10;&#9;&#9;,      PARTIES          SOLP&#10;&#9;&#9;,      CODED_PARTIES    CP&#10;&#9;&#9;,      GIVEN_ADDRESSES  GA&#10;&#9;&#9;,      CPR_TO_CPR_RELATIONSHIP CPR2CPR &#10;&#9;&#9;WHERE  CPR.CASE_NUMBER =  ?&#10;&#9;&#9;AND    CPR.PARTY_ROLE_CODE = &apos;SOLICITOR&apos; &#10;&#9;&#9;AND    SOLP.PARTY_ID = CPR.PARTY_ID &#10;&#9;&#9;AND    CP.PARTY_ID (+)= CPR.PARTY_ID &#10;&#9;&#9;AND    CP.ADMIN_COURT_CODE (+)= ?&#10;&#9;&#9;AND    GA.CASE_NUMBER IS NULL&#10;&#9;&#9;AND    GA.PARTY_ROLE_CODE IS NULL&#10;&#9;&#9;AND    GA.CASE_PARTY_NO IS NULL&#10;&#9;&#9;AND    GA.PARTY_ID = CPR.PARTY_ID&#10;&#9;&#9;AND    GA.ADDRESS_TYPE_CODE = &apos;CODED PARTY&apos;&#10;&#9;&#9;AND    GA.VALID_TO IS NULL&#10;&#9;&#9;AND&#9;CPR.CASE_PARTY_NO = CPR2CPR.CPR_B_CASE_PARTY_NO&#10;           AND    CPR2CPR.CPR_A_CASE_NUMBER = ? &#10;&#9;&#9;AND    CPR2CPR.CPR_A_CASE_PARTY_NO = ?&#10;&#9;&#9;AND    CPR2CPR.CPR_A_PARTY_ROLE_CODE = &apos;DEFENDANT&apos;&#10;&#9;&#9;AND    CPR2CPR.CPR_B_PARTY_ROLE_CODE = &apos;SOLICITOR&apos; &#10;&#9;&#9;AND    CPR2CPR.DELETED_FLAG = &apos;N&apos;) "/>
                <pl:parameter name="forward_option" value="9"/>
                <pl:parameter name="sqlwarntoerror" value="false"/>
                <pl:parameter name="query" value="true"/>
                <pl:parameter name="input_mappings">
                    <pl:parameter name="input schemas">
                        <pl:parameter name="0">
                            <pl:parameter name="root" value="/Defendants"/>
                            <pl:parameter name="tempRoot" value="/Defendants/Defendant"/>
                            <pl:parameter name="schema" value="legacy_defendant"/>
                            <pl:parameter name="using" value="."/>
                        </pl:parameter>
                    </pl:parameter>
                    <pl:parameter name="output schemas">
                        <pl:parameter name="0">
                            <pl:parameter name="root" value="/aa:parameters"/>
                            <pl:parameter name="schema" value="dbsqlinput.8"/>
                            <pl:parameter name="using" value="."/>
                        </pl:parameter>
                    </pl:parameter>
                    <pl:parameter name="tracing" value="off"/>
                    <pl:parameter name="exception-on-null" value="true"/>
                    <pl:parameter name="exception-on-nomapping" value="false"/>
                    <pl:parameter name="verbose-exceptions" value="false"/>
                    <pl:parameter name="show-local-functions" value="false"/>
                    <pl:parameter name="width" value="1030"/>
                    <pl:parameter name="height" value="774"/>
                    <pl:parameter name="mappings">
                        <pl:parameter name="[0]/aa:parameters">
                            <pl:parameter name="main">
