                <pl:parameter name="trigger" value="start"/>
                <pl:parameter name="message" value="-&#10;--&gt; Retrieve Claimant Address CPR Sql for Case Number = {$case_number-complex}&#10;--&gt; SEQUENCE -CPR Claimant Count CPR Sequence &#10;--&gt; VIEW - CPR Claimant Count&#10;--&gt; CIRCUIT - {$CircuitName}&#10;----------------------------------------------------------------------------------"/>
