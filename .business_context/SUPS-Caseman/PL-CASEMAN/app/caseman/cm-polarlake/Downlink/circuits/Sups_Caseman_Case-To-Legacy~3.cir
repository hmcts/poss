        <pl:documentation name="Case_Sups_Case-To-Legacy"/>
        <pl:application-data name="Resources" type="Resources">
            <pl:application-data name="Functions" type="functions" application="com.polarlake.platform.librarymodule.LibraryModuleApplication">
                <pl:application-data name="formatDates" type="function" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value="">
                    <pl:application-data name="type" type="property" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value="beanshell"/>
                    <pl:application-data name="methodName" type="property" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value="formatDates"/>
                    <pl:application-data name="category" type="property" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value="Miscellaneous"/>
                    <pl:application-data name="script" type="property" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value="import org.apache.log4j.Logger;&#10;import java.text.ParseException;&#10;import java.text.SimpleDateFormat;&#10;import java.util.Date;&#10;&#10;String formatDates(String pDate)&#10;    {&#10;        Logger logger = Logger.getRootLogger();&#10;        String function_name = &quot;formatDates&quot;;&#10;&#10;        if(pDate != null &amp;&amp; (!pDate.trim().equals(&quot;&quot;))) {&#9;&#10;        &#9;SimpleDateFormat dateFormat = null;&#10;        &#9;dateFormat = new SimpleDateFormat(&quot;yyyy-MM-dd&quot;);&#10;         &#9;dateFormat.applyPattern(&quot;yyyy-MM-dd&quot;);&#10;       &#9;Date parseDate = null;&#10;&#10;&#9;try {&#10;          &#9;&#9; parseDate = dateFormat.parse(pDate);&#10;      &#9; } catch (ParseException pe) {&#10;           &#9;&#9; logger.error(&quot;ParseException caught&quot;);  &#10;       &#9;}&#10;&#9; logger.info(&quot;Date is not null in &quot; + function_name + &quot; , returning null&quot;);&#10;       &#9;return dateFormat.format(parseDate);&#10;       } else {&#10;&#9; logger.info(&quot;Date is null in &quot; + function_name + &quot; , returning null&quot;);&#10;&#9;return null;&#10;        }&#10;    }"/>
                    <pl:application-data name="description" type="property" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value=""/>
                </pl:application-data>
                <pl:application-data name="removeFiftyDays" type="function" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value="">
                    <pl:application-data name="type" type="property" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value="beanshell"/>
                    <pl:application-data name="methodName" type="property" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value="addFiftyDays"/>
                    <pl:application-data name="category" type="property" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value="Miscellaneous"/>
                    <pl:application-data name="script" type="property" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value="import org.apache.log4j.Logger;&#10;import java.text.ParseException;&#10;import java.text.SimpleDateFormat;&#10;import java.util.Calendar;&#10;import java.util.Date;&#10;import java.util.GregorianCalendar;&#10;&#10;String addFiftyDays(String pDate)&#10;    {&#10;        Logger logger = Logger.getRootLogger();&#10;        String function_name = &quot;formatDates&quot;;&#10;        System.out.println(&quot;\n\n in 1&quot;);&#9;&#10;        if(pDate != null || (!pDate.trim().equals(&quot;&quot;)) || (!pDate.equals(&quot;EMPTY&quot;))) {&#9;&#10;        &#9;SimpleDateFormat dateFormat = null;&#10;    &#9;        System.out.println(&quot;\n\n in 2&quot;);&#9;&#10;        &#9;dateFormat = new SimpleDateFormat(&quot;yyyy-MM-dd&quot;);&#10;         &#9;dateFormat.applyPattern(&quot;yyyy-MM-dd&quot;);&#10;         &#9;Date parseDate = null;&#10;       &#9;        System.out.println(&quot;\n\n in 3&quot;);&#9;&#10;         &#9;try {&#10;          &#9;&#9; parseDate = dateFormat.parse(pDate);&#10;         &#9;} catch (ParseException pe) {&#10;           &#9;&#9; logger.error(&quot;ParseException caught&quot;); &#10;         &#9;}&#10;     &#9;        System.out.println(&quot;\n\n in 4&quot;);&#9;&#10;      &#9;GregorianCalendar gCal = new GregorianCalendar();&#10;      &#9;gCal.setTime(parseDate);&#10;      &#9;gCal.add(Calendar.DATE, -50);&#10;      &#9;        System.out.println(&quot;\n\n in 5&quot;);&#9;     &#9;&#10;      &#9;logger.info(&quot;Date is not null in &quot; + function_name + &quot; , returning null&quot;);&#10;       &#9;return dateFormat.format(gCal.getTime());&#10;       } else {&#10;&#9;        System.out.println(&quot;\n\n in 55&quot;);&#9;&#10;&#9; logger.info(&quot;Date is null in &quot; + function_name + &quot; , returning null&quot;);&#10;&#9;return null;&#10;        }&#10;    }"/>
                    <pl:application-data name="description" type="property" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value="Given a Date and add Fifty days to and return it in Sql Oracle Format"/>
                </pl:application-data>
                <pl:application-data name="truncateErrorMsg" type="function" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value="">
                    <pl:application-data name="type" type="property" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value="beanshell"/>
                    <pl:application-data name="methodName" type="property" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value="truncateErrorMsg"/>
                    <pl:application-data name="category" type="property" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value="Miscellaneous"/>
                    <pl:application-data name="script" type="property" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value="import org.apache.log4j.Logger;&#10;&#10;String truncateErrorMsg(String pMsg)&#10;    {&#10;        Logger logger = Logger.getLogger(&quot;com.error&quot;);&#10;        String function_name = &quot;truncateErrorMsg&quot;;&#10;&#10;        if(pMsg != null &amp;&amp; (!pMsg.trim().equals(&quot;&quot;)) &amp;&amp; pMsg.length() &lt;=200 ) {&#10;        &#9;&#10;&#9; logger.error(&quot;Msg for &quot; + function_name + &quot; , &quot; +pMsg);&#10;       &#9;return pMsg;&#10;       } else if (pMsg != null &amp;&amp; (!pMsg.trim().equals(&quot;&quot;))) {&#10;&#9; logger.error(&quot;Msg for &quot; + function_name + &quot; , &quot; + pMsg.substring(0, 200));&#10;       &#9;return pMsg.substring(0, 200);&#10;        } else {&#10;&#9; logger.error(&quot;Msg for &quot; + function_name + &quot; , &quot; + pMsg);&#10;&#9;return pMsg;&#10;        }&#10;    }"/>
                    <pl:application-data name="description" type="property" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value=""/>
                </pl:application-data>
                <pl:application-data name="setFlag" type="function" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value="">
                    <pl:application-data name="type" type="property" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value="beanshell"/>
                    <pl:application-data name="methodName" type="property" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value="setFlag"/>
                    <pl:application-data name="category" type="property" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value="Miscellaneous"/>
                    <pl:application-data name="script" type="property" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value="import org.apache.log4j.Logger;&#10;&#10;String setFlag(String pFlag)&#10;    {&#10;        Logger logger = Logger.getLogger(&quot;com.info&quot;);&#10;        String function_name = &quot;setFlag&quot;;&#10;&#10;        if(pFlag != null &amp;&amp; (!pFlag.trim().equals(&quot;&quot;))) {&#10;        &#9;&#10;&#9; logger.info(&quot;Flag for &quot; + function_name + &quot; , &quot; +pFlag);&#10;       &#9;return pFlag;&#10;       } else {&#10;&#9; logger.info(&quot;Flag for &quot; + function_name + &quot; , &quot; + pFlag + &quot; - Returning value of N for Flag&quot;);&#10;&#9;return &quot;N&quot;;&#10;        }&#10;    }"/>
                    <pl:application-data name="description" type="property" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value=""/>
                </pl:application-data>
                <pl:application-data name="determineDeftID" type="function" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value="">
                    <pl:application-data name="type" type="property" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value="beanshell"/>
                    <pl:application-data name="methodName" type="property" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value="determineDeftID"/>
                    <pl:application-data name="category" type="property" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value="Miscellaneous"/>
                    <pl:application-data name="script" type="property" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value="import org.apache.log4j.Logger;&#10;&#10;String determineDeftID(String pPartyNo, String pParty)&#10;    {&#10;        Logger logger = Logger.getLogger(&quot;com.info&quot;);&#10;        String function_name = &quot;determineDeftID&quot;;&#10;&#10;        if(pPartyNo != null &amp;&amp; (!pPartyNo.trim().equals(&quot;&quot;)) &amp;&amp; pParty != null &amp;&amp; (!pParty.trim().equals(&quot;&quot;)) &amp;&amp; (pParty.trim().equals(&quot;DEFENDANT&quot;))) {&#9;&#10;        &#9;&#10;&#9; logger.info(&quot;Event Party Role Code for &quot; + function_name + &quot; , is Defendant&quot;);&#10;       &#9; return pPartyNo;&#10;        } else if(pPartyNo != null &amp;&amp; (!pPartyNo.trim().equals(&quot;&quot;)) &amp;&amp; pParty != null &amp;&amp; (!pParty.trim().equals(&quot;&quot;)) &amp;&amp; (pParty.trim().equals(&quot;CLAIMANT&quot;))) {&#9;     &#9;&#10;&#9; logger.info(&quot;Event Party Role Code for &quot; + function_name + &quot; , is Claimant&quot;);&#10;       &#9; return &quot;&quot;;&#10;        } else {&#10; &#9; logger.info(&quot;Event Party Role Code for &quot; + function_name + &quot; , is unknown&quot;);&#10;       &#9; return &quot;&quot;;&#10;       }&#10;    }"/>
                    <pl:application-data name="description" type="property" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value=""/>
                </pl:application-data>
                <pl:application-data name="setTruncationFlag" type="function" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value="">
                    <pl:application-data name="type" type="property" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value="beanshell"/>
                    <pl:application-data name="methodName" type="property" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value="setTruncationFlag"/>
                    <pl:application-data name="category" type="property" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value="Miscellaneous"/>
                    <pl:application-data name="script" type="property" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value="import org.apache.log4j.Logger;&#10;&#10;String setTruncationFlag(String pPart20Exists, String pNoTranJudgmentExists, String pNoTranPartyExists)&#10;&#9;{&#10;&#9;String returnvalue = &quot;&quot;;&#10;&#9;&#9;&#9;&#9;&#10;&#9;Logger logger = Logger.getLogger(&quot;com.info&quot;);&#10;&#9;String function_name = &quot;setTruncationFlag&quot;;&#10;&#9;&#9;&#10;&#9;if((pPart20Exists != null &amp;&amp; (!pPart20Exists.trim().equals(&quot;0&quot;))) || &#10;&#9;&#9;(pNoTranJudgmentExists != null &amp;&amp; (!pNoTranJudgmentExists.trim().equals(&quot;0&quot;))) ||&#10;&#9;&#9;&#9;(pNoTranPartyExists != null &amp;&amp; (!pNoTranPartyExists.trim().equals(&quot;0&quot;)))) &#10;&#9;&#9;{&#9;&#10;&#9;       &#9;&#9; logger.info(&quot;Setting Truncation Flag to 1 from &quot; + function_name);&#10;&#9;       &#9;&#9; returnvalue = &quot;1&quot;;&#10;&#9;&#9;} &#10;&#9;&#9;else&#10;&#9;        &#9;{&#10;&#9;&#9;&#9;logger.info(&quot;Setting Truncation Flag to 0 from &quot; + function_name);&#10;&#9;        &#9;&#9;returnvalue = &quot;0&quot;;&#10;&#9;&#9;}&#10;&#9;&#9;&#9;&#10;&#9;&#9;&#9;&#10;&#9;&#9;return returnvalue;&#10;&#9;}"/>
                    <pl:application-data name="description" type="property" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value=""/>
                </pl:application-data>
                <pl:application-data name="truncateResponse" type="function" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value="">
                    <pl:application-data name="type" type="property" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value="beanshell"/>
                    <pl:application-data name="methodName" type="property" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value="truncateResponse"/>
                    <pl:application-data name="category" type="property" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value="Miscellaneous"/>
                    <pl:application-data name="script" type="property" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value="import org.apache.log4j.Logger;&#10;&#10;String truncateResponse(String pResponse)&#10;    {&#10;        Logger logger = Logger.getLogger(&quot;com.error&quot;);&#10;        String function_name = &quot;truncateResponse&quot;;&#10;&#10;        if(pResponse != null &amp;&amp; (!pResponse.trim().equals(&quot;&quot;)) &amp;&amp; pResponse.length() &lt;=12 ) {&#10;        &#9;&#10;&#9; logger.info(&quot;Response for &quot; + function_name + &quot; , &quot; +pResponse);&#10;       &#9;return pResponse;&#10;       } else if (pResponse != null &amp;&amp; (!pResponse.trim().equals(&quot;&quot;))) {&#10;&#9; logger.info(&quot;Response for &quot; + function_name + &quot; , &quot; + pResponse.substring(0, 12));&#10;       &#9;return pResponse.substring(0, 12);&#10;        } else {&#10;&#9; logger.info(&quot;Response for &quot; + function_name + &quot; , &quot; + pResponse);&#10;&#9;return pResponse;&#10;        }&#10;    }"/>
                    <pl:application-data name="description" type="property" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value=""/>
                </pl:application-data>
                <pl:application-data name="formatVariationResult" type="function" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value="">
                    <pl:application-data name="type" type="property" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value="beanshell"/>
                    <pl:application-data name="methodName" type="property" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value="formatVariationResult"/>
                    <pl:application-data name="category" type="property" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value="Miscellaneous"/>
                    <pl:application-data name="script" type="property" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value="import org.apache.log4j.Logger;&#10; &#10;String formatVariationResult(String pResult) {&#10; Logger logger = Logger.getLogger(&quot;com.info&quot;);&#10; String function_name = &quot;formatVariationResult&quot;;&#10; &#10; if(pResult != null &amp;&amp; (pResult.trim().equals(&quot;REFERRED TO JUDGE&quot;)) ) {&#10;  logger.info(&quot;Result for &quot; + function_name + &quot; , &quot; +pResult);&#10;  return &quot;TRANSFERRED&quot;;&#10; } else {&#10;      logger.info(&quot;Result for for &quot; + function_name + &quot; , &quot; +pResult);&#10;  return pResult;&#10; }&#10; &#10; &#10;}&#10; "/>
                    <pl:application-data name="description" type="property" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value=""/>
                </pl:application-data>
                <pl:application-data name="determineWFTOldStatus" type="function" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value="">
                    <pl:application-data name="type" type="property" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value="beanshell"/>
                    <pl:application-data name="methodName" type="property" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value="determineWFTOldStatus"/>
                    <pl:application-data name="category" type="property" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value="Miscellaneous"/>
                    <pl:application-data name="script" type="property" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value="package uk.gov.dca.caseman.case_service;&#10;import org.apache.log4j.Logger;&#10;&#10;String determineWFTOldStatus(String pWFTOldStatus, String pWFTStatus)&#10;    {&#10;        Logger logger = Logger.getLogger(&quot;com.info&quot;);&#10;        String function_name = &quot;determineWFTStatus&quot;;&#10;&#10;        if(pWFTOldStatus != null &amp;&amp; (!pWFTOldStatus.trim().equals(&quot;&quot;)) ) &#10;        {&#9;&#9;&#10;        &#9;logger.info(&quot;WFT Old Status is present &quot; + function_name);&#10;       &#9; &#9;return pWFTOldStatus;&#10;       &#9; &#9;&#10;        } &#10;        else &#10;        {&#10;        &#9;logger.info(&quot;WFT Old Status is NOT present &quot; + function_name);&#10;       &#9; &#9;return pWFTStatus;&#10;        } &#10;    }&#10;"/>
                    <pl:application-data name="description" type="property" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value=""/>
                </pl:application-data>
                <pl:application-data name="determineWFTOldOutcome" type="function" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value="">
                    <pl:application-data name="type" type="property" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value="beanshell"/>
                    <pl:application-data name="methodName" type="property" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value="determineWFTOldOutcome"/>
                    <pl:application-data name="category" type="property" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value="Miscellaneous"/>
                    <pl:application-data name="script" type="property" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value="package uk.gov.dca.caseman.case_service;&#10;import org.apache.log4j.Logger;&#10;&#10;String determineWFTOldOutcome(String pWFTOldOutcome, String pWFTOutcome)&#10;    {&#10;        Logger logger = Logger.getLogger(&quot;com.info&quot;);&#10;        String function_name = &quot;determineWFTOldOutcome&quot;;&#10;&#10;        if(pWFTOldOutcome != null &amp;&amp; (!pWFTOldOutcome.trim().equals(&quot;&quot;)) ) &#10;        {&#9;&#9;&#10;        &#9;logger.info(&quot;WFT Old Outcome is present &quot; + function_name);&#10;       &#9; &#9;return pWFTOldOutcome;&#10;       &#9; &#9;&#10;        } &#10;        else &#10;        {&#10;        &#9;logger.info(&quot;WFT Old Outcome is NOT present &quot; + function_name);&#10;       &#9; &#9;return pWFTOutcome;&#10;        } &#10;    }&#10;"/>
                    <pl:application-data name="description" type="property" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value=""/>
                </pl:application-data>
                <pl:application-data name="determineAEType" type="function" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value="">
                    <pl:application-data name="type" type="property" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value="beanshell"/>
                    <pl:application-data name="methodName" type="property" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value="determineAEType"/>
                    <pl:application-data name="category" type="property" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value="Miscellaneous"/>
                    <pl:application-data name="script" type="property" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value="import org.apache.log4j.Logger;&#10;&#10;String determineAEType(String pPartyAgainstRoleCode, String pAEType) {&#10;&#9; Logger logger = Logger.getLogger(&quot;com.info&quot;);&#10;&#9; String function_name = &quot;determineAEType&quot;;&#10;&#9; &#10;&#9; if((pPartyAgainstRoleCode != null) &amp;&amp; (pPartyAgainstRoleCode.trim().equals(&quot;CLAIMANT&quot;)) &amp;&amp; (pAEType.trim().equals(&quot;JD&quot;)) ) {&#10;&#9;  logger.info(&quot;Change AEType to JD in function &quot; + function_name + &quot; , &quot; +pPartyAgainstRoleCode);&#10;&#9;  return &quot;JP&quot;;&#10;&#9; } else {&#10;&#9;      logger.info(&quot;Existing AEType in function &quot; + function_name + &quot; , &quot; +pPartyAgainstRoleCode);&#10;&#9;  return pAEType;&#10;&#9; }&#10;&#9; &#10;&#9; &#10;&#9;}"/>
                    <pl:application-data name="description" type="property" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value=""/>
                </pl:application-data>
                <pl:application-data name="truncatePayeeTelephone" type="function" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value="">
                    <pl:application-data name="type" type="property" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value="beanshell"/>
                    <pl:application-data name="methodName" type="property" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value="truncatePayeeTelephone"/>
                    <pl:application-data name="category" type="property" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value="Miscellaneous"/>
                    <pl:application-data name="script" type="property" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value="import org.apache.log4j.Logger;&#10;&#10;String truncatePayeeTelephone(String pPayeeTelNo)&#10;    {&#10;        Logger logger = Logger.getLogger(&quot;com.error&quot;);&#10;        String functionName = &quot;truncatePayeeTelephone&quot;;&#10;        String payeeTelephone;&#10;        final int TEL_NO_LENGTH = 14;&#10;        final int TEL_NO_MAX_INDEX = 13;&#10;        String vPayeeTelNoWithoutSpace;&#10;        &#10;        if (pPayeeTelNo == null){&#10;        &#9;pPayeeTelNo = &quot;&quot;;&#10;        }   &#10;&#10;        StringTokenizer st = new StringTokenizer(pPayeeTelNo,&quot; &quot;,false);&#10;&#9;String vPayeeTelNoWithoutSpace=&quot;&quot;;&#10;&#9;while (st.hasMoreElements()) vPayeeTelNoWithoutSpace += st.nextElement();&#10;&#9;&#10;&#10;        if(vPayeeTelNoWithoutSpace != null &amp;&amp; (!vPayeeTelNoWithoutSpace.trim().equals(&quot;&quot;)) &amp;&amp; vPayeeTelNoWithoutSpace.length() &lt;=TEL_NO_LENGTH ) {&#10;        &#9;logger.info(&quot;Response for &quot; + functionName + &quot; , &quot; +vPayeeTelNoWithoutSpace);&#10;        &#9;payeeTelephone = vPayeeTelNoWithoutSpace;&#10;       } else if (vPayeeTelNoWithoutSpace != null &amp;&amp; (!vPayeeTelNoWithoutSpace.trim().equals(&quot;&quot;))) {&#10;       &#9;&#9;logger.info(&quot;Response for &quot; + functionName + &quot; , &quot; + vPayeeTelNoWithoutSpace.substring(0, TEL_NO_MAX_INDEX));&#10;       &#9;&#9;payeeTelephone = vPayeeTelNoWithoutSpace.substring(0,TEL_NO_MAX_INDEX);&#10;        } else {&#10;        &#9;logger.info(&quot;Response for &quot; + functionName + &quot; , &quot; + vPayeeTelNoWithoutSpace);&#10;        &#9;payeeTelephone = &quot;&quot;;&#10;        }&#10;        return payeeTelephone;&#10;    }"/>
                    <pl:application-data name="description" type="property" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value=""/>
                </pl:application-data>
                <pl:application-data name="truncatePayeeReference" type="function" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value="">
                    <pl:application-data name="type" type="property" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value="beanshell"/>
                    <pl:application-data name="methodName" type="property" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value="truncatePayeeReference"/>
                    <pl:application-data name="category" type="property" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value="Miscellaneous"/>
                    <pl:application-data name="script" type="property" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value="import org.apache.log4j.Logger;&#10;&#10;String truncatePayeeReference(String pPayeeReference)&#10;    {&#10;        Logger logger = Logger.getLogger(&quot;com.error&quot;);&#10;        String functionName = &quot;truncatePayeeReference&quot;;&#10;        String payeeReference;&#10;        final int PAYEE_REF_LENGTH = 24;&#10;        final int PAYEE_REF_MAX_INDEX = 23;&#10;&#10;        if(pPayeeReference != null &amp;&amp; (!pPayeeReference.trim().equals(&quot;&quot;)) &amp;&amp; pPayeeReference.length() &lt;=PAYEE_REF_LENGTH ) {&#10;        &#9;logger.info(&quot;Response for &quot; + functionName + &quot; , &quot; +pPayeeReference);&#10;        &#9;payeeReference = pPayeeReference;&#10;       } else if (pPayeeReference != null &amp;&amp; (!pPayeeReference.trim().equals(&quot;&quot;))) {&#10;       &#9;&#9;logger.info(&quot;Response for &quot; + functionName + &quot; , &quot; + pPayeeReference.substring(0, PAYEE_REF_MAX_INDEX));&#10;       &#9;&#9;payeeReference = pPayeeReference.substring(0,PAYEE_REF_MAX_INDEX);&#10;        } &#10;       &#9;else {payeeReference = pPayeeReference;&#10;       &#9;}&#10;        return payeeReference;&#10;    }"/>
                    <pl:application-data name="description" type="property" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value=""/>
                </pl:application-data>
                <pl:application-data name="determineRequestor" type="function" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value="">
                    <pl:application-data name="type" type="property" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value="beanshell"/>
                    <pl:application-data name="methodName" type="property" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value="determineRequestor"/>
                    <pl:application-data name="category" type="property" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value="Miscellaneous"/>
                    <pl:application-data name="script" type="property" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value="import org.apache.log4j.Logger;&#10;&#10;String determineRequestor(String pParty)&#10;    {&#10;        Logger logger = Logger.getLogger(&quot;com.info&quot;);&#10;        String function_name = &quot;determineRequestor&quot;;&#10;&#10;        if(pParty != null &amp;&amp; (!pParty.trim().equals(&quot;&quot;)) &amp;&amp; (pParty.trim().equals(&quot;PARTY FOR&quot;))) {&#9;&#10;                &#9;&#9;&#10;&#9; logger.info(&quot;Requestor for &quot; + function_name + &quot; , is a CLAIMANT&quot;);&#10;       &#9;return &quot;CLAIMANT&quot;;&#10;       } else if(pParty != null &amp;&amp; (!pParty.trim().equals(&quot;&quot;)) &amp;&amp; (pParty.trim().equals(&quot;PARTY AGAINST&quot;))) {&#9;&#9;&#10;        &#9;&#10;&#9; logger.info(&quot;Requestor for &quot; + function_name + &quot; , is DEFENDANT&quot;);&#10;       &#9;return &quot;DEFENDANT&quot;;&#10;       } else if  (pParty != null &amp;&amp; (!pParty.trim().equals(&quot;&quot;))){&#10;&#9; logger.info(&quot;Event Party Role Code for &quot; + function_name + &quot; , is &quot; + pParty);&#10;&#9;return pParty;&#10;        } else {&#10; &#9;logger.info(&quot;Event Party Role Code for &quot; + function_name + &quot; , No Party Role&quot;);&#10;&#9;return &quot;&quot;;&#10;       }&#10;    }"/>
                    <pl:application-data name="description" type="property" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value=""/>
                </pl:application-data>
                <pl:application-data name="determineAEPartyNumber" type="function" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value="">
                    <pl:application-data name="type" type="property" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value="beanshell"/>
                    <pl:application-data name="methodName" type="property" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value="determineAEPartyNumber"/>
                    <pl:application-data name="category" type="property" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value="Miscellaneous"/>
                    <pl:application-data name="script" type="property" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value="import org.apache.log4j.Logger;&#10;&#10;String determineAEPartyNumber(String pPartyAgainstRoleCode, String pAEType, String partyAgainstNumber, String partyForNumber) {&#10;&#9; Logger logger = Logger.getLogger(&quot;com.info&quot;);&#10;&#9; String function_name = &quot;determineAEPartyNumber&quot;;&#10;&#9; &#10;&#9; if((pPartyAgainstRoleCode != null) &amp;&amp; (pPartyAgainstRoleCode.trim().equals(&quot;CLAIMANT&quot;)) &amp;&amp; (pAEType.trim().equals(&quot;JD&quot;)) ) {&#10;&#9;  logger.info(&quot;AEType = JD in function &quot; + function_name + &quot; , &quot; +pPartyAgainstRoleCode);&#10;&#9;  return partyForNumber;&#10;&#9; } else {&#10;&#9;      logger.info(&quot;AEType is not JD in function &quot; + function_name + &quot; , &quot; +pPartyAgainstRoleCode );&#10;&#9;  return partyAgainstNumber;&#10;&#9; }&#10;&#9; &#10;&#9; &#10;&#9;}"/>
                    <pl:application-data name="description" type="property" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value=""/>
                </pl:application-data>
                <pl:application-data name="determineAEAmount" type="function" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value="">
                    <pl:application-data name="type" type="property" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value="beanshell"/>
                    <pl:application-data name="methodName" type="property" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value="determineAEAmount"/>
                    <pl:application-data name="category" type="property" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value="Miscellaneous"/>
                    <pl:application-data name="script" type="property" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value="import org.apache.log4j.Logger;&#10;&#10;String determineAEAmount(String pAEAmount, String pAEFee)&#10;&#9;{&#10;&#9;&#9;String returnvalue = &quot;&quot;;&#10;&#9;&#9;double dAEAmount;&#10;&#9;&#9;double dAEFee;&#10;&#9;&#9;double dAEAmountAndFee;&#10;&#9;&#10;&#9;&#9;Logger logger = Logger.getLogger(&quot;com.info&quot;);&#10;&#9;&#9;String function_name = &quot;determineAEAmount&quot;;&#10;&#9;&#9;&#10;&#9;&#9;&#10;&#10;&#9;&#9;if (pAEAmount != null &amp;&amp; !pAEAmount.equals(&quot;&quot;)){&#10;&#9;&#9;&#9;dAEAmount = Double.parseDouble(pAEAmount);&#10;&#9;&#9;}&#9;&#10;&#9;&#9;else{&#10;&#9;&#9;&#9;dAEAmount = 0.00;&#10;&#9;&#9;}&#10;&#9;&#9;&#10;&#9;&#9;if (pAEFee != null &amp;&amp; !pAEFee.equals(&quot;&quot;)){&#10;&#9;&#9;&#9;dAEFee = Double.parseDouble(pAEFee);&#10;&#9;&#9;}&#10;&#9;&#9;else{&#10;&#9;&#9;&#9;dAEFee = 0.00;&#10;&#9;&#9;}&#10;&#9;&#9;&#10;&#9;&#9;&#10;&#9;&#9;dAEAmountAndFee = dAEAmount + dAEFee;&#10;&#9;&#9;&#9;&#9;&#9;&#9;&#10;&#9;&#9;&#10;&#9;         returnvalue  = Double.toString(dAEAmountAndFee);&#10;&#9;&#9; logger.info(&quot;AEAmount + AEFee in &quot; + function_name + &quot; = &quot; + returnvalue);&#10;&#9;&#9;&#9;        &#9;&#9;&#10;&#9;    return returnvalue;&#10;&#9;}&#9;"/>
                    <pl:application-data name="description" type="property" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value=""/>
                </pl:application-data>
            </pl:application-data>
            <pl:application-data name="Initial Contexts" type="initialcontexts" application="com.polarlake.platform.librarymodule.LibraryModuleApplication"/>
            <pl:application-data name="Scripts" type="scripts" application="com.polarlake.platform.librarymodule.LibraryModuleApplication">
                <pl:application-data name="Document Logger Error Case-Sups - Caseman" type="script" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value="">
                    <pl:application-data name="url" type="property" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value=""/>
                    <pl:application-data name="remote" type="property" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value="false"/>
                    <pl:application-data name="type" type="property" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value="beanshell"/>
                    <pl:application-data name="cache" type="property" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value="never_resolve"/>
                    <pl:application-data name="script" type="property" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value="import org.apache.log4j.Logger;&#10;import org.jdom.*;  &#10;import org.jdom.input.*;  &#10;import org.jdom.output.*;  &#10;import com.polarlake.platform.api.*;  &#10;import com.polarlake.platform.api.helper.*;  &#10;import com.polarlake.platform.api.exception.*;  &#10;  &#10;/**  &#10; * A JDOM beanshell must return a JDOM document.  &#10; */  &#10; Document processDocument(Document doc, ExecutiveProcessInterface process) &#10; { &#10;&#10;   try &#10;   { &#10;      VariableContainerInterface vci = process.getProcessDocGroup(); &#10;      if (vci != null) &#10;      { &#10;        VariableInterface vi = vci.getVariable(&quot;Case-Sups&quot;); &#10;        Document doc = (Document)vi.getValue(); &#10;        XMLOutputter xo = new XMLOutputter(Format.getPrettyFormat());&#10;        Logger logger = Logger.getRootLogger();&#10;        logger.error(xo.outputString(doc));&#10;     } &#10;  } &#10;  catch (DocVariableException dve) &#10;  { &#10;    /* do nothing */ &#10;   } &#10;      return doc;&#9;&#10;} &#10;"/>
                    <pl:application-data name="description" type="property" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value="A PolarLake Platform Beanshell script must be coded to return a JDOM document.They can be composed from calls to imported modules as well as local methods.Only the first method in the script will be executed, so it should make any appropriate method calls if the entire script is not contained in it."/>
                </pl:application-data>
                <pl:application-data name="Process Doc Logger Error - Caseman" type="script" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value="">
                    <pl:application-data name="url" type="property" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value=""/>
                    <pl:application-data name="remote" type="property" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value="false"/>
                    <pl:application-data name="type" type="property" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value="beanshell"/>
                    <pl:application-data name="cache" type="property" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value="never_resolve"/>
                    <pl:application-data name="script" type="property" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value="import org.apache.log4j.Logger;&#10;import org.jdom.*;  &#10;import org.jdom.input.*;  &#10;import org.jdom.output.*;  &#10;import com.polarlake.platform.api.*;  &#10;import com.polarlake.platform.api.helper.*;  &#10;import com.polarlake.platform.api.exception.*;  &#10;import com.polarlake.platform.common.ParameterName;&#10;  &#10;/**  &#10; * A JDOM beanshell must return a JDOM document.  &#10; */  &#10; Document processDocument(Document doc, ExecutiveProcessInterface process) &#10; { &#10;       XMLOutputter xo = new XMLOutputter(Format.getPrettyFormat());&#10;       Logger logger = Logger.getRootLogger();&#10;&#10;       String processCaseName = Util.getProcessVariable (process, new ParameterName(&quot;case_number-complex&quot;));&#10;       String processCircuitName = Util.getProcessVariable (process, new ParameterName(&quot;CircuitName&quot;));&#10;       logger.error(&quot;\n&quot; +&#10;     &quot;Error in Caseman Transfer Script Printing Xml Doc in Circuit = &quot; +  &#10;      processCircuitName +&#10;      &quot;\n For CaseNumber = &quot; +&#9;&#10;       processCaseName+ &#10;       &quot;\n&quot;+ &#10;       xo.outputString(doc));&#10;      return doc;&#9;&#10;} &#10;"/>
                    <pl:application-data name="description" type="property" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value="A PolarLake Platform Beanshell script must be coded to return a JDOM document.They can be composed from calls to imported modules as well as local methods.Only the first method in the script will be executed, so it should make any appropriate method calls if the entire script is not contained in it."/>
                </pl:application-data>
                <pl:application-data name="Process Doc Logger Debug - Caseman" type="script" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value="">
                    <pl:application-data name="url" type="property" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value=""/>
                    <pl:application-data name="remote" type="property" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value="false"/>
                    <pl:application-data name="type" type="property" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value="beanshell"/>
                    <pl:application-data name="cache" type="property" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value="never_resolve"/>
                    <pl:application-data name="script" type="property" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value="import org.apache.log4j.Logger;&#10;import org.jdom.*;  &#10;import org.jdom.input.*;  &#10;import org.jdom.output.*;  &#10;import com.polarlake.platform.api.*;  &#10;import com.polarlake.platform.api.helper.*;  &#10;import com.polarlake.platform.api.exception.*;  &#10;import com.polarlake.platform.common.ParameterName;&#10;  &#10;/**  &#10; * A JDOM beanshell must return a JDOM document.  &#10; */  &#10; Document processDocument(Document doc, ExecutiveProcessInterface process) &#10; { &#10;       XMLOutputter xo = new XMLOutputter(Format.getPrettyFormat());&#10;       Logger logger = Logger.getRootLogger();&#10;&#10;       String processCaseName = Util.getProcessVariable (process, new ParameterName(&quot;case_number-complex&quot;));&#10;       String processCircuitName = Util.getProcessVariable (process, new ParameterName(&quot;CircuitName&quot;));&#10;&#10;      logger.debug(&quot;\n&quot; +&#10;     &quot;Debug in Caseman Transfer Script Printing Xml Doc in Circuit = &quot; +  &#10;      processCircuitName +&#10;      &quot;\n For CaseNumber = &quot; +&#9;&#10;       processCaseName+ &#10;       &quot;\n&quot;+ &#10;       xo.outputString(doc));&#10;      return doc;&#9;&#10;} &#10;"/>
                    <pl:application-data name="description" type="property" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value="A PolarLake Platform Beanshell script must be coded to return a JDOM document.They can be composed from calls to imported modules as well as local methods.Only the first method in the script will be executed, so it should make any appropriate method calls if the entire script is not contained in it."/>
                </pl:application-data>
                <pl:application-data name="Process Doc Logger Info - Caseman" type="script" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value="">
                    <pl:application-data name="url" type="property" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value=""/>
                    <pl:application-data name="remote" type="property" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value="false"/>
                    <pl:application-data name="type" type="property" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value="beanshell"/>
                    <pl:application-data name="cache" type="property" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value="never_resolve"/>
                    <pl:application-data name="script" type="property" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value="import org.apache.log4j.Logger;&#10;import org.jdom.*;  &#10;import org.jdom.input.*;  &#10;import org.jdom.output.*;  &#10;import com.polarlake.platform.api.*;  &#10;import com.polarlake.platform.api.helper.*;  &#10;import com.polarlake.platform.api.exception.*;  &#10;import com.polarlake.platform.common.ParameterName;&#10;  &#10;/**  &#10; * A JDOM beanshell must return a JDOM document.  &#10; */  &#10; Document processDocument(Document doc, ExecutiveProcessInterface process) &#10; { &#10;       XMLOutputter xo = new XMLOutputter(Format.getPrettyFormat());&#10;       Logger logger = Logger.getRootLogger();&#10;&#10;       String processCaseName = Util.getProcessVariable (process, new ParameterName(&quot;case_number-complex&quot;));&#10;&#10;       String processCircuitName = Util.getProcessVariable (process, new ParameterName(&quot;CircuitName&quot;));&#10;&#10;       logger.info(&quot;\n&quot; +&#10;     &quot;In Caseman Transfer Script Printing Xml Doc in Circuit = &quot; +  &#10;      processCircuitName +&#10;      &quot;\n For CaseNumber = &quot; +&#9;&#10;       processCaseName+ &#10;       &quot;\n&quot;+ &#10;       xo.outputString(doc));&#10;      return doc;&#9;&#10;} &#10;"/>
                    <pl:application-data name="description" type="property" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value="A PolarLake Platform Beanshell script must be coded to return a JDOM document.They can be composed from calls to imported modules as well as local methods.Only the first method in the script will be executed, so it should make any appropriate method calls if the entire script is not contained in it."/>
                </pl:application-data>
                <pl:application-data name="JDom Processing" type="script" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value="">
                    <pl:application-data name="url" type="property" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value=""/>
                    <pl:application-data name="remote" type="property" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value="false"/>
                    <pl:application-data name="type" type="property" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value="beanshell"/>
                    <pl:application-data name="cache" type="property" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value="never_resolve"/>
                    <pl:application-data name="script" type="property" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value="import org.jdom.*;&#10;import org.jdom.input.*;&#10;import org.jdom.output.*;&#10;import com.polarlake.platform.api.*;&#10;import com.polarlake.platform.api.helper.*;&#10;import com.polarlake.platform.api.exception.*;&#10;&#10;/**&#10; * A JDOM beanshell must return a JDOM document.&#10; */&#10;Document processDocument(Document doc) {&#10;&#10;   return doc;&#10;}"/>
                    <pl:application-data name="description" type="property" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value="This returns the empty doc without doing anything."/>
                </pl:application-data>
                <pl:application-data name="Process Doc Logger Fatal - Caseman" type="script" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value="">
                    <pl:application-data name="url" type="property" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value=""/>
                    <pl:application-data name="remote" type="property" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value="false"/>
                    <pl:application-data name="type" type="property" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value="beanshell"/>
                    <pl:application-data name="cache" type="property" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value="never_resolve"/>
                    <pl:application-data name="script" type="property" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value="import org.apache.log4j.Logger;&#10;import org.jdom.*;  &#10;import org.jdom.input.*;  &#10;import org.jdom.output.*;  &#10;import com.polarlake.platform.api.*;  &#10;import com.polarlake.platform.api.helper.*;  &#10;import com.polarlake.platform.api.exception.*;  &#10;import com.polarlake.platform.common.ParameterName;&#10;  &#10;/**  &#10; * A JDOM beanshell must return a JDOM document.  &#10; */  &#10; Document processDocument(Document doc, ExecutiveProcessInterface process) &#10; { &#10;       XMLOutputter xo = new XMLOutputter(Format.getPrettyFormat());&#10;       Logger logger = Logger.getRootLogger();&#10;&#10;       String processCaseName = Util.getProcessVariable (process, new ParameterName(&quot;case_number-complex&quot;));&#10;       String processCircuitName = Util.getProcessVariable (process, new ParameterName(&quot;CircuitName&quot;));&#10;       logger.error(&quot;\n&quot; +&#10;     &quot;Fatal Error in Caseman Transfer Script Printing Xml Doc in Circuit = &quot; +  &#10;      processCircuitName +&#10;      &quot;\n For CaseNumber = &quot; +&#9;&#10;       processCaseName+ &#10;       &quot;\n&quot;+ &#10;       xo.outputString(doc));&#10;      return doc;&#9;&#10;} &#10;"/>
                    <pl:application-data name="description" type="property" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value="A PolarLake Platform Beanshell script must be coded to return a JDOM document.They can be composed from calls to imported modules as well as local methods.Only the first method in the script will be executed, so it should make any appropriate method calls if the entire script is not contained in it."/>
                </pl:application-data>
                <pl:application-data name="CaseEventMapper" type="script" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value="">
                    <pl:application-data name="url" type="property" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value=""/>
                    <pl:application-data name="remote" type="property" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value="false"/>
                    <pl:application-data name="type" type="property" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value="beanshell"/>
                    <pl:application-data name="cache" type="property" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value="never_resolve"/>
                    <pl:application-data name="script" type="property" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value="import java.util.Iterator;&#10;import java.util.List;&#10; &#10;import org.apache.log4j.Logger;&#10; &#10;import org.jdom.*;  &#10;import org.jdom.input.*;  &#10;import org.jdom.output.*;  &#10;import org.jdom.xpath.XPath;&#10; &#10;import com.polarlake.platform.api.*;  &#10;import com.polarlake.platform.api.helper.*;  &#10;import com.polarlake.platform.api.exception.*;  &#10;import com.polarlake.platform.common.ParameterName;&#10;  &#10;/**  &#10; * A JDOM beanshell must return a JDOM document.  &#10; */  &#10; Document processDocument(Document doc, ExecutiveProcessInterface process) &#10; { &#10; &#10;       XMLOutputter xo = new XMLOutputter(Format.getPrettyFormat());&#10;       Logger logger = Logger.getRootLogger();&#10;       Document docEvent;&#10;       String eventString = &quot;Event Id has been mapped from &quot;;&#10; &#10;      try &#10;      { &#10;          VariableContainerInterface vci = process.getProcessDocGroup(); &#10; &#10;          if (vci != null) &#10;          { &#10;              VariableInterface vi = vci.getVariable(&quot;CaseEventMap&quot;); &#10;              docEvent = (Document)vi.getValue();  &#10;          } &#10;      } &#10;      catch (DocVariableException dve) &#10;      { &#10;          logger.error(&quot;\n Error in Run Script Map Events&quot;);&#10;      } &#10; &#10;        List paramsEvents;&#10;        try {&#10;            paramsEvents = XPath.selectNodes(doc, &quot;//CaseEvent&quot;);&#10; &#10;            Iterator it = paramsEvents.iterator();&#10;            while(it.hasNext()) {&#10;                Element currentElement = (Element) it.next();&#10; &#10;                if(currentElement instanceof Element) {&#10; &#10;                    Element paramsDetails = (Element) XPath.selectSingleNode(currentElement, &quot;./Details&quot;);&#10;                    Element paramsEventID = (Element) XPath.selectSingleNode(currentElement, &quot;./StandardEventID&quot;);                      &#10;                 &#10;                    if(paramsEventID != null) {&#10; &#10;                    String eventIdStr = paramsEventID.getText();&#10;                        List paramMappedEventIdList = XPath.selectNodes(docEvent, &quot;//NonLegacyEvent[SupsEventID =&quot; +eventIdStr+ &quot;]&quot;);&#10;                              &#10;                        Iterator itEventMap = paramMappedEventIdList.iterator();&#10;                        while(itEventMap.hasNext()) {&#10; &#10;                            Element mappedElement = (Element) itEventMap.next();&#10; &#10;                            Element paramsSupsEventId = (Element) XPath.selectSingleNode(mappedElement, &quot;./LegacyEventID&quot;);&#10;    &#10;                            paramsEventID.setText(paramsSupsEventId.getText());&#10;                            if(paramsDetails.getText().length()+eventString.length()+4 &lt; 2000) {&#10;                                paramsDetails.setText(paramsDetails.getText()+ eventString+eventIdStr);&#10;                            }&#10;                            &#10;                        }&#10;                    }&#10;                }&#10;            }&#10;        } catch (JDOMException e) {&#10;            log.error(&quot;Jdom Exception ErrorError in Run Script Map Events = &quot; + e.getMessage(), e);  &#10;        }&#10;      return doc; &#10;}"/>
                    <pl:application-data name="description" type="property" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value="A PolarLake Platform Beanshell script must be coded to return a JDOM document.They can be composed from calls to imported modules as well as local methods.Only the first method in the script will be executed, so it should make any appropriate method calls if the entire script is not contained in it."/>
                </pl:application-data>
                <pl:application-data name="MapLegacyEvents" type="script" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value="">
                    <pl:application-data name="url" type="property" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value=""/>
                    <pl:application-data name="remote" type="property" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value="false"/>
                    <pl:application-data name="type" type="property" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value="beanshell"/>
                    <pl:application-data name="cache" type="property" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value="never_resolve"/>
                    <pl:application-data name="script" type="property" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value="import java.util.Iterator;&#10;import java.util.List;&#10;&#10;import org.apache.log4j.Logger;&#10;&#10;import org.jdom.*;  &#10;import org.jdom.input.*;  &#10;import org.jdom.output.*;  &#10;import org.jdom.xpath.XPath;&#10;&#10;import com.polarlake.platform.api.*;  &#10;import com.polarlake.platform.api.helper.*;  &#10;import com.polarlake.platform.api.exception.*;  &#10;import com.polarlake.platform.common.ParameterName;&#10;  &#10;/**  &#10; * A JDOM beanshell must return a JDOM document.  &#10; */  &#10; Document processDocument(Document doc, ExecutiveProcessInterface process) &#10; { &#10;&#10;       XMLOutputter xo = new XMLOutputter(Format.getPrettyFormat());&#10;       Logger loggerI = Logger.getLogger(&quot;com.info&quot;);&#10;       Logger loggerE = Logger.getLogger(&quot;com.error&quot;);&#10;       Document docEvent;&#10;&#10;      try &#10;      { &#10;          VariableContainerInterface vci = process.getProcessDocGroup(); &#10;&#10;          if (vci != null) &#10;          { &#10;              VariableInterface vi = vci.getVariable(&quot;CaseEventMap&quot;); &#10;              docEvent = (Document)vi.getValue();  &#10;          } &#10;      } &#10;      catch (DocVariableException dve) &#10;      { &#10;          loggerE.error(&quot;\n Error in Run Script MapLegacyEvents&quot;);&#10;      } &#10;&#10;        List paramsEvents;&#10;        try {&#10;            paramsEvents = XPath.selectNodes(doc, &quot;//CaseEvent&quot;);&#10;&#10;            Iterator it = paramsEvents.iterator();&#10;            loggerI.info(&quot;Count of Case Event Records = &quot; + paramsEvents.size());&#10;            &#10;            while(it.hasNext()) {&#10;                Element currentElement = (Element) it.next();&#10;&#10;                if(currentElement instanceof Element) {&#10;&#10;                    Element paramsEventID = (Element) XPath.selectSingleNode(currentElement, &quot;./StandardEventID&quot;); &#10;                    Element paramsKeyID = (Element) XPath.selectSingleNode(currentElement, &quot;./PartyRoleCode&quot;);                     &#10;&#10;                    if(paramsEventID != null &amp;&amp; paramsEventID.getText() != null &amp;&amp; (!paramsEventID.getText().equals(&quot;&quot;)) &amp;&amp;&#10;                    paramsKeyID != null &amp;&amp; paramsKeyID.getText() != null &amp;&amp; (!paramsKeyID.getText().equals(&quot;&quot;))) {&#10;&#10;                    &#9;String eventIdStr = paramsEventID.getText();&#10;                    &#9;String eventKeyIdStr = paramsKeyID.getText();&#10;             &#9;&#9;loggerI.info(&quot;Event ID = &quot;+ eventIdStr);&#10;             &#9;&#9;loggerI.info(&quot;Key = &quot; + eventKeyIdStr);              &#10;                    &#9;&#10;       &#9;&#10;                        Element paramMappedEventId = (Element) XPath.selectSingleNode(docEvent, &quot;//NonLegacyEvent[SupsEventID =&quot; +eventIdStr+ &quot; and Key =\&apos;&quot; + eventKeyIdStr+ &quot;\&apos;]/LegacyEventID&quot;);&#10;&#10; &#9;&#9;&#9;&#9;if(paramMappedEventId != null &amp;&amp; paramMappedEventId.getText() != null &amp;&amp;  (!paramMappedEventId.getText().equals(&quot;&quot;))) {&#10; &#9;&#9;&#9;&#9;&#9;loggerI.info(&quot;Mapping Sups Event ID = &quot; + eventIdStr + &quot; to Legacy Event ID = &quot; + paramMappedEventId.getText()); &#10; &#9;&#9;&#9;&#9;&#9;paramsEventID.setText(paramMappedEventId.getText());&#10; &#9;&#9;&#9;&#9;}&#10;                        loggerI.info(&quot;Checked if Event ID is in Xml Config File&quot;);&#10;                        &#10;                    }&#10;                }&#10;            }&#10;        } catch (JDOMException e) {&#10;            loggerE.error(&quot;Jdom Exception ErrorError in Run Script MapLegacyEvents = &quot; + e.getMessage(), e);  &#10;        }&#10;      return doc;&#9;&#10;} "/>
                    <pl:application-data name="description" type="property" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value="A PolarLake Platform Beanshell script must be coded to return a JDOM document.They can be composed from calls to imported modules as well as local methods.Only the first method in the script will be executed, so it should make any appropriate method calls if the entire script is not contained in it."/>
                </pl:application-data>
            </pl:application-data>
