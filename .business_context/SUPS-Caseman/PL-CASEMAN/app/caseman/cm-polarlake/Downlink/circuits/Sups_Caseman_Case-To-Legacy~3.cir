                <pl:parameter name="trigger" value="start"/>
                <pl:parameter name="message" value="-&#10;--&gt; Starting DB SQL select for OTHER Address&#10;--&gt; SEQUENCE - Address Sequence&#10;--&gt; VIEW - Address View&#10;--&gt; CIRCUIT - {$CircuitName}&#10; ----------------------------------------------------------------------------------"/>
