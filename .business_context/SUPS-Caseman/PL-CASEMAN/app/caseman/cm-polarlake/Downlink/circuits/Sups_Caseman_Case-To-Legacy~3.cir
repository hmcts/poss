<?xml version="1.0" encoding="utf-8"?>
<pl:system-content xmlns:pl="http://www.polarlake.com/platform/1.0">
    <pl:circuit name="Sups_Caseman_Case-To-Legacy">
        <pl:definitions>
            <pl:definition name="OracleDB-06" value="file:///{pl$caseman_home}/Common/circuits/Database/Sups-Database-OracleDB-Dev06.cir"/>
            <pl:definition name="CircuitCommon" value="file:///{pl$polarlake_home}/CircuitCommon.cir"/>
            <pl:definition name="Sups-Database-Oracle817" value="file:///{pl$caseman_home}/Common/circuits/Database/Sups-Database-Oracle817.cir"/>
            <pl:definition name="SchedulerModuleApplicationCircuit" value="file:///{pl$polarlake_home}/SchedulerModule/circuits/SchedulerModule.cir"/>
            <pl:definition name="Case_Sups_Case-To-Legacy" value="file:///{pl$caseman_home}/Downlink/circuits/Case_Sups_Case-To-Legacy.html"/>
        </pl:definitions>
