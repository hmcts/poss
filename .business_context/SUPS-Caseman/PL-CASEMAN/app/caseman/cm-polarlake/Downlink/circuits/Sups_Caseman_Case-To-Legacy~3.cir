                <pl:parameter name="output_mappings">
                    <pl:parameter name="input schemas">
                        <pl:parameter name="0">
                            <pl:parameter name="root" value="/aa:resultSet"/>
                            <pl:parameter name="schema" value="dbsql.First.query.(SELECT NULL                               AS &quot;CP.CODE&quot;&#10;&#9;&#9;,&#9; GA.ADDRESS_ID                      AS &quot;GA.ADDRESS_ID&quot;&#10;&#9;&#9;,      SUBSTR(GA.ADDRESS_LINE1, 1, 30)   AS &quot;GA.ADDRESS_LINE1&quot;&#10;&#9;&#9;,      SUBSTR(GA.ADDRESS_LINE2, 1, 30)   AS &quot;GA.ADDRESS_LINE2&quot;&#10;&#9;&#9;,      SUBSTR(GA.ADDRESS_LINE3, 1, 30)   AS &quot;GA.ADDRESS_LINE3&quot;&#10;&#9;&#9;,      SUBSTR(GA.ADDRESS_LINE4, 1, 30)   AS &quot;GA.ADDRESS_LINE4&quot;&#10;&#9;&#9;,      SUBSTR(GA.ADDRESS_LINE5, 1, 30)   AS &quot;GA.ADDRESS_LINE5&quot;&#10;&#9;&#9;,      GA.POSTCODE                        AS &quot;GA.POSTCODE&quot;&#10;&#9;&#9;,      GA.PARTY_ID                        AS &quot;GA.PARTY_ID&quot;&#10;&#9;&#9;,      SUBSTR(SOLP.DX_NUMBER, 1, 30)  AS &quot;SOLP.DX_NUMBER&quot;&#10;&#9;&#9;,      SOLP.TEL_NO                        AS &quot;SOLP.TEL_NO&quot;&#10;&#9;&#9;,      SOLP.PERSON_REQUESTED_NAME         AS &quot;SOLP.PERSON_REQUESTED_NAME&quot;&#10;&#9;&#9;,      SUBSTR(CPR.REFERENCE, 1, 24)         AS &quot;CPR.REFERENCE&quot;&#10;&#9;&#9;,      CPR.ORA_ROWSCN                     AS &quot;CPR_ORA_ROWSCN&quot;&#10;&#9;&#9;,      SOLP.ORA_ROWSCN                    AS &quot;SOLP_ORA_ROWSCN&quot;&#10;&#9;&#9;,      NULL                               AS &quot;CP_ORA_ROWSCN&quot;&#10;&#9;&#9;,      PR.ORA_ROWSCN                      AS &quot;PR_ORA_ROWSCN&quot;&#10;&#9;&#9;,      GA.ORA_ROWSCN                      AS &quot;GA_ORA_ROWSCN&quot;&#10;&#9;&#9;FROM   CASE_PARTY_ROLES CPR&#10;&#9;&#9;,      PARTIES          SOLP&#10;&#9;&#9;,      PARTY_ROLES      PR&#10;&#9;&#9;,      GIVEN_ADDRESSES  GA&#10;&#9;&#9;WHERE  CPR.CASE_NUMBER = ?&#10;&#9;&#9;AND    CPR.PARTY_ROLE_CODE = &apos;SOLICITOR&apos; &#10;&#9;&#9;AND    SOLP.PARTY_ID = CPR.PARTY_ID &#10;&#9;&#9;AND    PR.PARTY_ROLE_CODE = CPR.PARTY_ROLE_CODE &#10;&#9;&#9;AND    GA.CASE_NUMBER = ?&#10;&#9;&#9;AND    GA.PARTY_ROLE_CODE = &apos;SOLICITOR&apos;&#10;&#9;&#9;AND    GA.CASE_PARTY_NO = CPR.CASE_PARTY_NO&#10;&#9;&#9;AND    GA.ADDRESS_TYPE_CODE = &apos;SOLICITOR&apos;&#10;&#9;&#9;AND    CPR.CASE_PARTY_NO = 1&#10;&#9;&#9;) UNION (&#10;&#9;&#9;SELECT  CP.CODE                            AS &quot;CP.CODE&quot;&#10;&#9;&#9;,&#9; GA.ADDRESS_ID                      AS &quot;GA.ADDRESS_ID&quot;&#10;&#9;&#9;,      SUBSTR(GA.ADDRESS_LINE1, 1, 30)   AS &quot;GA.ADDRESS_LINE1&quot;&#10;&#9;&#9;,      SUBSTR(GA.ADDRESS_LINE2, 1, 30)   AS &quot;GA.ADDRESS_LINE2&quot;&#10;&#9;&#9;,      SUBSTR(GA.ADDRESS_LINE3, 1, 30)   AS &quot;GA.ADDRESS_LINE3&quot;&#10;&#9;&#9;,      SUBSTR(GA.ADDRESS_LINE4, 1, 30)   AS &quot;GA.ADDRESS_LINE4&quot;&#10;&#9;&#9;,      SUBSTR(GA.ADDRESS_LINE5, 1, 30)   AS &quot;GA.ADDRESS_LINE5&quot;&#10;&#9;&#9;,      GA.POSTCODE                        AS &quot;GA.POSTCODE&quot;&#10;&#9;&#9;,      GA.PARTY_ID                        AS &quot;GA.PARTY_ID&quot;&#10;&#9;&#9;,      SUBSTR(SOLP.DX_NUMBER, 1, 30)  AS &quot;SOLP.DX_NUMBER&quot;&#10;&#9;&#9;,      SOLP.TEL_NO                        AS &quot;SOLP.TEL_NO&quot;&#10;&#9;&#9;,      SOLP.PERSON_REQUESTED_NAME         AS &quot;SOLP.PERSON_REQUESTED_NAME&quot;&#10;&#9;&#9;,      CPR.REFERENCE         AS &quot;CPR.REFERENCE&quot;&#10;&#9;&#9;,      CPR.ORA_ROWSCN                     AS &quot;CPR_ORA_ROWSCN&quot;&#10;&#9;&#9;,      SOLP.ORA_ROWSCN                    AS &quot;SOLP_ORA_ROWSCN&quot;&#10;&#9;&#9;,      CP.ORA_ROWSCN                      AS &quot;CP_ORA_ROWSCN&quot;&#10;&#9;&#9;,      PR.ORA_ROWSCN                      AS &quot;PR_ORA_ROWSCN&quot;&#10;&#9;&#9;,      GA.ORA_ROWSCN                      AS &quot;GA_ORA_ROWSCN&quot;&#10;&#9;&#9;FROM   CASE_PARTY_ROLES CPR&#10;&#9;&#9;,      PARTIES          SOLP&#10;&#9;&#9;,      CODED_PARTIES    CP&#10;&#9;&#9;,      PARTY_ROLES      PR&#10;&#9;&#9;,      GIVEN_ADDRESSES  GA&#10;&#9;&#9;WHERE  CPR.CASE_NUMBER = ?&#10;&#9;&#9;AND    CPR.PARTY_ROLE_CODE = &apos;SOLICITOR&apos; &#10;&#9;&#9;AND    SOLP.PARTY_ID = CPR.PARTY_ID &#10;&#9;&#9;AND    CP.PARTY_ID (+)= CPR.PARTY_ID &#10;&#9;&#9;AND    CP.ADMIN_COURT_CODE (+)= ?&#10;&#9;&#9;AND    PR.PARTY_ROLE_CODE = CPR.PARTY_ROLE_CODE &#10;&#9;&#9;AND    GA.CASE_NUMBER IS NULL&#10;&#9;&#9;AND    GA.PARTY_ROLE_CODE IS NULL&#10;&#9;&#9;AND    GA.CASE_PARTY_NO IS NULL&#10;&#9;&#9;AND    GA.PARTY_ID = CPR.PARTY_ID&#10;&#9;&#9;AND    GA.ADDRESS_TYPE_CODE = &apos;CODED PARTY&apos;&#10;&#9;&#9;AND    CPR.CASE_PARTY_NO = 1)"/>
