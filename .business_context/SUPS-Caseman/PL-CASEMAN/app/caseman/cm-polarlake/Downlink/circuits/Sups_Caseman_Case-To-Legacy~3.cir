        <pl:table name="Main Sups Caseman to Legacy  Table" operation="create">
            <pl:namespace uri="http://www.w3.org/2001/XMLSchema" prefix="xs" operation="create"/>
            <pl:namespace uri="http://www.polarlake.com/platform/1.0" prefix="pl" operation="create"/>
            <pl:namespace uri="http://www.w3.org/2001/XMLSchema-instance" prefix="xsi" operation="create"/>
            <pl:entry factory="com.polarlake.platform.event.NamedEventProcessorFactory" rule="/pl:exception[(@type=&quot;javax.mail.SendFailedException&quot;)]" operation="create" description="Email Failure Sequence  rule">
                <pl:parameter name="epName" value="Email Failure Sequence "/>
            </pl:entry>
            <pl:entry factory="com.polarlake.platform.event.NamedEventProcessorFactory" rule="/pl:exception[@type =&apos;java.sql.SQLException&apos;]" operation="create" description="Database Failure Sequence rule">
