                <pl:parameter name="trigger" value="start"/>
                <pl:parameter name="message" value="--&gt;Variation Insert Completed for Case Number = {$case_number-complex} &#10;--&gt; SEQUENCE - Process Variations Sequence&#10;--&gt; VIEW - Process Variations View&#10;--&gt; CIRCUIT - Main Sups Caseman to Legacy Process&#10;----------------------------------------------------------------------------------"/>
