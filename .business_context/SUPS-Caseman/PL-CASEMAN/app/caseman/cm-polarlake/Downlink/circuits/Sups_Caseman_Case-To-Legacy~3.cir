                            <pl:parameter name="root" value="/aa:resultSet"/>
                            <pl:parameter name="schema" value="dbsql.First.query.(SELECT GA.CASE_NUMBER AS &quot;GA.DEFT_CASE_NUMBER&quot;&#10;&#9;&#9;, &#9;GA.ADDRESS_ID AS &quot;GA.ADDRESS_ID&quot;&#10;&#9;       &#9;, &#9;0 AS &quot;GA.DEFT_ID&quot;&#10;&#9;        &#9;,   &#9;GA.COURT_CODE AS &quot;GA.COURT_CODE&quot;&#10;&#9;        &#9;,&#9;GA.ADDRESS_TYPE_CODE AS &quot;GA.ADDRESS_TYPE_CODE&quot;&#10;&#9;       &#9;,&#9;SUBSTR(GA.ADDRESS_LINE1, 1, 30)   AS &quot;GA.ADDRESS_LINE1&quot;&#10;&#9;&#9;&#9;,      SUBSTR(GA.ADDRESS_LINE2, 1, 30)   AS &quot;GA.ADDRESS_LINE2&quot;&#10;&#9;&#9;&#9;,      SUBSTR(GA.ADDRESS_LINE3, 1, 30)   AS &quot;GA.ADDRESS_LINE3&quot;&#10;&#9;&#9;&#9;,      SUBSTR(GA.ADDRESS_LINE4, 1, 30)   AS &quot;GA.ADDRESS_LINE4&quot;&#10;&#9;&#9;&#9;,      SUBSTR(GA.ADDRESS_LINE5, 1, 30)   AS &quot;GA.ADDRESS_LINE5&quot;&#10;&#9;&#9;&#9;,      GA.POSTCODE&#9;&#9;AS&#9;&quot;GA.POSTCODE&quot;&#10;&#9;&#9;&#9;,      GA.UPDATED_BY&#9;AS&#9;&quot;GA.UPDATED_BY&quot;&#10;&#9;&#9;&#9;,&#9;GA.VALID_FROM &#9;AS &#9;&quot;GA.VALID_FROM&quot;&#10;&#9;&#9;&#9;,&#9;GA.VALID_TO &#9;AS &#9;&quot;GA.VALID_TO&quot;&#10;&#9;&#9;&#9;,      SUBSTR(P.DX_NUMBER, 1, 30)  AS &quot;P.DX_NUMBER&quot;&#10;&#9;&#9;&#9;,      P.TEL_NO                        AS &quot;P.TEL_NO&quot;&#10;&#9;&#9;&#9;,      CPR.ORA_ROWSCN                     AS &quot;CPR_ORA_ROWSCN&quot;&#10;&#9;&#9;&#9;,      P.ORA_ROWSCN                    AS &quot;P_ORA_ROWSCN&quot;&#10;&#9;&#9;&#9;,      GA.ORA_ROWSCN                      AS &quot;GA_ORA_ROWSCN&quot;&#9;&#9;&#10;&#9;&#9;&#9;FROM   CASE_PARTY_ROLES CPR&#10;&#9;&#9;&#9;,      PARTIES          P&#10;&#9;&#9;&#9;,      GIVEN_ADDRESSES  GA&#10;&#9;&#9;&#9;WHERE  GA.CASE_NUMBER  = ?&#9;&#10;&#9;&#9;&#9;AND CPR.CASE_NUMBER = GA.CASE_NUMBER&#10;&#9;&#9;&#9;AND  CPR.PARTY_ROLE_CODE = GA.PARTY_ROLE_CODE &#9;&#10;&#9;&#9;&#9;AND  GA.CASE_PARTY_NO = CPR.CASE_PARTY_NO&#10;&#9;&#9;&#9;AND P.PARTY_ID = CPR.PARTY_ID&#10;&#9;&#9;&#9;AND GA.PARTY_ROLE_CODE = &apos;CLAIMANT&apos;&#10;&#9;&#9;&#9;AND GA.CASE_PARTY_NO = 1&#10;&#9;&#9;&#9;AND   (GA.ADDRESS_TYPE_CODE = &apos;SUBSERV&apos; &#10;&#9;&#9;&#9;&#9;&#9;OR GA.ADDRESS_TYPE_CODE = &apos;WORKPLACE&apos; ))&#10;&#9;&#9;&#9;UNION &#10;&#9;&#9;&#9;(SELECT GA.CASE_NUMBER AS &quot;GA.DEFT_CASE_NUMBER&quot;&#10;&#9;&#9;&#9;, &#9;GA.ADDRESS_ID AS &quot;GA.ADDRESS_ID&quot;&#10;&#9;&#9;&#9;, &#9;GA.CASE_PARTY_NO AS  &quot;GA.DEFT_ID&quot;&#10;&#9;        &#9;,   &#9;GA.COURT_CODE AS &quot;GA.COURT_CODE&quot;&#10;&#9;        &#9;,&#9;GA.ADDRESS_TYPE_CODE AS &quot;GA.ADDRESS_TYPE_CODE&quot;&#10;&#9;       &#9;,&#9;SUBSTR(GA.ADDRESS_LINE1, 1, 30)   AS &quot;GA.ADDRESS_LINE1&quot;&#10;&#9;&#9;&#9;,      SUBSTR(GA.ADDRESS_LINE2, 1, 30)   AS &quot;GA.ADDRESS_LINE2&quot;&#10;&#9;&#9;&#9;,      SUBSTR(GA.ADDRESS_LINE3, 1, 30)   AS &quot;GA.ADDRESS_LINE3&quot;&#10;&#9;&#9;&#9;,      SUBSTR(GA.ADDRESS_LINE4, 1, 30)   AS &quot;GA.ADDRESS_LINE4&quot;&#10;&#9;&#9;&#9;,      SUBSTR(GA.ADDRESS_LINE5, 1, 30)   AS &quot;GA.ADDRESS_LINE5&quot;&#10;&#9;&#9;&#9;,      GA.POSTCODE&#9;&#9;AS&#9;&quot;GA.POSTCODE&quot;&#10;&#9;&#9;&#9;,      GA.UPDATED_BY&#9;AS&#9;&quot;GA.UPDATED_BY&quot;&#10;&#9;&#9;&#9;,&#9;GA.VALID_FROM &#9;AS &#9;&quot;GA.VALID_FROM&quot;&#10;&#9;&#9;&#9;,&#9;GA.VALID_TO &#9;AS &#9;&quot;GA.VALID_TO&quot;&#10;&#9;&#9;&#9;,      SUBSTR(P.DX_NUMBER, 1, 30)  AS &quot;P.DX_NUMBER&quot;&#10;&#9;&#9;&#9;,      P.TEL_NO                        AS &quot;P.TEL_NO&quot;&#10;&#9;&#9;&#9;,      CPR.ORA_ROWSCN                     AS &quot;CPR_ORA_ROWSCN&quot;&#10;&#9;&#9;&#9;,      P.ORA_ROWSCN                    AS &quot;P_ORA_ROWSCN&quot;&#10;&#9;&#9;&#9;,      GA.ORA_ROWSCN                      AS &quot;GA_ORA_ROWSCN&quot;&#9;&#9;&#10;&#9;&#9;&#9;FROM   CASE_PARTY_ROLES CPR&#10;&#9;&#9;&#9;,      PARTIES          P&#10;&#9;&#9;&#9;,      GIVEN_ADDRESSES  GA&#10;&#9;&#9;&#9;WHERE  GA.CASE_NUMBER  = ?&#9;&#10;&#9;&#9;&#9;AND CPR.CASE_NUMBER = GA.CASE_NUMBER&#10;&#9;&#9;&#9;AND  CPR.PARTY_ROLE_CODE = GA.PARTY_ROLE_CODE &#9;&#10;&#9;&#9;&#9;AND  GA.CASE_PARTY_NO = CPR.CASE_PARTY_NO&#10;&#9;&#9;&#9;AND P.PARTY_ID = CPR.PARTY_ID&#10;&#9;&#9;&#9;AND GA.PARTY_ROLE_CODE = &apos;DEFENDANT&apos;&#9;&#10;&#9;&#9;&#9;AND GA.CASE_PARTY_NO &lt;= 9&#9;&#10;&#9;&#9;&#9;AND   (GA.ADDRESS_TYPE_CODE = &apos;SUBSERV&apos;&#10;&#9;&#9;&#9;&#9;&#9;OR GA.ADDRESS_TYPE_CODE = &apos;WORKPLACE&apos;)&#9;&#9;&#9;&#9;&#9;&#10;&#9;&#9;&#9;)&#9;"/>
                            <pl:parameter name="using" value="."/>
                        </pl:parameter>
