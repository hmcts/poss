                </pl:parameter>
            </pl:eventprocessor>
            <pl:eventprocessor name="pl:starttransaction" disable="false">
                <pl:parameter name="design">
                    <pl:parameter name="uid" value="13"/>
                    <pl:parameter name="alias" value="DB Start - First"/>
                </pl:parameter>
                <pl:parameter name="trigger" value="start"/>
                <pl:parameter name="connection" value="CasemanLegacyCentral"/>
                <pl:parameter name="transaction_key" value="First"/>
                <pl:parameter name="transaction_level" value="0"/>
            </pl:eventprocessor>
            <pl:eventprocessor name="pl:sqltoxml" disable="false">
                <pl:parameter name="design">
                    <pl:parameter name="uid" value="668"/>
                    <pl:parameter name="alias" value="DB SQL - Get Transfer Cases {$TableName}"/>
                </pl:parameter>
                <pl:parameter name="transaction_key" value="First"/>
                <pl:parameter name="sql" value="select t.transfer_number, t.trans_seq, t.SENDING_COURT_CODE from transfer_control t, warrants w where t.transfer_type = &apos;W&apos; and t.TRANSFER_STATUS = &apos;0&apos; and t.RECEIVING_COURT_CODE = ? and w.warrant_number = t.transfer_number and w.trans_seq = t.trans_seq"/>
                <pl:parameter name="forward_option" value="0"/>
                <pl:parameter name="sqlwarntoerror" value="false"/>
                <pl:parameter name="query" value="true"/>
                <pl:parameter name="input_mappings">
                    <pl:parameter name="input schemas"/>
                    <pl:parameter name="output schemas">
