                                    <pl:parameter name="location">
                                        <pl:parameter name="x" value="432"/>
                                        <pl:parameter name="y" value="141"/>
                                    </pl:parameter>
                                    <pl:parameter name="1">
                                        <pl:parameter name="variable" value="transfer_seq"/>
                                    </pl:parameter>
                                </pl:parameter>
                            </pl:parameter>
                        </pl:parameter>
                    </pl:parameter>
                </pl:parameter>
                <pl:parameter name="output_mappings"/>
                <pl:parameter name="uses_transaction" value="true"/>
            </pl:eventprocessor>
            <pl:eventprocessor name="pl:sqltoxml" disable="false">
                <pl:parameter name="design">
                    <pl:parameter name="uid" value="1223"/>
                    <pl:parameter name="alias" value="DB SQL - Update Warrant"/>
