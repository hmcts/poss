        <pl:seqlist name="Update Transfer Status Seqeuence">
            <pl:eventprocessor name="pl:printmessage" disable="false">
                <pl:parameter name="design">
                    <pl:parameter name="uid" value="169"/>
                    <pl:parameter name="alias" value="Print Message"/>
                </pl:parameter>
                <pl:parameter name="trigger" value="start"/>
                <pl:parameter name="message" value="-&#10;--&gt; Update Transfer Status for {$TableName} Number = {$case_number-complex} and Transfer Sequence  = {$transfer_seq}&#10;--&gt; SEQUENCE - Update Transfer Status Sequence&#10;--&gt; VIEW - Update Transfer Status View&#10;--&gt; CIRCUIT - {$CircuitName}&#10;----------------------------------------------------------------------------------"/>
                <pl:parameter name="use_log4j" value="true"/>
                <pl:parameter name="log_level" value="INFO"/>
            </pl:eventprocessor>
            <pl:eventprocessor name="pl:starttransaction" disable="false">
                <pl:parameter name="design">
                    <pl:parameter name="uid" value="33"/>
                    <pl:parameter name="alias" value="DB Start - Third"/>
                </pl:parameter>
                <pl:parameter name="trigger" value="start"/>
                <pl:parameter name="connection" value="CasemanLegacyCentral"/>
                <pl:parameter name="transaction_key" value="Third"/>
                <pl:parameter name="transaction_level" value="0"/>
            </pl:eventprocessor>
            <pl:eventprocessor name="pl:storecontextdoc" disable="false">
                <pl:parameter name="design">
                    <pl:parameter name="uid" value="104"/>
                    <pl:parameter name="alias" value="Store Context Document"/>
                </pl:parameter>
                <pl:parameter name="variable" value="Warrant-Status"/>
                <pl:parameter name="consume" value="false"/>
                <pl:parameter name="validate" value="false"/>
            </pl:eventprocessor>
            <pl:eventprocessor name="pl:sqltoxml" disable="false">
                <pl:parameter name="design">
                    <pl:parameter name="uid" value="218"/>
                    <pl:parameter name="alias" value="DB SQL - Update Transfer Status"/>
                </pl:parameter>
                <pl:parameter name="transaction_key" value="Third"/>
                <pl:parameter name="sql" value="update transfer_control set transfer_status= &apos;2&apos;, DATE_TRANSFERRED = sysdate where trans_seq = ?"/>
                <pl:parameter name="forward_option" value="0"/>
                <pl:parameter name="sqlwarntoerror" value="false"/>
                <pl:parameter name="query" value="false"/>
                <pl:parameter name="input_mappings">
                    <pl:parameter name="input schemas">
                        <pl:parameter name="0">
                            <pl:parameter name="root" value="/any"/>
                            <pl:parameter name="schema" value=""/>
