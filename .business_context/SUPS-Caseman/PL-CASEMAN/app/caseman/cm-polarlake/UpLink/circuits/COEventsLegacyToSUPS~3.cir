                <pl:parameter name="output_mappings">
                    <pl:parameter name="input schemas">
                        <pl:parameter name="0">
                            <pl:parameter name="root" value="/aa:resultSet"/>
                            <pl:parameter name="schema" value="dbsql.First.query.select t.transfer_number, t.trans_seq, t.SENDING_COURT_CODE &#10;from transfer_control t, central_co_case_events ce &#10;where t.transfer_type = &apos;F&apos; and t.TRANSFER_STATUS = &apos;1&apos; &#10;and t.RECEIVING_COURT_CODE = ? &#10;and ce.case_number = t.transfer_number&#10;and ce.trans_seq = t.trans_seq"/>
