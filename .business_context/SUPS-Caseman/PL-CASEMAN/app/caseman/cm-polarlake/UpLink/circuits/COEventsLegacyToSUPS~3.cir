                    <pl:application-data name="script" type="property" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value="import org.apache.log4j.Logger;&#10;&#10;String determinePreviousCourtID(String pCourtID, String pTransCourtID)&#10;    {&#10;        Logger logger = Logger.getLogger(&quot;com.info&quot;);&#10;        String function_name = &quot;determinePreviousCourtID&quot;;&#10;&#10;        if(pCourtID != null &amp;&amp; (!pCourtID.trim().equals(&quot;&quot;))) {&#9;&#10;        &#9;&#10;&#9; logger.info(&quot;Previous CourtID for &quot; + function_name + &quot; = &quot;);&#10;       &#9;return pCourtID;&#10;       } else {&#10;&#9; logger.info(&quot;Bar Judgment for &quot; + function_name + &quot; = Y&quot;);&#10;       &#9;return pTransCourtID;&#10;       }&#10;    }"/>
