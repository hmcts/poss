                    <pl:application-data name="script" type="property" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value="import org.apache.log4j.Logger; &#10;    &#10;String determineCasePartyRoleInFavourParty(String pParty)&#10;    {&#10;        Logger logger = Logger.getLogger(&quot;com.info&quot;);&#10;        String function_name = &quot;determineCasePartyRoleInFavourParty&quot;;&#10;&#10;        if(pParty != null &amp;&amp; (!pParty.trim().equals(&quot;&quot;)) &amp;&amp; (pParty.trim().equals(&quot;DEFENDANT&quot;))) {&#9;&#10;        &#9;&#10;&#9; logger.info(&quot;Event Party Role Code for &quot; + function_name + &quot; , is Defendant&quot;);&#10;       &#9; return &quot;DEFENDANT&quot;;&#10;        } else {&#10; &#9;logger.info(&quot;Event Party Role Code for &quot; + function_name + &quot; , is Claimant&quot;);&#10;       &#9;return &quot;CLAIMANT&quot;;&#10;       }&#10;    }"/>
