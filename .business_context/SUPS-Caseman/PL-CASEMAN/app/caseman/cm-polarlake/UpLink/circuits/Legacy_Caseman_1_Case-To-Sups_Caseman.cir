                    <pl:parameter name="alias" value="Print Exception Message"/>
                </pl:parameter>
                <pl:parameter name="trigger" value="start"/>
                <pl:parameter name="message" value="-&#10;--&gt; Database Failure Exception&#10;---&gt; Cause is More then one threading running and this is creating additional global temporary tables temp_wp_ouput. THERE CAN ONLY BE ONE THREAD running for this circuit, if you need to have more than one thread then, please change the circuit. As this circuit IS NOT THREAD SAFE. If however the temp_wp_ouput is still in exisitance due to the circuit hanging and not terminating then please re run the circuit twice, the first time will remove the Temp Table and close down the circuit, to ensure its thread safe the second time it will run in normal mode again.&#10;--&gt; SEQUENCE - Iterate Fatal Database Exceptions 00955 Sequence&#10;--&gt; VIEW - Iterate Fatal Database Exceptions&#10;--&gt; CIRCUIT - {$CircuitName}&#10;----------------------------------------------------------------------------------"/>
                <pl:parameter name="use_log4j" value="true"/>
                <pl:parameter name="log_level" value="FATAL"/>
            </pl:eventprocessor>
