                <pl:parameter name="message" value="-&#10;--&gt; The  Removing WP Output Temp Table - &#10;--&gt; SEQUENCE - Create Temp WP Output Sequence Exception&#10;--&gt; VIEW - Create Temp WP Output View&#10;--&gt; CIRCUIT - {$CircuitName}&#10;----------------------------------------------------------------------------------"/>
                <pl:parameter name="use_log4j" value="true"/>
                <pl:parameter name="log_level" value="FATAL"/>
            </pl:eventprocessor>
            <pl:eventprocessor name="pl:interpreter" disable="false">
                <pl:parameter name="useview" value="Remove Temp WP Output View"/>
                <pl:parameter name="design">
                    <pl:parameter name="uid" value="1749"/>
                    <pl:parameter name="alias" value="PolarLake Interpreter"/>
                </pl:parameter>
            </pl:eventprocessor>
        </pl:seqlist>
