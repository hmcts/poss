                    <pl:parameter name="alias" value="Print Message"/>
                </pl:parameter>
                <pl:parameter name="trigger" value="start"/>
                <pl:parameter name="message" value="-&#10;--&gt; Create Plantiff Address and Party sequences&#10;--&gt; SEQUENCE - Create Plantiff Case Address and Party Seq Sequence &#10;--&gt; VIEW - Create Plantiff Case Address and Party Seq View&#10;--&gt; CIRCUIT - {$CircuitName}&#10;----------------------------------------------------------------------------------"/>
