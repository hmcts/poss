                    <pl:application-data name="script" type="property" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value="import org.apache.log4j.Logger;&#10;&#10;String formatPostcode(String pPostcode) {&#10;&#9;Logger logger = Logger.getLogger(&quot;com.info&quot;);&#10;&#9;String function_name = &quot;formatPostcode&quot;;&#10;&#10;&#9;if(pPostcode != null &amp;&amp; ( pPostcode.trim().matches(&quot;^[A-Z]{1,2}[1-9][0-9]?[A-Z]? [0-9][A-Z]{2,}|GIR 0AA$&quot;) || pPostcode.trim().matches(&quot;^[A-Z]{1,2}[1-9][0-9]?[A-Z]?[0-9][A-Z]{2,}|GIR 0AA$&quot;) ) ) {&#10;&#9;            &#9;&#10;&#9;&#9;logger.info(&quot;PostCode for &quot; + function_name + &quot; , &quot; +pPostcode);&#10;&#9;&#9;return pPostcode;&#10;&#9;} else {&#10;&#9;    &#9;logger.info(&quot;Returning Null for unmatched format PostCode for &quot; + function_name + &quot; , &quot; +pPostcode);&#10;&#9;&#9;return &quot;&quot;;&#10;&#9;}&#10;}"/>
                    <pl:application-data name="description" type="property" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value=""/>
                </pl:application-data>
                <pl:application-data name="formatErrorMapperIDMessage" type="function" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value="">
                    <pl:application-data name="type" type="property" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value="beanshell"/>
                    <pl:application-data name="methodName" type="property" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value="formatErrorMapperIDMessage"/>
                    <pl:application-data name="category" type="property" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value="Miscellaneous"/>
                    <pl:application-data name="script" type="property" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value="import org.apache.log4j.Logger;&#10;&#10;String formatErrorMapperIDMessage(String pMsg)&#10;    {&#10;        Logger logger = Logger.getLogger(&quot;com.error&quot;);&#10;        String function_name = &quot;formatErrorMapperIDMessage&quot;;&#10;&#10;        if(pMsg != null &amp;&amp; (!pMsg.trim().equals(&quot;&quot;))) {&#10;&#10;         int posEnd = pMsg.indexOf(&quot;ID_AT_THE_END&quot;);&#10;         int posStart = pMsg.indexOf(&quot;Target exception: java.lang.RuntimeException: UnmappedID&quot;);&#10;&#10;         if(posEnd != -1 &amp;&amp; posStart != -1) {&#10;&#9; logger.error(&quot;Error Message truncated for &quot; + function_name + &quot; ,  &quot; +pMsg.substring(posStart, posEnd-1));&#10;         &#9;return pMsg.substring(posStart, posEnd-1);&#10;         }&#10;&#9;&#10;&#9; logger.error(&quot;Error Message truncated for &quot; + function_name + &quot; , &quot; +pMsg);&#10;       &#9;return pMsg;&#10;       } else {&#10;&#9; logger.error(&quot;Error Message for &quot; + function_name + &quot; , &quot; +pMsg);&#10;       &#9; return pMsg;&#10;       }&#10;    }"/>
                    <pl:application-data name="description" type="property" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value=""/>
                </pl:application-data>
