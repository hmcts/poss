                            <pl:parameter name="schema" value="dbsql.First.query.select t.transfer_number, t.trans_seq, t.SENDING_COURT_CODE from transfer_control t, cases c where t.transfer_type = &apos;C&apos; and t.TRANSFER_STATUS = &apos;3&apos; and t.RECEIVING_COURT_CODE = ? and c.case_number = t.transfer_number"/>
