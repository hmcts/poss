                    <pl:application-data name="cache" type="property" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value="never_resolve"/>
                    <pl:application-data name="script" type="property" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value="import java.util.Iterator;&#10;import java.util.List;&#10;&#10;import org.apache.log4j.Logger;&#10;&#10;import org.jdom.*;  &#10;import org.jdom.input.*;  &#10;import org.jdom.output.*;  &#10;import org.jdom.xpath.XPath;&#10;&#10;import com.polarlake.platform.api.*;  &#10;import com.polarlake.platform.api.helper.*;  &#10;import com.polarlake.platform.api.exception.*;  &#10;import com.polarlake.platform.common.ParameterName;&#10;  &#10;/**  &#10; * A JDOM beanshell must return a JDOM document.  &#10; */  &#10; Document processDocument(Document doc, ExecutiveProcessInterface process) &#10; { &#10;&#10;       XMLOutputter xo = new XMLOutputter(Format.getPrettyFormat());&#10;       Logger loggerI = Logger.getLogger(&quot;com.info&quot;);&#10;       Logger loggerE = Logger.getLogger(&quot;com.error&quot;);&#10;       Document docEvent;&#10;       Document docJudgment;&#10;&#10;      try &#10;      { &#10;          VariableContainerInterface vci = process.getProcessDocGroup(); &#10;&#10;          if (vci != null) &#10;          { &#10;              VariableInterface viE = vci.getVariable(&quot;CCBCCaseEventMap&quot;); &#10;              docEvent = (Document)viE.getValue();&#10;              VariableInterface viJ = vci.getVariable(&quot;Case-Judgment&quot;); &#10;              docJudgment = (Document)viJ.getValue();   &#10;          } &#10;      } &#10;      catch (DocVariableException dve) &#10;      { &#10;          loggerE.error(&quot;\n Error in Run Script MapCCBCEvents&quot;);&#10;      } &#10;&#10;        List paramsEvents;&#10;        try {&#10;            paramsEvents = XPath.selectNodes(doc, &quot;//CaseEvent&quot;);&#10;&#10;            Iterator it = paramsEvents.iterator();&#10;            while(it.hasNext()) {&#10;                Element currentElement = (Element) it.next();&#10;&#10;                if(currentElement instanceof Element) {&#10;&#10;                    Element paramsDetails = (Element) XPath.selectSingleNode(currentElement, &quot;./Details&quot;);&#10;                    Element paramsEventID = (Element) XPath.selectSingleNode(currentElement, &quot;./StandardEventID&quot;);                      &#10;                 &#10;                    if(paramsEventID != null &amp;&amp; paramsEventID.getText() != null &amp;&amp;  (!paramsEventID.getText().equals(&quot;&quot;))) {&#10;&#10;                    &#9;String eventIdStr = paramsEventID.getText();&#10;                    &#9;loggerI.info(&quot;Processing Event ID in run script MapCCBCEvents and Event ID = &quot; +eventIdStr);&#10;                        List paramMappedEventIdList = XPath.selectNodes(docEvent, &quot;//Event[LegacyEventID =&quot; +eventIdStr+ &quot;]&quot;);&#10;                              &#10;                        Iterator itEventMap = paramMappedEventIdList.iterator();&#10;                        while(itEventMap.hasNext()) {&#10;&#10;                            Element mappedElement = (Element) itEventMap.next();&#10;                                                     &#10;                            Element paramsSupsJudgmentCase = (Element) XPath.selectSingleNode(mappedElement, &quot;./JudgmentCase&quot;); &#10;                            Element paramsSupsJudgmentType = (Element) XPath.selectSingleNode(mappedElement, &quot;./JudgmentType&quot;); &#10;                            Element paramsSupsJudgmentDefendant = (Element) XPath.selectSingleNode(mappedElement, &quot;./JudgmentDefendant&quot;); &#10;                            Element paramsSupsReason = (Element) XPath.selectSingleNode(mappedElement, &quot;./Reason&quot;); &#10;                                           &#10;                            if(paramsSupsJudgmentCase != null &amp;&amp; paramsSupsJudgmentCase.getText() != null) {&#10;                            &#9;//Check Judgment Case&#10;                    &#9;&#9;Element paramsCaseNumber = (Element) XPath.selectSingleNode(currentElement, &quot;./StandardEventID&quot;); &#10;                    &#9;&#9;//This can&apos;t be null&#10;                            &#9;String caseNumber = paramsCaseNumber.getText();&#10;                            &#9;                                                        &#9;&#10;                            &#9;List paramsJudg;&#10;                            &#9;paramsJudg = XPath.selectNodes(docJudgment, &quot;//Judgment[CaseNumber =&quot;+ caseNumber +&quot;]&quot;);&#10;                            &#9;    &#10;                            &#9;if(paramsJudg.size() &gt; 0) {&#10;                            &#9;    &#10;                                    Element paramsSupsEventId = (Element) XPath.selectSingleNode(docEvent, &quot;//Event[LegacyEventID =&quot; +eventIdStr+ &quot; and JudgmentCase =&apos;Y&apos;]/SupsEventID&quot;);&#10;                                    paramsEventID.setText(paramsSupsEventId.getText());                            &#9;    &#10;                            } else {&#10;                            &#9;    &#10;                                    Element paramsSupsEventId = (Element) XPath.selectSingleNode(docEvent, &quot;//Event[LegacyEventID =&quot; +eventIdStr+ &quot; and JudgmentCase =&apos;N&apos;]/SupsEventID&quot;);&#10;                                    paramsEventID.setText(paramsSupsEventId.getText());                           &#9;    &#10;                            &#9;}&#10;                         &#9;&#10;                                break; //Prevent the second iteration&#10;                                &#10;                            } else if(paramsSupsJudgmentType != null &amp;&amp; paramsSupsJudgmentType.getText() != null) {&#10;                            &#9;//Check Judgment Type&#10;                            &#9;Element paramsCasePartyNo = (Element) XPath.selectSingleNode(mappedElement, &quot;./CasePartyNo&quot;);&#10;                            &#9;Element paramsPartyRoleCode = (Element) XPath.selectSingleNode(mappedElement, &quot;./PartyRoleCode&quot;);&#10;                            &#9;&#10;                            &#9;if(paramsCasePartyNo != null &amp;&amp; paramsCasePartyNo.getText() &amp;&amp; (!paramsCasePartyNo.getText().equals(&quot;&quot;)) &amp;&amp; paramsPartyRoleCode != null &amp;&amp; paramsPartyRoleCode.getText() != null &amp;&amp; paramsPartyRoleCode.getText().equals(&quot;DEFENDANT&quot;)) {&#10;                            &#9;&#10;                            &#9;    List paramsJudg;&#10;                            &#9;    String casePartyNo = paramsCasePartyNo.getText();&#10;                            &#9;    paramsJudg = XPath.selectNodes(docJudgment, &quot;//Judgment[AgainstPartyRoleCode =DEFENDANT and JudgmentType =DEFAULT and AgainstCasePartyNo =&quot;+ casePartyNo +&quot;]&quot;);&#10;                            &#9;    &#10;                            &#9;    if(paramsJudg.size() &gt; 0) {&#10;                            &#9;    &#10;                                        Element paramsSupsEventId = (Element) XPath.selectSingleNode(docEvent, &quot;//Event[LegacyEventID =&quot; +eventIdStr+ &quot; and JudgmentType =&apos;DEFAULT&apos;]/SupsEventID&quot;);&#10;                                        paramsEventID.setText(paramsSupsEventId.getText());                            &#9;    &#10;                            &#9;   }  else {&#10;                            &#9;    &#10;                                        Element paramsSupsEventId = (Element) XPath.selectSingleNode(docEvent, &quot;//Event[LegacyEventID =&quot; +eventIdStr+ &quot; and JudgmentType =&apos;NA&apos;]/SupsEventID&quot;);&#10;                                        paramsEventID.setText(paramsSupsEventId.getText());                           &#9;    &#10;                            &#9;    }&#10;                            &#9;                               &#9;    &#10;                            &#9;}  else {&#10;                                    Element paramsSupsEventId = (Element) XPath.selectSingleNode(docEvent, &quot;//Event[LegacyEventID =&quot; +eventIdStr+ &quot; and JudgmentType =&apos;NA&apos;]/SupsEventID&quot;);&#10;                                    paramsEventID.setText(paramsSupsEventId.getText());                            &#9;&#10;                            &#9;}&#10;                                break; //Prevent the second iteration&#10;                                &#10;                             } else if(paramsSupsJudgmentDefendant != null &amp;&amp; paramsSupsJudgmentDefendant.getText() != null) {&#10;                            &#9;//Check Judgment Defendant&#10;                            &#9;Element paramsCasePartyNo = (Element) XPath.selectSingleNode(mappedElement, &quot;./CasePartyNo&quot;);&#10;                            &#9;Element paramsPartyRoleCode = (Element) XPath.selectSingleNode(mappedElement, &quot;./PartyRoleCode&quot;);&#10;                            &#9;&#10;                            &#9;if(paramsCasePartyNo != null &amp;&amp; paramsCasePartyNo.getText() &amp;&amp; (!paramsCasePartyNo.getText().equals(&quot;&quot;)) &amp;&amp; paramsPartyRoleCode != null &amp;&amp; paramsPartyRoleCode.getText() != null &amp;&amp; paramsPartyRoleCode.getText().equals(&quot;DEFENDANT&quot;)) {&#10;                            &#9;&#10;                            &#9;    List paramsJudg;&#10;                            &#9;    String casePartyNo = paramsCasePartyNo.getText();&#10;                            &#9;    paramsJudg = XPath.selectNodes(docJudgment, &quot;//Judgment[AgainstPartyRoleCode =DEFENDANT and AgainstCasePartyNo =&quot;+ casePartyNo +&quot;]&quot;);&#10;                            &#9;    &#10;                            &#9;    if(paramsJudg.size() &gt; 0) {&#10;                            &#9;    &#10;                                        Element paramsSupsEventId = (Element) XPath.selectSingleNode(docEvent, &quot;//Event[LegacyEventID =&quot; +eventIdStr+ &quot; and JudgmentDefendant =&apos;Y&apos;]/SupsEventID&quot;);&#10;                                        paramsEventID.setText(paramsSupsEventId.getText());                            &#9;    &#10;                            &#9;}   else {&#10;                            &#9;    &#10;                                        Element paramsSupsEventId = (Element) XPath.selectSingleNode(docEvent, &quot;//Event[LegacyEventID =&quot; +eventIdStr+ &quot; and JudgmentDefendant =&apos;N&apos;]/SupsEventID&quot;);&#10;                                        paramsEventID.setText(paramsSupsEventId.getText());                           &#9;    &#10;                            &#9;    }&#10;                            &#9;                               &#9;    &#10;                            &#9;} else {&#10;                                    Element paramsSupsEventId = (Element) XPath.selectSingleNode(docEvent, &quot;//Event[LegacyEventID =&quot; +eventIdStr+ &quot; and JudgmentDefendant =&apos;N&apos;]/SupsEventID&quot;);&#10;                                    paramsEventID.setText(paramsSupsEventId.getText());                            &#9;&#10;                            &#9;}&#10;                                break; //Prevent the second iteration&#10;                            &#10;                            } else if(paramsSupsReason != null &amp;&amp; paramsSupsReason.getText() != null &amp;&amp; (!paramsSupsReason.getText().equals(&quot;&quot;))) {&#10;                                Element paramsSupsEventId = (Element) XPath.selectSingleNode(mappedElement, &quot;./SupsEventID&quot;);                  &#10;                                paramsDetails.setText(paramsSupsReason.getText());&#10;                                paramsEventID.setText(paramsSupsEventId.getText());&#10;                            } else {&#10;                                Element paramsSupsEventId = (Element) XPath.selectSingleNode(mappedElement, &quot;./SupsEventID&quot;); &#10;                            &#9;paramsEventID.setText(paramsSupsEventId.getText());&#10;                            }&#10;                            &#10;                        }&#10;                    }&#10;                }&#10;            }&#10;        } catch (JDOMException e) {&#10;            loggerE.error(&quot;Jdom Exception ErrorError in Run Script MapCCBCEvents = &quot; + e.getMessage(), e);  &#10;        }&#10;      return doc;&#9;&#10;} "/>
                    <pl:application-data name="description" type="property" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value="A PolarLake Platform Beanshell script must be coded to return a JDOM document.They can be composed from calls to imported modules as well as local methods.Only the first method in the script will be executed, so it should make any appropriate method calls if the entire script is not contained in it."/>
                </pl:application-data>
                <pl:application-data name="mapEmployerPartyIdToAEApplication" type="script" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value="">
                    <pl:application-data name="url" type="property" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value=""/>
                    <pl:application-data name="remote" type="property" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value="false"/>
                    <pl:application-data name="type" type="property" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value="beanshell"/>
                    <pl:application-data name="cache" type="property" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value="never_resolve"/>
                    <pl:application-data name="script" type="property" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value="import java.util.Iterator;&#10;import java.util.List;&#10;import java.util.HashMap;&#10;&#10;import org.apache.log4j.Logger;&#10;&#10;import org.jdom.*;  &#10;import org.jdom.input.*;  &#10;import org.jdom.output.*;  &#10;import org.jdom.xpath.XPath;&#10;&#10;import com.polarlake.platform.api.*;  &#10;import com.polarlake.platform.api.helper.*;  &#10;import com.polarlake.platform.api.exception.*;  &#10;import com.polarlake.platform.common.ParameterName;&#10;  &#10;/**  &#10; * A JDOM beanshell must return a JDOM document.  &#10; */  &#10; Document processDocument(Document doc, ExecutiveProcessInterface process) &#10; { &#10;&#10;       XMLOutputter xo = new XMLOutputter(Format.getPrettyFormat());&#10;       Logger loggerI = Logger.getLogger(&quot;com.info&quot;);&#10;       Logger loggerE = Logger.getLogger(&quot;com.error&quot;);&#10;       Document docJudg;&#10;&#10;      try &#10;      { &#10;          VariableContainerInterface vci = process.getProcessDocGroup(); &#10;&#10;          if (vci != null) &#10;          { &#10;              VariableInterface vi = vci.getVariable(&quot;Case-DefendantAddress&quot;); &#10;              docJudg = (Document)vi.getValue();  &#10;          } &#10;      } &#10;      catch (DocVariableException dve) &#10;      { &#10;          loggerE.error(&quot;\n Error in Run Script mapEmployerPartyIdToAEApplication for Case-DefendantAddress-To-AEApplication Mapper&quot;);&#10;      } &#10;&#10;        List paramsVariations;&#10;        try {&#10;            paramsVariations = XPath.selectNodes(doc, &quot;//AEApplication&quot;);&#10;&#9;    HashMap employerMap = new HashMap();&#10;&#9;    &#10;            Iterator it = paramsVariations.iterator();&#10;            while(it.hasNext()) {&#10;                Element currentElement = (Element) it.next();&#10;&#10;                if(currentElement instanceof Element) {&#10;&#10;                    Element aeDeftID = (Element) XPath.selectSingleNode(currentElement, &quot;./PartyAgainstCasePartyNo&quot;);&#10;                    Element aePartyID = (Element) XPath.selectSingleNode(currentElement, &quot;./DebtorsEmployersPartyID&quot;);  &#10;                    Element judgSequence = (Element) XPath.selectSingleNode(currentElement, &quot;./JudgSequence&quot;);   &#10;                    String judgString;&#10;                    &#10;                    if(judgSequence != null) {&#10;                    &#9;judgString = judgSequence.getText();&#9;&#10;                    }&#9;&#10;                                          &#10;                    if(aeDeftID != null &amp;&amp; aeDeftID.getText() != null &amp;&amp; (!aeDeftID.getText().equals(&quot;&quot;)) &amp;&amp; aePartyID != null) {&#10;&#10;                    String deftID = aeDeftID.getText();&#10;&#10;                        Element addressPartyId = (Element) XPath.selectSingleNode(docJudg, &quot;//Addresses[Address/AddrTypeCode = \&apos;EMPLOYER\&apos; and Address/CasePartyNo =&quot; +deftID+ &quot; and Address/ValidTo = \&apos;\&apos;]/Parties/PartyId&quot;);&#10;&#10;    &#9;&#9;&#9;if(addressPartyId != null &amp;&amp; (!employerMap.containsKey(deftID))) {&#10;                            aePartyID.setText(addressPartyId.getValue());&#10;                            employerMap.put(deftID, addressPartyId.getText());&#10;                            loggerI.info(&quot;Party ID for Defendant = &quot; +  deftID + &quot; And Judgement Sequence = &quot; + judgString + &quot; and Party ID = &quot; + addressPartyId.getText() + &quot; - Run Script mapEmployerPartyIdToAEApplication for Case-Judgment-To-AEApplication &quot;);&#10;                        } else {&#10;                            loggerI.info(&quot;Unmapped Party for Deft ID = &quot; +  deftID + &quot; And Judgement Sequence = &quot; + judgString + &quot; - Run Script mapEmployerPartyIdToAEApplication for Case-Judgment-To-AEApplication &quot;);&#10;&#9;       String endStr = &quot;  ID_AT_THE_END&quot;;&#10;                            //throw new RuntimeException(&quot;UnmappedID - Table AE Application - Employer Party ID has not been mapped for &quot; + aeDeftID.getText() + endStr);&#10;                        }&#10;                            &#10;                    }&#10;                }&#10;            }&#10;        } catch (JDOMException e) {&#10;            loggerE.error(&quot;Jdom Exception ErrorError in Run Script mapEmployerPartyIdToAEApplication for Case-DefendantAddress-To-AEApplication for = &quot; + e.getMessage(), e);  &#10;        }&#10;      return doc;&#9;&#10;} "/>
                    <pl:application-data name="description" type="property" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value="A PolarLake Platform Beanshell script must be coded to return a JDOM document.They can be composed from calls to imported modules as well as local methods.Only the first method in the script will be executed, so it should make any appropriate method calls if the entire script is not contained in it."/>
                </pl:application-data>
                <pl:application-data name="mapCaseEventClaimantAndDefendant" type="script" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value="">
                    <pl:application-data name="url" type="property" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value=""/>
                    <pl:application-data name="remote" type="property" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value="false"/>
                    <pl:application-data name="type" type="property" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value="beanshell"/>
                    <pl:application-data name="cache" type="property" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value="never_resolve"/>
                    <pl:application-data name="script" type="property" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value="import java.util.Iterator;&#10;import java.util.List;&#10;&#10;import org.apache.log4j.Logger;&#10;&#10;import org.jdom.*;  &#10;import org.jdom.input.*;  &#10;import org.jdom.output.*;  &#10;import org.jdom.xpath.XPath;&#10;&#10;import com.polarlake.platform.api.*;  &#10;import com.polarlake.platform.api.helper.*;  &#10;import com.polarlake.platform.api.exception.*;  &#10;import com.polarlake.platform.common.ParameterName;&#10;  &#10;/**  &#10; * A JDOM beanshell must return a JDOM document.  &#10; */  &#10; Document processDocument(Document doc, ExecutiveProcessInterface process) &#10; { &#10;&#10;       XMLOutputter xo = new XMLOutputter(Format.getPrettyFormat());&#10;       Logger loggerI = Logger.getLogger(&quot;com.info&quot;);&#10;       Logger loggerE = Logger.getLogger(&quot;com.error&quot;);&#10;       Document docEvent;&#10;&#10;      try &#10;      { &#10;          VariableContainerInterface vci = process.getProcessDocGroup(); &#10;&#10;          if (vci != null) &#10;          { &#10;              VariableInterface vi = vci.getVariable(&quot;CaseEventMap&quot;); &#10;              docEvent = (Document)vi.getValue();  &#10;          } &#10;      } &#10;      catch (DocVariableException dve) &#10;      { &#10;          loggerE.error(&quot;\n Error in Run Script Map DefendantClaimant Events&quot;);&#10;      } &#10;&#10;        List paramsEvents;&#10;        try {&#10;            paramsEvents = XPath.selectNodes(doc, &quot;//CaseEvent&quot;);&#10;&#10;            Iterator it = paramsEvents.iterator();&#10;            while(it.hasNext()) {&#10;                Element currentElement = (Element) it.next();&#10;&#10;                if(currentElement instanceof Element) {&#10;&#10;                    Element paramsEventID = (Element) XPath.selectSingleNode(currentElement, &quot;./StandardEventID&quot;);                      &#10;                 &#10;                    if(paramsEventID != null &amp;&amp; paramsEventID.getText() != null &amp;&amp;  (!paramsEventID.getText().equals(&quot;&quot;))) {&#10;&#10;                    String eventIdStr = paramsEventID.getText();&#10;                        List paramMappedEventIdList = XPath.selectNodes(docEvent, &quot;//NonLegacyEvent[LegacyEventID =&quot; +eventIdStr+ &quot;]&quot;);&#10;                              &#10;                        Iterator itEventMap = paramMappedEventIdList.iterator();&#10;                        while(itEventMap.hasNext()) {&#10;&#10;                            Element mappedElement = (Element) itEventMap.next();&#10;&#10;                            Element paramsSupsEventId = (Element) XPath.selectSingleNode(mappedElement, &quot;./SupsEventID&quot;);&#10;    &#10;                            paramsEventID.setText(paramsSupsEventId.getText());&#10;                          &#10;                        }&#10;                    }&#10;                }&#10;            }&#10;        } catch (JDOMException e) {&#10;            loggerE.error(&quot;Jdom Exception ErrorError in Run Script DefendantClaimant Map Events = &quot; + e.getMessage(), e);  &#10;        }&#10;      return doc;&#9;&#10;} "/>
                    <pl:application-data name="description" type="property" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value="A PolarLake Platform Beanshell script must be coded to return a JDOM document.They can be composed from calls to imported modules as well as local methods.Only the first method in the script will be executed, so it should make any appropriate method calls if the entire script is not contained in it."/>
                </pl:application-data>
                <pl:application-data name="mapCaseEventSeqAndNewCaseEventSeqToWpOutput" type="script" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value="">
                    <pl:application-data name="url" type="property" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value=""/>
                    <pl:application-data name="remote" type="property" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value="false"/>
                    <pl:application-data name="type" type="property" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value="beanshell"/>
                    <pl:application-data name="cache" type="property" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value="never_resolve"/>
                    <pl:application-data name="script" type="property" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value="import java.util.Iterator;                                                                                                                                                                               &#10;import java.util.List;                                                                                                                                                                                   &#10;                                                                                                                                                                                                         &#10;import org.apache.log4j.Logger;                                                                                                                                                                          &#10;                                                                                                                                                                                                         &#10;import org.jdom.*;                                                                                                                                                                                       &#10;import org.jdom.input.*;                                                                                                                                                                                 &#10;import org.jdom.output.*;                                                                                                                                                                                &#10;import org.jdom.xpath.XPath;                                                                                                                                                                             &#10;                                                                                                                                                                                                         &#10;import com.polarlake.platform.api.*;                                                                                                                                                                     &#10;import com.polarlake.platform.api.helper.*;                                                                                                                                                              &#10;import com.polarlake.platform.api.exception.*;                                                                                                                                                           &#10;import com.polarlake.platform.common.ParameterName;                                                                                                                                                      &#10;                                                                                                                                                                                                         &#10;/**                                                                                                                                                                                                      &#10; * A JDOM beanshell must return a JDOM document.                                                                                                                                                         &#10; */                                                                                                                                                                                                      &#10; Document processDocument(Document doc, ExecutiveProcessInterface process)                                                                                                                               &#10; {                                                                                                                                                                                                       &#10;                                                                                                                                                                                                         &#10;       XMLOutputter xo = new XMLOutputter(Format.getPrettyFormat());                                                                                                                                     &#10;       Logger loggerI = Logger.getLogger(&quot;com.info&quot;);                                                                                                                                                    &#10;       Logger loggerE = Logger.getLogger(&quot;com.error&quot;);                                                                                                                                                   &#10;       Document docCaseEvent;                                                                                                                                                                            &#10;       Document docNewCaseEvent;                                                                                                                                                                         &#10;       String endStr = &quot;  ID_AT_THE_END&quot;;                                                                                                                                                                &#10;                                                                                                                                                                                                         &#10;      try                                                                                                                                                                                                &#10;      {                                                                                                                                                                                                  &#10;          VariableContainerInterface vci = process.getProcessDocGroup();                                                                                                                                 &#10;                                                                                                                                                                                                         &#10;          if (vci != null)                                                                                                                                                                               &#10;          {                                                                                                                                                                                              &#10;              VariableInterface vi = vci.getVariable(&quot;Case-Events&quot;);                                                                                                                                     &#10;              docCaseEvent = (Document)vi.getValue();                                                                                                                                                    &#10;              VariableInterface vi = vci.getVariable(&quot;New-Case-Events&quot;);                                                                                                                                 &#10;              docNewCaseEvent = (Document)vi.getValue();                                                                                                                                                 &#10;          }                                                                                                                                                                                              &#10;      }                                                                                                                                                                                                  &#10;      catch (DocVariableException dve)                                                                                                                                                                   &#10;      {                                                                                                                                                                                                  &#10;          loggerE.error(&quot;\n Error in Run Script mapCaseEventSeqAndNewCaseEventSeqToWpOutput for CaseEvent-To-WpOutput Mapper&quot;);                                                                          &#10;      }                                                                                                                                                                                                  &#10;                                                                                                                                                                                                         &#10;        List paramsVariations;                                                                                                                                                                           &#10;        try {                                                                                                                                                                                            &#10;                                                                                                                                                                                                         &#10;            paramsCaseEvent = XPath.selectNodes(doc, &quot;//WpOutput&quot;);                                                                                                                                      &#10;                                                                                                                                                                                                         &#10;            Iterator it = paramsCaseEvent.iterator();                                                                                                                                                    &#10;            while(it.hasNext()) {                                                                                                                                                                        &#10;                Element currentElement = (Element) it.next();                                                                                                                                            &#10;                                                                                                                                                                                                         &#10;                if(currentElement instanceof Element) {                                                                                                                                                  &#10;                                                                                                                                                                                                         &#10;                    Element paramsOldCaseEventSeq = (Element) XPath.selectSingleNode(currentElement, &quot;./CaseEventSequence&quot;);                                                                             &#10;                                                                                                                                                                                                         &#10;                    if(paramsOldCaseEventSeq != null &amp;&amp; paramsOldCaseEventSeq.getText() != null &amp;&amp; (!paramsOldCaseEventSeq.getText().equals(&quot;&quot;))) {                                                      &#10;                                                                                                                                                                                                         &#10;                    String caseEventIdStr = paramsOldCaseEventSeq.getText();                                                                                                                             &#10;                                                                                                                                                                                                         &#10;                        Attribute mappedAttribute = (Attribute) XPath.selectSingleNode(docCaseEvent, &quot;//CaseEvent[OldSupsEventSeq =&quot; +caseEventIdStr+ &quot;]/EventSequence/@newSequenceNumber&quot;);               &#10;;                                                                                                                                                                                                        &#10;    &#9;&#9;&#9;if(mappedAttribute != null) {&#9;&#9;&#9;                                                                                                                                 &#10;                            paramsOldCaseEventSeq.setAttribute(&quot;newSequenceNumber&quot;, mappedAttribute.getValue());                                                                                         &#10;                        } else {                                                                                                                                                                         &#10;                                                                                                                                                                                                         &#10;                        &#9;Attribute mappedAttribute = (Attribute) XPath.selectSingleNode(docNewCaseEvent, &quot;//CaseEvent[EventSequence =&quot; +caseEventIdStr+ &quot;]/EventSequence/@newSequenceNumber&quot;);    &#10;                        &#9;                                                                                                                                                                         &#10;                        &#9;if(mappedAttribute != null) {                   &#9;                                                                                                                 &#10;                            &#9;&#9;paramsOldCaseEventSeq.setAttribute(&quot;newSequenceNumber&quot;, mappedAttribute.getValue());                                                                             &#10;                        &#9;} else {                                                                                                                                                                 &#10;                    &#9;                                                                                                                                                                                 &#10;                            &#9;&#9;loggerE.error(&quot;Unmapped CaseEvent Sequence for ID = &quot; +  caseEventIdStr + &quot; - Run Script mapCaseEventSeqAndNewCaseEventSeqToWpOutput for CaseEvent-To-WpOutput&quot;);&#10;                            &#9;&#9;//throw new RuntimeException(&quot;UnmappedID - Table WP Output - Case Event Sequence has not been mapped for &quot; + paramsOldCaseEventSeq.getText() + endStr);          &#10;                        &#9;}                                                                                                                                                                        &#10;                        &#9;                                                                                                                                                                         &#10;                                                                                                                                                                                                         &#10;                        }                                                                                                                                                                                &#10;                                                                                                                                                                                                         &#10;                    }                                                                                                                                                                                    &#10;                                                                                                                                                                                                         &#10;                }                                                                                                                                                                                        &#10;            }                                                                                                                                                                                            &#10;        } catch (JDOMException e) {                                                                                                                                                                      &#10;            loggerE.error(&quot;Jdom Exception ErrorError in Run Script mapCaseEventSeqAndNewCaseEventSeqToWpOutput for CaseEvent-To-WpOutput = &quot; + e.getMessage(), e);                                       &#10;        }                                                                                                                                                                                                &#10;      return doc;&#9;                                                                                                                                                                                 &#10;}                                                                                                                                                                                                        "/>
                    <pl:application-data name="description" type="property" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value="A PolarLake Platform Beanshell script must be coded to return a JDOM document.They can be composed from calls to imported modules as well as local methods.Only the first method in the script will be executed, so it should make any appropriate method calls if the entire script is not contained in it."/>
                </pl:application-data>
                <pl:application-data name="mapAEEventSeqToWpOutput" type="script" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value="">
                    <pl:application-data name="url" type="property" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value=""/>
                    <pl:application-data name="remote" type="property" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value="false"/>
                    <pl:application-data name="type" type="property" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value="beanshell"/>
                    <pl:application-data name="cache" type="property" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value="never_resolve"/>
                    <pl:application-data name="script" type="property" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value="import java.util.Iterator;                                                                                                                                                                      &#10;import java.util.List;                                                                                                                                                                          &#10;                                                                                                                                                                                                &#10;import org.apache.log4j.Logger;                                                                                                                                                                 &#10;                                                                                                                                                                                                &#10;import org.jdom.*;                                                                                                                                                                              &#10;import org.jdom.input.*;                                                                                                                                                                        &#10;import org.jdom.output.*;                                                                                                                                                                       &#10;import org.jdom.xpath.XPath;                                                                                                                                                                    &#10;                                                                                                                                                                                                &#10;import com.polarlake.platform.api.*;                                                                                                                                                            &#10;import com.polarlake.platform.api.helper.*;                                                                                                                                                     &#10;import com.polarlake.platform.api.exception.*;                                                                                                                                                  &#10;import com.polarlake.platform.common.ParameterName;                                                                                                                                             &#10;                                                                                                                                                                                                &#10;/**                                                                                                                                                                                             &#10; * A JDOM beanshell must return a JDOM document.                                                                                                                                                &#10; */                                                                                                                                                                                             &#10; Document processDocument(Document doc, ExecutiveProcessInterface process)                                                                                                                      &#10; {                                                                                                                                                                                              &#10;                                                                                                                                                                                                &#10;       XMLOutputter xo = new XMLOutputter(Format.getPrettyFormat());                                                                                                                            &#10;       Logger loggerI = Logger.getLogger(&quot;com.info&quot;);                                                                                                                                           &#10;       Logger loggerE = Logger.getLogger(&quot;com.error&quot;);                                                                                                                                          &#10;       Document docCaseEvent;                                                                                                                                                                   &#10;       Document docNewCaseEvent;                                                                                                                                                                &#10;       String endStr = &quot;  ID_AT_THE_END&quot;;                                                                                                                                                       &#10;                                                                                                                                                                                                &#10;      try                                                                                                                                                                                       &#10;      {                                                                                                                                                                                         &#10;          VariableContainerInterface vci = process.getProcessDocGroup();                                                                                                                        &#10;                                                                                                                                                                                                &#10;          if (vci != null)                                                                                                                                                                      &#10;          {                                                                                                                                                                                     &#10;              VariableInterface vi = vci.getVariable(&quot;Case-AEEvents&quot;);                                                                                                                          &#10;              docCaseEvent = (Document)vi.getValue();                                                                                                                                           &#10;          }                                                                                                                                                                                     &#10;      }                                                                                                                                                                                         &#10;      catch (DocVariableException dve)                                                                                                                                                          &#10;      {                                                                                                                                                                                         &#10;          loggerE.error(&quot;\n Error in Run Script mapAEEventSeqToWpOutput for AEEvent-To-WpOutput Mapper&quot;);                                                                                       &#10;      }                                                                                                                                                                                         &#10;                                                                                                                                                                                                &#10;        List paramsVariations;                                                                                                                                                                  &#10;        try {                                                                                                                                                                                   &#10;            paramsCaseEvent = XPath.selectNodes(doc, &quot;//WpOutput&quot;);                                                                                                                             &#10;                                                                                                                                                                                                &#10;            Iterator it = paramsCaseEvent.iterator();                                                                                                                                           &#10;            while(it.hasNext()) {                                                                                                                                                               &#10;                Element currentElement = (Element) it.next();                                                                                                                                   &#10;                                                                                                                                                                                                &#10;                if(currentElement instanceof Element) {                                                                                                                                         &#10;                                                                                                                                                                                                &#10;                    Element paramsOldAEEventSeq = (Element) XPath.selectSingleNode(currentElement, &quot;./AEEventSequence&quot;);                                                                        &#10;                                                                                                                                                                                                &#10;                    if(paramsOldAEEventSeq != null &amp;&amp; paramsOldAEEventSeq.getText() != null &amp;&amp; (!paramsOldAEEventSeq.getText().equals(&quot;&quot;))) {                                                   &#10;                                                                                                                                                                                                &#10;                    String aeEventIdStr = paramsOldAEEventSeq.getText();                                                                                                                        &#10;                                                                                                                                                                                                &#10;                        Attribute mappedAttribute = (Attribute) XPath.selectSingleNode(docCaseEvent, &quot;//AEEvent[OldSupsAEEventSeq =&quot; +aeEventIdStr+ &quot;]/AEEventSequence/@newSequenceNumber&quot;);  &#10;                                                                                                                                                                                                &#10;    &#9;&#9;&#9;if(mappedAttribute != null) {                                                                                                                                           &#10;                            paramsOldAEEventSeq.setAttribute(&quot;newSequenceNumber&quot;, mappedAttribute.getValue());                                                                                  &#10;                        } else {                                                                                                                                                                &#10;                                                                                                                                                                                                &#10;                                                                                                                                                                                                &#10;                        &#9;                                                                                                                                                                &#10;                        loggerE.error(&quot;Unmapped AEEvent Sequence for ID = &quot; +  aeEventIdStr + &quot; - Run Script mapAEEventSeqToWpOutput for AEEvent-To-WpOutput Mapper for CaseEvent-To-WpOutput&quot;);&#10;                        //throw new RuntimeException(&quot;UnmappedID - Table AE Event - AE Event Sequence has not been mapped for &quot; + paramsOldAEEventSeq.getText() + endStr);                      &#10;                        &#9;                                                                                                                                                                &#10;                        }                                                                                                                                                                       &#10;                                                                                                                                                                                                &#10;                    }                                                                                                                                                                           &#10;                                                                                                                                                                                                &#10;                }                                                                                                                                                                               &#10;            }                                                                                                                                                                                   &#10;        } catch (JDOMException e) {                                                                                                                                                             &#10;            loggerE.error(&quot;Jdom Exception ErrorError in Run Script mapAEEventSeqToWpOutput for AEEvent-To-WpOutput Mapper = &quot; + e.getMessage(), e);                                             &#10;        }                                                                                                                                                                                       &#10;      return doc;&#9;                                                                                                                                                                        &#10;}                                                                                                                                                                                               "/>
                    <pl:application-data name="description" type="property" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value="A PolarLake Platform Beanshell script must be coded to return a JDOM document.They can be composed from calls to imported modules as well as local methods.Only the first method in the script will be executed, so it should make any appropriate method calls if the entire script is not contained in it."/>
                </pl:application-data>
                <pl:application-data name="mapAddressToJudgment" type="script" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value="">
                    <pl:application-data name="url" type="property" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value=""/>
                    <pl:application-data name="remote" type="property" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value="false"/>
                    <pl:application-data name="type" type="property" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value="beanshell"/>
                    <pl:application-data name="cache" type="property" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value="never_resolve"/>
                    <pl:application-data name="script" type="property" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value="import java.lang.Double;&#10;import java.text.ParseException;&#10;import java.text.SimpleDateFormat;&#10;import java.util.ArrayList;&#10;import java.util.Date;&#10;import java.util.Iterator;&#10;import java.util.List;&#10;import java.util.HashMap;&#10;import java.util.TreeMap;&#10;&#10;import org.apache.log4j.Logger;&#10;&#10;import org.jdom.*;  &#10;import org.jdom.input.*;  &#10;import org.jdom.output.*;  &#10;import org.jdom.xpath.XPath;&#10;&#10;import com.polarlake.platform.api.*;  &#10;import com.polarlake.platform.api.helper.*;  &#10;import com.polarlake.platform.api.exception.*;  &#10;import com.polarlake.platform.common.ParameterName;&#10;  &#10;/**  &#10; * A JDOM beanshell must return a JDOM document.  &#10; */  &#10; Document processDocument(Document doc, ExecutiveProcessInterface process) &#10; { &#10;&#10;       XMLOutputter xo = new XMLOutputter(Format.getPrettyFormat());&#10;       Logger loggerI = Logger.getLogger(&quot;com.info&quot;);&#10;       Logger loggerE = Logger.getLogger(&quot;com.error&quot;);&#10;       Document docAddress;&#10;       TreeMap addressMap = new TreeMap();&#10;       Date rtlDate = null;&#10;&#10;       String processClaimantAddressID = Util.getProcessVariable (process, new ParameterName(&quot;plantiff_address_id&quot;));&#10;       loggerI.info(&quot;Process Claimant Address ID = &quot; + processClaimantAddressID);&#10;       &#10;      try &#10;      { &#10;          VariableContainerInterface vci = process.getProcessDocGroup(); &#10;&#10;          if (vci != null) &#10;          { &#10;              VariableInterface vi = vci.getVariable(&quot;Case-Defendants&quot;); &#10;              docAddress = (Document)vi.getValue();  &#10;          } &#10;      } &#10;      catch (DocVariableException dve) &#10;      { &#10;          loggerE.error(&quot;\n Error in Run Script mapAddressToJudgment for Case-Defendants-To-Judgment Mapper&quot;);&#10;      } &#10;&#10;        List paramsVariations;&#10;        try {&#10;            paramsVariations = XPath.selectNodes(doc, &quot;//Judgment&quot;);&#10;&#9;    &#10;            Iterator it = paramsVariations.iterator();&#10;            while(it.hasNext()) {&#10;                Element currentElement = (Element) it.next();&#10;&#10;                if(currentElement instanceof Element) {&#10;&#10;                    Element jdDeftID = (Element) XPath.selectSingleNode(currentElement, &quot;./AgainstCasePartyNo&quot;);&#10;                    Element jdPartyRoleCode = (Element) XPath.selectSingleNode(currentElement, &quot;./AgainstPartyRoleCode&quot;); &#10;                    Element jdSentToRTL = (Element) XPath.selectSingleNode(currentElement, &quot;./SentToRTL&quot;); &#10;                    Element jdRTLAddressID = (Element) XPath.selectSingleNode(currentElement, &quot;./RTLAddressID&quot;);  &#10;                  &#10;                    Element judgSequence = (Element) XPath.selectSingleNode(currentElement, &quot;./JudgSequence&quot;);   &#10;                    String judgString;&#10;                   &#10;                    if(judgSequence != null) {&#10;                    &#9;judgString = judgSequence.getText();&#9;&#10;                    }&#9;&#10;                                                        &#10;                    if(jdDeftID != null &amp;&amp; jdDeftID.getText() != null &amp;&amp; (!jdDeftID.getText().equals(&quot;&quot;)) &amp;&amp; jdPartyRoleCode != null &amp;&amp; jdPartyRoleCode.getText() != null &amp;&amp; (!jdPartyRoleCode.getText().equals(&quot;&quot;)) &amp;&amp; jdSentToRTL != null &amp;&amp; jdSentToRTL.getText() != null &amp;&amp; (!jdSentToRTL.getText().equals(&quot;&quot;))) {&#10;                    &#10;                    &#9;String deftID = jdDeftID.getText();&#10;                    &#9;String partyRoleCode = jdPartyRoleCode.getText();&#10;                    &#9;String sentToRTL = jdSentToRTL.getText();  &#10;                  &#9;                    &#9;&#10;                    &#9;if(partyRoleCode.equals(&quot;CLAIMANT&quot;)) {&#10;                            loggerI.info(&quot;Setting Judgment RTL Address ID for a Claimant Address ID = &quot; + processClaimantAddressID);&#10;                            jdRTLAddressID.setText(processClaimantAddressID);                   &#9;&#9;&#10;                    &#9;} else if (partyRoleCode.equals(&quot;DEFENDANT&quot;)) {&#10;                            loggerI.info(&quot;Determining Judgment RTL Address ID for a Defendant&quot;);&#10;                    &#9;                     &#9;   &#10;                    &#9;    Object countObject = XPath.selectSingleNode(docAddress, &quot;count(//Defendants/Defendant/DefendantAddress/Address[PartyRoleCode = \&apos;DEFENDANT\&apos; and CasePartyNo =&quot; +deftID+ &quot;]/AddressId)&quot;);&#10;              &#9;                   &#9;                     &#9;    &#10;                    &#9;    int addressCount = 0;&#10;                    &#9;    &#10;                    &#9;    if(countObject instanceof Double) {&#10;                    &#9;        loggerI.info(&quot;Integer count of Addresses = &quot; + countObject);&#10;                    &#9;    &#9;addressCount = ((Double)countObject).intValue();&#10;                    &#9;    } else {&#10;                    &#9;        loggerI.info(&quot;The type of object is = &quot; + countObject.getClass().getName());                   &#9;        &#10;                    &#9;    }&#10;                    &#9;                   &#9;&#10;                    &#9;    if(addressCount == 1) {&#10;                    &#9;        Element addressId = (Element) XPath.selectSingleNode(docAddress, &quot;//Defendants/Defendant/DefendantAddress/Address[PartyRoleCode = \&apos;DEFENDANT\&apos; and CasePartyNo =&quot; +deftID+ &quot;]/AddressId&quot;);&#10;                                loggerI.info(&quot;Setting Address ID for Judgment agaisnt the Defendant and their is only one address = &quot; + addressId.getText());&#10;                            &#9;jdRTLAddressID.setText(addressId.getText());&#10;                            } else if(addressCount &gt; 1) {&#10;                                 loggerI.info(&quot;Address Count is greater than 1 therefore need to determine the correct date&quot;);&#10;                                 &#10;                                 //Can&apos;t use Xpath casting for RTL date due to date problems with legacy date format for Judgment RTL Date is in dd-MMM-yy&#10;                    &#9;        loggerI.info(&quot;Processing RTL Date Format&quot;);&#10;        &#9;&#9;&#9;SimpleDateFormat dateFormat = new SimpleDateFormat(&quot;dd-MMM-yy&quot;);&#10;                                &#10;&#9;&#9;&#9;&#9;try {   &#10;          &#9;&#9; &#9;&#9;rtlDate = dateFormat.parse(sentToRTL);&#10;      &#9; &#9;&#9;&#9;} catch (ParseException pe) {&#10;           &#9;&#9; &#9;&#9;logger.error(&quot;ParseException caught due to the fact that in some instances the date format is somehow being corrupted, but reverting to using different date format - dirty fix&quot;);  &#10;&#9;                 &#9;&#9;dateFormat = new SimpleDateFormat(&quot;yyyy-MM-dd&quot;);&#10;&#9;                 &#10;&#9;                 &#9;&#9;try {&#10;          &#9;&#9; &#9;&#9;&#9;rtlDate = dateFormat.parse(sentToRTL);&#10;          &#9;&#9; &#9;&#9;&#9;logger.error(&quot;Dirty Fix has worked, carry on processing&quot;);&#10;          &#9;&#9; &#9;&#9;}  catch (ParseException pe) {&#10;          &#9;&#9; &#9;&#9;&#9;logger.error(&quot;ParseException caught again in mapAddressToJudgment for Case-Defendants-To-Judgment!!!&quot;);          &#9;&#9; &#10;          &#9;&#9; &#9;&#9;}&#9;                 &#9;                 &#9;                      &#10;       &#9;&#9;&#9;&#9;}&#10;&#10;                                dateFormat.applyPattern(&quot;yyyy-MM-dd&quot;);&#10;                                String rtlDateStr = dateFormat.format(rtlDate); &#10;                                loggerI.info(&quot;Processed RTL Date Format = &quot; + rtlDateStr);&#10;                   &#9;        &#10;                   &#9;        //Since we haven&apos;t got XPATH 2.0 revert to using Java to process and determine dates&#10;                   &#9;        List addressList = XPath.selectNodes(docAddress, &quot;//Defendants/Defendant/DefendantAddress/Address[PartyRoleCode = \&apos;DEFENDANT\&apos; and CasePartyNo =&quot; +deftID+ &quot;]&quot;);&#10;                 &#9;        &#10;            &#9;&#9;&#9;Iterator itAddress = addressList.iterator();&#10;                   &#9;        while(itAddress.hasNext()) {&#10;&#10;                &#9;&#9;&#9;Element currentAddressElement = (Element) itAddress.next();&#10; &#10;                &#9;&#9;&#9;if(currentAddressElement instanceof Element) {&#10;&#10;                    &#9;&#9;&#9;&#9;Element adAddressId = (Element) XPath.selectSingleNode(currentAddressElement, &quot;./AddressId&quot;);&#10;                    &#9;&#9;&#9;&#9;Element adValidFromId = (Element) XPath.selectSingleNode(currentAddressElement, &quot;./ValidFrom&quot;);&#10;                    &#9;&#9;&#9;&#9;Element adValidToId = (Element) XPath.selectSingleNode(currentAddressElement, &quot;./ValidTo&quot;);&#10;       &#9;&#9;&#9;&#9;&#10;                    &#9;&#9;&#9;&#9;if(adAddressId != null &amp;&amp; adAddressId.getText() != null &amp;&amp; (!adAddressId.getText().equals(&quot;&quot;)) &amp;&amp; adValidFromId != null &amp;&amp; adValidFromId.getText() != null &amp;&amp; (!adValidFromId.getText().equals(&quot;&quot;))) {&#10;          &#9;&#9;&#9;&#9;&#10;                    &#9;&#9;&#9;&#9;&#9;SimpleDateFormat dateFormatAddress = new SimpleDateFormat(&quot;yyyy-MM-dd&quot;);              &#10;                                &#9;&#9;&#9;Date validFROMDate = null;&#10;&#9;&#9;&#9;&#9;&#9;&#9;&#9;try {   &#10;          &#9;&#9; &#9;&#9;&#9;&#9;&#9;validFROMDate = dateFormat.parse(adValidFromId.getText());&#10;      &#9; &#9;&#9;&#9;&#9;&#9;&#9;} catch (ParseException pe) {&#10;           &#9;&#9; &#9;&#9;&#9;&#9;&#9;logger.error(&quot;ParseException caught&quot;);  &#10;&#9;                &#9;                 &#9;                 &#9;                      &#10;       &#9;&#9;&#9;&#9;&#9;&#9;&#9;}&#10;                                &#9;&#9;&#9;String validFROMDateStr = dateFormat.format(validFROMDate); &#10;                                &#9;&#9;&#9;loggerI.info(&quot;Processed Valid To Date Format = &quot; + validFROMDate);&#10;                                 &#9;&#9;&#9;loggerI.info(&quot;Processed Address ID = &quot; + adAddressId.getText());&#10;                    &#9;&#9;&#9;&#9;&#9;addressMap.put(Integer.valueOf(adAddressId.getText()), validFROMDate);     &#9;      &#10;                    &#9;&#9;&#9;&#9;}&#10;                    &#9;&#9;&#9;}                  &#9;        &#10;                   &#9;        } &#10;               &#9;                           &#9;         &#10;                   &#9;        Iterator itKeyAddress = addressMap.keySet().iterator();&#10;&#9;&#9;&#9;&#9;ArrayList arry = new ArrayList();&#10;&#9;&#9;&#9;&#9;&#10;                   &#9;        while(itKeyAddress.hasNext()) {                  &#9;        &#10;                   &#9;                Integer itT = (Integer) itKeyAddress.next();                &#9;                &#10;&#9;&#9;&#9;&#9;&#9;Date retValidFrom = (Date) addressMap.get(itT);&#10;&#9;&#9;&#9;&#9;&#9;if(retValidFrom.before(rtlDate) || retValidFrom.equals(rtlDate)) {&#10;&#9;&#9;&#9;&#9;&#9;&#9;//Do nothing&#10;&#9;&#9;&#9;&#9;&#9;&#9;loggerI.info(&quot;Keeping defendant IDs = &quot; + itT);&#10;&#9;&#9;&#9;&#9;&#9;} else {&#10; &#9;&#9;&#9;&#9;                loggerI.info(&quot;Adding defendant IDs for removal into Array list  = &quot; + itT);&#10;&#9;&#9;&#9;&#9;&#9;        arry.add(itT);&#9;&#9;&#9;&#9;&#9;        &#10;&#9;&#9;&#9;&#9;&#9;        //Won&apos;t work because of sync&#10;&#9;&#9;&#9;&#9;&#9;&#9;//addressMap.remove(itT);&#10;&#9;&#9;&#9;&#9;&#9;}&#10;                   &#9;        } &#10;&#9;&#9;&#9;&#9;Iterator itRemoveAddress = arry.iterator();&#10; &#9;&#9;&#9;&#9;while(itRemoveAddress.hasNext()) {&#10; &#9;&#9;&#9;&#9;&#9;addressMap.remove(itRemoveAddress.next());&#10; &#9;&#9;&#9;&#9;}&#10;&#10;&#9;&#9;&#9;&#9;if(!addressMap.isEmpty()) {&#10;                   &#9;        &#9;loggerI.info(&quot;Defendant Address has been mapped to  = &quot; + ((Integer) addressMap.firstKey()));&#10;                   &#9;        &#9;jdRTLAddressID.setText(((Integer) addressMap.firstKey()).toString());                  &#9;        &#10;                   &#9;        } else {&#10;                            &#9;&#9;loggerI.info(&quot;UnmappedID in Iteration - Judgment for Defendant where defendant id = &quot; +  deftID + &quot; And Judgement Sequence = &quot; + judgString + &quot; - Run Script mapAddressToJudgment for Case-Defendants-To-Judgment&quot;);&#10;                   &#9;        }            &#9;        &#10;                    &#9;                                        &#10;                            } else {&#10;                            &#9;loggerI.info(&quot;UnmappedID - Judgment for Defendant where defendant id = &quot; +  deftID + &quot; And Judgement Sequence = &quot; + judgString + &quot; - Run Script mapAddressToJudgment for Case-Defendants-To-Judgment&quot;);&#10;&#9;       &#9;&#9;&#9;String endStr = &quot;  ID_AT_THE_END&quot;;&#10;                            //throw new RuntimeException(&quot;UnmappedID - Judgment - Judgement for Defendant has not been mapped for defendant id = &quot; + jdDeftID.getText() + endStr);&#10;                            }                    &#9;                 &#9;&#10;                    &#9;}                                               &#10;                    }&#10;                }&#10;            }&#10;        } catch (JDOMException e) {&#10;            loggerE.error(&quot;Jdom Exception ErrorError in Run Script mapAddressToJudgment for Case-Defendants-To-Judgment for = &quot; + e.getMessage(), e);  &#10;        }&#10;      return doc;&#9;&#10;} &#10;"/>
                    <pl:application-data name="description" type="property" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value="A PolarLake Platform Beanshell script must be coded to return a JDOM document.They can be composed from calls to imported modules as well as local methods.Only the first method in the script will be executed, so it should make any appropriate method calls if the entire script is not contained in it."/>
                </pl:application-data>
            </pl:application-data>
            <pl:application-data name="Statistics sensors" type="sensors" application="com.polarlake.sysinfo.SystemInformation"/>
            <pl:application-data name="Condition Groups" type="conditiongroups" application="com.polarlake.platform.librarymodule.LibraryModuleApplication"/>
            <pl:application-data name="XML Wrapper Request Processors" type="Wrapper-Request-Processors" application="com.polarlake.requestprocessors.wrapper.WrapperApplication"/>
            <pl:application-data name="Document Variables" type="documentvariables" application="SYSTEM">
                <pl:application-data name="Case-Sups" type="document">
                    <pl:application-data name="schema" type="property" application="" value=""/>
                    <pl:application-data name="type" type="property" application="" value="xml"/>
                    <pl:application-data name="root" type="property" application="" value="/Cases"/>
                </pl:application-data>
                <pl:application-data name="Case-Status" type="document">
                    <pl:application-data name="schema" type="property" application="" value="cases"/>
                    <pl:application-data name="type" type="property" application="" value="xml"/>
                    <pl:application-data name="root" type="property" application="" value="/Cases"/>
                </pl:application-data>
                <pl:application-data name="Case-Events" type="document">
                    <pl:application-data name="schema" type="property" application="" value="case_event"/>
                    <pl:application-data name="type" type="property" application="" value="xml"/>
                    <pl:application-data name="root" type="property" application="" value="/CaseEvents"/>
                </pl:application-data>
                <pl:application-data name="Cases" type="document">
                    <pl:application-data name="schema" type="property" application="" value=""/>
                    <pl:application-data name="type" type="property" application="" value="xml"/>
                    <pl:application-data name="root" type="property" application="" value="/Cases"/>
                </pl:application-data>
                <pl:application-data name="CaseEventMap" type="document">
                    <pl:application-data name="schema" type="property" application="" value="case_events_map"/>
                    <pl:application-data name="type" type="property" application="" value="xml"/>
                    <pl:application-data name="root" type="property" application="" value="/NonLegacyEvents"/>
                </pl:application-data>
                <pl:application-data name="Case-Judgment" type="document">
                    <pl:application-data name="schema" type="property" application="" value="judgment"/>
                    <pl:application-data name="type" type="property" application="" value="xml"/>
