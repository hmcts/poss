                    <pl:application-data name="script" type="property" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value="import java.util.Iterator;&#10;import java.util.List;&#10;&#10;import org.apache.log4j.Logger;&#10;&#10;import org.jdom.*;  &#10;import org.jdom.input.*;  &#10;import org.jdom.output.*;  &#10;import org.jdom.xpath.XPath;&#10;&#10;import com.polarlake.platform.api.*;  &#10;import com.polarlake.platform.api.helper.*;  &#10;import com.polarlake.platform.api.exception.*;  &#10;import com.polarlake.platform.common.ParameterName;&#10;  &#10;/**  &#10; * A JDOM beanshell must return a JDOM document.  &#10; */  &#10; Document processDocument(Document doc, ExecutiveProcessInterface process) &#10; { &#10; &#10;       XMLOutputter xo = new XMLOutputter(Format.getPrettyFormat());&#10;       Logger loggerI = Logger.getLogger(&quot;com.info&quot;);&#10;       Logger loggerE = Logger.getLogger(&quot;com.error&quot;);&#10;       Document docCaseEvent;&#10;&#10;      try &#10;      { &#10;          VariableContainerInterface vci = process.getProcessDocGroup(); &#10;&#10;          if (vci != null) &#10;          { &#10;              VariableInterface vi = vci.getVariable(&quot;Case-Events&quot;); &#10;              docCaseEvent = (Document)vi.getValue();  &#10;          } &#10;      } &#10;      catch (DocVariableException dve) &#10;      { &#10;          loggerE.error(&quot;\n Error in Run Script mapCaseEventSeqToEchrArticleProtocol for CaseEvent-To-EchrArticleProtocol Mapper&quot;);&#10;      } &#10;&#10;        List paramsCaseEvent;&#10;        try {&#10;            paramsCaseEvent = XPath.selectNodes(doc, &quot;//ECHRArticleProtocol&quot;);&#10;&#10;            Iterator it = paramsCaseEvent.iterator();&#10;            while(it.hasNext()) {&#10;                Element currentElement = (Element) it.next();&#10;&#10;                if(currentElement instanceof Element) {&#10;&#10;                    Element paramsCaseEventSeq = (Element) XPath.selectSingleNode(currentElement, &quot;./EventSeq&quot;);    &#10;                   &#10;                    &#10;                    if(paramsCaseEventSeq != null &amp;&amp; paramsCaseEventSeq.getText() != null &amp;&amp; (!paramsCaseEventSeq.getText().equals(&quot;&quot;))) {&#10;&#10;                    String ceIdStr = paramsCaseEventSeq.getText();&#10;&#10;                        Attribute mappedAttribute = (Attribute) XPath.selectSingleNode(docCaseEvent, &quot;//CaseEvent[EventSequence =&quot; +ceIdStr+ &quot;]/EventSequence/@newSequenceNumber&quot;);&#10;&#10;    &#9;&#9;&#9;if(mappedAttribute != null) {&#10;                            paramsCaseEventSeq.setText(mappedAttribute.getValue());&#10;                        } else {&#10;                            loggerE.error(&quot;Unmapped Event Sequence for ID = &quot; + ceIdStr + &quot; - Run Script mapCaseEventSeqToEchrArticleProtocol for CaseEvent-To-EchrArticleProtocol &quot;);&#10;&#9;       String endStr = &quot;  ID_AT_THE_END&quot;;&#10;                            throw new RuntimeException(&quot;UnmappedID - Table EchrArticleProtocol - Case Event Sequence has not been mapped for &quot; + paramsCaseEventSeq.getText() + endStr);&#10;                        }&#10;                            &#10;                    } &#10;                    &#10;                    &#10;                }&#10;            }&#10;        } catch (JDOMException e) {&#10;            loggerE.error(&quot;Jdom Exception ErrorError in Run Script mapCaseEventSeqToEchrArticleProtocol for CaseEvent-To-EchrArticleProtocol = &quot; + e.getMessage(), e);  &#10;        }&#10;      return doc;&#9;&#10;} "/>
