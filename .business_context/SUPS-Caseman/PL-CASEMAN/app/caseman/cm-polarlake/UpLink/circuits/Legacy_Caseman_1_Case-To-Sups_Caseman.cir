                <pl:parameter name="transaction_key" value="First"/>
                <pl:parameter name="sql" value="select t.transfer_number, t.trans_seq, t.SENDING_COURT_CODE from transfer_control t, cases c where t.transfer_type = &apos;C&apos; and t.TRANSFER_STATUS = &apos;1&apos; and t.RECEIVING_COURT_CODE = ? and c.case_number = t.transfer_number and c.TRANS_SEQ = t.TRANS_SEQ and c.TRANS_CRT_CODE is not null"/>
