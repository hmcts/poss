                </pl:parameter>
                <pl:parameter name="transaction_key" value="Second"/>
                <pl:parameter name="sql" value="select addr_sequence.nextval as add_val,  parties_sequence.nextval as party_val from dual"/>
                <pl:parameter name="forward_option" value="8"/>
                <pl:parameter name="sqlwarntoerror" value="false"/>
                <pl:parameter name="query" value="true"/>
                <pl:parameter name="input_mappings"/>
