                    <pl:application-data name="script" type="property" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value="import org.apache.log4j.Logger;&#10;import java.text.ParseException;&#10;import java.text.SimpleDateFormat;&#10;import java.util.Date;&#10;&#10;String formatDates(String pDate)&#10;    {&#10;&#10;        Logger logger = Logger.getLogger(&quot;com.info&quot;);&#10;        String function_name = &quot;formatDatesForSelect&quot;;&#10;&#10;        logger.info(&quot;Date String is for  &quot; + function_name + &quot; , = &quot; +pDate);&#10;&#10;        if(pDate != null &amp;&amp; (!pDate.trim().equals(&quot;&quot;)) &amp;&amp; (!pDate.trim().equals(&quot;null&quot;))) {&#9;&#10;        &#9;SimpleDateFormat dateFormat = null;&#10;&#10;        &#9;dateFormat = new SimpleDateFormat(&quot;dd-MMM-yy&quot;);&#10;        &#9;//dateFormat = new SimpleDateFormat(&quot;yyyy-MM-dd&quot;);&#10;       &#9;Date parseDate = null;&#10;&#9;try {&#10;          &#9;&#9; parseDate = dateFormat.parse(pDate);&#10;      &#9; } catch (ParseException pe) {&#10;           &#9;&#9; logger.error(&quot;ParseException caught not sure why, but reverting to using different date format - dirty fix&quot;);  &#10;&#9;                 dateFormat = new SimpleDateFormat(&quot;yyyy-MM-dd&quot;);&#10;&#9;                 &#10;&#9;                 try {&#10;          &#9;&#9; &#9;parseDate = dateFormat.parse(pDate);&#10;          &#9;&#9; &#9;logger.error(&quot;Dirty Fix has worked, carry on processing&quot;);&#10;          &#9;&#9; }  catch (ParseException pe) {&#10;          &#9;&#9; &#9;logger.error(&quot;ParseException caught again!!!&quot;);&#10;          &#9;&#9; &#10;          &#9;&#9; }&#9;                 &#9;                 &#10;&#9;                      &#10;       &#9;}&#10;         &#9;dateFormat.applyPattern(&quot;yyyy-MM-dd&quot;);&#10;&#9; logger.info(&quot;Date is not null in &quot; + function_name + &quot; , returning = &quot; + dateFormat.format(parseDate));&#10;       &#9;return dateFormat.format(parseDate);&#10;       } else {&#10;&#9; logger.info(&quot;Date is null in &quot; + function_name + &quot; , returning null&quot;);&#10;&#9;return &quot;&quot;;&#10;        }&#10;    }"/>
                    <pl:application-data name="description" type="property" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value=""/>
                </pl:application-data>
                <pl:application-data name="truncateAmendmentCol" type="function" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value="">
                    <pl:application-data name="type" type="property" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value="beanshell"/>
                    <pl:application-data name="methodName" type="property" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value="truncateAmendmentCol"/>
                    <pl:application-data name="category" type="property" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value="Miscellaneous"/>
                    <pl:application-data name="script" type="property" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value="import org.apache.log4j.Logger;&#10;&#10;String truncateAmendmentCol(String pStatus)&#10;    {&#10;        Logger logger = Logger.getLogger(&quot;com.info&quot;);&#10;        String function_name = &quot;truncateAmendmentCol&quot;;&#10;&#10;        if (pStatus != null &amp;&amp; (!pStatus.trim().equals(&quot;&quot;)) &amp;&amp; pStatus.substring(0, 1).equals(&quot;Y&quot;)) {&#10;&#9; logger.info(&quot;Amendment Col value for &quot; + function_name + &quot;  =  N&quot; );&#10;       &#9;return &quot;N&quot;;&#10;        } else {&#10;&#9; logger.info(&quot;Amendment Col value &quot; + function_name + &quot;  =  Y&quot;);&#10;       &#9;return &quot;Y&quot;;&#10;       }&#10;    }"/>
                    <pl:application-data name="description" type="property" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value=""/>
                </pl:application-data>
                <pl:application-data name="determinePartyRoleCodeForEmployerWithDeftID" type="function" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value="">
                    <pl:application-data name="type" type="property" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value="beanshell"/>
                    <pl:application-data name="methodName" type="property" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value="determinePartyRoleCodeForEmployer"/>
                    <pl:application-data name="category" type="property" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value="Miscellaneous"/>
                    <pl:application-data name="script" type="property" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value="import org.apache.log4j.Logger;&#10;&#10;String determinePartyRoleCodeForEmployer(String pParty, String pDeftID)&#10;    {&#10;        Logger logger = Logger.getLogger(&quot;com.info&quot;);&#10;        String function_name = &quot;determinePartyRoleCodeForEmployer&quot;;&#10;&#10;        if(pParty != null &amp;&amp; (!pParty.trim().equals(&quot;&quot;)) &amp;&amp; (!pParty.trim().equals(&quot;EMPLOYER&quot;)) &amp;&amp; pDeftID != null &amp;&amp;  (!pDeftID.trim().equals(&quot;0&quot;))) {&#9;&#10;        &#9;&#10;&#9; logger.info(&quot;Party Role Code for &quot; + function_name + &quot; , is not Employer and is a Defendant&quot;);&#10;       &#9;return &quot;DEFENDANT&quot;;&#10;       &#9;&#10;       &#9;} else if(pParty != null &amp;&amp; (!pParty.trim().equals(&quot;&quot;)) &amp;&amp; (!pParty.trim().equals(&quot;EMPLOYER&quot;)) &amp;&amp; pDeftID != null &amp;&amp;  (pDeftID.trim().equals(&quot;0&quot;))) {&#9;&#10;        &#9;&#10;&#9; logger.info(&quot;Party Role Code for &quot; + function_name + &quot; , is not Employer and is a Claimant&quot;);&#10;       &#9;return &quot;CLAIMANT&quot;;&#10;      &#9;&#10;       } else if(pParty != null &amp;&amp; (!pParty.trim().equals(&quot;&quot;)) &amp;&amp; (pParty.trim().equals(&quot;EMPLOYER&quot;))) {&#9;&#10;        &#9;&#10;&#9; logger.info(&quot;Party Role Code for &quot; + function_name + &quot; , is Employer&quot;);&#10;       &#9;return &quot;EMPLOYER&quot;;&#10;       } else {&#10;&#9; logger.info(&quot;Event Party Role Code for &quot; + function_name + &quot; , is Party Role is Empty&quot;);&#10;&#9;return &quot;&quot;;&#10;        }&#10;    }"/>
                    <pl:application-data name="description" type="property" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value=""/>
                </pl:application-data>
                <pl:application-data name="incrementDeftID" type="function" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value="">
                    <pl:application-data name="type" type="property" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value="beanshell"/>
                    <pl:application-data name="methodName" type="property" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value="incrementDeftID"/>
                    <pl:application-data name="category" type="property" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value="Miscellaneous"/>
                    <pl:application-data name="script" type="property" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value="import org.apache.log4j.Logger;&#10;&#10;String incrementDeftID(String pDeftID)&#10;    {&#10;        Logger logger = Logger.getLogger(&quot;com.info&quot;);&#10;        String function_name = &quot;incrementDeftID&quot;;&#10;&#10;        if(pDeftID != null &amp;&amp; (!pDeftID.trim().equals(&quot;&quot;))) {&#9;&#10;        &#9;&#10;&#9; logger.info(&quot;DEFT ID - Adding one -  for &quot; + function_name + &quot; = &quot; +pDeftID);&#10;       &#9;return Integer.toString((Integer.parseInt(pDeftID)+1));&#10;       } else {&#10;&#9; logger.info(&quot;DeftID &quot; + function_name + &quot; = &quot; +pDeftID);&#10;       &#9;return pDeftID;&#10;       }&#10;    }"/>
                    <pl:application-data name="description" type="property" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value=""/>
                </pl:application-data>
                <pl:application-data name="determineRequestorforEvent160" type="function" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value="">
                    <pl:application-data name="type" type="property" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value="beanshell"/>
                    <pl:application-data name="methodName" type="property" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value="determineRequestorforEvent160"/>
                    <pl:application-data name="category" type="property" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value="Miscellaneous"/>
                    <pl:application-data name="script" type="property" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value="import org.apache.log4j.Logger;&#10;&#10;String determineRequestorforEvent160(String pParty, String pEventID)&#10;    {&#10;        Logger logger = Logger.getLogger(&quot;com.info&quot;);&#10;        String function_name = &quot;determineRequestorforEvent160&quot;;&#10;&#10;        if(pParty != null &amp;&amp; (!pParty.trim().equals(&quot;&quot;)) &amp;&amp; (pParty.trim().equals(&quot;CLAIMANT&quot;)) &amp;&amp; &#10;        pEventID != null &amp;&amp; (!pEventID.trim().equals(&quot;&quot;)) &amp;&amp; (pEventID.trim().equals(&quot;160&quot;))) {&#9;&#10;                &#9;&#9;&#10;&#9; logger.info(&quot;Requestor for &quot; + function_name + &quot; , is a PARTY FOR&quot;);&#10;       &#9;return &quot;PARTY FOR&quot;;&#10;       } else if(pParty != null &amp;&amp; (!pParty.trim().equals(&quot;&quot;)) &amp;&amp; (pParty.trim().equals(&quot;DEFENDANT&quot;)) &amp;&amp; &#10;        pEventID != null &amp;&amp; (!pEventID.trim().equals(&quot;&quot;)) &amp;&amp; (pEventID.trim().equals(&quot;160&quot;))) {&#9;&#9;&#10;        &#9;&#10;&#9; logger.info(&quot;Requestor for &quot; + function_name + &quot; , is PARTY AGAISNT&quot;);&#10;       &#9;return &quot;PARTY AGAINST&quot;;&#10;       } else if  (pParty != null &amp;&amp; (!pParty.trim().equals(&quot;&quot;))){&#10;&#9; logger.info(&quot;Event Party Role Code for &quot; + function_name + &quot; , is Requestor is not a 160&quot;);&#10;&#9;return pParty;&#10;        } else {&#10; &#9;logger.info(&quot;Event Party Role Code for &quot; + function_name + &quot; , is Requestor is not a 160&quot;);&#10;&#9;return &quot;&quot;;&#10;       }&#10;    }"/>
                    <pl:application-data name="description" type="property" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value=""/>
                </pl:application-data>
                <pl:application-data name="determineBMSType" type="function" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value="">
                    <pl:application-data name="type" type="property" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value="beanshell"/>
                    <pl:application-data name="methodName" type="property" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value="determineBMSType"/>
                    <pl:application-data name="category" type="property" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value="Miscellaneous"/>
                    <pl:application-data name="script" type="property" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value="import org.apache.log4j.Logger;&#10;&#10;import org.jdom.*;  &#10;import org.jdom.input.*;  &#10;import org.jdom.output.*;  &#10;import org.jdom.xpath.XPath;&#10;&#10;import com.polarlake.platform.api.*;  &#10;import com.polarlake.platform.api.helper.*;  &#10;import com.polarlake.platform.api.exception.*;  &#10;import com.polarlake.platform.common.ParameterName;&#10;&#10;String determineBMSType(String pCaseType, String pEventID)&#10;    {&#10;        Logger logger = Logger.getLogger(&quot;com.info&quot;);&#10;        String function_name = &quot;determineBMSType&quot;;&#10;        &#10;        &#10;       &#9;Logger loggerE = Logger.getLogger(&quot;com.error&quot;);&#10;       &#9;Document docBmsCaseTypes;&#10;      &#9;try &#10;      &#9;{ &#10;      &#9;  ExecutiveProcessInterface process;&#10;          VariableContainerInterface vci = process.getProcessDocGroup(); &#10;&#10;          if (vci != null) &#10;          { &#10;              &#9;VariableInterface vi = vci.getVariable(&quot;BmsCaseTypes&quot;); &#10;              &#9;docBmsCaseTypes = (Document)vi.getValue();  &#10;          } &#10;      &#9;} &#10;      &#9;catch (DocVariableException dve) &#10;      &#9;{ &#10;        &#9;loggerE.error(&quot;\n Error in Function Script in retrieving the BmsCaseType Doc var in  &quot;+ function_name);&#10;      &#9;}&#10;        if(pCaseType != null &amp;&amp; (!pCaseType.trim().equals(&quot;&quot;)) &amp;&amp; &#10;        pEventID != null &amp;&amp; (!pEventID.trim().equals(&quot;&quot;)) &amp;&amp; (!pEventID.trim().equals(&quot;0&quot;))) {&#9;&#9;&#9;        &#10;&#9;        try {&#10;&#9;            Element paramsCaseTypes = XPath.selectSingleNode(doc, &quot;//CaseType[Type =\&apos;&quot; + pCaseType + &quot;\&apos;]/BMSCourtType&quot;);       &#10;&#9;&#9;    if(paramsCaseTypes != null &amp;&amp; paramsCaseTypes.getText() != null &amp;&amp;  (!paramsCaseTypes.getText().equals(&quot;&quot;))) {&#10;&#9;    &#9;&#9;    &#10;&#9;&#9;    &#9;Element paramsBmsTypes = XPath.selectSingleNode(doc, &quot;//Event[EventID =&quot; + pEventID + &quot; and Type =\&apos;&quot;+ paramsCaseTypes.getText() +&quot;\&apos;]/BmsTask&quot;);&#10;&#10;&#9;&#9;    &#9; if(paramsBmsTypes != null &amp;&amp; paramsBmsTypes.getText() != null &amp;&amp;  (!paramsBmsTypes.getText().equals(&quot;&quot;))) {&#10;&#9;&#9;    &#9; &#9;logger.info(&quot;BMS Type for &quot; + function_name + &quot; , is &quot; + paramsBmsTypes.getText());&#10;&#9;&#9;    &#9; &#9;return paramsBmsTypes.getText();&#10;&#9;&#9;    &#9; } else {&#10;&#9;&#9;&#9;&#9;logger.info(&quot;No BMS Type for &quot; + function_name + &quot; , in Else - No Bms Returned&quot;);&#10;&#9;&#9;    &#9;&#9;return &quot;&quot;;&#10;&#9;&#9;    &#9; }&#9;&#10;&#9;&#9;    &#9;&#9;    &#10;&#9;&#9;    } else {&#10;&#9;&#9;&#9;logger.info(&quot;No BMS Type for &quot; + function_name + &quot; , in Second Last Else - unmatched Court Type&quot;);&#10;&#9;&#9;    &#9;return &quot;&quot;;&#10;&#9;&#9;    }&#10;&#9;&#9;&#10;&#9;&#10;&#9;        } catch (JDOMException e) {&#10;&#9;            loggerE.error(&quot;Jdom Exception ErrorError in Run Script DefendantClaimant Map Events = &quot; + e.getMessage(), e);  &#10;&#9;        }&#9;&#10;        &#9;&#9;   &#9;&#9;  &#9;&#9;&#9;&#10;&#10;        } else {&#10;&#9;&#9;logger.info(&quot;No BMS Type for &quot; + function_name + &quot; , in Last Else, either CaseType or Event id is null or empty&quot;);&#10;&#9;&#9;return &quot;&quot;;&#10;        }&#10;    }"/>
                    <pl:application-data name="description" type="property" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value=""/>
                </pl:application-data>
                <pl:application-data name="formatVariationResult" type="function" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value="">
                    <pl:application-data name="type" type="property" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value="beanshell"/>
                    <pl:application-data name="methodName" type="property" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value="formatVariationResult"/>
                    <pl:application-data name="category" type="property" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value="Miscellaneous"/>
                    <pl:application-data name="script" type="property" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value="import org.apache.log4j.Logger;&#10;&#10;String formatVariationResult(String pResult) {&#10;&#9;Logger logger = Logger.getLogger(&quot;com.info&quot;);&#10;&#9;String function_name = &quot;formatVariationResult&quot;;&#10;&#10;&#9;if(pResult != null &amp;&amp; (pResult.trim().equals(&quot;TRANSFERRED&quot;)) ) {&#10;&#9;&#9;logger.info(&quot;Result for &quot; + function_name + &quot; , &quot; +pResult + &quot; Set to empty&quot;);&#10;&#9;&#9;return &quot;&quot;;&#10;&#9;} else if (pResult != null) {&#10;&#9;    &#9;logger.info(&quot;Result for for &quot; + function_name + &quot; , &quot; +pResult);&#10;&#9;&#9;return pResult;&#10;&#9;} else {&#10;&#9;    &#9;logger.info(&quot;Result for for &quot; + function_name + &quot; , &quot; +pResult);&#10;&#9;&#9;return&quot;&quot;;&#10;&#9;}&#10;&#9;&#10;&#9;&#10;}"/>
                    <pl:application-data name="description" type="property" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value=""/>
                </pl:application-data>
                <pl:application-data name="formatVariationResultDate" type="function" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value="">
                    <pl:application-data name="type" type="property" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value="beanshell"/>
                    <pl:application-data name="methodName" type="property" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value="formatVariationResultDate"/>
                    <pl:application-data name="category" type="property" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value="Miscellaneous"/>
                    <pl:application-data name="script" type="property" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value="import org.apache.log4j.Logger;&#10;&#10;String formatVariationResultDate(String pResult, String pResultDate) {&#10;&#9;Logger logger = Logger.getLogger(&quot;com.info&quot;);&#10;&#9;String function_name = &quot;formatVariationResultDate&quot;;&#10;&#10;&#9;if(pResult != null &amp;&amp; (pResult.trim().equals(&quot;TRANSFERRED&quot;)) ) {&#10;&#9;&#9;logger.info(&quot;Result for &quot; + function_name + &quot; , &quot; +pResult + &quot; Set to empty&quot;);&#10;&#9;&#9;return &quot;&quot;;&#10;&#9;} else {&#10;&#9;    &#9;logger.info(&quot;Result for for &quot; + function_name + &quot; , &quot; +pResult);&#10;&#9;&#9;return pResultDate;&#10;&#9;}&#10;&#9;&#10;}"/>
                    <pl:application-data name="description" type="property" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value=""/>
                </pl:application-data>
                <pl:application-data name="determineRequestor" type="function" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value="">
                    <pl:application-data name="type" type="property" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value="beanshell"/>
                    <pl:application-data name="methodName" type="property" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value="determineRequestor"/>
                    <pl:application-data name="category" type="property" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value="Miscellaneous"/>
                    <pl:application-data name="script" type="property" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value="import org.apache.log4j.Logger;&#10;&#10;String determineRequestor(String pParty)&#10;    {&#10;        Logger logger = Logger.getLogger(&quot;com.info&quot;);&#10;        String function_name = &quot;determineRequestorforEvent160&quot;;&#10;&#10;        if(pParty != null &amp;&amp; (!pParty.trim().equals(&quot;&quot;)) &amp;&amp; (pParty.trim().equals(&quot;CLAIMANT&quot;))) {&#9;&#10;                &#9;&#9;&#10;&#9; logger.info(&quot;Requestor for &quot; + function_name + &quot; , is a PARTY FOR&quot;);&#10;       &#9;return &quot;PARTY FOR&quot;;&#10;       } else if(pParty != null &amp;&amp; (!pParty.trim().equals(&quot;&quot;)) &amp;&amp; (pParty.trim().equals(&quot;DEFENDANT&quot;))) {&#9;&#9;&#10;        &#9;&#10;&#9; logger.info(&quot;Requestor for &quot; + function_name + &quot; , is PARTY AGAISNT&quot;);&#10;       &#9;return &quot;PARTY AGAINST&quot;;&#10;       } else if  (pParty != null &amp;&amp; (!pParty.trim().equals(&quot;&quot;))){&#10;&#9; logger.info(&quot;Event Party Role Code for &quot; + function_name + &quot; , is &quot; + pParty);&#10;&#9;return pParty;&#10;        } else {&#10; &#9;logger.info(&quot;Event Party Role Code for &quot; + function_name + &quot; , No Party Role&quot;);&#10;&#9;return &quot;&quot;;&#10;       }&#10;    }"/>
                    <pl:application-data name="description" type="property" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value=""/>
                </pl:application-data>
                <pl:application-data name="determineWftTrack" type="function" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value="">
                    <pl:application-data name="type" type="property" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value="beanshell"/>
                    <pl:application-data name="methodName" type="property" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value="determineWftTrack"/>
                    <pl:application-data name="category" type="property" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value="Miscellaneous"/>
                    <pl:application-data name="script" type="property" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value="import org.apache.log4j.Logger;&#10;&#10;String determineWftTrack(String pWftTrack)&#10;    {&#10;        Logger logger = Logger.getLogger(&quot;com.info&quot;);&#10;        String function_name = &quot;determineWftTrack&quot;;&#10;&#10;        if(pWftTrack != null &amp;&amp; (!pWftTrack.trim().equals(&quot;&quot;)) &amp;&amp; (pWftTrack.trim().equals(&quot;SMALL CLAIM&quot;))) {&#9;&#10;                &#9;&#9;&#10;&#9;&#9;logger.info(&quot;WFT Track &quot; + function_name + &quot; , is &quot; + pWftTrack);&#10;       &#9;&#9;return &quot;SMALL&quot;;&#10;       } else if  (pWftTrack != null &amp;&amp; (!pWftTrack.trim().equals(&quot;&quot;))){&#10;       &#10;&#9;&#9;logger.info(&quot;WFT Track &quot; + function_name + &quot; , is &quot; + pWftTrack);&#9; &#10;&#9;&#9;return pWftTrack;&#10;        } else {&#10;        &#10;&#9;&#9;logger.info(&quot;WFT Track &quot; + function_name + &quot; , is &quot; + pWftTrack);&#9; &#10;&#9;&#9;return &quot;&quot;;&#10;       }&#10;    }"/>
                    <pl:application-data name="description" type="property" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value=""/>
                </pl:application-data>
                <pl:application-data name="determineReceiptDateforEvent160" type="function" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value="">
                    <pl:application-data name="type" type="property" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value="beanshell"/>
                    <pl:application-data name="methodName" type="property" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value="determineReceiptDateforEvent160"/>
                    <pl:application-data name="category" type="property" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value="Miscellaneous"/>
                    <pl:application-data name="script" type="property" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value="import org.apache.log4j.Logger;&#10;&#10;String determineReceiptDateforEvent160(String pEventId, String receiptDate, String eventDate)&#10;    {&#10;        Logger logger = Logger.getLogger(&quot;com.info&quot;);&#10;        String function_name = &quot;determineReceiptDateforEvent160&quot;;&#10;&#10;        if(pEventId != null &amp;&amp; (!pEventId.trim().equals(&quot;&quot;)) &amp;&amp; (pEventId.trim().equals(&quot;160&quot;))) {&#9;&#10;                &#9;&#9;&#10;&#9; logger.info(&quot;Returning EventDate as Receipt Date &quot; + function_name);&#10;       &#9;return eventDate;&#10;        } else {&#10;&#9; logger.info(&quot;Returning Receipt Date &quot; + function_name);&#10;&#9;return receiptDate;&#10;       }&#10;    }"/>
                    <pl:application-data name="description" type="property" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value=""/>
                </pl:application-data>
                <pl:application-data name="determineAETypeForAEApplication" type="function" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value="">
                    <pl:application-data name="type" type="property" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value="beanshell"/>
                    <pl:application-data name="methodName" type="property" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value="determineAETypeForAEApplication"/>
                    <pl:application-data name="category" type="property" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value="Miscellaneous"/>
                    <pl:application-data name="script" type="property" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value="import org.apache.log4j.Logger;&#10;&#10;&#10;String determineAETypeForAEApplication(String pType)&#10;    {&#10;        Logger logger = Logger.getLogger(&quot;com.info&quot;);&#10;        String function_name = &quot;determineAETypeForAEApplication&quot;;&#10;&#10;        if(pType != null &amp;&amp; (pType.trim().equals(&quot;JP&quot;))) {&#9;&#10;        &#9;&#10;&#9; logger.info(&quot;AE type is for &quot; + function_name + &quot; , &quot; +pType + &quot; - returning JD&quot;);&#10;       &#9;  return &quot;JD&quot;;&#10;       } else {&#10;&#9; logger.info(&quot;AE type is for &quot; + function_name + &quot; , &quot; +pType);&#10;&#9; return pType;&#10;        }&#10;    }"/>
                    <pl:application-data name="description" type="property" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value=""/>
                </pl:application-data>
                <pl:application-data name="determinePartyNumberForEmployer" type="function" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value="">
                    <pl:application-data name="type" type="property" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value="beanshell"/>
                    <pl:application-data name="methodName" type="property" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value="determinePartyNumberForEmployer"/>
                    <pl:application-data name="category" type="property" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value="Miscellaneous"/>
                    <pl:application-data name="script" type="property" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value="import org.apache.log4j.Logger;&#10;&#10;&#10;String determinePartyNumberForEmployer(String pPartyNo)&#10;    {&#10;        Logger logger = Logger.getLogger(&quot;com.info&quot;);&#10;        String function_name = &quot;determinePartyNumberForEmployer&quot;;&#10;&#10;        if(pPartyNo != null &amp;&amp; (pPartyNo.trim().equals(&quot;0&quot;))) {&#9;&#10;        &#9;&#10;&#9; logger.info(&quot;Party No for &quot; + function_name + &quot; , &quot; +pPartyNo + &quot; - returning Claimant and Party no = 1&quot;);&#10;&#9; return &quot;1&quot;;&#10;       } else {&#10;&#9; logger.info(&quot;Party No for &quot; + function_name + &quot; , &quot; +pPartyNo + &quot; - returning Defendant Party no = &quot; +pPartyNo);&#10;       &#9;  return pPartyNo;&#10;        }&#10;    }"/>
                    <pl:application-data name="description" type="property" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value=""/>
                </pl:application-data>
                <pl:application-data name="determinePartyRoleCodeForEmployer" type="function" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value="">
                    <pl:application-data name="type" type="property" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value="beanshell"/>
                    <pl:application-data name="methodName" type="property" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value="determinePartyRoleCodeForEmployer"/>
                    <pl:application-data name="category" type="property" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value="Miscellaneous"/>
                    <pl:application-data name="script" type="property" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value="import org.apache.log4j.Logger;&#10;&#10;String determinePartyRoleCodeForEmployer(String pParty)&#10;    {&#10;        Logger logger = Logger.getLogger(&quot;com.info&quot;);&#10;        String function_name = &quot;determinePartyRoleCodeForEmployer&quot;;&#10;&#10;        if(pParty != null &amp;&amp; (!pParty.trim().equals(&quot;&quot;)) &amp;&amp; (!pParty.trim().equals(&quot;EMPLOYER&quot;))) {&#9;&#10;        &#9;&#10;&#9; logger.info(&quot;Party Role Code for &quot; + function_name + &quot; , is not Employer&quot;);&#10;       &#9;return &quot;DEFENDANT&quot;;&#10;       } else if(pParty != null &amp;&amp; (!pParty.trim().equals(&quot;&quot;)) &amp;&amp; (pParty.trim().equals(&quot;EMPLOYER&quot;))) {&#9;&#10;        &#9;&#10;&#9; logger.info(&quot;Party Role Code for &quot; + function_name + &quot; , is Employer&quot;);&#10;       &#9;return &quot;EMPLOYER&quot;;&#10;       } else {&#10;&#9; logger.info(&quot;Event Party Role Code for &quot; + function_name + &quot; , is Party Role is Empty&quot;);&#10;&#9;return &quot;&quot;;&#10;        }&#10;    }"/>
                    <pl:application-data name="description" type="property" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value=""/>
                </pl:application-data>
                <pl:application-data name="determineCasePartyNumberForJudgmentInverse" type="function" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value="">
                    <pl:application-data name="type" type="property" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value="beanshell"/>
                    <pl:application-data name="methodName" type="property" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value="determineCasePartyNumberForJudgmentInverse"/>
                    <pl:application-data name="category" type="property" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value="Miscellaneous"/>
                    <pl:application-data name="script" type="property" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value="import org.apache.log4j.Logger;&#10;&#10;String determineCasePartyNumberForJudgmentInverse(String pEvent, String pParty)&#10;    {&#10;        Logger logger = Logger.getLogger(&quot;com.info&quot;);&#10;        String function_name = &quot;determineCasePartyNumberForJudgmentInverse&quot;;&#10;&#10;        if(pEvent != null &amp;&amp; (!pEvent.trim().equals(&quot;&quot;)) &amp;&amp; (!pEvent.trim().equals(&quot;0&quot;)) &amp;&amp; pParty != null &amp;&amp; (!pParty.trim().equals(&quot;&quot;)) &amp;&amp; (pParty.trim().equals(&quot;CLAIMANT&quot;))) {&#9;&#10;        &#9;&#10;&#9; logger.info(&quot;Event Party Role Code for &quot; + function_name + &quot; , is Claimant&quot;);&#10;       &#9; return &quot;1&quot;;&#10;        } else {&#10; &#9; logger.info(&quot;Event Party Role Code for &quot; + function_name + &quot; , is Defendant&quot;);&#10;       &#9; return pEvent;&#10;       }&#10;    }"/>
                    <pl:application-data name="description" type="property" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value=""/>
                </pl:application-data>
                <pl:application-data name="determineCCBCCasemanPostcode" type="function" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value="">
                    <pl:application-data name="type" type="property" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value="beanshell"/>
                    <pl:application-data name="methodName" type="property" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value="determineCCBCCasemanPostcode"/>
                    <pl:application-data name="category" type="property" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value="Miscellaneous"/>
                    <pl:application-data name="script" type="property" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value="import org.apache.log4j.Logger;&#10;&#10;String determineCCBCCasemanPostcode(String pPreviousCourtCode, String pPlaintiff6, String pPlaintiff7)&#10;    {&#10;        Logger logger = Logger.getLogger(&quot;com.info&quot;);&#10;        String function_name = &quot;determineCCBCCasemanPostcode&quot;;&#10;         logger.info(&quot;Previous Court Code for &quot; + function_name + &quot; = &quot; + pPreviousCourtCode); &#10;&#10;        if(pPreviousCourtCode != null &amp;&amp; (!pPreviousCourtCode.trim().equals(&quot;&quot;)) &amp;&amp; (pPreviousCourtCode.trim().equals(&quot;335&quot;))) {&#10;        &#10;  &#9; &#9;logger.info(&quot;Processing Postcode for CCBC &quot; + function_name);       &#10;&#9;&#9;if(pPlaintiff7 != null &amp;&amp; ( pPlaintiff7.trim().matches(&quot;^[A-Z]{1,2}[1-9][0-9]?[A-Z]? [0-9][A-Z]{2,}|GIR 0AA$&quot;) || &#9;&#9;&#9;&#9;pPlaintiff7.trim().matches(&quot;^[A-Z]{1,2}[1-9][0-9]?[A-Z]?[0-9][A-Z]{2,}|GIR 0AA$&quot;) ) ) {&#10;&#9;&#9;            &#9;&#10;&#9;&#9;&#9;logger.info(&quot;PostCode for &quot; + function_name + &quot; , &quot; +pPlaintiff7);&#10;&#9;&#9;&#9;return pPlaintiff7;&#10;&#9;&#9;} else {&#10;&#9;&#9;    &#9;logger.info(&quot;Returning Null for unmatched format PostCode for &quot; + function_name + &quot; , &quot; +pPlaintiff7);&#10;&#9;&#9;&#9;return &quot;&quot;;&#10;&#9;&#9;} &#10;        &#9;&#10;&#10;        } else {&#10;          &#9;logger.info(&quot;Processing Postcode for CASEMAN &quot; + function_name);  &#10;      &#10;&#9;&#9;if(pPlaintiff6 != null &amp;&amp; ( pPlaintiff6.trim().matches(&quot;^[A-Z]{1,2}[1-9][0-9]?[A-Z]? [0-9][A-Z]{2,}|GIR 0AA$&quot;) || &#9;&#9;&#9;&#9;pPlaintiff6.trim().matches(&quot;^[A-Z]{1,2}[1-9][0-9]?[A-Z]?[0-9][A-Z]{2,}|GIR 0AA$&quot;) ) ) {&#10;&#9;&#9;            &#9;&#10;&#9;&#9;&#9;logger.info(&quot;PostCode for &quot; + function_name + &quot; , &quot; +pPlaintiff6);&#10;&#9;&#9;&#9;return pPlaintiff6;&#10;&#9;&#9;} else {&#10;&#9;&#9;    &#9;logger.info(&quot;Returning Null for unmatched format PostCode for &quot; + function_name + &quot; , &quot; +pPlaintiff6);&#10;&#9;&#9;&#9;return &quot;&quot;;&#10;&#9;&#9;}       &#10;       }&#10;    }&#10;"/>
                    <pl:application-data name="description" type="property" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value=""/>
                </pl:application-data>
                <pl:application-data name="determineCCBCAddressLine5" type="function" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value="">
                    <pl:application-data name="type" type="property" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value="beanshell"/>
                    <pl:application-data name="methodName" type="property" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value="determineCCBCAddressLine5"/>
                    <pl:application-data name="category" type="property" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value="Miscellaneous"/>
                    <pl:application-data name="script" type="property" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value="import org.apache.log4j.Logger;&#10;&#10;String determineCCBCAddressLine5(String pPreviousCourtCode, String pPlaintiff6)&#10;    {&#10;        Logger logger = Logger.getLogger(&quot;com.info&quot;);&#10;        String function_name = &quot;determineCCBCAddressLine5&quot;;&#10;         logger.info(&quot;Previous Court Code for &quot; + function_name + &quot; = &quot; + pPreviousCourtCode); &#10;&#10;        if(pPreviousCourtCode != null &amp;&amp; (!pPreviousCourtCode.trim().equals(&quot;&quot;)) &amp;&amp; (pPreviousCourtCode.trim().equals(&quot;335&quot;))) {&#10;        &#10;  &#9; &#9;logger.info(&quot;Processing AddressLine5 for CCBC &quot; + function_name);       &#10;&#9;&#9;return pPlaintiff6;&#10;        &#10;        } else {&#10;          &#9;logger.info(&quot;Not Processing Telephone as a case is Caseman &quot; + function_name);       &#10;&#9;&#9;return &quot;&quot;;&#10;       }&#10;    }"/>
                    <pl:application-data name="description" type="property" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value=""/>
                </pl:application-data>
                <pl:application-data name="determineCasemanTelephone" type="function" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value="">
                    <pl:application-data name="type" type="property" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value="beanshell"/>
                    <pl:application-data name="methodName" type="property" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value="determineCasemanTelephone"/>
                    <pl:application-data name="category" type="property" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value="Miscellaneous"/>
                    <pl:application-data name="script" type="property" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value="import org.apache.log4j.Logger;&#10;&#10;String determineCasemanTelephone(String pPreviousCourtCode, String pPlaintiff7)&#10;    {&#10;        Logger logger = Logger.getLogger(&quot;com.info&quot;);&#10;        String function_name = &quot;determineCasemanTelephone&quot;;&#10;         logger.info(&quot;Previous Court Code for &quot; + function_name + &quot; = &quot; + pPreviousCourtCode); &#10;&#10;        if(pPreviousCourtCode != null &amp;&amp; (!pPreviousCourtCode.trim().equals(&quot;&quot;)) &amp;&amp; (pPreviousCourtCode.trim().equals(&quot;335&quot;))) {&#10;        &#10;  &#9; &#9;logger.info(&quot;Not Processing Telephone as a case is CCBC &quot; + function_name);       &#10;&#9;&#9;return &quot;&quot;;&#10;          &#10;       } else {&#10;       &#10;       &#9;&#9;if (pPlaintiff7 != null &amp;&amp; (!pPlaintiff7.trim().equals(&quot;&quot;))){&#10;          &#9;&#9;logger.info(&quot;Processing Telephone for Caseman &quot; + function_name);       &#10;&#9;&#9;&#9;return pPlaintiff7;  &#10;&#9;&#9;} else {&#10;       &#10;  &#9; &#9;&#9;logger.info(&quot;Processing Telephone for Caseman and its empty &quot; + function_name);   &#10;       &#9;&#9;&#9;return &quot;&quot;;&#10;       &#9;&#9;}&#10;       }&#9;&#10;    }"/>
                    <pl:application-data name="description" type="property" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value=""/>
                </pl:application-data>
                <pl:application-data name="determineJudgmentCrtCode" type="function" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value="">
                    <pl:application-data name="type" type="property" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value="beanshell"/>
                    <pl:application-data name="methodName" type="property" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value="determineJudgmentCrtCode"/>
                    <pl:application-data name="category" type="property" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value="Miscellaneous"/>
                    <pl:application-data name="script" type="property" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value="import org.apache.log4j.Logger;&#10;&#10;String determineJudgmentCrtCode(String pPreviousCourtCode)&#10;    {&#10;        Logger logger = Logger.getLogger(&quot;com.info&quot;);&#10;        String function_name = &quot;determineJudgmentCrtCode&quot;;&#10;         logger.info(&quot;Previous Court Code for &quot; + function_name + &quot; = &quot; + pPreviousCourtCode); &#10;&#10;        if(pPreviousCourtCode != null &amp;&amp; (!pPreviousCourtCode.trim().equals(&quot;&quot;)) &amp;&amp; (!pPreviousCourtCode.trim().equals(&quot;335&quot;))) {&#10;        &#10;  &#9; &#9;logger.info(&quot;Court Code is not a CCBC &quot; + function_name); &#10;&#9;&#9;return pPreviousCourtCode;                 &#10;        } else {&#10;  &#9; &#9;logger.info(&quot;Court Code is a CCBC &quot; + function_name);     &#10;&#9;&#9;return &quot;335&quot;;&#10;       }&#10;    }"/>
                    <pl:application-data name="description" type="property" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value=""/>
                </pl:application-data>
                <pl:application-data name="determineDateRecievedForCCBC" type="function" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value="">
                    <pl:application-data name="type" type="property" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value="beanshell"/>
                    <pl:application-data name="methodName" type="property" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value="determineDateRecievedForCCBC"/>
                    <pl:application-data name="category" type="property" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value="Miscellaneous"/>
                    <pl:application-data name="script" type="property" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value="import org.apache.log4j.Logger;&#10;&#10;String determineDateRecievedForCCBC(String pPreviousCourtCode, String pDateIssued)&#10;    {&#10;        Logger logger = Logger.getLogger(&quot;com.info&quot;);&#10;        String function_name = &quot;determineDateRecievedForCCBC&quot;;&#10;         logger.info(&quot;Previous Court Code for &quot; + function_name + &quot; = &quot; + pPreviousCourtCode); &#10;&#10;        if(pPreviousCourtCode != null &amp;&amp; (!pPreviousCourtCode.trim().equals(&quot;&quot;)) &amp;&amp; (!pPreviousCourtCode.trim().equals(&quot;335&quot;))) {&#10;        &#10;  &#9; &#9;logger.info(&quot;Court Code is not a CCBC &quot; + function_name); &#10;&#9;&#9;return &quot;&quot;;                 &#10;        } else {&#10;  &#9; &#9;logger.info(&quot;Court Code is a CCBC &quot; + function_name + &quot; - Date Received = &quot; + pDateIssued);     &#10;&#9;&#9;return pDateIssued;&#10;       }&#10;    }"/>
                    <pl:application-data name="description" type="property" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value=""/>
                </pl:application-data>
                <pl:application-data name="determineDateRecieved" type="function" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value="">
                    <pl:application-data name="type" type="property" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value="beanshell"/>
                    <pl:application-data name="methodName" type="property" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value="determineDateRecieved"/>
                    <pl:application-data name="category" type="property" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value="Miscellaneous"/>
                    <pl:application-data name="script" type="property" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value="import org.apache.log4j.Logger;&#10;&#10;String determineDateRecieved(String pDateIssued)&#10;    {&#10;        Logger logger = Logger.getLogger(&quot;com.info&quot;);&#10;        String function_name = &quot;determineDateRecieved&quot;;&#10;         logger.info(&quot;Date Issued &quot; + function_name + &quot; = &quot; + pDateIssued); &#10;&#10;        if(pDateIssued != null &amp;&amp; (!pDateIssued.trim().equals(&quot;&quot;))) {&#10;        &#10;  &#9; &#9;logger.info(&quot;Date Received will be Date Issued &quot; + function_name + &quot; - Date Issued = &quot; + pDateIssued); &#10;&#9;&#9;return pDateIssued;                 &#10;        } else {&#10;  &#9; &#9;logger.info(&quot;Date Received is 01-01-1900 as Date Issued is Null&quot; + function_name);     &#10;&#9;&#9;return &quot;1900-01-01T00:00:00.000&quot;;&#10;       }&#10;    }"/>
                    <pl:application-data name="description" type="property" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value=""/>
                </pl:application-data>
                <pl:application-data name="formatApostrophe" type="function" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value="">
                    <pl:application-data name="type" type="property" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value="beanshell"/>
                    <pl:application-data name="methodName" type="property" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value="formatApostrophe"/>
                    <pl:application-data name="category" type="property" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value="Miscellaneous"/>
                    <pl:application-data name="script" type="property" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value="import org.apache.log4j.Logger;&#10;&#10;String formatApostrophe(String pString) {&#10;&#9;Logger logger = Logger.getLogger(&quot;com.info&quot;);&#10;&#9;String function_name = &quot;formatApostrophe&quot;;&#10;&#10;&#9;logger.info(&quot;String line for &quot; + function_name + &quot; , &quot; +pString);&#10; &#9;if (pString != null &amp;&amp; (!pString.trim().equals(&quot;&quot;)) ) {&#10;&#9;&#9;pString = pString.replace(&apos;\&apos;&apos;, &apos; &apos;);&#10;&#9;&#9;logger.info(&quot;String line Amended for &quot; + function_name + &quot; , &quot; +pString);&#10;&#9;&#9;return pString;&#10;&#9;} else {&#10;&#9;&#9;return &quot;&quot;;&#10;&#9;}&#9;&#10;}"/>
                    <pl:application-data name="description" type="property" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value=""/>
                </pl:application-data>
                <pl:application-data name="determineCaseEventForRTL" type="function" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value="">
                    <pl:application-data name="type" type="property" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value="beanshell"/>
                    <pl:application-data name="methodName" type="property" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value="determineCaseEventForRTL"/>
                    <pl:application-data name="category" type="property" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value="Miscellaneous"/>
                    <pl:application-data name="script" type="property" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value="import org.apache.log4j.Logger;&#10;&#10;String determineCaseEventForRTL(String pEventDate, String pStdEventID)&#10;    {&#10;        Logger logger = Logger.getLogger(&quot;com.info&quot;);&#10;        String function_name = &quot;determineCaseEventForRTL&quot;;&#10;        logger.info(&quot;Std Event ID &quot; + function_name + &quot; = &quot; + pStdEventID); &#10;        logger.info(&quot;Event Date &quot; + function_name + &quot; = &quot; + pEventDate); &#10;        &#10;        if(pStdEventID != null &amp;&amp; (!pStdEventID.trim().equals(&quot;&quot;)) &amp;&amp; pEventDate != null &amp;&amp; (!pEventDate.trim().equals(&quot;&quot;))) {&#10;        &#9; &#9;&#10;  &#9; &#9;if(pStdEventID.trim().equals(&quot;236&quot;) || pStdEventID.trim().equals(&quot;375&quot;) || pStdEventID.trim().equals(&quot;600&quot;)&#10;  &#9; &#9;|| pStdEventID.trim().equals(&quot;230&quot;) || pStdEventID.trim().equals(&quot;233&quot;) || pStdEventID.trim().equals(&quot;240&quot;)&#10;  &#9; &#9;|| pStdEventID.trim().equals(&quot;250&quot;) || pStdEventID.trim().equals(&quot;251&quot;) || pStdEventID.trim().equals(&quot;253&quot;)&#10;  &#9; &#9;|| pStdEventID.trim().equals(&quot;254&quot;)) {&#10;  &#9; &#9;&#9;logger.info(&quot;Std Event id is an RTL Event &quot; + function_name + &quot;  - Returning Date To Rtl as &quot; + pEventDate);&#10;&#9;&#9;&#9;return pEventDate;&#10;&#9;&#9;} else {&#10;  &#9; &#9;&#9;logger.info(&quot;Std Event id is not an RTL Event &quot; + function_name + &quot;  - Returning Null for Date to RTL&quot;);     &#10;&#9;&#9;&#9;return null;&#10;&#9;&#9;}                 &#10;        } else {&#10;  &#9; &#9;logger.info(&quot;Unable to determine Std Event id or Event Date  &quot; + function_name + &quot;  - Returning Null for Date to RTL&quot;);     &#10;&#9;&#9;return null;&#10;       }&#10;    }"/>
                    <pl:application-data name="description" type="property" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value=""/>
                </pl:application-data>
            </pl:application-data>
            <pl:application-data name="Initial Contexts" type="initialcontexts" application="com.polarlake.platform.librarymodule.LibraryModuleApplication"/>
            <pl:application-data name="Scripts" type="scripts" application="com.polarlake.platform.librarymodule.LibraryModuleApplication">
                <pl:application-data name="Document Logger Error Case-Sups - Caseman" type="script" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value="">
                    <pl:application-data name="url" type="property" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value=""/>
                    <pl:application-data name="remote" type="property" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value="false"/>
                    <pl:application-data name="type" type="property" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value="beanshell"/>
                    <pl:application-data name="cache" type="property" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value="never_resolve"/>
                    <pl:application-data name="script" type="property" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value="import org.apache.log4j.Logger;&#10;import org.jdom.*;  &#10;import org.jdom.input.*;  &#10;import org.jdom.output.*;  &#10;import com.polarlake.platform.api.*;  &#10;import com.polarlake.platform.api.helper.*;  &#10;import com.polarlake.platform.api.exception.*;  &#10;  &#10;/**  &#10; * A JDOM beanshell must return a JDOM document.  &#10; */  &#10; Document processDocument(Document doc, ExecutiveProcessInterface process) &#10; { &#10;&#10;   try &#10;   { &#10;      VariableContainerInterface vci = process.getProcessDocGroup(); &#10;      if (vci != null) &#10;      { &#10;        VariableInterface vi = vci.getVariable(&quot;Case-Sups&quot;); &#10;        Document doc = (Document)vi.getValue(); &#10;        XMLOutputter xo = new XMLOutputter(Format.getPrettyFormat());&#10;        Logger logger = Logger.getRootLogger();&#10;        logger.error(xo.outputString(doc));&#10;     } &#10;  } &#10;  catch (DocVariableException dve) &#10;  { &#10;    /* do nothing */ &#10;   } &#10;      return doc;&#9;&#10;} &#10;"/>
                    <pl:application-data name="description" type="property" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value="A PolarLake Platform Beanshell script must be coded to return a JDOM document.They can be composed from calls to imported modules as well as local methods.Only the first method in the script will be executed, so it should make any appropriate method calls if the entire script is not contained in it."/>
                </pl:application-data>
                <pl:application-data name="Process Doc Logger Error - Caseman" type="script" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value="">
