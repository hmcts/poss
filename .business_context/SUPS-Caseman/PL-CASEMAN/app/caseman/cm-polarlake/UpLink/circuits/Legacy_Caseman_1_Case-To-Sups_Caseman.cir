                <pl:parameter name="message" value="-&#10;--&gt; Attempting to Commit Outer Select Transaction&#10;--&gt; SEQUENCE - Iterate Court Records Sequence&#10;--&gt; VIEW - Iterate Court Records View&#10;--&gt; CIRCUIT - {$CircuitName}&#10;----------------------------------------------------------------------------------"/>
