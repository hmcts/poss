<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE log4j:configuration SYSTEM "log4j.dtd">
<log4j:configuration xmlns:log4j="http://jakarta.apache.org/log4j/">
	<appender name="polarlake" class="org.apache.log4j.ConsoleAppender">
		<layout class="org.apache.log4j.PatternLayout">
			<param name="ConversionPattern" value="%-5p %d{dd MMM yyyy HH:mm:ss} %-4r %l [%t] %37c  %M %3x - %m%n"/>
		</layout>
	</appender>
	<appender name="rfaDebug" class="org.apache.log4j.RollingFileAppender">
		<param name="File" value="${polarlake_home}/polarlake/log/Debug/debug.log"/>
		<param name="Append" value="true"/>
		<param name="MaxFileSize" value="10000KB"/>
		<param name="MaxBackupIndex" value="2"/>
		<layout class="org.apache.log4j.PatternLayout">
			<param name="ConversionPattern" value="%-5p %d{dd MMM yyyy HH:mm:ss} %-4r %l [%t] %37c  %M %3x - %m%n"/>
		</layout>
		<filter class="org.apache.log4j.varia.LevelRangeFilter">
			<param name="LevelMin" value="DEBUG"/>
			<param name="LevelMax" value="DEBUG"/>
			<param name="AcceptOnMatch" value="true"/>
		</filter>
	</appender>
	<appender name="rfaInfo" class="org.apache.log4j.RollingFileAppender">
		<param name="File" value="${polarlake_home}/polarlake/log/Info/info.log"/>
		<param name="Append" value="true"/>
		<param name="MaxFileSize" value="10000KB"/>
		<param name="MaxBackupIndex" value="2"/>
		<layout class="org.apache.log4j.PatternLayout">
			<param name="ConversionPattern" value="%-5p %d{dd MMM yyyy HH:mm:ss} %-4r %l [%t] %37c  %M %3x - %m%n"/>
		</layout>
		<filter class="org.apache.log4j.varia.LevelRangeFilter">
			<param name="LevelMin" value="INFO"/>
			<param name="LevelMax" value="INFO"/>
			<param name="AcceptOnMatch" value="true"/>
		</filter>
	</appender>
    <appender name="rfaPatrol" class="org.apache.log4j.RollingFileAppender">
     <param name="File" value="${polarlake_home}/polarlake/log/Patrol/patrol.log"/>
     <param name="Append" value="false"/>
     <param name="MaxFileSize" value="10000KB"/>
     <param name="MaxBackupIndex" value="2"/>
    <layout class="org.apache.log4j.PatternLayout">
          <param name="ConversionPattern" value="%-5p %d{dd MMM yyyy HH:mm:ss} %-4r %l [%t] %37c  %M %3x - %m%n"/>
    </layout>
    <filter class="org.apache.log4j.varia.LevelRangeFilter">
      <param name="LevelMin" value="WARN" />
      <param name="LevelMax" value="WARN" />
      <param name="AcceptOnMatch" value="true"/>
    </filter>
  </appender>
	<appender name="rfaError" class="org.apache.log4j.RollingFileAppender">
		<param name="File" value="${polarlake_home}/polarlake/log/Error/error.log"/>
		<param name="Append" value="true"/>
		<param name="MaxFileSize" value="10000KB"/>
		<param name="MaxBackupIndex" value="2"/>
		<layout class="org.apache.log4j.PatternLayout">
			<param name="ConversionPattern" value="%-5p %d{dd MMM yyyy HH:mm:ss} %-4r %l [%t] %37c  %M %3x - %m%n"/>
		</layout>
		<filter class="org.apache.log4j.varia.LevelRangeFilter">
			<param name="LevelMin" value="ERROR"/>
			<param name="LevelMax" value="ERROR"/>
			<param name="AcceptOnMatch" value="true"/>
		</filter>
	</appender>
	<appender name="rfaFatal" class="org.apache.log4j.RollingFileAppender">
		<param name="File" value="${polarlake_home}/polarlake/log/Fatal/Fatal.log"/>
		<param name="Append" value="true"/>
		<param name="MaxFileSize" value="10000KB"/>
		<param name="MaxBackupIndex" value="2"/>
		<layout class="org.apache.log4j.PatternLayout">
			<param name="ConversionPattern" value="%-5p %d{dd MMM yyyy HH:mm:ss} %-4r %l [%t] %37c  %M %3x - %m%n"/>
		</layout>
		<filter class="org.apache.log4j.varia.LevelRangeFilter">
			<param name="LevelMin" value="FATAL"/>
			<param name="LevelMax" value="FATAL"/>
			<param name="AcceptOnMatch" value="true"/>
		</filter>
	</appender>
	<logger name="com.debug" additivity="false">
		<appender-ref ref="rfaDebug"/>
	</logger>
	<logger name="com.info" additivity="false">
		<appender-ref ref="rfaInfo"/>
	</logger>
	<logger name="com.patrol" additivity="false">
        <appender-ref ref="rfaPatrol"  />        
    </logger>
	<logger name="com.error" additivity="false">
		<appender-ref ref="rfaError"/>
	</logger>
	<logger name="com.fatal" additivity="false">
		<appender-ref ref="rfaFatal"/>
	</logger>
	<logger name="com.polarlake.platform">
		<level value="error"/>
	</logger>
	<logger name="com.polarlake.scheduler">
		<level value="error"/>
	</logger>
	<logger name="com.polarlake.platform.librarymodule.eventprocessors.PrintMessageEP">
		<level value="info"/>
	</logger>
	<logger name="com.org.quartz">
		<level value="error"/>
	</logger>
	<logger name="org.apache.catalina">
		<level value="error"/>
	</logger>
	<logger name="org.apache.catalina.startup.Embedded">
		<level value="error"/>
	</logger>
	<!--  <logger name="com.polarlake.pmc">
        <level value="error" /> 
    </logger>   
     <logger name="PMC">
        <level value="error" /> 
    </logger>  
      <logger name="SYSTEM">
		<level value="error"/>
    </logger>  -->
    
	<root>
		<priority value="ERROR"/>
		<appender-ref ref="polarlake"/>
		<appender-ref ref="rfaDebug"/>
		<appender-ref ref="rfaInfo"/>
		<appender-ref ref="rfaPatrol"/>
		<appender-ref ref="rfaError"/>
		<appender-ref ref="rfaFatal"/>
	</root>
</log4j:configuration>
