                </pl:parameter>
                <pl:parameter name="trigger" value="start"/>
                <pl:parameter name="message" value="-&#10;--&gt; Failed to Email Support&#10;--&gt; SEQUENCE - Email Support Exception Sequence&#10;--&gt; VIEW - Email Support View&#10;--&gt; VIEW - Iterate Case Exception View&#10;--&gt; VIEW - Iterate Case Exception View&#10;--&gt; VIEW - Iterate Each Transfer Case Number View&#10;--&gt; CIRCUIT - Main Sups Caseman to Legacy Process&#10;----------------------------------------------------------------------------------"/>
                <pl:parameter name="use_log4j" value="true"/>
                <pl:parameter name="log_level" value="ERROR"/>
            </pl:eventprocessor>
        </pl:seqlist>
        <pl:table name="Main Sups Caseman to Legacy  Table" operation="create">
            <pl:namespace uri="http://www.w3.org/2001/XMLSchema" prefix="xs" operation="create"/>
            <pl:namespace uri="http://www.polarlake.com/platform/1.0" prefix="pl" operation="create"/>
            <pl:entry factory="com.polarlake.platform.event.NamedEventProcessorFactory" rule="/pl:exception" operation="create" description="Main Exception Sequence rule">
                <pl:parameter name="epName" value="Main Exception Sequence"/>
            </pl:entry>
            <pl:entry factory="com.polarlake.platform.event.NamedEventProcessorFactory" rule="/*" operation="create" description="Main Sups Caseman to Legacy Sequence rule">
                <pl:parameter name="epName" value="Main Sups Caseman to Legacy Sequence"/>
            </pl:entry>
        </pl:table>
        <pl:table name="Sups -  Retrieve and Update Case Data Table" operation="create">
            <pl:namespace uri="http://www.polarlake.com/platform/1.0" prefix="pl" operation="create"/>
            <pl:namespace uri="http://www.w3.org/2001/XMLSchema-instance" prefix="xsi" operation="create"/>
            <pl:entry factory="com.polarlake.platform.event.NamedEventProcessorFactory" rule="/pl:exception" operation="create" description="Exception Sequence - Retrieve and Update Case Data rule">
                <pl:parameter name="epName" value="Exception Sequence - Retrieve and Update Case Data"/>
            </pl:entry>
            <pl:entry factory="com.polarlake.platform.event.NamedEventProcessorFactory" rule="/Case" operation="create" description="Retrieve and Update Case Data Sequence rule">
                <pl:parameter name="epName" value="Retrieve and Update Case Data Sequence"/>
            </pl:entry>
        </pl:table>
        <pl:table name="Update Transfer Status Table" operation="create">
            <pl:namespace uri="http://www.polarlake.com/platform/1.0" prefix="pl" operation="create"/>
            <pl:namespace uri="http://www.w3.org/2001/XMLSchema-instance" prefix="xsi" operation="create"/>
            <pl:entry factory="com.polarlake.platform.event.NamedEventProcessorFactory" rule="/pl:exception" operation="create" description="Update Transfer Status Exception Sequence rule">
                <pl:parameter name="epName" value="Update Transfer Status Exception Sequence"/>
            </pl:entry>
            <pl:entry factory="com.polarlake.platform.event.NamedEventProcessorFactory" rule="/Case" operation="create" description="Update Transfer Status Seqeuence rule">
                <pl:parameter name="epName" value="Update Transfer Status Seqeuence"/>
            </pl:entry>
            <pl:entry factory="com.polarlake.platform.event.NamedEventProcessorFactory" rule="/*" operation="create" description="Test Seqeuence rule">
                <pl:parameter name="epName" value="Test Seqeuence"/>
            </pl:entry>
        </pl:table>
        <pl:table name="Iterate Each Transfer Case Number Table" operation="create">
            <pl:namespace uri="http://www.polarlake.com/platform/1.0" prefix="pl" operation="create"/>
            <pl:namespace uri="http://www.w3.org/2001/XMLSchema-instance" prefix="xsi" operation="create"/>
            <pl:entry factory="com.polarlake.platform.event.NamedEventProcessorFactory" rule="/pl:exception" operation="create" description="Iterate Each Transfer Case Number Exception Sequence rule">
                <pl:parameter name="epName" value="Iterate Each Transfer Case Number Exception Sequence"/>
            </pl:entry>
            <pl:entry factory="com.polarlake.platform.event.NamedEventProcessorFactory" rule="/Cases/Case[CaseNumber != &apos;&apos;]" operation="create" description="Iterate Each Transfer Case Number Sequence rule">
                <pl:parameter name="epName" value="Iterate Each Transfer Case Number Sequence"/>
            </pl:entry>
            <pl:entry factory="com.polarlake.platform.event.NamedEventProcessorFactory" rule="/Cases/Case[CaseNumber=&quot;&quot;]" operation="create" description="No Case Records to Run rule">
                <pl:parameter name="epName" value="No Case Records to Run"/>
            </pl:entry>
        </pl:table>
        <pl:table name="Iterate Case Exception Table" operation="create">
            <pl:namespace uri="http://www.polarlake.com/platform/1.0" prefix="pl" operation="create"/>
            <pl:namespace uri="http://www.w3.org/2001/XMLSchema-instance" prefix="xsi" operation="create"/>
            <pl:namespace uri="" prefix="ca" operation="create"/>
            <pl:namespace uri="http://www.w3.org/2001/XMLSchema" prefix="xs" operation="create"/>
            <pl:entry factory="com.polarlake.platform.event.NamedEventProcessorFactory" rule="/Case[{$Retry_Count}=&quot;5&quot;]" operation="create" description="Iterate Case Exception - Failed rule">
                <pl:parameter name="epName" value="Iterate Case Exception - Failed"/>
            </pl:entry>
            <pl:entry factory="com.polarlake.platform.event.NamedEventProcessorFactory" rule="/pl:exception[(@message=&quot;PLR_LIB_THROWN&quot;)]" operation="create" description="Iterate Case Exception - Caught rule">
                <pl:parameter name="epName" value="Iterate Case Exception - Caught"/>
            </pl:entry>
            <pl:entry factory="com.polarlake.platform.event.NamedEventProcessorFactory" rule="/pl:exception" operation="create" description="Iterate Case Exception Local rule">
                <pl:parameter name="epName" value="Iterate Case Exception Local"/>
