                    <pl:parameter name="alias" value="Print Message"/>
                </pl:parameter>
                <pl:parameter name="trigger" value="start"/>
                <pl:parameter name="message" value="-&#10;--&gt; Starting Sql Select/Retrieve for Case Number = {$case_number-complex}&#10;--&gt; SEQUENCE - Retrieve and Update Case Data &#10;--&gt; VIEW - Retrieve and Update Case Data View&#10;--&gt; CIRCUIT - Main Sups Caseman to Legacy Process&#10;----------------------------------------------------------------------------------"/>
