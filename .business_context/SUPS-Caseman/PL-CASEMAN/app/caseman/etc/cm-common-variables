# Need this to run properly under Autosys which strangely does not have $USER set!
# what the line below does is leave user alone if it already exists but if not
# then it snarfs it out of the AutoSys variable $__owner:
if [ ! -z $__owner ]; then
    declare -x      USER=${USER:-$__owner}
    declare -rx     USER=${USER:-$__owner}
    declare -rx  LOGNAME=${LOGNAME:-$__owner}
    declare -rx USERNAME=${USERNAME:-$__owner}
    declare -rx BASH_ENV=~/.bashrc
fi

