                    <pl:application-data name="script" type="property" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value="import org.jdom.*;&#10;import org.jdom.input.*;&#10;import org.jdom.output.*;&#10;import com.polarlake.platform.api.*;&#10;import com.polarlake.platform.api.helper.*;&#10;import com.polarlake.platform.api.exception.*;&#10;&#10;/**&#10; * A JDOM beanshell must return a JDOM document.&#10; */&#10;Document processDocument(Document doc) {&#10;   System.out.println();&#10;&#10;   return doc;&#10;}"/>
                    <pl:application-data name="description" type="property" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value="A PolarLake Platform Beanshell script must be coded to return a JDOM document.They can be composed from calls to imported modules as well as local methods.Only the first method in the script will be executed, so it should make any appropriate method calls if the entire script is not contained in it."/>
