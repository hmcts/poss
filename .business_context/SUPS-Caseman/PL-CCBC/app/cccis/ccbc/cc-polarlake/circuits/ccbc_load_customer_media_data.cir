        <pl:application-data name="Resources" type="Resources">
            <pl:application-data name="Functions" type="functions" application="com.polarlake.platform.librarymodule.LibraryModuleApplication">
                <pl:application-data name="isValidFloat" type="function" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value="">
                    <pl:application-data name="type" type="property" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value="beanshell"/>
                    <pl:application-data name="methodName" type="property" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value="isValidFloat"/>
                    <pl:application-data name="category" type="property" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value="Miscellaneous"/>
                    <pl:application-data name="script" type="property" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value="import java.text.DecimalFormat;&#10;&#10;String isValidFloat(String[] params)&#10;{&#10;   String s = params[0];&#10;   String man = params[1];&#10;&#10;&#10;&#10;   if(man.compareToIgnoreCase(&quot;true&quot;)==0){&#10;      if(s == null || s.trim().length() &lt; 4)&#10;         return &quot;false&quot;;&#10;   }else{&#10;      if(s == null || s.trim().length() ==0)&#10;         return &quot;true&quot;;&#10;   }&#10;    if((s.length() - s.indexOf(&apos;.&apos;)) != 3)&#10;      return &quot;false&quot;;&#10;&#10;    try&#10;    {&#10;          Float.parseFloat(s);&#10;    }&#10;    catch(NumberFormatException ne)&#10;    {&#10;        return &quot;false&quot;;&#10;    }&#10;&#10;    return &quot;true&quot;;&#10;}"/>
                    <pl:application-data name="description" type="property" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value=""/>
                </pl:application-data>
                <pl:application-data name="checkCpcCode" type="function" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value="">
                    <pl:application-data name="type" type="property" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value="beanshell"/>
                    <pl:application-data name="methodName" type="property" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value="checkCpcCode"/>
                    <pl:application-data name="category" type="property" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value="Miscellaneous"/>
                    <pl:application-data name="script" type="property" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value="String checkCpcCode(String s){&#10;    int len = 4;&#10;&#10;&#10;&#10;  if(s==NULL)&#10;    return &quot;false&quot;;&#10;&#10;   try{&#10;        Integer.parseInt(s);&#10;    }&#10;    catch(NumberFormatException ne)&#10;    {&#10;        return &quot;false&quot;;&#10;    }&#10;&#10;    if(s.trim().length() != len)&#10;        return &quot;false&quot;;&#10;   &#10;   return &quot;true&quot;;&#10;}"/>
                    <pl:application-data name="description" type="property" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value=""/>
                </pl:application-data>
                <pl:application-data name="isValidDate" type="function" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value="">
                    <pl:application-data name="type" type="property" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value="beanshell"/>
                    <pl:application-data name="methodName" type="property" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value="isValidDate"/>
                    <pl:application-data name="category" type="property" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value="Miscellaneous"/>
                    <pl:application-data name="script" type="property" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value="import java.text.ParseException;&#10;import java.text.SimpleDateFormat;&#10;import java.util.Date;&#10;&#10;String isValidDate(String[] params)&#10;{&#10;    String pDate = params[0];&#10;    String pattern = params[1];&#10;&#10;&#10;&#10;    if(pDate == null || pDate.trim().length()==0)&#10;        return &quot;true&quot;;&#10;&#10;    SimpleDateFormat dateFormat = new SimpleDateFormat(pattern);&#10;    dateFormat.setLenient(false);&#10;    Date parseDate = null;&#10;        try {&#10;            parseDate = dateFormat.parse(pDate);&#10;        } catch (ParseException pe) {&#10;            return &quot;false&quot;;    &#10;        }&#10;&#10;   return &quot;true&quot;;&#10;}"/>
                    <pl:application-data name="description" type="property" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value=""/>
                </pl:application-data>
                <pl:application-data name="checkEnfCourtCode" type="function" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value="">
                    <pl:application-data name="type" type="property" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value="beanshell"/>
                    <pl:application-data name="methodName" type="property" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value="checkEnfCourtCode"/>
                    <pl:application-data name="category" type="property" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value="Miscellaneous"/>
                    <pl:application-data name="script" type="property" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value="String checkEnfCourtCode(String s){&#10;   int len = 3;&#10;&#10;   if(s==NULL)&#10;    return &quot;false&quot;;&#10;&#10;   try{&#10;        Integer.parseInt(s);&#10;    }&#10;    catch(NumberFormatException ne)&#10;    {&#10;        return &quot;false&quot;;&#10;    }&#10;&#10;    if(s.trim().length() != len)&#10;        return &quot;false&quot;;&#10;   &#10;   return &quot;true&quot;;&#10;}"/>
                    <pl:application-data name="description" type="property" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value=""/>
                </pl:application-data>
                <pl:application-data name="trimNumber" type="function" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value="">
                    <pl:application-data name="type" type="property" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value="beanshell"/>
                    <pl:application-data name="methodName" type="property" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value="trimNumber"/>
                    <pl:application-data name="category" type="property" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value="Miscellaneous"/>
                    <pl:application-data name="script" type="property" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value="String trimNumber(String pNumber)&#10;    {&#10;&#10;        if(pNumber != null) {&#10;&#9;return pNumber.trim();&#10;       } else {&#10;&#9;return pNumber;&#10;       }&#10;}&#10;&#10;   &#9;"/>
                    <pl:application-data name="description" type="property" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value=""/>
                </pl:application-data>
                <pl:application-data name="calcFileSizeDifference" type="function" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value="">
                    <pl:application-data name="type" type="property" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value="beanshell"/>
                    <pl:application-data name="methodName" type="property" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value="calcFileSizeDifference"/>
                    <pl:application-data name="category" type="property" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value="Miscellaneous"/>
                    <pl:application-data name="script" type="property" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value="String calcFileSizeDifference(String[] params)&#10;{&#10;   String sCurr_size = params[0];&#10;   String sNo_of_recs = params[1];&#10;   String sRec_size = params[2];&#10;   String sReturnVal;&#10;&#9;&#9;   &#10;   int iCurr_size = Integer.parseInt(sCurr_size);&#10;   int iNo_of_recs = Integer.parseInt(sNo_of_recs);&#10;   int iRec_size = Integer.parseInt(sRec_size);&#10;&#10;  &#10;   int iDifference = iCurr_size - (iNo_of_recs * iRec_size);&#10;   &#10;   int iMod= iCurr_size % iRec_size ; &#10;&#10;   if (iMod != 0) {&#10;   &#9;&#9;   &#10;   &#9;sReturnVal = &quot;There are &quot;+Integer.toString(iDifference)+&quot; extra characters in the file&quot;;&#10;   }else{&#10;   &#9;sReturnVal = &quot;The number of records does not match what is expected&quot;;&#10;   &#9;}&#10;   return sReturnVal;&#10;&#9;&#9;   &#10; //  System.out.println(sReturnVal);&#10;   &#10;}"/>
                    <pl:application-data name="description" type="property" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value=""/>
                </pl:application-data>
            </pl:application-data>
