                    <pl:parameter name="alias" value="Retrieve the current address IDs for the claimant&apos;s solicitor"/>
                </pl:parameter>
                <pl:parameter name="transaction_key" value="CASM_start"/>
                <pl:parameter name="sql" value="SELECT ADDR.ADDRESS_ID&#10;FROM   GIVEN_ADDRESSES ADDR&#10;WHERE  ADDR.PARTY_ID =?&#10;AND   ADDR.VALID_TO IS NULL&#10;"/>
                <pl:parameter name="forward_option" value="8"/>
