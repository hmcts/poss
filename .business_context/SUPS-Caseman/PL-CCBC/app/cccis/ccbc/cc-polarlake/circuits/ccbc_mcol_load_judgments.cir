        <pl:seqlist name="shut_down">
            <pl:eventprocessor name="pl:printmessage" disable="false">
                <pl:parameter name="design">
                    <pl:parameter name="uid" value="88"/>
                    <pl:parameter name="alias" value="Print Message"/>
                </pl:parameter>
                <pl:parameter name="trigger" value="start"/>
                <pl:parameter name="message" value="*************************************************&#10;=&gt; Circuit: mcol_load_judgements&#10;=&gt; View:         JOB&#10;=&gt; Sequence: shutdown&#10;=&gt; Message:   shutdown command is sent to the main view&#10;_________________________________"/>
                <pl:parameter name="use_log4j" value="true"/>
                <pl:parameter name="log_level" value="INFO"/>
            </pl:eventprocessor>
            <pl:eventprocessor name="pl:addprocessvariable" disable="false">
                <pl:parameter name="design">
                    <pl:parameter name="uid" value="153"/>
                    <pl:parameter name="alias" value="heartbeat_status"/>
                </pl:parameter>
                <pl:parameter name="trigger" value="start"/>
                <pl:parameter name="map">
                    <pl:parameter name="heartbeat_status" value="F"/>
                </pl:parameter>
            </pl:eventprocessor>
            <pl:eventprocessor name="pl:interpreter" disable="false">
                <pl:parameter name="useview" value="start/end heart beat"/>
                <pl:parameter name="design">
                    <pl:parameter name="uid" value="208"/>
                    <pl:parameter name="alias" value="PolarLake Interpreter"/>
                </pl:parameter>
            </pl:eventprocessor>
            <pl:eventprocessor name="pl:retrievedocument" disable="false">
                <pl:parameter name="design">
                    <pl:parameter name="uid" value="46"/>
                    <pl:parameter name="alias" value="Retrieve Document"/>
                </pl:parameter>
                <pl:parameter name="transport">
                    <pl:parameter name="name" value="transport.retrieve"/>
                    <pl:parameter name="provider" value="transport.retrieve"/>
                    <pl:parameter name="parameters">
                        <pl:parameter name="address" value="file:///{pl$ccbc_home}/xml/shutdown.xml"/>
                        <pl:parameter name="wait" value="false"/>
                        <pl:parameter name="process_priority" value="5"/>
                    </pl:parameter>
                </pl:parameter>
                <pl:parameter name="trigger" value="start"/>
                <pl:parameter name="action" value="stream"/>
                <pl:parameter name="options">
                    <pl:parameter name="type" value="sink"/>
                </pl:parameter>
            </pl:eventprocessor>
            <pl:eventprocessor name="pl:send" disable="false">
                <pl:parameter name="design">
                    <pl:parameter name="uid" value="47"/>
                    <pl:parameter name="alias" value="Send to Channels"/>
                    <pl:parameter name="description" value="Send to Channels"/>
                </pl:parameter>
                <pl:parameter name="formatter" value="XML"/>
                <pl:parameter name="formatter_parameters">
                    <pl:parameter name="normalise_namespaces" value="true"/>
                </pl:parameter>
                <pl:parameter name="channels">
                    <pl:parameter name="address" value="xmlt://localhost:{pl$ccbc_load_judgments_xmlt_boot_port}"/>
                </pl:parameter>
            </pl:eventprocessor>
        </pl:seqlist>
        <pl:seqlist name="start/end heart beat">
            <pl:eventprocessor name="pl:printmessage" disable="false">
                <pl:parameter name="design">
                    <pl:parameter name="uid" value="89"/>
                    <pl:parameter name="alias" value="Print Message"/>
                </pl:parameter>
                <pl:parameter name="trigger" value="start"/>
                <pl:parameter name="message" value="*************************************************&#10;=&gt; Circuit: mcol_load_judgements&#10;=&gt; View:         send heart beat &#10;=&gt; Sequence:  send heart beat &#10;=&gt; Message:   send a heart beat:{$heartbeat_status}&#10;_________________________________________________"/>
                <pl:parameter name="use_log4j" value="true"/>
                <pl:parameter name="log_level" value="INFO"/>
            </pl:eventprocessor>
            <pl:eventprocessor name="pl:starttransaction" disable="false">
                <pl:parameter name="design">
                    <pl:parameter name="uid" value="56"/>
                    <pl:parameter name="alias" value="DB Start"/>
                </pl:parameter>
                <pl:parameter name="trigger" value="start"/>
                <pl:parameter name="connection" value="Heart_beat"/>
                <pl:parameter name="transaction_key" value="TR_HeartBeat"/>
                <pl:parameter name="transaction_level" value="0"/>
            </pl:eventprocessor>
            <pl:eventprocessor name="pl:sqltoxml" disable="false">
                <pl:parameter name="design">
                    <pl:parameter name="uid" value="58"/>
                    <pl:parameter name="alias" value="DB SQL"/>
                </pl:parameter>
                <pl:parameter name="transaction_key" value="TR_HeartBeat"/>
                <pl:parameter name="sql" value="insert into PL_XML_STATUS (sequence_no, circuit_name, shell_circuit_id,date_time_stamp, status) values(PL_XML_STATUS_SEQ.nextval,?,?,sysdate,?)"/>
                <pl:parameter name="forward_option" value="8"/>
                <pl:parameter name="sqlwarntoerror" value="false"/>
                <pl:parameter name="query" value="true"/>
                <pl:parameter name="input_mappings">
                    <pl:parameter name="input schemas"/>
                    <pl:parameter name="output schemas">
                        <pl:parameter name="0">
                            <pl:parameter name="root" value="/aa:parameters"/>
                            <pl:parameter name="schema" value="dbsqlinput.3"/>
                            <pl:parameter name="using" value="."/>
                        </pl:parameter>
                    </pl:parameter>
                    <pl:parameter name="tracing" value="off"/>
                    <pl:parameter name="exception-on-null" value="true"/>
                    <pl:parameter name="exception-on-nomapping" value="false"/>
                    <pl:parameter name="verbose-exceptions" value="false"/>
                    <pl:parameter name="show-local-functions" value="false"/>
                    <pl:parameter name="width" value="774"/>
                    <pl:parameter name="height" value="518"/>
                    <pl:parameter name="mappings">
                        <pl:parameter name="[0]/aa:parameters/aa:param0/text()">
                            <pl:parameter name="main">
                                <pl:parameter name="nocontext">
                                    <pl:parameter name="function-id" value="1"/>
