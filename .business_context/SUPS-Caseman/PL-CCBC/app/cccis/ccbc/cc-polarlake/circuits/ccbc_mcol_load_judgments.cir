            <pl:eventprocessor name="pl:sqltoxml" disable="false">
                <pl:parameter name="design">
                    <pl:parameter name="uid" value="126"/>
                    <pl:parameter name="alias" value="Set MC TAPE_FILES STATUS = T"/>
                </pl:parameter>
                <pl:parameter name="transaction_key" value="DB Start_Media_Center"/>
                <pl:parameter name="sql" value="update tape_files&#10;set status=&apos;T&apos;&#10;where ORDERSEQ in&#10;                 ( select tf.ORDERSEQ&#10;                    from  tape_files tf , tapes t&#10;                    where t.cust_code=1999&#10;                AND   t.seqno=tf.seqno&#10;                AND   tf.file_name like &apos;1999JG%&apos;&#10;                AND   tf.status=&apos;L&apos; )&#10;"/>
                <pl:parameter name="forward_option" value="0"/>
