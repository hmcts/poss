                <pl:parameter name="sql" value="update transfer_control&#10;set transfer_status=&apos;6&apos;&#10;where transfer_type=&apos;R&apos;&#10;and transfer_status = &apos;1&apos;&#10;and trans_seq in (select b.trans_seq&#10;                  &#9;&#9;from warrant_returns b&#10;                  &#9;&#9;where (length(b.warrant_number) = 8&#10;                         &#9;or substr(b.warrant_number,1,2)=&apos;RI&apos;))"/>
