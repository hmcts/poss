        <pl:documentation name="ftp_rep_doc"/>
        <pl:application-data name="Resources" type="Resources">
            <pl:application-data name="Functions" type="functions" application="com.polarlake.platform.librarymodule.LibraryModuleApplication">
                <pl:application-data name="storeRepIds" type="function" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value="">
                    <pl:application-data name="type" type="property" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value="beanshell"/>
                    <pl:application-data name="methodName" type="property" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value="storeRepIds"/>
                    <pl:application-data name="category" type="property" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value="Miscellaneous"/>
                    <pl:application-data name="script" type="property" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value="String storeRepIds(String[] args){&#10;   String s= &quot;&quot;;&#10;&#10;   for(int i=0;i&lt; args.length;i++){&#10;      s += args[i];&#10;      if(i != (args.length-1))&#10;         s+= &quot;,&quot;;&#10;   }&#10;   return s;&#10;}"/>
                    <pl:application-data name="description" type="property" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value=""/>
                </pl:application-data>
                <pl:application-data name="getMaxString200" type="function" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value="">
                    <pl:application-data name="type" type="property" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value="beanshell"/>
                    <pl:application-data name="methodName" type="property" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value="getMaxString200"/>
                    <pl:application-data name="category" type="property" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value="Miscellaneous"/>
                    <pl:application-data name="script" type="property" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value="String getMaxString200(String arg){&#10;    String s = arg;&#10;    if(s.length() &gt;150){&#10;        return s.substring(0,200);&#10;    }else{&#10;        return s;&#10;    }&#10;}"/>
                    <pl:application-data name="description" type="property" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value=""/>
                </pl:application-data>
                <pl:application-data name="tagConvert" type="function" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value="">
                    <pl:application-data name="type" type="property" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value="beanshell"/>
                    <pl:application-data name="methodName" type="property" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value="tagConvert"/>
                    <pl:application-data name="category" type="property" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value="Miscellaneous"/>
                    <pl:application-data name="script" type="property" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value="import org.jdom.input.SAXBuilder;&#10;import org.jdom.output.Format;&#10;import org.jdom.output.XMLOutputter;&#10;&#10;String tagConvert(String arg){&#10;   private XMLOutputter out = new XMLOutputter(Format.getCompactFormat()); &#10;&#10;   SAXBuilder builder = new SAXBuilder();  &#10;   &#10;   return out.outputString(builder.build(new StringReader(arg)).getRootElement()); &#10;}"/>
                    <pl:application-data name="description" type="property" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value=""/>
                </pl:application-data>
                <pl:application-data name="getFileType" type="function" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value="">
                    <pl:application-data name="type" type="property" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value="beanshell"/>
                    <pl:application-data name="methodName" type="property" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value="getFileType"/>
                    <pl:application-data name="category" type="property" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value="Miscellaneous"/>
                    <pl:application-data name="script" type="property" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value="String getFileType(String arg){&#10;&#10;   if(arg == null)&#10;      return &quot;&quot;;&#10;&#10;   String[] mimeParams = arg.split(&quot;/&quot;);&#10;&#10;   if(mimeParams.length &lt;=1)&#10;      return &quot;&quot;;&#10;&#10;   return mimeParams[1];&#10;}"/>
                    <pl:application-data name="description" type="property" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value="Returns the file type from the MIME type string passed in."/>
                </pl:application-data>
            </pl:application-data>
            <pl:application-data name="Initial Contexts" type="initialcontexts" application="com.polarlake.platform.librarymodule.LibraryModuleApplication"/>
            <pl:application-data name="Scripts" type="scripts" application="com.polarlake.platform.librarymodule.LibraryModuleApplication">
                <pl:application-data name="JDOM Process" type="script" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value="">
                    <pl:application-data name="url" type="property" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value=""/>
                    <pl:application-data name="remote" type="property" application="com.polarlake.platform.librarymodule.LibraryModuleApplication" value="false"/>
