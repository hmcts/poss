            <pl:definition name="SchedulerModuleApplicationCircuit" value="file:///{pl$polarlake_home}/SchedulerModule/circuits/SchedulerModule.cir"/>
            <pl:definition name="ftp_rep_doc" value="file:///{pl$ftp_rep_home}/doc/ftp_rep_doc.html"/>
            <pl:definition name="cccis_ftp_rep_db_connect" value="file:///{pl$ftp_rep_home}/circuits/cccis_report_ftp_db_connect.cir"/>
        </pl:definitions>
        <pl:importcircuit name="com.polarlake.circuits.BaseCircuit"/>
        <pl:importcircuit name="SchedulerModuleApplicationCircuit"/>
        <pl:importcircuit name="cccis_ftp_rep_db_connect"/>
        <pl:importmodule name="com.polarlake.platform.databasemodule.DatabaseModuleApplication"/>
