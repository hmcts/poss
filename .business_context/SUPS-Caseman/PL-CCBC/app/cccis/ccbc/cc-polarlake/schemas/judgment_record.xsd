			<xsd:element name="payment_slip_codeline_2" type="judgment.payment_slip_codeline_2"/>
			<xsd:element name="payee_bank_sort_code" type="judgment.payee_bank_sort_code"/>
			<xsd:element name="payee_account_holder" type="judgment.payee_account_holder"/>
			<xsd:element name="payee_bank_name" type="judgment.payee_bank_name"/>
			<xsd:element name="payee_bank_info_1" type="judgment.payee_bank_info_1"/>
			<xsd:element name="payee_bank_info_2" type="judgment.payee_bank_info_2"/>
			<xsd:element name="payee_girobank_account_number" type="judgment.payee_girobank_account_number"/>
			<xsd:element name="payee_bank_account_numer" type="judgment.payee_bank_account_numer"/>
			<xsd:element name="girobank_transaction_code_1" type="judgment.girobank_transaction_code_1"/>
			<xsd:element name="girobank_transaction_code_2" type="judgment.girobank_transaction_code_2"/>
			<xsd:element name="APACS_transaction_code" type="judgment.APACS_transaction_code"/>
			<xsd:element name="filler" type="judgment.filler"/>
                        <xsd:element name="defendant_dob" type="judgment.defendant_dob"/>
		</xsd:sequence>
	</xsd:complexType>
	</xsd:element>
</xsd:schema>
