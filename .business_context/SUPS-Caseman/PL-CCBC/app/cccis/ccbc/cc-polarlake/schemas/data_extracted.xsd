  </xsd:simpleType>
  <xsd:simpleType name="record.def_date_of_birth">
    <xsd:restriction base="xsd:string">
      <xsd:length value="8" fixed="true" />
    </xsd:restriction>
  </xsd:simpleType>
  <xsd:complexType name="record">
    <xsd:sequence>
      <xsd:element name="court_code" type="record.court_code" minOccurs="1" maxOccurs="1" />
      <xsd:element name="case_number" type="record.case_number" minOccurs="1" maxOccurs="1" />
      <xsd:element name="total" type="record.total" minOccurs="1" maxOccurs="1" />
      <xsd:element name="judgment_date" type="record.judgment_date" minOccurs="1" maxOccurs="1" />
      <xsd:element name="judgment_status" type="record.judgment_status" minOccurs="1" maxOccurs="1" />
      <xsd:element name="cancellation_date_or_date_of_final_payment" type="record.cancellation_date_or_date_of_final_payment" minOccurs="1" maxOccurs="1" />
