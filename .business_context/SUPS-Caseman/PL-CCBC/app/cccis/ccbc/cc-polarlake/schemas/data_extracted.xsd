    </xsd:restriction>
  </xsd:simpleType>
  <xsd:simpleType name="record.def_address_line_1">
    <xsd:restriction base="xsd:string">
      <xsd:length value="35" fixed="true" />
    </xsd:restriction>
  </xsd:simpleType>
  <xsd:simpleType name="record.def_address_line_2">
    <xsd:restriction base="xsd:string">
      <xsd:length value="35" fixed="true" />
